{
  "entries": [
    {
      "start": 46.199,
      "duration": 4.601,
      "text": "議場マイクテスト議場マイクテスト議場"
    },
    {
      "start": 48.52,
      "duration": 2.28,
      "text": "マイク"
    },
    {
      "start": 58.92,
      "duration": 3.0,
      "text": "テスト"
    },
    {
      "start": 146.08,
      "duration": 7.12,
      "text": "おはようございますおはようごい"
    },
    {
      "start": 148.84,
      "duration": 7.759,
      "text": "ますから本日の会議を開きます日程第地西"
    },
    {
      "start": 153.2,
      "duration": 7.56,
      "text": "が新城の委員会付託を行います今定例会の"
    },
    {
      "start": 156.599,
      "duration": 7.681,
      "text": "3月21日までに受理した陳情正眼陳情は"
    },
    {
      "start": 160.76,
      "duration": 6.839,
      "text": "6陳情第6号から6陳情第9号までの4件"
    },
    {
      "start": 164.28,
      "duration": 7.8,
      "text": "です以上4件はお手元にご配布しました"
    },
    {
      "start": 167.599,
      "duration": 8.441,
      "text": "西岸尋常委員会追加付託予定表の通り所管"
    },
    {
      "start": 172.08,
      "duration": 7.72,
      "text": "の常人委員会及び議会運営委員会に付託し"
    },
    {
      "start": 176.04,
      "duration": 6.16,
      "text": "ますお別れしますただいま付託した4件は"
    },
    {
      "start": 179.8,
      "duration": 5.2,
      "text": "中の継続審査とすることにご異議ありませ"
    },
    {
      "start": 182.2,
      "duration": 6.24,
      "text": "んかご異議なしと認めただいま付託しまし"
    },
    {
      "start": 185.0,
      "duration": 7.28,
      "text": "た尋常4件は閉会中の継続審査案件と決定"
    },
    {
      "start": 188.44,
      "duration": 7.28,
      "text": "しました一定第2閉会中継続審査案件を"
    },
    {
      "start": 192.28,
      "duration": 6.92,
      "text": "議題とします各常任委員会委員長議会運営"
    },
    {
      "start": 195.72,
      "duration": 7.96,
      "text": "委員会委員長及び各特別委員会委員長"
    },
    {
      "start": 199.2,
      "duration": 8.319,
      "text": "から委員会において審査え審査調査中の"
    },
    {
      "start": 203.68,
      "duration": 7.08,
      "text": "事件につき会議規則第74条の規定により"
    },
    {
      "start": 207.519,
      "duration": 7.161,
      "text": "閉会中継続審査案件一覧の通り申し出が"
    },
    {
      "start": 210.76,
      "duration": 6.92,
      "text": "ありましたお諮りします本件は閉中もなお"
    },
    {
      "start": 214.68,
      "duration": 6.8,
      "text": "審査することにご異議ありませんかご異議"
    },
    {
      "start": 217.68,
      "duration": 7.4,
      "text": "なと認め閉会中継続審査案件一覧表の通り"
    },
    {
      "start": 221.48,
      "duration": 6.759,
      "text": "継続審査することと決定しました日程第3"
    },
    {
      "start": 225.08,
      "duration": 7.439,
      "text": "委員会特定事件継続調査案件を議題とし"
    },
    {
      "start": 228.239,
      "duration": 7.601,
      "text": "ます厚生文教委員会建設環境委員会総務"
    },
    {
      "start": 232.519,
      "duration": 8.36,
      "text": "企画委員会及び議会運営委員会からお手元"
    },
    {
      "start": 235.84,
      "duration": 8.0,
      "text": "にご配布の件名表の通り特定事件について"
    },
    {
      "start": 240.879,
      "duration": 6.601,
      "text": "継続調査の要求があります本件について"
    },
    {
      "start": 243.84,
      "duration": 6.759,
      "text": "要求の通り閉会中の継続調査とすることに"
    },
    {
      "start": 247.48,
      "duration": 7.08,
      "text": "ご異議ありませんかご異議なしと認め委員"
    },
    {
      "start": 250.599,
      "duration": 7.401,
      "text": "会特定事件継続調査案件一覧表の通り継続"
    },
    {
      "start": 254.56,
      "duration": 6.359,
      "text": "調査とすることと決定しました日程第4"
    },
    {
      "start": 258.0,
      "duration": 6.88,
      "text": "議員の派遣についてを議題としますお別れ"
    },
    {
      "start": 260.919,
      "duration": 7.28,
      "text": "します地方寺地方第100条第13項及び"
    },
    {
      "start": 264.88,
      "duration": 6.0,
      "text": "会議規則第120条の規定に基づきお手元"
    },
    {
      "start": 268.199,
      "duration": 6.481,
      "text": "に配布しました議員議員の派遣についての"
    },
    {
      "start": 270.88,
      "duration": 7.159,
      "text": "通り閉会中に議員派遣を行うこととし初犯"
    },
    {
      "start": 274.68,
      "duration": 6.32,
      "text": "の事情により変更が生じた場合は議長にご"
    },
    {
      "start": 278.039,
      "duration": 5.961,
      "text": "一任いただくことにご異議ありませんかご"
    },
    {
      "start": 281.0,
      "duration": 5.68,
      "text": "異議の認めただいま申し上げました通りえ"
    },
    {
      "start": 284.0,
      "duration": 7.12,
      "text": "申し上げた通り行うことと決定しまし"
    },
    {
      "start": 286.68,
      "duration": 8.28,
      "text": "た重てお諮りしますなお閉会中に議員派遣"
    },
    {
      "start": 291.12,
      "duration": 7.68,
      "text": "を行う必要が生じた場合その日時場所目的"
    },
    {
      "start": 294.96,
      "duration": 6.799,
      "text": "及び派遣議員名等については議長にご一任"
    },
    {
      "start": 298.8,
      "duration": 5.28,
      "text": "いただくことにありませんかご異議な人と"
    },
    {
      "start": 301.759,
      "duration": 5.641,
      "text": "認めただいま申し上げた通り行うことと"
    },
    {
      "start": 304.08,
      "duration": 6.119,
      "text": "決定しました以上で今定例会に付議された"
    },
    {
      "start": 307.4,
      "duration": 6.239,
      "text": "案件は全て終了しましたこれを持ちまして"
    },
    {
      "start": 310.199,
      "duration": 6.28,
      "text": "会議を閉じ令和6年第1回小金市議会定例"
    },
    {
      "start": 313.639,
      "duration": 2.84,
      "text": "会を閉会し"
    },
    {
      "start": 328.639,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 337.759,
      "duration": 3.0,
      "text": "God"
    }
  ]
}