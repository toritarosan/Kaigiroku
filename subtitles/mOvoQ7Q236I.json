    {
      "start": 505.12,
      "duration": 5.639,
      "text": "1人で修正をさせていただきたいと思い"
    },
    {
      "start": 507.36,
      "duration": 6.599,
      "text": "ますがよろしいですかはいの他この報告書"
    },
    {
      "start": 510.759,
      "duration": 5.561,
      "text": "について何かございますでしょうかはいえ"
