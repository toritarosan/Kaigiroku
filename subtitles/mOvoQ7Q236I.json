    {
      "start": 533.88,
      "duration": 4.199,
      "text": "思いますこれにご異議ありませんかご異議"
    },
    {
      "start": 535.959,
      "duration": 4.641,
      "text": "なしと認めます従って本査は継続調査と"
    },
    {
      "start": 538.079,
      "duration": 4.561,
      "text": "決定いたしました以で当委員会に託されて"
