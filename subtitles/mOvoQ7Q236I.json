{
  "entries": [
    {
      "start": 50.96,
      "duration": 4.84,
      "text": "はい皆様お疲れ様でございますえおれで"
    },
    {
      "start": 53.32,
      "duration": 6.759,
      "text": "ございますが議会員会協議会を始めさせて"
    },
    {
      "start": 55.8,
      "duration": 7.919,
      "text": "いただきましてえ協議会事項のその2から"
    },
    {
      "start": 60.079,
      "duration": 7.4,
      "text": "でございますねでえ本日の進行と議会整理"
    },
    {
      "start": 63.719,
      "duration": 6.04,
      "text": "Bについて定例会第6回6年え令和6年度"
    },
    {
      "start": 67.479,
      "duration": 4.761,
      "text": "定例会の認定については事務局の方からで"
    },
    {
      "start": 69.759,
      "duration": 5.761,
      "text": "議会報告会実行委員会についてはえ議長の"
    },
    {
      "start": 72.24,
      "duration": 5.559,
      "text": "方からでございましてでえその前にですね"
    },
    {
      "start": 75.52,
      "duration": 4.279,
      "text": "議会会会に関する初問題の調査が1件残っ"
    },
    {
      "start": 77.799,
      "duration": 6.201,
      "text": "ておりましてこちらについては今お手元に"
    },
    {
      "start": 79.799,
      "duration": 5.761,
      "text": "報告書案をお配りしておりましてあの事前"
    },
    {
      "start": 84.0,
      "duration": 4.36,
      "text": "に皆様にあの確認させていただきましたが"
    },
    {
      "start": 85.56,
      "duration": 5.68,
      "text": "特段のご意見はなかったのでまここであの"
    },
    {
      "start": 88.36,
      "duration": 6.719,
      "text": "確認をさせていただいて確定にしたいと"
    },
    {
      "start": 91.24,
      "duration": 8.04,
      "text": "いうところでえございます"
    },
    {
      "start": 95.079,
      "duration": 8.841,
      "text": "はいそのか何か進行ではい安田にすいませ"
    },
    {
      "start": 99.28,
      "duration": 7.24,
      "text": "ん議会報告会の実施報告書のこと今委員長"
    },
    {
      "start": 103.92,
      "duration": 6.519,
      "text": "おっしゃった議会報告会じゃないですあの"
    },
    {
      "start": 106.52,
      "duration": 6.4,
      "text": "こっち今これ験者教験者教ことですよね"
    },
    {
      "start": 110.439,
      "duration": 5.081,
      "text": "すいませんあの私はアンケートの集計を"
    },
    {
      "start": 112.92,
      "duration": 4.72,
      "text": "ちょっと勘違いしておりましてあの"
    },
    {
      "start": 115.52,
      "duration": 4.68,
      "text": "ちょっと記事っぽくあの市議会頼よりに"
    },
    {
      "start": 117.64,
      "duration": 5.56,
      "text": "載せる記事っていう感じで書いてしまいん"
    },
    {
      "start": 120.2,
      "duration": 6.959,
      "text": "ですけれどもま前回は全部のあの生徒さん"
    },
    {
      "start": 123.2,
      "duration": 6.64,
      "text": "の意見あの全てあのモーラしているような"
    },
    {
      "start": 127.159,
      "duration": 5.521,
      "text": "表をあの報告書で上がってるんですけど"
    },
    {
      "start": 129.84,
      "duration": 5.32,
      "text": "そちらの方が適正かなと思いましてえっと"
    },
    {
      "start": 132.68,
      "duration": 4.76,
      "text": "それを作り直して皆様にお示ししたんです"
    },
    {
      "start": 135.16,
      "duration": 4.28,
      "text": "けれどもちょっとあの遅くなってしまった"
    },
    {
      "start": 137.44,
      "duration": 3.56,
      "text": "んですがそちらの方がいいかなという風"
    },
    {
      "start": 139.44,
      "duration": 3.68,
      "text": "思っておりますありがとございますはい"
    },
    {
      "start": 141.0,
      "duration": 4.319,
      "text": "あのいだいたあのものはですね自由気は"
    },
    {
      "start": 143.12,
      "duration": 6.119,
      "text": "ベシという風に記載させていただいてます"
    },
    {
      "start": 145.319,
      "duration": 6.721,
      "text": "のではいあの前回もあ去年もあの"
    },
    {
      "start": 149.239,
      "duration": 4.681,
      "text": "アンケートの自由術についてはベシという"
    },
    {
      "start": 152.04,
      "duration": 4.199,
      "text": "形になってますのでささんが作って"
    },
    {
      "start": 153.92,
      "duration": 4.72,
      "text": "いただいたのはそちらの方でベシつけさせ"
    },
    {
      "start": 156.239,
      "duration": 5.0,
      "text": "ていただくというような予定でございます"
    },
    {
      "start": 158.64,
      "duration": 6.04,
      "text": "ちなみにあとご指摘になったら当日の"
    },
    {
      "start": 161.239,
      "duration": 6.761,
      "text": "スライドと写真も別子という形でこれ以外"
    },
    {
      "start": 164.68,
      "duration": 6.199,
      "text": "にその3つが3点がついて1つの報告書に"
    },
    {
      "start": 168.0,
      "duration": 6.44,
      "text": "なるという理解でございますのではいその"
    },
    {
      "start": 170.879,
      "duration": 7.36,
      "text": "ございますかあはいはいあはいざいます"
    },
    {
      "start": 174.44,
      "duration": 6.719,
      "text": "はいえっとですねあの当日の議会の議事録"
    },
    {
      "start": 178.239,
      "duration": 6.72,
      "text": "をですねあのていただいたんですけれども"
    },
    {
      "start": 181.159,
      "duration": 5.921,
      "text": "あのこちらのこのえっと報告書については"
    },
    {
      "start": 184.959,
      "duration": 5.321,
      "text": "あのまホームページにもあげるというよう"
    },
    {
      "start": 187.08,
      "duration": 6.2,
      "text": "なこともあると思うのであの割とこう簡単"
    },
    {
      "start": 190.28,
      "duration": 7.36,
      "text": "にというかこの8で参加生徒の意見という"
    },
    {
      "start": 193.28,
      "duration": 6.64,
      "text": "ところでグループの特のとこの発表とあと"
    },
    {
      "start": 197.64,
      "duration": 5.72,
      "text": "感想だけですねをあのピックアップしてる"
    },
    {
      "start": 199.92,
      "duration": 6.239,
      "text": "と思うんですただあの全体のこ次第をあの"
    },
    {
      "start": 203.36,
      "duration": 5.84,
      "text": "後で確認できるようなあのことが必要なの"
    },
    {
      "start": 206.159,
      "duration": 5.881,
      "text": "かなと思って理科委会の資料としては私は"
    },
    {
      "start": 209.2,
      "duration": 5.44,
      "text": "あの郎全体をこう一応配っといて方がいい"
    },
    {
      "start": 212.04,
      "duration": 5.04,
      "text": "のかなという風に思っていたところです"
    },
    {
      "start": 214.64,
      "duration": 5.12,
      "text": "はいそれだからま今日今ここにないって"
    },
    {
      "start": 217.08,
      "duration": 5.719,
      "text": "ことであればまた次回の回運営会とかです"
    },
    {
      "start": 219.76,
      "duration": 6.16,
      "text": "ね何かの時にでもあの配っておいて"
    },
    {
      "start": 222.799,
      "duration": 6.681,
      "text": "いただくとま資料として一応表にあって"
    },
    {
      "start": 225.92,
      "duration": 5.36,
      "text": "あの他の会派の方あ他にこう理由の委員"
    },
    {
      "start": 229.48,
      "duration": 4.039,
      "text": "じゃない方も後で確認できるんじゃないか"
    },
    {
      "start": 231.28,
      "duration": 4.44,
      "text": "なと思っておりますのでそのようにできれ"
    },
    {
      "start": 233.519,
      "duration": 5.64,
      "text": "ばなと思いますはいありがとうございます"
    },
    {
      "start": 235.72,
      "duration": 5.439,
      "text": "今あの副長からあったのは全部あの文副長"
    },
    {
      "start": 239.159,
      "duration": 5.64,
      "text": "の方であのDVDを見てしていただいたん"
    },
    {
      "start": 241.159,
      "duration": 6.08,
      "text": "ですねでその全部に全ての意見はここに"
    },
    {
      "start": 244.799,
      "duration": 6.16,
      "text": "ついて自主報告書には載せてなくて"
    },
    {
      "start": 247.239,
      "duration": 6.481,
      "text": "あくまであの最後のえ討論のところと最後"
    },
    {
      "start": 250.959,
      "duration": 5.361,
      "text": "の感想のところだけしか乗っけてないん"
    },
    {
      "start": 253.72,
      "duration": 4.72,
      "text": "ですよだそれ前段のま質疑の模様であると"
    },
    {
      "start": 256.32,
      "duration": 4.039,
      "text": "かそういう議事録についてはホームページ"
    },
    {
      "start": 258.44,
      "duration": 3.96,
      "text": "には載せないんだけれどもこういった質疑"
    },
    {
      "start": 260.359,
      "duration": 3.921,
      "text": "がありましたよという情報共有を各議員の"
    },
    {
      "start": 262.4,
      "duration": 5.76,
      "text": "皆さんにした方がいいんじゃないかという"
    },
    {
      "start": 264.28,
      "duration": 6.24,
      "text": "問題意識ということでございますのであの"
    },
    {
      "start": 268.16,
      "duration": 5.52,
      "text": "特段ご意見がなければそのようににはい"
    },
    {
      "start": 270.52,
      "duration": 6.399,
      "text": "配らせていただくとはいはいその他ござい"
    },
    {
      "start": 273.68,
      "duration": 6.079,
      "text": "ますかはいじゃあ最後頑張って参り"
    },
    {
      "start": 276.919,
      "duration": 2.84,
      "text": "ましょう"
    },
    {
      "start": 280.4,
      "duration": 6.0,
      "text": "はい再開します議会改革に関する諸問題の"
    },
    {
      "start": 283.759,
      "duration": 5.401,
      "text": "調査を議題といたしますか1議会改革に"
    },
    {
      "start": 286.4,
      "duration": 4.96,
      "text": "ついてを行います直に3の4チラシに記載"
    },
    {
      "start": 289.16,
      "duration": 5.64,
      "text": "した議員と話してみようか意見交換会の"
    },
    {
      "start": 291.36,
      "duration": 6.88,
      "text": "思考実施え議会によるシシップ教育の推進"
    },
    {
      "start": 294.8,
      "duration": 6.52,
      "text": "の取り組みか続編を議題といたしますえ"
    },
    {
      "start": 298.24,
      "duration": 7.36,
      "text": "中方大学付属高等学この特別事業について"
    },
    {
      "start": 301.32,
      "duration": 8.2,
      "text": "え実施報告書案を制服案としてお示しをさ"
    },
    {
      "start": 305.6,
      "duration": 5.76,
      "text": "せていただきましたえこれについてえ皆様"
    },
    {
      "start": 309.52,
      "duration": 5.64,
      "text": "からご意見等があれば受けてまりたいと"
    },
    {
      "start": 311.36,
      "duration": 3.8,
      "text": "思いますこれから質疑を行い"
    },
    {
      "start": 315.639,
      "duration": 6.201,
      "text": "ますこれについて特段質疑がございますか"
    },
    {
      "start": 318.68,
      "duration": 5.44,
      "text": "よろしいですかあはい片山委員長すいませ"
    },
    {
      "start": 321.84,
      "duration": 4.199,
      "text": "んはいえっと先ほどあの協議会でも"
    },
    {
      "start": 324.12,
      "duration": 4.199,
      "text": "申し上げましたけど一応委員会の方でも"
    },
    {
      "start": 326.039,
      "duration": 5.28,
      "text": "行っとこうかなと思いますえっとこちらの"
    },
    {
      "start": 328.319,
      "duration": 5.32,
      "text": "あのえっと模擬議会のですねあの疑似録"
    },
    {
      "start": 331.319,
      "duration": 4.44,
      "text": "えっと全体についてはこの報告書の中には"
    },
    {
      "start": 333.639,
      "duration": 4.721,
      "text": "載っていないんですけれどもまベッドあの"
    },
    {
      "start": 335.759,
      "duration": 4.72,
      "text": "議会委員会の資料としてあの共有できる"
    },
    {
      "start": 338.36,
      "duration": 4.8,
      "text": "ようにできればなと思っておりますあの"
    },
    {
      "start": 340.479,
      "duration": 5.481,
      "text": "そういった形であの全体の次第が分かる方"
    },
    {
      "start": 343.16,
      "duration": 4.96,
      "text": "がままたあの次の時のですね参考になるの"
    },
    {
      "start": 345.96,
      "duration": 5.56,
      "text": "かなという風に考えておりますでもう1つ"
    },
    {
      "start": 348.12,
      "duration": 5.44,
      "text": "ちょっとですねあのえっとこれえもう一応"
    },
    {
      "start": 351.52,
      "duration": 6.0,
      "text": "あの記録として残しときたいなと思って"
    },
    {
      "start": 353.56,
      "duration": 7.72,
      "text": "ますのがあのまDVDえっと後ろの方から"
    },
    {
      "start": 357.52,
      "duration": 6.88,
      "text": "こう録画で撮らしてあ撮ってそれはあの"
    },
    {
      "start": 361.28,
      "duration": 6.6,
      "text": "DVD残したものであの確認したんです"
    },
    {
      "start": 364.4,
      "duration": 6.4,
      "text": "けれども音声が非常にこう小さくてあの"
    },
    {
      "start": 367.88,
      "duration": 4.52,
      "text": "ほぼ非常に聞こえない状態だったんですが"
    },
    {
      "start": 370.8,
      "duration": 4.88,
      "text": "ちょっとやっぱりせっかくこのマイクを"
    },
    {
      "start": 372.4,
      "duration": 5.76,
      "text": "使って議場でやってましたのであの録音を"
    },
    {
      "start": 375.68,
      "duration": 4.6,
      "text": "ここのあの危機での録音をしとけばよかっ"
    },
    {
      "start": 378.16,
      "duration": 5.439,
      "text": "たなという風なことを思っておりまして"
    },
    {
      "start": 380.28,
      "duration": 5.56,
      "text": "ちょっとそちらではあの次もし模擬議会を"
    },
    {
      "start": 383.599,
      "duration": 4.241,
      "text": "ま来年とかちょっと難しいのかもしれない"
    },
    {
      "start": 385.84,
      "duration": 4.16,
      "text": "んですけどまたいつかやる時にはそういっ"
    },
    {
      "start": 387.84,
      "duration": 4.24,
      "text": "た形でできるといいんじゃないかなという"
    },
    {
      "start": 390.0,
      "duration": 3.52,
      "text": "ことを一応記録として残してきたいと思い"
    },
    {
      "start": 392.08,
      "duration": 6.119,
      "text": "ます"
    },
    {
      "start": 393.52,
      "duration": 7.16,
      "text": "ですはいその他ございますかはい三谷はい"
    },
    {
      "start": 398.199,
      "duration": 4.44,
      "text": "あのDVDからの文字起こしがすごく大変"
    },
    {
      "start": 400.68,
      "duration": 6.239,
      "text": "だったということでありがとうございます"
    },
    {
      "start": 402.639,
      "duration": 6.721,
      "text": "えっとそれでえっと後で参照する時のこと"
    },
    {
      "start": 406.919,
      "duration": 6.28,
      "text": "で気になったんですけど議案とか議案資料"
    },
    {
      "start": 409.36,
      "duration": 7.48,
      "text": "など配布したものもなんらかあの後で誰で"
    },
    {
      "start": 413.199,
      "duration": 5.84,
      "text": "も見られるような形で保存しておいたら"
    },
    {
      "start": 416.84,
      "duration": 5.52,
      "text": "良いかなと思ったんですがあとはまもし"
    },
    {
      "start": 419.039,
      "duration": 4.88,
      "text": "可能でこの報告書にけるっていうのも"
    },
    {
      "start": 422.36,
      "duration": 3.6,
      "text": "よろしいかと思ったんですがちょっと今"
    },
    {
      "start": 423.919,
      "duration": 4.601,
      "text": "気づいたので発言が遅くなりましたが"
    },
    {
      "start": 425.96,
      "duration": 2.56,
      "text": "いかがでしょう"
    },
    {
      "start": 428.84,
      "duration": 8.359,
      "text": "かうんはいま議案と議案資料もここの報告"
    },
    {
      "start": 434.52,
      "duration": 3.6,
      "text": "書に添付したらどうかというご意見で"
    },
    {
      "start": 437.199,
      "duration": 2.521,
      "text": "ござい"
    },
    {
      "start": 438.12,
      "duration": 5.199,
      "text": "ますが"
    },
    {
      "start": 439.72,
      "duration": 3.599,
      "text": "あいかがでしょう"
    },
    {
      "start": 447.24,
      "duration": 9.2,
      "text": "かじゃスライドはいはいはい安田員あはい"
    },
    {
      "start": 452.44,
      "duration": 7.4,
      "text": "えっとやはりこの報告書だけでは確かに"
    },
    {
      "start": 456.44,
      "duration": 5.8,
      "text": "分からない部分があるからあのそのえ資料"
    },
    {
      "start": 459.84,
      "duration": 4.24,
      "text": "としてつけるっていうのは良いと思います"
    },
    {
      "start": 462.24,
      "duration": 4.44,
      "text": "えっとついでに言いますとあのアンケート"
    },
    {
      "start": 464.08,
      "duration": 5.959,
      "text": "集計もですねちょっとあのこのここでは"
    },
    {
      "start": 466.68,
      "duration": 6.16,
      "text": "あのえっとざっくりとしたあのまとめが"
    },
    {
      "start": 470.039,
      "duration": 5.521,
      "text": "書いてあるだけなんですけどもあの別子で"
    },
    {
      "start": 472.84,
      "duration": 5.6,
      "text": "あの自由技術は全部あの載せ"
    },
    {
      "start": 475.56,
      "duration": 7.039,
      "text": "るっていうことも"
    },
    {
      "start": 478.44,
      "duration": 7.719,
      "text": "あの別であの用意してるということなので"
    },
    {
      "start": 482.599,
      "duration": 5.361,
      "text": "えっとえっとその議案などもあのより理解"
    },
    {
      "start": 486.159,
      "duration": 5.921,
      "text": "を深めるためにつつけるのは良いと思い"
    },
    {
      "start": 487.96,
      "duration": 7.799,
      "text": "ますはいそれでは今特段皆さんからご異議"
    },
    {
      "start": 492.08,
      "duration": 6.0,
      "text": "がなければ議案と議案資料についても別子"
    },
    {
      "start": 495.759,
      "duration": 5.12,
      "text": "という形でつけるということでよろしい"
    },
    {
      "start": 498.08,
      "duration": 4.799,
      "text": "ですかねはいえっとその他まあの事務局の"
