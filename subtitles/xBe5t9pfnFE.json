{
  "entries": [
    {
      "start": 12.32,
      "duration": 5.28,
      "text": "皆様こんにちはお揃いでございますのでえ"
    },
    {
      "start": 15.2,
      "duration": 4.68,
      "text": "議会委員会協議会を始めさせていただき"
    },
    {
      "start": 17.6,
      "duration": 5.0,
      "text": "ますお手元の協議事項をご覧くださいえ"
    },
    {
      "start": 19.88,
      "duration": 5.8,
      "text": "本日の進行についてでございますえ新参権"
    },
    {
      "start": 22.6,
      "duration": 5.36,
      "text": "議長の諮問事項1件でございますえ問事項"
    },
    {
      "start": 25.68,
      "duration": 5.439,
      "text": "についてえ市長総案件の取り扱いについて"
    },
    {
      "start": 27.96,
      "duration": 5.759,
      "text": "え視聴報告本日の本で所定の手続きを取る"
    },
    {
      "start": 31.119,
      "duration": 5.881,
      "text": "ことについてでその他あればご発言お願い"
    },
    {
      "start": 33.719,
      "duration": 6.321,
      "text": "します進行について何かございますかはい"
    },
    {
      "start": 37.0,
      "duration": 3.04,
      "text": "それでは入ってもり"
    },
    {
      "start": 40.079,
      "duration": 6.681,
      "text": "ますなんかあったあ大丈夫です"
    },
    {
      "start": 44.0,
      "duration": 5.079,
      "text": "はいただ今から議会運営委員会の会議を"
    },
    {
      "start": 46.76,
      "duration": 4.279,
      "text": "開きます直に議事に入ります当委員会に"
    },
    {
      "start": 49.079,
      "duration": 4.401,
      "text": "負託されております案件は議長の諮問事項"
    },
    {
      "start": 51.039,
      "duration": 4.441,
      "text": "1件であります議長からお手元に議会運営"
    },
    {
      "start": 53.48,
      "duration": 4.0,
      "text": "委員会協議事項が提示されておりますので"
    },
    {
      "start": 55.48,
      "duration": 4.559,
      "text": "その順序に従って順次協議していきたいと"
    },
    {
      "start": 57.48,
      "duration": 5.12,
      "text": "思います議会上に関する議長の問事項に"
    },
    {
      "start": 60.039,
      "duration": 5.001,
      "text": "ついてを議題といたします始めに協議事項"
    },
    {
      "start": 62.6,
      "duration": 4.4,
      "text": "1市長総案件の取り扱いについてを議題"
    },
    {
      "start": 65.04,
      "duration": 4.48,
      "text": "協議いたします部局から発言があればお"
    },
    {
      "start": 67.0,
      "duration": 6.479,
      "text": "願いいたします総部"
    },
    {
      "start": 69.52,
      "duration": 7.48,
      "text": "長はいえ追加送付案件についてご報告"
    },
    {
      "start": 73.479,
      "duration": 6.6,
      "text": "いたしますえ追加送付案件として昨日3月"
    },
    {
      "start": 77.0,
      "duration": 5.439,
      "text": "4日付け視聴報告を送付させていただき"
    },
    {
      "start": 80.079,
      "duration": 5.241,
      "text": "ましたので取り扱い方よろしくお願い"
    },
    {
      "start": 82.439,
      "duration": 4.441,
      "text": "いたします取り合いについて議長の指案が"
    },
    {
      "start": 85.32,
      "duration": 3.92,
      "text": "示されれておりますので議長から説明お"
    },
    {
      "start": 86.88,
      "duration": 7.04,
      "text": "願いいたします議長事務局から説明いたし"
    },
    {
      "start": 89.24,
      "duration": 7.68,
      "text": "ます長ですはいえ市長報告につきましては"
    },
    {
      "start": 93.92,
      "duration": 5.32,
      "text": "本日の本会議で所定の手続きを取りたいと"
    },
    {
      "start": 96.92,
      "duration": 5.199,
      "text": "いうのが議長の審問案でござい"
    },
    {
      "start": 99.24,
      "duration": 6.199,
      "text": "ます議長及び事務局の説明は終わりました"
    },
    {
      "start": 102.119,
      "duration": 3.32,
      "text": "ご意見ご質疑とございます"
    },
    {
      "start": 105.84,
      "duration": 4.44,
      "text": "かはいお諮りいたします本件については"
    },
    {
      "start": 108.399,
      "duration": 3.561,
      "text": "議長の質問通り決定することにご異議あり"
    },
    {
      "start": 110.28,
      "duration": 4.839,
      "text": "ませんか"
    },
    {
      "start": 111.96,
      "duration": 5.479,
      "text": "はいよいしょご異議出しと認めます従って"
    },
    {
      "start": 115.119,
      "duration": 4.92,
      "text": "本件は議長の指通り決定いたしました次に"
    },
    {
      "start": 117.439,
      "duration": 3.561,
      "text": "協議事項にその他について何かご発は"
    },
    {
      "start": 120.039,
      "duration": 3.561,
      "text": "ございます"
    },
    {
      "start": 121.0,
      "duration": 4.56,
      "text": "か以上で当委員会に付託されております"
    },
    {
      "start": 123.6,
      "duration": 4.0,
      "text": "案件の審査は全て終了いたしましたこれで"
    },
    {
      "start": 125.56,
      "duration": 5.679,
      "text": "議会運営委員会の会議を閉じ参加いたし"
    },
    {
      "start": 127.6,
      "duration": 3.639,
      "text": "ますはいお疲れ様"
    },
    {
      "start": 134.68,
      "duration": 3.0,
      "text": "です"
    }
  ]
}