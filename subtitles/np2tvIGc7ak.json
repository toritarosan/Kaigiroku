{
  "entries": [
    {
      "start": 161.92,
      "duration": 8.12,
      "text": "すいませんあのおはようござい"
    },
    {
      "start": 164.72,
      "duration": 7.76,
      "text": "ますえあのちょっと協議会え始める前にと"
    },
    {
      "start": 170.04,
      "duration": 5.96,
      "text": "いうかえっと"
    },
    {
      "start": 172.48,
      "duration": 5.72,
      "text": "おもう言っちゃっていいんだ協議会でいい"
    },
    {
      "start": 176.0,
      "duration": 5.959,
      "text": "んだよねもう"
    },
    {
      "start": 178.2,
      "duration": 6.2,
      "text": "会あこんにちはえ企画委員会の協議会を"
    },
    {
      "start": 181.959,
      "duration": 7.56,
      "text": "始めたいと思いますよろしくお願いします"
    },
    {
      "start": 184.4,
      "duration": 7.839,
      "text": "えっと今日の案件え進行予定についてと"
    },
    {
      "start": 189.519,
      "duration": 4.881,
      "text": "いうことでえ本日の委員会審査予定表の"
    },
    {
      "start": 192.239,
      "duration": 9.121,
      "text": "順序で審査を行うことについて審査案件"
    },
    {
      "start": 194.4,
      "duration": 10.479,
      "text": "身長2件とでえ保留事項がえ6陳情第36"
    },
    {
      "start": 201.36,
      "duration": 7.799,
      "text": "号及び7陳情第1号の審査ということで"
    },
    {
      "start": 204.879,
      "duration": 10.161,
      "text": "この2件だということでございますえ6第"
    },
    {
      "start": 209.159,
      "duration": 10.041,
      "text": "36号の方はあのえ院外え会派の方にもえ"
    },
    {
      "start": 215.04,
      "duration": 5.759,
      "text": "ご了解いただきましてえ審議未料おええ"
    },
    {
      "start": 219.2,
      "duration": 7.039,
      "text": "ごめんなさいごめんなさいごめんなさい"
    },
    {
      "start": 220.799,
      "duration": 9.561,
      "text": "ごめんなさいえ前言でかいえっと出出"
    },
    {
      "start": 226.239,
      "duration": 7.08,
      "text": "全択ということでえっとお諮りしていき"
    },
    {
      "start": 230.36,
      "duration": 5.12,
      "text": "ますのでよろしくお願いしますでいの方え"
    },
    {
      "start": 233.319,
      "duration": 5.56,
      "text": "7千場第1号の方はえっとちょっと"
    },
    {
      "start": 235.48,
      "duration": 5.52,
      "text": "取り扱いを少しか協議した上でえどうする"
    },
    {
      "start": 238.879,
      "duration": 4.681,
      "text": "かということでまこれは協議をしていき"
    },
    {
      "start": 241.0,
      "duration": 4.36,
      "text": "たいと思いますんでよろしくお願いします"
    },
    {
      "start": 243.56,
      "duration": 2.679,
      "text": "あと他に皆さんから何かございます"
    },
    {
      "start": 245.36,
      "duration": 5.239,
      "text": "でしょう"
    },
    {
      "start": 246.239,
      "duration": 9.08,
      "text": "か今今やっちゃう今じゃ今やっちゃいます"
    },
    {
      "start": 250.599,
      "duration": 7.281,
      "text": "かで7所第1号なんです取り扱いになん"
    },
    {
      "start": 255.319,
      "duration": 6.521,
      "text": "ですけど村山さん採決でお願いしますあ"
    },
    {
      "start": 257.88,
      "duration": 7.319,
      "text": "じゃあまず採決ご視聴ということでえっと"
    },
    {
      "start": 261.84,
      "duration": 9.52,
      "text": "もいかがですか皆"
    },
    {
      "start": 265.199,
      "duration": 9.961,
      "text": "さんはい継続を聴された方がて対決でうん"
    },
    {
      "start": 271.36,
      "duration": 6.96,
      "text": "あでそれで終わってたとと持ち帰りでその"
    },
    {
      "start": 275.16,
      "duration": 7.12,
      "text": "まあの前回の委員会で初めて出てきたもの"
    },
    {
      "start": 278.32,
      "duration": 6.719,
      "text": "でその取り扱いについてはえ協議等がが"
    },
    {
      "start": 282.28,
      "duration": 6.759,
      "text": "会派で協議したいとかまそういう理由で"
    },
    {
      "start": 285.039,
      "duration": 7.961,
      "text": "えっと一旦ここに保留でもうんでこそう"
    },
    {
      "start": 289.039,
      "duration": 6.761,
      "text": "ですねでここではあの特に取り扱いだけま"
    },
    {
      "start": 293.0,
      "duration": 6.4,
      "text": "あのちゃんとやりましょっていうことでえ"
    },
    {
      "start": 295.8,
      "duration": 6.8,
      "text": "話があったで今があるとうんうんはいて"
    },
    {
      "start": 299.4,
      "duration": 4.92,
      "text": "いうでえ今そのえ村山さんすいません"
    },
    {
      "start": 302.6,
      "duration": 3.8,
      "text": "ちょっと失礼いたしましたあのちょっと私"
    },
    {
      "start": 304.32,
      "duration": 4.24,
      "text": "の方で確か1回あの持ち帰らせてくれ的な"
    },
    {
      "start": 306.4,
      "duration": 5.799,
      "text": "こと言ったんですが結果的にはもう採決で"
    },
    {
      "start": 308.56,
      "duration": 6.919,
      "text": "今日できればとはいえということではい渡"
    },
    {
      "start": 312.199,
      "duration": 6.84,
      "text": "さんえっとま"
    },
    {
      "start": 315.479,
      "duration": 6.44,
      "text": "継続あちょっと色々論点も数多い尋常だっ"
    },
    {
      "start": 319.039,
      "duration": 4.401,
      "text": "たのであのもう少し慎重にきちんと考えて"
    },
    {
      "start": 321.919,
      "duration": 4.0,
      "text": "まもちろんあの継続はしないわけですけど"
    },
    {
      "start": 323.44,
      "duration": 5.24,
      "text": "ね人気が切れるからただまあのここでやに"
    },
    {
      "start": 325.919,
      "duration": 5.641,
      "text": "ちょっと答えを出せるだけのまだあの調査"
    },
    {
      "start": 328.68,
      "duration": 4.4,
      "text": "検討とかが行き届いていないのでま継続し"
    },
    {
      "start": 331.56,
      "duration": 2.359,
      "text": "ていただいた方がありがたいかなと思って"
    },
    {
      "start": 333.08,
      "duration": 4.399,
      "text": "おり"
    },
    {
      "start": 333.919,
      "duration": 9.0,
      "text": "ますえ"
    },
    {
      "start": 337.479,
      "duration": 8.28,
      "text": "え継続の声がございましてもじゃ継続そう"
    },
    {
      "start": 342.919,
      "duration": 6.601,
      "text": "するとですねうんあ"
    },
    {
      "start": 345.759,
      "duration": 6.241,
      "text": "ではいはいあで野さんはいえっとおそらく"
    },
    {
      "start": 349.52,
      "duration": 5.48,
      "text": "前回委員会時から求めていましたがうちは"
    },
    {
      "start": 352.0,
      "duration": 8.44,
      "text": "採決でお願いします"
    },
    {
      "start": 355.0,
      "duration": 8.28,
      "text": "決継続継続3対最決でしょ33であの"
    },
    {
      "start": 360.44,
      "duration": 6.92,
      "text": "あ"
    },
    {
      "start": 363.28,
      "duration": 7.759,
      "text": "長えっとかこの"
    },
    {
      "start": 367.36,
      "duration": 6.679,
      "text": "まあ言っちゃった方がいいあしい"
    },
    {
      "start": 371.039,
      "duration": 3.0,
      "text": "エビデンス"
    },
    {
      "start": 392.28,
      "duration": 12.88,
      "text": "でしょまなってけるからうん"
    },
    {
      "start": 397.96,
      "duration": 9.639,
      "text": "だうんままそうま一応ねうんま今回あのま"
    },
    {
      "start": 405.16,
      "duration": 7.479,
      "text": "最後の委員会というかこういう状況である"
    },
    {
      "start": 407.599,
      "duration": 9.561,
      "text": "のでまあまあそういう形でえそうですね"
    },
    {
      "start": 412.639,
      "duration": 8.68,
      "text": "はいあのいいですよあの私がやって山に"
    },
    {
      "start": 417.16,
      "duration": 4.159,
      "text": "立ってもいいですけどはい"
    },
    {
      "start": 421.479,
      "duration": 6.361,
      "text": "ないやめた方"
    },
    {
      "start": 423.24,
      "duration": 9.32,
      "text": "がじゃあえと対決対決"
    },
    {
      "start": 427.84,
      "duration": 8.639,
      "text": "するあのそこまで持ち込むものなのかね"
    },
    {
      "start": 432.56,
      "duration": 6.479,
      "text": "ちょっとじゃ一応継続として測ってそれで"
    },
    {
      "start": 436.479,
      "duration": 5.681,
      "text": "えっと行きたいと思いますけれども"
    },
    {
      "start": 439.039,
      "duration": 4.44,
      "text": "よろしいですかここで判断続きます大丈夫"
    },
    {
      "start": 442.16,
      "duration": 7.8,
      "text": "です"
    },
    {
      "start": 443.479,
      "duration": 12.521,
      "text": "かれれば採決あの率で測るしかうんうん"
    },
    {
      "start": 449.96,
      "duration": 6.04,
      "text": "会の中の休憩でお願いしますはいはい"
    },
    {
      "start": 531.839,
      "duration": 3.0,
      "text": "た"
    },
    {
      "start": 540.64,
      "duration": 3.72,
      "text": "ま仕方ないということで"
    },
    {
      "start": 546.8,
      "duration": 5.84,
      "text": "はいまあまあそういうことですはい分かり"
    },
    {
      "start": 551.16,
      "duration": 5.919,
      "text": "まし"
    },
    {
      "start": 552.64,
      "duration": 6.759,
      "text": "たさんよろしいはいじゃあこちら継続でお"
    },
    {
      "start": 557.079,
      "duration": 4.921,
      "text": "諮りしますんでえとよろしくお願いします"
    },
    {
      "start": 559.399,
      "duration": 5.641,
      "text": "それでは始めましょうかねよろしいですか"
    },
    {
      "start": 562.0,
      "duration": 6.04,
      "text": "ねはいお願いし"
    },
    {
      "start": 565.04,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 568.36,
      "duration": 6.28,
      "text": "こんにちは議を開きます直に本日の議事に"
    },
    {
      "start": 571.959,
      "duration": 5.361,
      "text": "入ります当委員会に付託されております"
    },
    {
      "start": 574.64,
      "duration": 6.56,
      "text": "案件は前回の委員会で保留といたしました"
    },
    {
      "start": 577.32,
      "duration": 6.48,
      "text": "近常2件です以上2件につきましては総務"
    },
    {
      "start": 581.2,
      "duration": 4.84,
      "text": "企画委員会審査予定表の順序で行うことと"
    },
    {
      "start": 583.8,
      "duration": 2.24,
      "text": "いたし"
    },
    {
      "start": 589.77,
      "duration": 7.23,
      "text": "[音楽]"
    },
    {
      "start": 592.36,
      "duration": 8.76,
      "text": "ますこっちかこれこれ言わない"
    },
    {
      "start": 597.0,
      "duration": 9.399,
      "text": "とこの最初にあ2"
    },
    {
      "start": 601.12,
      "duration": 8.8,
      "text": "ペえ始めにえ6陳所第36号消防団員の"
    },
    {
      "start": 606.399,
      "duration": 6.201,
      "text": "確保を図るため処遇改善を求める陳情書を"
    },
    {
      "start": 609.92,
      "duration": 5.72,
      "text": "議題といたしますえ部局から発言があり"
    },
    {
      "start": 612.6,
      "duration": 5.88,
      "text": "ましたらこれを求めますえこれから質を"
    },
    {
      "start": 615.64,
      "duration": 7.639,
      "text": "行います"
    },
    {
      "start": 618.48,
      "duration": 6.919,
      "text": "えはいえ本件につきまして委員長報告に"
    },
    {
      "start": 623.279,
      "duration": 5.24,
      "text": "乗せる意見要望がございましたら発言をお"
    },
    {
      "start": 625.399,
      "duration": 5.88,
      "text": "願いいたしますえ以上で本件に対する質疑"
    },
    {
      "start": 628.519,
      "duration": 5.641,
      "text": "を終了することにご異ありませんかご異議"
    },
    {
      "start": 631.279,
      "duration": 6.481,
      "text": "なしと認めます従って質疑を終了いたし"
    },
    {
      "start": 634.16,
      "duration": 7.0,
      "text": "ますえこれから討論を行います"
    },
    {
      "start": 637.76,
      "duration": 6.12,
      "text": "ええ本件に対する討論を終了することにご"
    },
    {
      "start": 641.16,
      "duration": 6.359,
      "text": "異議ありませんかご異議なしと認めまし"
    },
    {
      "start": 643.88,
      "duration": 3.639,
      "text": "たがって討論を終了いたします"
    },
    {
      "start": 648.079,
      "duration": 8.281,
      "text": "えそれでは直に採決いたしますえお諮り"
    },
    {
      "start": 652.24,
      "duration": 7.32,
      "text": "いたします本件は主旨択の上市長に付する"
    },
    {
      "start": 656.36,
      "duration": 8.64,
      "text": "ことにご異議ありませんか"
    },
    {
      "start": 659.56,
      "duration": 10.719,
      "text": "認本は択の上市長にすべきものと決定"
    },
    {
      "start": 665.0,
      "duration": 10.24,
      "text": "いたしましたえ次にえ7陳情第1号市民と"
    },
    {
      "start": 670.279,
      "duration": 7.441,
      "text": "共にいじめ自殺児童虐待犯罪等を減らす"
    },
    {
      "start": 675.24,
      "duration": 4.8,
      "text": "取り組みに関する陳情書を議題といたし"
    },
    {
      "start": 677.72,
      "duration": 4.679,
      "text": "ますえ部局から発言がありましたこれを"
    },
    {
      "start": 680.04,
      "duration": 2.359,
      "text": "求め"
    },
    {
      "start": 685.04,
      "duration": 7.52,
      "text": "ますこれから質疑を行います"
    },
    {
      "start": 689.959,
      "duration": 8.721,
      "text": "えっとあ"
    },
    {
      "start": 692.56,
      "duration": 10.079,
      "text": "あのですねはいえお諮りいたしますえ本件"
    },
    {
      "start": 698.68,
      "duration": 6.32,
      "text": "は現時点での質疑を終了し引き続き審査"
    },
    {
      "start": 702.639,
      "duration": 4.721,
      "text": "する必要があると認め継続審査といたし"
    },
    {
      "start": 705.0,
      "duration": 6.12,
      "text": "たいと思いますこれにご異議がありません"
    },
    {
      "start": 707.36,
      "duration": 7.12,
      "text": "かご異議なしと認めます従って本件は継続"
    },
    {
      "start": 711.12,
      "duration": 3.36,
      "text": "審査と決定いたしまし"
    },
    {
      "start": 715.04,
      "duration": 7.039,
      "text": "たはい以上で本日の定は全部終了いたし"
    },
    {
      "start": 718.68,
      "duration": 6.52,
      "text": "ました本日は以上で総務企画委員会を閉会"
    },
    {
      "start": 722.079,
      "duration": 8.081,
      "text": "いたしますお疲れ様でございましたたどう"
    },
    {
      "start": 725.2,
      "duration": 4.96,
      "text": "もお疲れ様お疲れ様でした"
    }
  ]
}