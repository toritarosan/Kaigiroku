{
  "entries": [
    {
      "start": 22.76,
      "duration": 3.96,
      "text": "はいお疲れ様でございますおれでござい"
    },
    {
      "start": 24.8,
      "duration": 5.719,
      "text": "ます回会の協議会を始めさせていただき"
    },
    {
      "start": 26.72,
      "duration": 8.64,
      "text": "ますえ討論採決を確認させていきます会派"
    },
    {
      "start": 30.519,
      "duration": 11.601,
      "text": "ございますかはい共産党さんえっと議員愛"
    },
    {
      "start": 35.36,
      "duration": 12.24,
      "text": "35号え反対討論対対はいワクチンですね"
    },
    {
      "start": 42.12,
      "duration": 9.88,
      "text": "1件であと銀案第39号登校児童に対する"
    },
    {
      "start": 47.6,
      "duration": 9.24,
      "text": "賛成討論森戸ですはいおはい以上2件はい"
    },
    {
      "start": 52.0,
      "duration": 8.16,
      "text": "他ございますかほほ"
    },
    {
      "start": 56.84,
      "duration": 7.359,
      "text": "ほなしはい"
    },
    {
      "start": 60.16,
      "duration": 7.959,
      "text": "では議員第35号反対で太委員議員でえ"
    },
    {
      "start": 64.199,
      "duration": 5.361,
      "text": "38号あ違9号の賛成で森戸議員はいの"
    },
    {
      "start": 68.119,
      "duration": 3.441,
      "text": "以上2件ということで確認させていただい"
    },
    {
      "start": 69.56,
      "duration": 5.64,
      "text": "てよろしいですかはいえ解決については"
    },
    {
      "start": 71.56,
      "duration": 6.16,
      "text": "従来通りよろしいですかはいでは他ござい"
    },
    {
      "start": 75.2,
      "duration": 6.52,
      "text": "ますかよろしいですかはいそれでは議会会"
    },
    {
      "start": 77.72,
      "duration": 4.0,
      "text": "協議会で参加いたします"
    }
  ]
}