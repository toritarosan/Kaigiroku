    {
      "start": 661.88,
      "duration": 4.92,
      "text": "すっていうことは、あ、ま、関連的にも"
    },
    {
      "start": 664.24,
      "duration": 4.64,
      "text": "やっていなかったっていうことで、小準と"
    },
    {
      "start": 666.8,
      "duration": 4.36,
      "text": "しては第2回定例会を目指しておりました"
    },
    {
      "start": 668.88,
      "duration": 4.759,
      "text": "。で、えっと、今回のその5月13日今日"
    },
    {
      "start": 671.16,
      "duration": 4.64,
      "text": "の臨時会におきましてもですね、えっと、"
    },
    {
      "start": 673.639,
      "duration": 4.601,
      "text": "ま、は最初からこう分かってたわけでは"
    },
    {
      "start": 675.8,
      "duration": 4.719,
      "text": "なく、えっと、ま、4月の段階になって、"
    },
    {
      "start": 678.24,
      "duration": 3.88,
      "text": "え、この、えっと、契約決を早めた方が"
    },
    {
      "start": 680.519,
      "duration": 4.041,
      "text": "いいという、ま、こういう判断になりまし"
