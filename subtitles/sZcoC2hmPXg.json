    {
      "start": 615.36,
      "duration": 6.719,
      "text": "れてるということで、え、他市については"
    },
    {
      "start": 618.68,
      "duration": 6.04,
      "text": "、え、3月の定例会で、ま、行ってですね"
    },
    {
      "start": 622.079,
      "duration": 4.641,
      "text": "、あの、クラスアルファの対策が取られ"
    },
    {
      "start": 624.72,
      "duration": 4.64,
      "text": "てるところもあるんではないかと考えて"
    },
    {
      "start": 626.72,
      "duration": 4.92,
      "text": "おります。国分寺なんかはもう非戦の関係"
    },
    {
      "start": 629.36,
      "duration": 6.719,
      "text": "で今日から定例会ですか?ま、そういった"
    },
    {
      "start": 631.64,
      "duration": 7.36,
      "text": "こともある中でですね、今の状況を考えれ"
    },
    {
      "start": 636.079,
      "duration": 5.521,
      "text": "ばですね、あの早急に手を打てる部分は手"
