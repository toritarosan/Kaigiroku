{
  "entries": [
    {
      "start": 0.28,
      "duration": 6.599,
      "text": "え3月にはえ時間が対応が一て見込まれ"
    },
    {
      "start": 3.8,
      "duration": 6.32,
      "text": "ます選挙事務もございますのでえ前回の9"
    },
    {
      "start": 6.879,
      "duration": 5.441,
      "text": "月のえ定例会の総務企画委員会でもご答弁"
    },
    {
      "start": 10.12,
      "duration": 4.679,
      "text": "いたしましたがえこのままのペースですと"
    },
    {
      "start": 12.32,
      "duration": 4.84,
      "text": "年間ま10万あるいは11万時間を超える"
    },
    {
      "start": 14.799,
      "duration": 5.72,
      "text": "というようなことも想定されるということ"
    },
    {
      "start": 17.16,
      "duration": 5.68,
      "text": "でえ担当といたしましてはえ非常にえ危惧"
    },
    {
      "start": 20.519,
      "duration": 6.6,
      "text": "をしている状況というようなことで分析を"
    },
    {
      "start": 22.84,
      "duration": 6.839,
      "text": "行ってございますえ選挙管理委員会事務局"
    },
    {
      "start": 27.119,
      "duration": 4.841,
      "text": "以外のところでもえ大幅に像となっている"
    },
    {
      "start": 29.679,
      "duration": 6.001,
      "text": "部署もございますがえこのような状況を"
    },
    {
      "start": 31.96,
      "duration": 6.84,
      "text": "受けましてえまず今年度の取り組みとし"
    },
    {
      "start": 35.68,
      "duration": 5.92,
      "text": "ましてはえ急遽え6月までの3ヶ月間の"
    },
    {
      "start": 38.8,
      "duration": 5.56,
      "text": "状況を踏まえましてえ大幅に像となって"
    },
    {
      "start": 41.6,
      "duration": 5.88,
      "text": "いるえご部署につきまして8月にえ急遽の"
    },
    {
      "start": 44.36,
      "duration": 5.8,
      "text": "ヒアリングを実施し状況確認とえ今まで"
    },
    {
      "start": 47.48,
      "duration": 5.68,
      "text": "以上の時間が抑制の取り組みの徹底を確認"
    },
    {
      "start": 50.16,
      "duration": 6.719,
      "text": "したところでございますえまたえ11月に"
    },
    {
      "start": 53.16,
      "duration": 6.8,
      "text": "は紙半期の状況についてえ同様にえ前年度"
    },
    {
      "start": 56.879,
      "duration": 5.401,
      "text": "費で大幅にえ時間外が増となっている部署"
    },
    {
      "start": 59.96,
      "duration": 5.159,
      "text": "えこれ急部所になりますがその給部所に"
    },
    {
      "start": 62.28,
      "duration": 5.04,
      "text": "ついてえ状況確認を行い必要に応じて"
    },
    {
      "start": 65.119,
      "duration": 4.841,
      "text": "ヒアリングを実施したところでございます"
    },
    {
      "start": 67.32,
      "duration": 5.04,
      "text": "え残り3ヶ月というところで非常にえ"
    },
    {
      "start": 69.96,
      "duration": 4.72,
      "text": "厳しい時間数とはなってございますがえ"
    },
    {
      "start": 72.36,
      "duration": 5.16,
      "text": "引き続き時間外の抑制の取り組みを徹底を"
    },
    {
      "start": 74.68,
      "duration": 5.479,
      "text": "していくということでえ長期等でもえ全長"
    },
    {
      "start": 77.52,
      "duration": 6.559,
      "text": "に集中を図っているところでございますえ"
    },
    {
      "start": 80.159,
      "duration": 5.801,
      "text": "答弁は以上です渡さんはいえご答弁あの"
    },
    {
      "start": 84.079,
      "duration": 3.641,
      "text": "ありがとうございましたまなかなか厳しい"
    },
    {
      "start": 85.96,
      "duration": 4.119,
      "text": "状況だなという風に思ってるんですけれど"
    },
    {
      "start": 87.72,
      "duration": 4.92,
      "text": "もあの是非あのま市長副市長あのあの"
    },
    {
      "start": 90.079,
      "duration": 5.161,
      "text": "トップの方からもですねあの十分あの"
    },
    {
      "start": 92.64,
      "duration": 4.6,
      "text": "いろんな発信をしていただいてあの3月末"
    },
    {
      "start": 95.24,
      "duration": 3.76,
      "text": "に向けてあの少しでも抑制できるような"
    },
    {
      "start": 97.24,
      "duration": 4.08,
      "text": "あの取り組みをあの具体的にやって"
    },
    {
      "start": 99.0,
      "duration": 4.28,
      "text": "いただくことをですねお願いをしておき"
    },
    {
      "start": 101.32,
      "duration": 3.92,
      "text": "たいという風にあの思いますまたあの選挙"
    },
    {
      "start": 103.28,
      "duration": 4.56,
      "text": "関係はどうしてもあの時間外増えのまま"
    },
    {
      "start": 105.24,
      "duration": 5.6,
      "text": "仕方ないんですがま応援体制なども"
    },
    {
      "start": 107.84,
      "duration": 5.16,
      "text": "しっかりとってですねあのちょっとえ"
    },
    {
      "start": 110.84,
      "duration": 4.599,
      "text": "あまり個人にですねちょっとあの健康に"
    },
    {
      "start": 113.0,
      "duration": 4.36,
      "text": "支障が起きるようなあの時間外が生じない"
    },
    {
      "start": 115.439,
      "duration": 4.241,
      "text": "ようなですねま総合応援体制と言い"
    },
    {
      "start": 117.36,
      "duration": 5.6,
      "text": "ましょうかま総務グループのみならずです"
    },
    {
      "start": 119.68,
      "duration": 6.32,
      "text": "ねあの互の応援体とってですねまなんと"
    },
    {
      "start": 122.96,
      "duration": 5.079,
      "text": "かえ3月まであまり極端な時間にならない"
    },
    {
      "start": 126.0,
      "duration": 5.52,
      "text": "ようにですねあのお取り組みをいただく"
    },
    {
      "start": 128.039,
      "duration": 3.481,
      "text": "ようにお願いして終わりたいと思い"
    },
    {
      "start": 132.72,
      "duration": 6.76,
      "text": "ます他ございますでしょう"
    },
    {
      "start": 136.08,
      "duration": 8.92,
      "text": "か特に大丈夫か"
    },
    {
      "start": 139.48,
      "duration": 5.52,
      "text": "なあどうしようえ大丈夫"
    },
    {
      "start": 145.12,
      "duration": 5.399,
      "text": "[音楽]"
    },
    {
      "start": 147.56,
      "duration": 8.52,
      "text": "うんえ"
    },
    {
      "start": 150.519,
      "duration": 8.121,
      "text": "えっとここはあの閉めますねはいえ以上で"
    },
    {
      "start": 156.08,
      "duration": 5.28,
      "text": "本件に対する質疑を終了することにご異議"
    },
    {
      "start": 158.64,
      "duration": 6.879,
      "text": "ありませんかご異議なしと認めます従って"
    },
    {
      "start": 161.36,
      "duration": 8.36,
      "text": "本件に対する質疑を終了いたしますえここ"
    },
    {
      "start": 165.519,
      "duration": 10.601,
      "text": "でえ昼食のためえ概ね1時間休憩いたし"
    },
    {
      "start": 169.72,
      "duration": 6.4,
      "text": "ますえ再開は1時を予定して"
    },
    {
      "start": 178.84,
      "duration": 4.0,
      "text": "ますJA"
    }
  ]
}