{
  "entries": [
    {
      "start": 0.0,
      "duration": 3.0,
      "text": "お"
    },
    {
      "start": 83.079,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 98.119,
      "duration": 3.0,
      "text": "っ"
    },
    {
      "start": 128.679,
      "duration": 6.481,
      "text": "え間もなく開会いたしますがえ今日ですね"
    },
    {
      "start": 132.2,
      "duration": 6.16,
      "text": "あの遠藤議員からあの体長不良ということ"
    },
    {
      "start": 135.16,
      "duration": 5.799,
      "text": "であの会議休むということでご連絡を受け"
    },
    {
      "start": 138.36,
      "duration": 4.8,
      "text": "ておりますのであらかじめあのお伝えして"
    },
    {
      "start": 140.959,
      "duration": 7.721,
      "text": "おき"
    },
    {
      "start": 143.16,
      "duration": 7.56,
      "text": "ますじゃあやれねおですお揃いえお揃い"
    },
    {
      "start": 148.68,
      "duration": 4.0,
      "text": "ですね"
    },
    {
      "start": 150.72,
      "duration": 4.159,
      "text": "それではあのお揃いですので始めたいと"
    },
    {
      "start": 152.68,
      "duration": 2.199,
      "text": "思い"
    },
    {
      "start": 157.2,
      "duration": 6.2,
      "text": "ますおはようございますおはようござい"
    },
    {
      "start": 159.72,
      "duration": 7.159,
      "text": "ますただいまからえただいまから令和6年"
    },
    {
      "start": 163.4,
      "duration": 6.4,
      "text": "第2回小金市議会臨時会を開会します本日"
    },
    {
      "start": 166.879,
      "duration": 6.401,
      "text": "の会議を開きます市長より発言を求められ"
    },
    {
      "start": 169.8,
      "duration": 7.12,
      "text": "ておりますので発言を許可します長"
    },
    {
      "start": 173.28,
      "duration": 7.48,
      "text": "おはようございますえ本日の臨時会の開催"
    },
    {
      "start": 176.92,
      "duration": 7.64,
      "text": "にたりましてはえこのような時期にとなり"
    },
    {
      "start": 180.76,
      "duration": 7.0,
      "text": "大変心苦しく思っておりますえまたえ風"
    },
    {
      "start": 184.56,
      "duration": 6.28,
      "text": "謝りえ風に事務に関し誤りがございまして"
    },
    {
      "start": 187.76,
      "duration": 5.039,
      "text": "えこの場をお借りしてえ市民の皆様へ上を"
    },
    {
      "start": 190.84,
      "duration": 5.119,
      "text": "申し上げます大変申し訳ございませんでし"
    },
    {
      "start": 192.799,
      "duration": 5.681,
      "text": "たえこの状態は早期に是正する必要がある"
    },
    {
      "start": 195.959,
      "duration": 4.681,
      "text": "という考えからえ本日の招集に至っており"
    },
    {
      "start": 198.48,
      "duration": 5.759,
      "text": "ますことをえご理解いただきえご審議の"
    },
    {
      "start": 200.64,
      "duration": 3.599,
      "text": "ほどよろしくお願いいたします以上"
    },
    {
      "start": 204.879,
      "duration": 7.0,
      "text": "です美事進行渡辺大蔵"
    },
    {
      "start": 208.76,
      "duration": 5.119,
      "text": "さんちょっと議事進行上あの発言しておき"
    },
    {
      "start": 211.879,
      "duration": 6.161,
      "text": "たいというのとあの確認したいことがあり"
    },
    {
      "start": 213.879,
      "duration": 6.44,
      "text": "ましてあの猿の7月31日の臨時議会が"
    },
    {
      "start": 218.04,
      "duration": 5.52,
      "text": "ございましてその日にあの会派代表者会議"
    },
    {
      "start": 220.319,
      "duration": 5.441,
      "text": "が開催されておりますでこの風りの件は"
    },
    {
      "start": 223.56,
      "duration": 4.44,
      "text": "その会派代表者会議でも一定のご報告を"
    },
    {
      "start": 225.76,
      "duration": 4.16,
      "text": "いただいたところでございましてあの近畿"
    },
    {
      "start": 228.0,
      "duration": 4.12,
      "text": "ま臨時会の必要があるということでま市長"
    },
    {
      "start": 229.92,
      "duration": 4.28,
      "text": "の側からもご説明があったところであり"
    },
    {
      "start": 232.12,
      "duration": 4.199,
      "text": "ましたでそこでまこういう時期であります"
    },
    {
      "start": 234.2,
      "duration": 5.0,
      "text": "のであのそれぞれ皆さんご予定もあるかと"
    },
    {
      "start": 236.319,
      "duration": 5.721,
      "text": "思ったのであの私の方からあの臨時議会の"
    },
    {
      "start": 239.2,
      "duration": 6.44,
      "text": "開催の時期についての目処についてその場"
    },
    {
      "start": 242.04,
      "duration": 6.52,
      "text": "で伺ったところなんですねでその時に"
    },
    {
      "start": 245.64,
      "duration": 7.28,
      "text": "えっと私の記憶に間違いがなければ市長の"
    },
    {
      "start": 248.56,
      "duration": 6.519,
      "text": "側からは早くても早くてもえ8月の19日"
    },
    {
      "start": 252.92,
      "duration": 4.439,
      "text": "以降になるというご説明をいただいたと"
    },
    {
      "start": 255.079,
      "duration": 4.16,
      "text": "いう風に思っておりまして一応あの局長に"
    },
    {
      "start": 257.359,
      "duration": 3.321,
      "text": "確認した当時その時議長いらっしゃら"
    },
    {
      "start": 259.239,
      "duration": 3.761,
      "text": "なかったんでちょっと局長に確認したいん"
    },
    {
      "start": 260.68,
      "duration": 4.04,
      "text": "ですがえそのように私から確認したところ"
    },
    {
      "start": 263.0,
      "duration": 3.72,
      "text": "そういう説明が視聴からあったということ"
    },
    {
      "start": 264.72,
      "duration": 5.36,
      "text": "で事実経過確認していいかどうかってこと"
    },
    {
      "start": 266.72,
      "duration": 6.12,
      "text": "が1つありますのでま確認したいのとあと"
    },
    {
      "start": 270.08,
      "duration": 5.28,
      "text": "市長に伺いたいのはあのま議会の日程をま"
    },
    {
      "start": 272.84,
      "duration": 5.68,
      "text": "色々こう決めたりする時もま例えばあの"
    },
    {
      "start": 275.36,
      "duration": 5.44,
      "text": "市長の日程が塞がっているところは外して"
    },
    {
      "start": 278.52,
      "duration": 4.44,
      "text": "あの議会の日程などもあの組むなどのま"
    },
    {
      "start": 280.8,
      "duration": 4.16,
      "text": "配慮をですねお互いにしているのかなと"
    },
    {
      "start": 282.96,
      "duration": 4.88,
      "text": "いう風に思っておりましてまそれから見る"
    },
    {
      "start": 284.96,
      "duration": 5.679,
      "text": "とあの先般のあの会派代表者会議でという"
    },
    {
      "start": 287.84,
      "duration": 5.079,
      "text": "ことでわざわざですねえ臨時議会がえどこ"
    },
    {
      "start": 290.639,
      "duration": 4.521,
      "text": "で開かれるのかっていうことを確認しえ"
    },
    {
      "start": 292.919,
      "duration": 4.801,
      "text": "そこで一定の説明が行われたのに今日は"
    },
    {
      "start": 295.16,
      "duration": 5.12,
      "text": "16日ですからこう全然違うこう設定に"
    },
    {
      "start": 297.72,
      "duration": 4.479,
      "text": "なっているということで聞くところでは"
    },
    {
      "start": 300.28,
      "duration": 3.919,
      "text": "かなりあらかじめ予定していたものをあの"
    },
    {
      "start": 302.199,
      "duration": 4.881,
      "text": "全部あの吹っ飛んでしまった議員さんも"
    },
    {
      "start": 304.199,
      "duration": 5.081,
      "text": "イルヤにもえ聞いてあのおりましてねお"
    },
    {
      "start": 307.08,
      "duration": 5.119,
      "text": "互いにやっぱりこういう点に関しては長都"
    },
    {
      "start": 309.28,
      "duration": 4.68,
      "text": "議会でですねお互いに色々配慮しながらえ"
    },
    {
      "start": 312.199,
      "duration": 4.681,
      "text": "やっていく必要があると思うんですが今後"
    },
    {
      "start": 313.96,
      "duration": 5.04,
      "text": "もまこういうことが続くのかま今回の件と"
    },
    {
      "start": 316.88,
      "duration": 4.319,
      "text": "いうのはそういう経過から考えても非常に"
    },
    {
      "start": 319.0,
      "duration": 4.759,
      "text": "良くないえ設定だったということでのご"
    },
    {
      "start": 321.199,
      "duration": 5.321,
      "text": "自覚があるのかどうかま今後のことも含め"
    },
    {
      "start": 323.759,
      "duration": 5.0,
      "text": "て市長にもきちんと見解をえ市長からの"
    },
    {
      "start": 326.52,
      "duration": 4.76,
      "text": "見解もえ頂いておきたいという風に思い"
    },
    {
      "start": 328.759,
      "duration": 4.961,
      "text": "ます繰り返しますがまお互いに行政と議会"
    },
    {
      "start": 331.28,
      "duration": 4.28,
      "text": "それぞれで日程の決定についてはまお互い"
    },
    {
      "start": 333.72,
      "duration": 4.199,
      "text": "に配慮してこれまでやってきた歴史がある"
    },
    {
      "start": 335.56,
      "duration": 4.0,
      "text": "と思ってるので今回は相当それと違うこと"
    },
    {
      "start": 337.919,
      "duration": 3.601,
      "text": "になっているんじゃないかなと思ってるの"
    },
    {
      "start": 339.56,
      "duration": 4.639,
      "text": "であまあのこういう場ではありますけれど"
    },
    {
      "start": 341.52,
      "duration": 5.16,
      "text": "もあのあの開発と代表者会議水面下の会議"
    },
    {
      "start": 344.199,
      "duration": 4.641,
      "text": "になってしまうので今この場でですね表の"
    },
    {
      "start": 346.68,
      "duration": 4.32,
      "text": "場でもきちんと確認して今後のことをも"
    },
    {
      "start": 348.84,
      "duration": 4.88,
      "text": "含めてご説明をいただきたいと思いますの"
    },
    {
      "start": 351.0,
      "duration": 6.12,
      "text": "で議事実行上え確認の発言をさして"
    },
    {
      "start": 353.72,
      "duration": 7.16,
      "text": "いただきますはいじゃじゃ局長それでは"
    },
    {
      "start": 357.12,
      "duration": 6.76,
      "text": "局長からはいはいえっと今あの会派代表者"
    },
    {
      "start": 360.88,
      "duration": 5.439,
      "text": "会議でのあのご発言っていうことの議事"
    },
    {
      "start": 363.88,
      "duration": 4.92,
      "text": "進行ございましたま私もその前出ており"
    },
    {
      "start": 366.319,
      "duration": 4.961,
      "text": "ましたけれどもえ渡辺議員がおっしゃる"
    },
    {
      "start": 368.8,
      "duration": 4.36,
      "text": "ような形でのご発言があったという風に私"
    },
    {
      "start": 371.28,
      "duration": 3.52,
      "text": "も記憶しております以上"
    },
    {
      "start": 373.16,
      "duration": 6.52,
      "text": "です"
    },
    {
      "start": 374.8,
      "duration": 7.64,
      "text": "長え渡辺大さんから議進行でえご質問を"
    },
    {
      "start": 379.68,
      "duration": 5.4,
      "text": "いいておりますえっとまこの経過は今あの"
    },
    {
      "start": 382.44,
      "duration": 5.159,
      "text": "危害事務局長がま答弁あのされた通りで"
    },
    {
      "start": 385.08,
      "duration": 4.2,
      "text": "あると認識をしておりますでえ今回え"
    },
    {
      "start": 387.599,
      "duration": 4.401,
      "text": "じゃあ16日になぜなったのかということ"
    },
    {
      "start": 389.28,
      "duration": 5.88,
      "text": "でざいますがえっと我々といたしましては"
    },
    {
      "start": 392.0,
      "duration": 6.56,
      "text": "ですねえ1日にも早くえこのえ土事案事情"
    },
    {
      "start": 395.16,
      "duration": 6.319,
      "text": "をえ現状を解消すべきだとえ考えましてで"
    },
    {
      "start": 398.56,
      "duration": 5.6,
      "text": "えっと確かに7月31日の会派代表者会議"
    },
    {
      "start": 401.479,
      "duration": 5.081,
      "text": "の中ではえま早くて19日あたりだという"
    },
    {
      "start": 404.16,
      "duration": 6.56,
      "text": "ことはえ伸ばさせていただいておりました"
    },
    {
      "start": 406.56,
      "duration": 6.96,
      "text": "がえま我々がまで31日の段階ではですね"
    },
    {
      "start": 410.72,
      "duration": 5.0,
      "text": "えその時もご説明をしたと思うんですが"
    },
    {
      "start": 413.52,
      "duration": 4.239,
      "text": "えっと対象者の方にえっとアプローチし"
    },
    {
      "start": 415.72,
      "duration": 4.319,
      "text": "始めた段階であるということをえっとご"
    },
    {
      "start": 417.759,
      "duration": 5.321,
      "text": "説明させていただいたと思っております"
    },
    {
      "start": 420.039,
      "duration": 6.16,
      "text": "でえっとそこからですね我々がえっとま"
    },
    {
      "start": 423.08,
      "duration": 5.679,
      "text": "考えていたよりも早くえまお会いする直接"
    },
    {
      "start": 426.199,
      "duration": 6.761,
      "text": "お会いすることができえま内容についてご"
    },
    {
      "start": 428.759,
      "duration": 7.601,
      "text": "説明をしえまそのえ段階においてえま1日"
    },
    {
      "start": 432.96,
      "duration": 7.519,
      "text": "も早くえ変換する方策についてえま町内で"
    },
    {
      "start": 436.36,
      "duration": 6.559,
      "text": "検討整理した結果えまこの16日にえま"
    },
    {
      "start": 440.479,
      "duration": 5.72,
      "text": "早くて開催できるという運びになったわけ"
    },
    {
      "start": 442.919,
      "duration": 6.921,
      "text": "でございますあのそういうえ事案の特性"
    },
    {
      "start": 446.199,
      "duration": 5.801,
      "text": "から考えてですねえま今回えま急遽という"
    },
    {
      "start": 449.84,
      "duration": 4.52,
      "text": "形になりましてえ大変ご迷惑をおかけして"
    },
    {
      "start": 452.0,
      "duration": 6.479,
      "text": "おりますがえそのような状況でございます"
    },
    {
      "start": 454.36,
      "duration": 5.36,
      "text": "でえっとま先ほどま大の方からはえま今後"
    },
    {
      "start": 458.479,
      "duration": 3.921,
      "text": "もこういうことがあるのかということで"
    },
    {
      "start": 459.72,
      "duration": 4.52,
      "text": "ございますがえ先ほど渡さんの方から"
    },
    {
      "start": 462.4,
      "duration": 5.6,
      "text": "おっしゃっていただいたようにえ議会の"
    },
    {
      "start": 464.24,
      "duration": 6.0,
      "text": "日程につきましてはまま当然双方のえま"
    },
    {
      "start": 468.0,
      "duration": 5.039,
      "text": "予定なんかを考慮してえ組んできた経過が"
    },
    {
      "start": 470.24,
      "duration": 5.28,
      "text": "あるってことは認識をしておりますでえ"
    },
    {
      "start": 473.039,
      "duration": 4.521,
      "text": "今後もですねえま当然えそういう認識に"
    },
    {
      "start": 475.52,
      "duration": 4.519,
      "text": "基づいてえ予定を組まさせていただきます"
    },
    {
      "start": 477.56,
      "duration": 6.12,
      "text": "がえ先ほども申し上げましたようにえ今回"
    },
    {
      "start": 480.039,
      "duration": 5.801,
      "text": "の事案のえ関係性上ですねえま急遽16日"
    },
    {
      "start": 483.68,
      "duration": 3.84,
      "text": "ということとなりましたことは改めてえ"
    },
    {
      "start": 485.84,
      "duration": 5.44,
      "text": "申し訳なく思ってるところでございます"
    },
    {
      "start": 487.52,
      "duration": 6.2,
      "text": "以上ですはい渡さんはいま一定のご発言"
    },
    {
      "start": 491.28,
      "duration": 5.0,
      "text": "いただきましたでまあの事案の性格から"
    },
    {
      "start": 493.72,
      "duration": 6.12,
      "text": "考えるとかつて小金市においてはあの社会"
    },
    {
      "start": 496.28,
      "duration": 5.599,
      "text": "福祉へのあの報酬があの条例よりもあの"
    },
    {
      "start": 499.84,
      "duration": 4.4,
      "text": "1000円少なくずっと払い続けていたて"
    },
    {
      "start": 501.879,
      "duration": 4.361,
      "text": "いう事案がありましてでこれであの当時の"
    },
    {
      "start": 504.24,
      "duration": 5.48,
      "text": "市長の処理が大変遅れてしまったために"
    },
    {
      "start": 506.24,
      "duration": 5.359,
      "text": "遅延損害金が有造して非常にあのま言って"
    },
    {
      "start": 509.72,
      "duration": 5.119,
      "text": "みると払わなくてもいいあの損害が死に"
    },
    {
      "start": 511.599,
      "duration": 5.161,
      "text": "生じた事案があってで高木明成さんと私で"
    },
    {
      "start": 514.839,
      "duration": 4.76,
      "text": "2人で監査請求をいたしましたところ監査"
    },
    {
      "start": 516.76,
      "duration": 6.279,
      "text": "院が我々の主張を認めて時の市長とその前"
    },
    {
      "start": 519.599,
      "duration": 5.601,
      "text": "の市長のにえこの遅延損害金のについては"
    },
    {
      "start": 523.039,
      "duration": 4.92,
      "text": "ですねあの個人的に賠償するようにとの"
    },
    {
      "start": 525.2,
      "duration": 5.68,
      "text": "監査請求のえ監査結果を出していただいて"
    },
    {
      "start": 527.959,
      "duration": 6.481,
      "text": "お2人のあの現元市長からえお金が"
    },
    {
      "start": 530.88,
      "duration": 5.32,
      "text": "56万円程度だったと思いますがえ市にえ"
    },
    {
      "start": 534.44,
      "duration": 3.6,
      "text": "払われたということがあってねまだから"
    },
    {
      "start": 536.2,
      "duration": 3.56,
      "text": "今回の件も急がれる事案だということは"
    },
    {
      "start": 538.04,
      "duration": 3.6,
      "text": "あの分かっているので急いでいたいいた"
    },
    {
      "start": 539.76,
      "duration": 3.56,
      "text": "ことはいいと思ってるんですがやっぱり"
    },
    {
      "start": 541.64,
      "duration": 4.4,
      "text": "あの日程のやっぱりあのだとしたら"
    },
    {
      "start": 543.32,
      "duration": 5.92,
      "text": "アナウンスもですねま考える中でもしここ"
    },
    {
      "start": 546.04,
      "duration": 4.72,
      "text": "が1番最初ここまでここまでからはえ可能"
    },
    {
      "start": 549.24,
      "duration": 3.599,
      "text": "性があるというところにあればあらかじめ"
    },
    {
      "start": 550.76,
      "duration": 4.639,
      "text": "アナウンスする必要あったのかなという風"
    },
    {
      "start": 552.839,
      "duration": 4.361,
      "text": "に思ってあのいるんですよねあの時は早く"
    },
    {
      "start": 555.399,
      "duration": 3.68,
      "text": "ても19日ということで断定されており"
    },
    {
      "start": 557.2,
      "duration": 3.4,
      "text": "ましたのであのそうするとなんか根拠が"
    },
    {
      "start": 559.079,
      "duration": 3.76,
      "text": "あったはずだという風に思うんですよねま"
    },
    {
      "start": 560.6,
      "duration": 4.44,
      "text": "だからその点から考えるとま今回のような"
    },
    {
      "start": 562.839,
      "duration": 5.041,
      "text": "件さっき申し上げましたけれどもあのその"
    },
    {
      "start": 565.04,
      "duration": 5.4,
      "text": "お話がなければね例えばま16日以降とか"
    },
    {
      "start": 567.88,
      "duration": 5.28,
      "text": "15日以降とか中の話があればみんなそれ"
    },
    {
      "start": 570.44,
      "duration": 4.6,
      "text": "に備えていたとあの思うんですよねあの私"
    },
    {
      "start": 573.16,
      "duration": 4.28,
      "text": "も実は今日は用事があったんですがあの"
    },
    {
      "start": 575.04,
      "duration": 4.239,
      "text": "議会にはですね親の死に目に会えなくても"
    },
    {
      "start": 577.44,
      "duration": 3.959,
      "text": "出ろていう風に言われてるんであの今日は"
    },
    {
      "start": 579.279,
      "duration": 5.201,
      "text": "出てきておりますけれどもあのやっぱり"
    },
    {
      "start": 581.399,
      "duration": 4.481,
      "text": "あの個々の議員によっては家庭の状況とか"
    },
    {
      "start": 584.48,
      "duration": 3.599,
      "text": "ですねいろんなことがあってどうしても"
    },
    {
      "start": 585.88,
      "duration": 4.16,
      "text": "休まざ得ないの人もいたりするわけなん"
    },
    {
      "start": 588.079,
      "duration": 4.041,
      "text": "ですよねえなのでやっぱりこの日程の設定"
    },
    {
      "start": 590.04,
      "duration": 4.08,
      "text": "に関してお互いに十分配慮を今後していく"
    },
    {
      "start": 592.12,
      "duration": 5.04,
      "text": "必要があるという風に思っておりまして"
    },
    {
      "start": 594.12,
      "duration": 5.279,
      "text": "今回の事案はみではあの残念なあだったな"
    },
    {
      "start": 597.16,
      "duration": 4.0,
      "text": "とえ日程の設定に関してはやっぱりあの"
    },
    {
      "start": 599.399,
      "duration": 3.321,
      "text": "可能性があるところに関してはやっぱり"
    },
    {
      "start": 601.16,
      "duration": 4.84,
      "text": "きちんと言及していただきたかったという"
    },
    {
      "start": 602.72,
      "duration": 4.96,
      "text": "ことを申し述べてま技震向上発言とさせて"
    },
    {
      "start": 606.0,
      "duration": 4.16,
      "text": "いただきますのでよろしくお願いいたし"
    },
    {
      "start": 607.68,
      "duration": 2.48,
      "text": "ます以上"
    },
    {
      "start": 610.6,
      "duration": 10.72,
      "text": "ですそれではえ進めますえ議会委員会とを"
    },
    {
      "start": 615.92,
      "duration": 5.4,
      "text": "開催するためしばらく休憩しますはいで"
    },
    {
      "start": 628.32,
      "duration": 4.0,
      "text": "議会あ"
    }
  ]
}