{
  "entries": [
    {
      "start": 20.039,
      "duration": 6.201,
      "text": "ああじゃ今"
    },
    {
      "start": 23.4,
      "duration": 6.039,
      "text": "はいじゃすいません総務企画委員会の協議"
    },
    {
      "start": 26.24,
      "duration": 5.72,
      "text": "会から始めます皆さんお集まりですのでえ"
    },
    {
      "start": 29.439,
      "duration": 7.64,
      "text": "おなのでちゃちゃとやりたいと思います"
    },
    {
      "start": 31.96,
      "duration": 8.36,
      "text": "えっとあの今日あのえっと案件があ陳情"
    },
    {
      "start": 37.079,
      "duration": 6.681,
      "text": "意見ですけれどもこれ全回派の確認"
    },
    {
      "start": 40.32,
      "duration": 7.32,
      "text": "取り扱いに関してえ全回派の確認が取れて"
    },
    {
      "start": 43.76,
      "duration": 7.16,
      "text": "おりますのでえっと委員会場ではあ継続で"
    },
    {
      "start": 47.64,
      "duration": 6.88,
      "text": "お諮りをしたいと思います"
    },
    {
      "start": 50.92,
      "duration": 6.52,
      "text": "あの休憩を挟まずにあのどんどん進みます"
    },
    {
      "start": 54.52,
      "duration": 4.48,
      "text": "んでえっとそのよろしいでしょうかえ"
    },
    {
      "start": 57.44,
      "duration": 4.799,
      "text": "そんな感じでやっていきたいと思いますの"
    },
    {
      "start": 59.0,
      "duration": 4.96,
      "text": "でよろしくお願いしますじゃ行きましょう"
    },
    {
      "start": 62.239,
      "duration": 5.201,
      "text": "か"
    },
    {
      "start": 63.96,
      "duration": 4.799,
      "text": "はいはい"
    },
    {
      "start": 67.44,
      "duration": 4.6,
      "text": "[音楽]"
    },
    {
      "start": 68.759,
      "duration": 6.521,
      "text": "うんこんにちはこんにちはえただいまから"
    },
    {
      "start": 72.04,
      "duration": 5.56,
      "text": "総務企画委員会の会議を開きます直に本日"
    },
    {
      "start": 75.28,
      "duration": 4.879,
      "text": "の議事に入ります当委員会に付託されて"
    },
    {
      "start": 77.6,
      "duration": 6.0,
      "text": "おります案件は前回の委員会で保留と"
    },
    {
      "start": 80.159,
      "duration": 6.28,
      "text": "いたしました陳情一件です以上1件につき"
    },
    {
      "start": 83.6,
      "duration": 8.08,
      "text": "ましては総務企画委員会審査予定表の通り"
    },
    {
      "start": 86.439,
      "duration": 9.281,
      "text": "行うことといたしますえ直にえ賃第29号"
    },
    {
      "start": 91.68,
      "duration": 6.36,
      "text": "母が中国で不法に逮捕されている件につい"
    },
    {
      "start": 95.72,
      "duration": 5.719,
      "text": "ての陳情書を議題といたします部局から"
    },
    {
      "start": 98.04,
      "duration": 5.96,
      "text": "発言がありましたこれを求めますこれから"
    },
    {
      "start": 101.439,
      "duration": 7.64,
      "text": "質疑を行い"
    },
    {
      "start": 104.0,
      "duration": 8.2,
      "text": "ますはいお諮りいたしますえ本件は現時点"
    },
    {
      "start": 109.079,
      "duration": 5.801,
      "text": "での質疑を終了し引き続き審査する必要が"
    },
    {
      "start": 112.2,
      "duration": 5.48,
      "text": "あると認め継続審査といたしたいと思い"
    },
    {
      "start": 114.88,
      "duration": 5.599,
      "text": "ますこれにご異議ありませんかご異議なし"
    },
    {
      "start": 117.68,
      "duration": 6.719,
      "text": "と認めます従って本件は継続審査と決定"
    },
    {
      "start": 120.479,
      "duration": 6.64,
      "text": "いたしましたえ以上で本日の日程は全部"
    },
    {
      "start": 124.399,
      "duration": 5.48,
      "text": "終了いたしました本日は以上で総務企画"
    },
    {
      "start": 127.119,
      "duration": 5.76,
      "text": "委員会を閉会いたしますありがとうござい"
    },
    {
      "start": 129.879,
      "duration": 3.0,
      "text": "ます"
    }
  ]
}