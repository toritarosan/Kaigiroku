{
  "entries": [
    {
      "start": 28.96,
      "duration": 3.0,
      "text": "あ"
    },
    {
      "start": 62.44,
      "duration": 5.28,
      "text": "お疲れ様ですお揃いでございますので議会"
    },
    {
      "start": 64.96,
      "duration": 6.76,
      "text": "運営会協議会を始めさせていただきます"
    },
    {
      "start": 67.72,
      "duration": 6.32,
      "text": "まず議案28号についてえ討論の確認をさ"
    },
    {
      "start": 71.72,
      "duration": 5.399,
      "text": "せていただきます討論があると会派はあり"
    },
    {
      "start": 74.04,
      "duration": 4.28,
      "text": "ますかお皆さんなしはいじゃ最近ついては"
    },
    {
      "start": 77.119,
      "duration": 3.281,
      "text": "充電通りということでよろしかった"
    },
    {
      "start": 78.32,
      "duration": 3.92,
      "text": "でしょうかはい討論なしということで"
    },
    {
      "start": 80.4,
      "duration": 4.679,
      "text": "ございますので確認させていただきました"
    },
    {
      "start": 82.24,
      "duration": 5.199,
      "text": "えその他何かございますかはいはい片山副"
    },
    {
      "start": 85.079,
      "duration": 6.641,
      "text": "長はいあ協議会"
    },
    {
      "start": 87.439,
      "duration": 8.281,
      "text": "協会はいはいあの昨日の議員会運営委員会"
    },
    {
      "start": 91.72,
      "duration": 7.759,
      "text": "で確認しましたえ3月5日のあの建設環境"
    },
    {
      "start": 95.72,
      "duration": 6.48,
      "text": "委員会後の本会議で行う視聴報告のですね"
    },
    {
      "start": 99.479,
      "duration": 5.0,
      "text": "についてはこれはあの判決分が必要である"
    },
    {
      "start": 102.2,
      "duration": 4.8,
      "text": "ということを申し上げてるわけなんですが"
    },
    {
      "start": 104.479,
      "duration": 4.92,
      "text": "こちらについては閲覧制限のところを確認"
    },
    {
      "start": 107.0,
      "duration": 5.2,
      "text": "して判決分を出すということについての"
    },
    {
      "start": 109.399,
      "duration": 3.961,
      "text": "確認はどうなったかかのえお聞きしたいと"
    },
    {
      "start": 112.2,
      "duration": 3.36,
      "text": "思い"
    },
    {
      "start": 113.36,
      "duration": 6.079,
      "text": "ますはい総部"
    },
    {
      "start": 115.56,
      "duration": 6.919,
      "text": "長あの前回答弁したあの閲覧制限がかかっ"
    },
    {
      "start": 119.439,
      "duration": 5.121,
      "text": "ておりますのでえ今裁判所からそこについ"
    },
    {
      "start": 122.479,
      "duration": 4.121,
      "text": "ての確認は取れてございませんの現時点で"
    },
    {
      "start": 124.56,
      "duration": 3.759,
      "text": "判決を出すのは難しいということでこれは"
    },
    {
      "start": 126.6,
      "duration": 6.12,
      "text": "変わってございませ"
    },
    {
      "start": 128.319,
      "duration": 6.721,
      "text": "んはい片山副員長え判決分を出さないと"
    },
    {
      "start": 132.72,
      "duration": 4.2,
      "text": "いうことなんですがではどうするんですか"
    },
    {
      "start": 135.04,
      "duration": 4.08,
      "text": "何か資料として他のものは出さないん"
    },
    {
      "start": 136.92,
      "duration": 2.2,
      "text": "でしょう"
    },
    {
      "start": 139.599,
      "duration": 7.801,
      "text": "かはい風副君長はいあの判決分の用紙を"
    },
    {
      "start": 144.76,
      "duration": 4.64,
      "text": "これはあの原告の弁護士の方がですね裁判"
    },
    {
      "start": 147.4,
      "duration": 4.8,
      "text": "所に要求して用紙を作ってもらってるん"
    },
    {
      "start": 149.4,
      "duration": 4.8,
      "text": "ですね裁判所の方からそそちらの方もです"
    },
    {
      "start": 152.2,
      "duration": 5.2,
      "text": "ねま一覧制限の部分はあると思います"
    },
    {
      "start": 154.2,
      "duration": 5.319,
      "text": "けれどもそちらについてはえあの確認すれ"
    },
    {
      "start": 157.4,
      "duration": 4.64,
      "text": "ば出せると思いますけれどももうすでに"
    },
    {
      "start": 159.519,
      "duration": 5.841,
      "text": "記者会見などでも配ってますのでそちらに"
    },
    {
      "start": 162.04,
      "duration": 5.559,
      "text": "ついては出せないんでしょうかはい総部長"
    },
    {
      "start": 165.36,
      "duration": 5.2,
      "text": "あの判決用紙につきましてはいずれにしろ"
    },
    {
      "start": 167.599,
      "duration": 6.0,
      "text": "原告の方の確認が必要とは思いますけれど"
    },
    {
      "start": 170.56,
      "duration": 6.319,
      "text": "もあの原告の方の確認が取れれば一定その"
    },
    {
      "start": 173.599,
      "duration": 6.321,
      "text": "中でえ少し黒塗りにする部分のあるかも"
    },
    {
      "start": 176.879,
      "duration": 5.161,
      "text": "しれませんがあの原告の方に確認をしたの"
    },
    {
      "start": 179.92,
      "duration": 4.239,
      "text": "とあの対応ができるのであれば対応させて"
    },
    {
      "start": 182.04,
      "duration": 7.08,
      "text": "いただきたいと思います以上"
    },
    {
      "start": 184.159,
      "duration": 7.481,
      "text": "ですはい片山委員長はいはい用紙は出すと"
    },
    {
      "start": 189.12,
      "duration": 4.32,
      "text": "いうことで資料として出していただくと"
    },
    {
      "start": 191.64,
      "duration": 4.36,
      "text": "いうことかもしれませんけれどもまあの"
    },
    {
      "start": 193.44,
      "duration": 4.64,
      "text": "判決分全体がないとやっぱり質疑が"
    },
    {
      "start": 196.0,
      "duration": 5.2,
      "text": "なかなかできないと私は思っております"
    },
    {
      "start": 198.08,
      "duration": 6.0,
      "text": "こちらの判決分全体についてあのきちんと"
    },
    {
      "start": 201.2,
      "duration": 5.319,
      "text": "ですね出していただくとまあの閲覧制限の"
    },
    {
      "start": 204.08,
      "duration": 4.519,
      "text": "部分だけは残しあのこちはマスキングした"
    },
    {
      "start": 206.519,
      "duration": 4.64,
      "text": "ものということで結構なんですけれども"
    },
    {
      "start": 208.599,
      "duration": 4.761,
      "text": "ちらについてはえ議員の方できちんと"
    },
    {
      "start": 211.159,
      "duration": 6.28,
      "text": "はっきりあの確認しませんと質疑に耐え"
    },
    {
      "start": 213.36,
      "duration": 5.68,
      "text": "られませんのでそちらについてのえ公開と"
    },
    {
      "start": 217.439,
      "duration": 4.961,
      "text": "いうかですねあの出していただくことに"
    },
    {
      "start": 219.04,
      "duration": 5.919,
      "text": "ついてもま例えばあるいは事務局の方に"
    },
    {
      "start": 222.4,
      "duration": 5.199,
      "text": "おいあの議会事務局の方で閲覧するという"
    },
    {
      "start": 224.959,
      "duration": 4.36,
      "text": "形でも結構ですけれども何かしらの形で"
    },
    {
      "start": 227.599,
      "duration": 3.801,
      "text": "議員の方で把握できるようにしていただき"
    },
    {
      "start": 229.319,
      "duration": 5.441,
      "text": "たいという風に考えておりますけれども"
    },
    {
      "start": 231.4,
      "duration": 5.36,
      "text": "いかがでしょうかはい村部長あのまず基本"
    },
    {
      "start": 234.76,
      "duration": 4.199,
      "text": "的な考え方は変わらないところでござい"
    },
    {
      "start": 236.76,
      "duration": 5.319,
      "text": "ますがまずはご意見として受け止めさせて"
    },
    {
      "start": 238.959,
      "duration": 3.12,
      "text": "いただきたいとと思い"
    },
    {
      "start": 244.48,
      "duration": 3.399,
      "text": "ますいいです"
    },
    {
      "start": 248.799,
      "duration": 7.28,
      "text": "かはいあじゃはいはい風長はいまご意見と"
    },
    {
      "start": 253.76,
      "duration": 5.12,
      "text": "いうかですねあのま当然のことだと思うん"
    },
    {
      "start": 256.079,
      "duration": 5.4,
      "text": "ですね主張報告での質疑ですから主張報告"
    },
    {
      "start": 258.88,
      "duration": 5.319,
      "text": "の元になるものがなければこれきちとした"
    },
    {
      "start": 261.479,
      "duration": 6.44,
      "text": "質疑できませんのであのそちらについては"
    },
    {
      "start": 264.199,
      "duration": 6.161,
      "text": "ですねまこの4日まで4日に中報告が出る"
    },
    {
      "start": 267.919,
      "duration": 4.481,
      "text": "んですかその時までにしっかりと確認して"
    },
    {
      "start": 270.36,
      "duration": 4.24,
      "text": "いただきたいですしまあの出せるような"
    },
    {
      "start": 272.4,
      "duration": 4.639,
      "text": "努力をしていただきたいということは"
    },
    {
      "start": 274.6,
      "duration": 4.0,
      "text": "申し上げておきたいですしまたそのあの"
    },
    {
      "start": 277.039,
      "duration": 3.641,
      "text": "もし出さなかった場合ですねちょっと"
    },
    {
      "start": 278.6,
      "duration": 4.84,
      "text": "私たちの会派の方では色々考えがあります"
    },
    {
      "start": 280.68,
      "duration": 4.32,
      "text": "のであのそういったことは一応意見として"
    },
    {
      "start": 283.44,
      "duration": 5.92,
      "text": "は申し上げておきたいと思い"
    },
    {
      "start": 285.0,
      "duration": 7.6,
      "text": "ますはいではまあの現段階とするとま用紙"
    },
    {
      "start": 289.36,
      "duration": 5.8,
      "text": "判決の用紙についてはま原告の方に確認し"
    },
    {
      "start": 292.6,
      "duration": 4.4,
      "text": "た後ま所定の手続きが取れるようであれば"
    },
    {
      "start": 295.16,
      "duration": 4.479,
      "text": "取っていただくというような形でござい"
    },
    {
      "start": 297.0,
      "duration": 4.28,
      "text": "ますで今お求めのあった前文についてはは"
    },
    {
      "start": 299.639,
      "duration": 3.681,
      "text": "ま現段階では難しいということではあり"
    },
    {
      "start": 301.28,
      "duration": 4.68,
      "text": "ますがまだちょっと品もありますのでま今"
    },
    {
      "start": 303.32,
      "duration": 4.48,
      "text": "出たご意見も含めてですねま例えば事務局"
    },
    {
      "start": 305.96,
      "duration": 3.76,
      "text": "で閲覧ができるようにするのかあるいは"
    },
    {
      "start": 307.8,
      "duration": 4.44,
      "text": "全文そのもの判決分そのものを皆さんに"
    },
    {
      "start": 309.72,
      "duration": 5.479,
      "text": "配るようにできるのかどうかも含めてま"
    },
    {
      "start": 312.24,
      "duration": 4.679,
      "text": "あのギリギリまでご調整ご努力をいただき"
    },
    {
      "start": 315.199,
      "duration": 5.28,
      "text": "たいとということはま委員長の方からも"
    },
    {
      "start": 316.919,
      "duration": 7.961,
      "text": "申し上げておくその他ございますかはい"
    },
    {
      "start": 320.479,
      "duration": 7.521,
      "text": "目上委員であのま是非あの用紙については"
    },
    {
      "start": 324.88,
      "duration": 6.72,
      "text": "固提出いただきたいのとま裁判所からの"
    },
    {
      "start": 328.0,
      "duration": 7.36,
      "text": "要するにあの通知が来れば判決部の"
    },
    {
      "start": 331.6,
      "duration": 5.8,
      "text": "取り扱いについては要するにあのなんて"
    },
    {
      "start": 335.36,
      "duration": 5.36,
      "text": "いうか議会にその資料として出せるかどう"
    },
    {
      "start": 337.4,
      "duration": 5.519,
      "text": "か分からないけれどもあの市として取扱"
    },
    {
      "start": 340.72,
      "duration": 6.28,
      "text": "取り扱いができるってことになるわけです"
    },
    {
      "start": 342.919,
      "duration": 6.681,
      "text": "よねだからそれはその裁判所からの要する"
    },
    {
      "start": 347.0,
      "duration": 4.52,
      "text": "に通知がなければあのそういう風にできな"
    },
    {
      "start": 349.6,
      "duration": 5.12,
      "text": "いっていうことがま一貫して言われてき"
    },
    {
      "start": 351.52,
      "duration": 7.2,
      "text": "てると思うんだけどもし最判所からの通知"
    },
    {
      "start": 354.72,
      "duration": 6.28,
      "text": "があった場合はあの議会に要するに資料と"
    },
    {
      "start": 358.72,
      "duration": 4.319,
      "text": "して配っていたいただけるのかどうかその"
    },
    {
      "start": 361.0,
      "duration": 6.68,
      "text": "辺についてはいかがなんでしょうかはい"
    },
    {
      "start": 363.039,
      "duration": 7.041,
      "text": "総部長あのまずあの閲覧制限ということで"
    },
    {
      "start": 367.68,
      "duration": 4.919,
      "text": "ございますのでまずあの閲覧についての"
    },
    {
      "start": 370.08,
      "duration": 4.959,
      "text": "考え方が裁判所から示されるということと"
    },
    {
      "start": 372.599,
      "duration": 5.761,
      "text": "なっておりますのでそこを映しを取ってお"
    },
    {
      "start": 375.039,
      "duration": 5.361,
      "text": "配りするというのはあの今ここでお返事と"
    },
    {
      "start": 378.36,
      "duration": 4.279,
      "text": "いうのは難しいと思ってございますが"
    },
    {
      "start": 380.4,
      "duration": 4.72,
      "text": "いずれにしろそういった通知をいたいて"
    },
    {
      "start": 382.639,
      "duration": 5.521,
      "text": "いって考え方が裁判所の考えか分かれば"
    },
    {
      "start": 385.12,
      "duration": 5.919,
      "text": "ですね一応あとは原告の方とご相談してと"
    },
    {
      "start": 388.16,
      "duration": 4.68,
      "text": "かどういう形でということは検討できるの"
    },
    {
      "start": 391.039,
      "duration": 5.361,
      "text": "ではないかという風に思ってございます"
    },
    {
      "start": 392.84,
      "duration": 5.56,
      "text": "以上ですはい水上委じゃああのま裁判所"
    },
    {
      "start": 396.4,
      "duration": 4.88,
      "text": "からの通知がいつ来るかどうか分からない"
    },
    {
      "start": 398.4,
      "duration": 7.079,
      "text": "とまいうことだと思うんですけれどもま"
    },
    {
      "start": 401.28,
      "duration": 7.8,
      "text": "もしその通知がま5日まで来るかどうか"
    },
    {
      "start": 405.479,
      "duration": 6.041,
      "text": "分かりませんけどあのしかも是非ですね"
    },
    {
      "start": 409.08,
      "duration": 6.2,
      "text": "なかなか求めづらいっていうあの発言も"
    },
    {
      "start": 411.52,
      "duration": 7.28,
      "text": "あったと思うんですけどあのま最大限"
    },
    {
      "start": 415.28,
      "duration": 7.599,
      "text": "やっぱりその視聴報告は判決に基づいて"
    },
    {
      "start": 418.8,
      "duration": 6.839,
      "text": "行われるのであの判決分をやっぱりその"
    },
    {
      "start": 422.879,
      "duration": 5.16,
      "text": "えっとま資料として出していたくっていう"
    },
    {
      "start": 425.639,
      "duration": 5.041,
      "text": "のはやっぱり必要だとは思うのでま最大限"
    },
    {
      "start": 428.039,
      "duration": 5.401,
      "text": "努力してもらいたいとまいうことはお願い"
    },
    {
      "start": 430.68,
      "duration": 6.079,
      "text": "しておきたいのと今日の一般質問の質疑の"
    },
    {
      "start": 433.44,
      "duration": 6.039,
      "text": "中であの子ども家庭部長があの要するに"
    },
    {
      "start": 436.759,
      "duration": 5.761,
      "text": "報告の中ではある程度判決の中身について"
    },
    {
      "start": 439.479,
      "duration": 7.12,
      "text": "はねあの説明できるみたいな発言があった"
    },
    {
      "start": 442.52,
      "duration": 6.44,
      "text": "と思うんですねだとすればあのま容子が"
    },
    {
      "start": 446.599,
      "duration": 3.32,
      "text": "どういうものか僕もよく分からないです"
    },
    {
      "start": 448.96,
      "duration": 4.239,
      "text": "けど"
    },
    {
      "start": 449.919,
      "duration": 7.68,
      "text": "その報告の中で補えるものがあるとすれば"
    },
    {
      "start": 453.199,
      "duration": 7.161,
      "text": "あの要するにそのあのましっかりと判決"
    },
    {
      "start": 457.599,
      "duration": 5.44,
      "text": "内容を踏まえたですねあの報告をしてもら"
    },
    {
      "start": 460.36,
      "duration": 5.799,
      "text": "うっていうことも必要だと思うのでまその"
    },
    {
      "start": 463.039,
      "duration": 6.12,
      "text": "際はその高等だけではなくある程度その"
    },
    {
      "start": 466.159,
      "duration": 6.241,
      "text": "文章も含めてあの出してもらいたいという"
    },
    {
      "start": 469.159,
      "duration": 5.04,
      "text": "風に思うのであのまその点ちょっとお願い"
    },
    {
      "start": 472.4,
      "duration": 6.28,
      "text": "しときたいと思うんですがいかがでしょう"
    },
    {
      "start": 474.199,
      "duration": 6.96,
      "text": "かはい村部長あのまその点も含めてあの"
    },
    {
      "start": 478.68,
      "duration": 5.479,
      "text": "少しあのの受け止めさせていただきたいと"
    },
    {
      "start": 481.159,
      "duration": 5.281,
      "text": "思っておりますはいまそそういたことも"
    },
    {
      "start": 484.159,
      "duration": 5.201,
      "text": "含めてご努力をいただいてま何か状況の"
    },
    {
      "start": 486.44,
      "duration": 5.52,
      "text": "変化があるようでしたらま速やかにえま"
    },
    {
      "start": 489.36,
      "duration": 4.76,
      "text": "制服議長でもこの議員会議会でもご報告"
    },
    {
      "start": 491.96,
      "duration": 5.0,
      "text": "いただきたいということは申し上げておき"
    },
    {
      "start": 494.12,
      "duration": 6.479,
      "text": "たいと思いますはいその他ございますか"
    },
    {
      "start": 496.96,
      "duration": 6.4,
      "text": "はいはい水谷はいあの今水上さんからあの"
    },
    {
      "start": 500.599,
      "duration": 4.681,
      "text": "ご発言があった先ほどの一般質問でのあの"
    },
    {
      "start": 503.36,
      "duration": 3.959,
      "text": "小供家庭部長の答弁だったんですけど私"
    },
    {
      "start": 505.28,
      "duration": 6.4,
      "text": "ちょっと受け止めが違ってたなと思ってい"
    },
    {
      "start": 507.319,
      "duration": 10.481,
      "text": "てあの何らかの形でえっと示された判断に"
    },
    {
      "start": 511.68,
      "duration": 8.76,
      "text": "ついて主義会に報告した上での視聴報告に"
    },
    {
      "start": 517.8,
      "duration": 5.919,
      "text": "あの形としては整えさせていただきたい"
    },
    {
      "start": 520.44,
      "duration": 5.56,
      "text": "けれども形としては紙で配るのか事前に"
    },
    {
      "start": 523.719,
      "duration": 4.521,
      "text": "なんかあのちょっとクローズの場で話すの"
    },
    {
      "start": 526.0,
      "duration": 4.16,
      "text": "かその辺はちょっとぼかされてたのかなと"
    },
    {
      "start": 528.24,
      "duration": 4.76,
      "text": "思っていてちょっと受け止めが違ったと"
    },
    {
      "start": 530.16,
      "duration": 4.28,
      "text": "いうことだけ発言させていただきますはい"
    },
    {
      "start": 533.0,
      "duration": 5.079,
      "text": "そございます"
    },
    {
      "start": 534.44,
      "duration": 6.399,
      "text": "かよろしいですかはいではそういったこと"
    },
    {
      "start": 538.079,
      "duration": 4.76,
      "text": "でまま少しまだ日ま短いですけど少しご"
    },
    {
      "start": 540.839,
      "duration": 3.841,
      "text": "努力をいただいてま状況の変化があれば"
    },
    {
      "start": 542.839,
