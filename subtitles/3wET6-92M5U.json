{
  "entries": [
    {
      "start": 0.0,
      "duration": 3.0,
      "text": "OG"
    },
    {
      "start": 197.879,
      "duration": 3.961,
      "text": "えそれではこれから始めますけれどもえ"
    },
    {
      "start": 200.879,
      "duration": 5.761,
      "text": "本日は"
    },
    {
      "start": 201.84,
      "duration": 9.959,
      "text": "え欠席届けが出ておりますえ響きのため本"
    },
    {
      "start": 206.64,
      "duration": 8.879,
      "text": "会議をえ田議員が席いたしますです"
    },
    {
      "start": 211.799,
      "duration": 3.72,
      "text": "いじゃあ始める"
    },
    {
      "start": 215.799,
      "duration": 9.36,
      "text": "よしょうがないねしょうがないです"
    },
    {
      "start": 220.2,
      "duration": 10.08,
      "text": "ねんちゃってますからねもうしょうが"
    },
    {
      "start": 225.159,
      "duration": 8.881,
      "text": "ないじゃ行きましょうはいきましょう"
    },
    {
      "start": 230.28,
      "duration": 9.56,
      "text": "はいもういやしょう"
    },
    {
      "start": 234.04,
      "duration": 8.559,
      "text": "もうおはようございます本3月日はのです"
    },
    {
      "start": 239.84,
      "duration": 6.0,
      "text": "の都合により特に会議を開くことにご異議"
    },
    {
      "start": 242.599,
      "duration": 6.081,
      "text": "ありませんかご異議なしと認め本日3月4"
    },
    {
      "start": 245.84,
      "duration": 6.44,
      "text": "日は特に会議を開くことに決定しました"
    },
    {
      "start": 248.68,
      "duration": 6.119,
      "text": "本日の会議を開きます本日議会運営委員会"
    },
    {
      "start": 252.28,
      "duration": 7.239,
      "text": "を開催していますので議会運営委員長の"
    },
    {
      "start": 254.799,
      "duration": 4.72,
      "text": "報告を求めます3番岸田正委員"
    },
    {
      "start": 263.88,
      "duration": 6.08,
      "text": "長本日議会委員会が開催いたしましたので"
    },
    {
      "start": 267.24,
      "duration": 6.76,
      "text": "その結果についてご報告いたします長から"
    },
    {
      "start": 269.96,
      "duration": 8.12,
      "text": "令和7年2月26日付けで議案第23号"
    },
    {
      "start": 274.0,
      "duration": 7.919,
      "text": "古賀市職員の勤務時間休日休暇等に関する"
    },
    {
      "start": 278.08,
      "duration": 7.64,
      "text": "条例の一部を改正する条例議案第24号"
    },
    {
      "start": 281.919,
      "duration": 6.12,
      "text": "子供子育て支援法施工規則の一部を改正"
    },
    {
      "start": 285.72,
      "duration": 7.64,
      "text": "する内閣不例の思考に"
    },
    {
      "start": 288.039,
      "duration": 8.801,
      "text": "伴う関係条例の整理に関する条例また3月"
    },
    {
      "start": 293.36,
      "duration": 5.48,
      "text": "3日付けで視聴報告の撤回についてが送付"
    },
    {
      "start": 296.84,
      "duration": 5.079,
      "text": "されましたのでその取り扱いについて協議"
    },
    {
      "start": 298.84,
      "duration": 7.199,
      "text": "いたしましたその結果議案第23号及び"
    },
    {
      "start": 301.919,
      "duration": 7.921,
      "text": "議案第24号については3月6日の本会議"
    },
    {
      "start": 306.039,
      "duration": 7.241,
      "text": "に定し説明質疑後委員会負託を省略し即決"
    },
    {
      "start": 309.84,
      "duration": 6.12,
      "text": "することとし市長報告の撤回については"
    },
    {
      "start": 313.28,
      "duration": 5.28,
      "text": "本日の本会議で所定の手続きを取ることと"
    },
    {
      "start": 315.96,
      "duration": 5.88,
      "text": "決定いたしました以上で議会運委員会の"
    },
    {
      "start": 318.56,
      "duration": 6.16,
      "text": "報告を終了いたします議会運委員長の報告"
    },
    {
      "start": 321.84,
      "duration": 5.52,
      "text": "に対して質疑はありますか質疑を終了する"
    },
    {
      "start": 324.72,
      "duration": 7.44,
      "text": "ことにご異議ありませんかご異議なと認め"
    },
    {
      "start": 327.36,
      "duration": 8.36,
      "text": "質疑を終了し議会営委員長の報告終了し"
    },
    {
      "start": 332.16,
      "duration": 6.68,
      "text": "ますお分りします議会委員長の報告通り"
    },
    {
      "start": 335.72,
      "duration": 5.84,
      "text": "決定することにご異議ありませんかご異議"
    },
    {
      "start": 338.84,
      "duration": 6.4,
      "text": "なしと認め議会運営委員長の報告通り決定"
    },
    {
      "start": 341.56,
      "duration": 6.759,
      "text": "しました日程第1視聴報告の撤回を議題と"
    },
    {
      "start": 345.24,
      "duration": 6.04,
      "text": "します本件は市長から撤回しタムでの"
    },
    {
      "start": 348.319,
      "duration": 5.44,
      "text": "申し出がありました撤回理由の説明を求め"
    },
    {
      "start": 351.28,
      "duration": 6.68,
      "text": "ます"
    },
    {
      "start": 353.759,
      "duration": 7.601,
      "text": "長え本日はえ再度お時間を頂戴しえ"
    },
    {
      "start": 357.96,
      "duration": 6.359,
      "text": "ありがとうございます令7年え2月17日"
    },
    {
      "start": 361.36,
      "duration": 6.48,
      "text": "に優先整備路線の検証及び総合的判断に"
    },
    {
      "start": 364.319,
      "duration": 6.361,
      "text": "ついて視聴報告を行いましたが2ページ3"
    },
    {
      "start": 367.84,
      "duration": 6.759,
      "text": "の総合的判断にあたって考慮すべき事項に"
    },
    {
      "start": 370.68,
      "duration": 7.04,
      "text": "ついてこ1環境の影響にかかる専門家の"
    },
    {
      "start": 374.599,
      "duration": 6.081,
      "text": "見解についての箇所は専門家からの意見の"
    },
    {
      "start": 377.72,
      "duration": 5.56,
      "text": "聴取の結果を引用したところでございます"
    },
    {
      "start": 380.68,
      "duration": 5.359,
      "text": "しかし市議会でもご指摘を受けましたが"
    },
    {
      "start": 383.28,
      "duration": 5.84,
      "text": "当該課所を引用するために適切な手続きを"
    },
    {
      "start": 386.039,
      "duration": 4.44,
      "text": "書いておりこの間ご本人との調整を行って"
    },
    {
      "start": 389.12,
      "duration": 4.4,
      "text": "まいりました"
    },
    {
      "start": 390.479,
      "duration": 5.921,
      "text": "環境に関する専門家のご意見は総合的判断"
    },
    {
      "start": 393.52,
      "duration": 5.32,
      "text": "を構成するにあたって重要な要素であり"
    },
    {
      "start": 396.4,
      "duration": 5.32,
      "text": "書くことができないと考えておりますが現"
    },
    {
      "start": 398.84,
      "duration": 6.639,
      "text": "時点において調整が整っておらず総合的"
    },
    {
      "start": 401.72,
      "duration": 8.759,
      "text": "判断を含む首相報告を一旦撤回し再整理"
    },
    {
      "start": 405.479,
      "duration": 7.641,
      "text": "する心よりお詫び申し上げますなお相報告"
    },
    {
      "start": 410.479,
      "duration": 6.641,
      "text": "の市民説明会を予定しておりましたが本日"
    },
    {
      "start": 413.12,
      "duration": 7.28,
      "text": "この後中止の告知をさせていただきます"
    },
    {
      "start": 417.12,
      "duration": 7.72,
      "text": "以上です"
    },
    {
      "start": 420.4,
      "duration": 9.0,
      "text": "質疑を行います議事進行擬似進行渡大蔵"
    },
    {
      "start": 424.84,
      "duration": 7.0,
      "text": "さんえっと擬似進行上ですねあの今あの"
    },
    {
      "start": 429.4,
      "duration": 5.479,
      "text": "市長から撤回があってこのあのこの後質疑"
    },
    {
      "start": 431.84,
      "duration": 5.12,
      "text": "になるかと思うんですけれどもあの資料と"
    },
    {
      "start": 434.879,
      "duration": 4.241,
      "text": "あ資料の方提出していただきたいものが"
    },
    {
      "start": 436.96,
      "duration": 5.48,
      "text": "あのございますので資料要求をあの議事震"
    },
    {
      "start": 439.12,
      "duration": 6.68,
      "text": "向上いたしますえっと1つはですねえっと"
    },
    {
      "start": 442.44,
      "duration": 6.84,
      "text": "3月3日付けであの今あの市長から撤回の"
    },
    {
      "start": 445.8,
      "duration": 6.2,
      "text": "中であったあの学識の専門家の方からの"
    },
    {
      "start": 449.28,
      "duration": 5.12,
      "text": "ですですね文書がえ小金市議会議員各位"
    },
    {
      "start": 452.0,
      "duration": 5.759,
      "text": "小金の行政に関わる方々ということであの"
    },
    {
      "start": 454.4,
      "duration": 5.68,
      "text": "行政と議会のそれぞれにえ提出をされて"
    },
    {
      "start": 457.759,
      "duration": 5.44,
      "text": "いるということでございますけれどもあの"
    },
    {
      "start": 460.08,
      "duration": 6.399,
      "text": "行政の方の手元に届いているこの先生から"
    },
    {
      "start": 463.199,
      "duration": 5.761,
      "text": "のあの文書についてあの市長報告のあの"
    },
    {
      "start": 466.479,
      "duration": 4.961,
      "text": "この撤回の議案のこの資料としてですね"
    },
    {
      "start": 468.96,
      "duration": 6.199,
      "text": "あのご提出をいただきたいということが1"
    },
    {
      "start": 471.44,
      "duration": 6.599,
      "text": "点ですえそれからですねあのえっと"
    },
    {
      "start": 475.159,
      "duration": 5.44,
      "text": "いわゆる総合的判断ですねこの総合的判断"
    },
    {
      "start": 478.039,
      "duration": 5.401,
      "text": "についても今の市長のご発源では一旦撤回"
    },
    {
      "start": 480.599,
      "duration": 5.16,
      "text": "する中にはこの総合的判断も含まれている"
    },
    {
      "start": 483.44,
      "duration": 5.4,
      "text": "ということなんですがちょっとこの総合的"
    },
    {
      "start": 485.759,
      "duration": 5.241,
      "text": "判断に関してあの撤回するという以上は"
    },
    {
      "start": 488.84,
      "duration": 5.4,
      "text": "ですね一旦行政決定されていると思われ"
    },
    {
      "start": 491.0,
      "duration": 6.12,
      "text": "ますのでこの総合的判断をその一旦その"
    },
    {
      "start": 494.24,
      "duration": 5.399,
      "text": "行政決定されていることま気安書などに"
    },
    {
      "start": 497.12,
      "duration": 5.359,
      "text": "なるんでしょうかあのそのあの行政決定し"
    },
    {
      "start": 499.639,
      "duration": 5.881,
      "text": "た事実関係が分かる資料についても合わせ"
    },
    {
      "start": 502.479,
      "duration": 4.881,
      "text": "てあのご提出をいただきたいと思います"
    },
    {
      "start": 505.52,
      "duration": 4.48,
      "text": "この2点資料として出していただいた上で"
    },
    {
      "start": 507.36,
      "duration": 8.52,
      "text": "質疑に入りたいと思います"
    },
    {
      "start": 510.0,
      "duration": 8.08,
      "text": "はいはい議事進行えいいいですかえはい今"
    },
    {
      "start": 515.88,
      "duration": 4.88,
      "text": "ですねあの2点議事進行がありましたあ2"
    },
    {
      "start": 518.08,
      "duration": 4.72,
      "text": "点の資料について議事進行がありましたえ"
    },
    {
      "start": 520.76,
      "duration": 5.36,
      "text": "これについてあの部局から答弁を求めたい"
    },
    {
      "start": 522.8,
      "duration": 6.84,
      "text": "と思います出せるかどう"
    },
    {
      "start": 526.12,
      "duration": 6.88,
      "text": "か報国で"
    },
    {
      "start": 529.64,
      "duration": 7.319,
      "text": "そないんですけどそういうのでるま視聴"
    },
    {
      "start": 533.0,
      "duration": 6.839,
      "text": "報国としてのまあのこう要求の本来ないん"
    },
    {
      "start": 536.959,
      "duration": 5.161,
      "text": "ですけどもま今出ましたのでえこれについ"
    },
    {
      "start": 539.839,
      "duration": 5.281,
      "text": "てちょっと出せるかどうかうん用意が"
    },
    {
      "start": 542.12,
      "duration": 6.12,
      "text": "できるかどうかということでえ部局の方で"
    },
    {
      "start": 545.12,
      "duration": 3.12,
      "text": "お答え願いたいと思い"
    },
    {
      "start": 563.32,
      "duration": 7.92,
      "text": "ますまあの今ちょっと急に聞いた話ですの"
    },
    {
      "start": 566.519,
      "duration": 4.721,
      "text": "でちょっと今確認中です"
    },
    {
      "start": 577.399,
      "duration": 6.521,
      "text": "はい理事進行はい大丈夫さんえっとですね"
    },
    {
      "start": 580.12,
      "duration": 7.2,
      "text": "あのちょっときちんと議論をするためには"
    },
    {
      "start": 583.92,
      "duration": 6.359,
      "text": "そもそもこの撤回の理由がこの高槻先生"
    },
    {
      "start": 587.32,
      "duration": 5.72,
      "text": "からの指摘が理由になって撤回されるわけ"
    },
    {
      "start": 590.279,
      "duration": 5.441,
      "text": "ですからその高槻先生からどういうご指摘"
    },
    {
      "start": 593.04,
      "duration": 4.44,
      "text": "があったのかていうことの資料がこの撤回"
    },
    {
      "start": 595.72,
      "duration": 4.16,
      "text": "の理由になってるわけですよねだそれに"
    },
    {
      "start": 597.48,
      "duration": 4.4,
      "text": "関してはきちんと我々の手元にも来ており"
    },
    {
      "start": 599.88,
      "duration": 4.24,
      "text": "ますけれども行政には行政の方にも出てる"
    },
    {
      "start": 601.88,
      "duration": 4.28,
      "text": "はずなのでその行政の方の手元に届いてる"
    },
    {
      "start": 604.12,
      "duration": 3.76,
      "text": "ものについてきちんと資料として出して"
    },
    {
      "start": 606.16,
      "duration": 4.16,
      "text": "くださいそれが撤回の理由なんですから"
    },
    {
      "start": 607.88,
      "duration": 5.959,
      "text": "根拠になるものそれからあともう1つは"
    },
    {
      "start": 610.32,
      "duration": 5.4,
      "text": "えっとですね総合的判断も一旦この撤回"
    },
    {
      "start": 613.839,
      "duration": 4.44,
      "text": "するとおっしゃってる以上撤回すると以上"
    },
    {
      "start": 615.72,
      "duration": 4.52,
      "text": "総合的判断は行政決定してるはずですから"
    },
    {
      "start": 618.279,
      "duration": 4.201,
      "text": "ま起案書などによるんでしょうね普通だ"
    },
    {
      "start": 620.24,
      "duration": 4.52,
      "text": "ちゃんとその気安書決済された文書に関し"
    },
    {
      "start": 622.48,
      "duration": 3.799,
      "text": "ても出していただかないと本当に行政決定"
    },
    {
      "start": 624.76,
      "duration": 3.44,
      "text": "されたかどうか分からないのでちゃあの"
    },
    {
      "start": 626.279,
      "duration": 4.321,
      "text": "行政決定されてるものだというんだったら"
    },
    {
      "start": 628.2,
      "duration": 5.24,
      "text": "行政決定したえ資料についても出して"
    },
    {
      "start": 630.6,
      "duration": 4.32,
      "text": "もらわないとだって撤回するって言ってる"
    },
    {
      "start": 633.44,
      "duration": 4.28,
      "text": "ものが存在してるのかどうかもわからない"
    },
    {
      "start": 634.92,
      "duration": 4.08,
      "text": "からちゃんとそれ出出して出していただき"
    },
    {
      "start": 637.72,
      "duration": 5.88,
      "text": "たいと思います"
    },
    {
      "start": 639.0,
      "duration": 7.44,
      "text": "はいえ静粛にお願いします防長の方々静粛"
    },
    {
      "start": 643.6,
      "duration": 4.799,
      "text": "にお願いしますはい議事進行井"
    },
    {
      "start": 646.44,
      "duration": 7.839,
      "text": "さんすみませ"
    },
    {
      "start": 648.399,
      "duration": 8.281,
      "text": "ん視聴報告そのものがあ撤回をしてまあの"
    },
    {
      "start": 654.279,
      "duration": 5.841,
      "text": "私も質疑をしようと思ってたんですけど"
    },
    {
      "start": 656.68,
      "duration": 6.159,
      "text": "質疑をすること自体も多分異例なと今まで"
    },
    {
      "start": 660.12,
      "duration": 7.76,
      "text": "なかった異例なことになるんですよねただ"
    },
    {
      "start": 662.839,
      "duration": 7.721,
      "text": "この撤回が出てるので今あの議資請求が出"
    },
    {
      "start": 667.88,
      "duration": 5.32,
      "text": "てるってことがありますのでちょっとこう"
    },
    {
      "start": 670.56,
      "duration": 6.36,
      "text": "今の時点でえどうなんだろうって思いは"
    },
    {
      "start": 673.2,
      "duration": 8.0,
      "text": "あるんですけどちょっとあの休憩を取って"
    },
    {
      "start": 676.92,
      "duration": 6.12,
      "text": "私はそのあのことについてきちっと整理し"
    },
    {
      "start": 681.2,
      "duration": 5.48,
      "text": "てから答えていただいた方がいいんじゃ"
    },
    {
      "start": 683.04,
      "duration": 7.76,
      "text": "ないかという風に思いますので記事運営上"
    },
    {
      "start": 686.68,
      "duration": 7.2,
      "text": "もあの含めて一度あのちゃんと整理した方"
    },
    {
      "start": 690.8,
      "duration": 6.52,
      "text": "がいいんじゃないかと思います議事進行場"
    },
    {
      "start": 693.88,
      "duration": 6.88,
      "text": "の発言はいはい議事進行場受け止めました"
    },
    {
      "start": 697.32,
      "duration": 5.8,
      "text": "えどうするかはえっとこちらサイドの方で"
    },
    {
      "start": 700.76,
      "duration": 2.36,
      "text": "決めて"
    },
    {
      "start": 710.56,
      "duration": 7.56,
      "text": "ください議事進行高木さん擬似進行ねはい"
    },
    {
      "start": 715.12,
      "duration": 3.0,
      "text": "さん"
    },
    {
      "start": 723.92,
      "duration": 6.039,
      "text": "希望私も資料を1点希望いたします"
    },
    {
      "start": 731.21,
      "duration": 3.029,
      "text": "[音楽]"
    },
    {
      "start": 737.8,
      "duration": 5.159,
      "text": "本本件視聴報告と撤回に"
    },
    {
      "start": 748.16,
      "duration": 4.32,
      "text": "かかる技の技の記録"
    },
    {
      "start": 755.24,
      "duration": 8.8,
      "text": "を出していただけませんでしょうか以上"
    },
    {
      "start": 760.6,
      "duration": 5.28,
      "text": "ですまあの議事進行場を受け止めますま"
    },
    {
      "start": 764.04,
      "duration": 5.88,
      "text": "これも含めて"
    },
    {
      "start": 765.88,
      "duration": 6.8,
      "text": "え部局の方からあの答えられるかま答える"
    },
    {
      "start": 769.92,
      "duration": 2.76,
      "text": "範囲でお願いし"
    },
    {
      "start": 775.04,
      "duration": 7.479,
      "text": "ますはい進行渡辺さんえと嵐さんからあの"
    },
    {
      "start": 780.24,
      "duration": 4.32,
      "text": "先ほど資産にとむ議事進行があったと私は"
    },
    {
      "start": 782.519,
      "duration": 3.68,
      "text": "思っているんですがそもそも主張報告の"
    },
    {
      "start": 784.56,
      "duration": 3.92,
      "text": "撤回なんていうのは見たことも聞いたこと"
    },
    {
      "start": 786.199,
      "duration": 4.041,
      "text": "もないわけですよねだそれに対する質疑の"
    },
    {
      "start": 788.48,
      "duration": 3.799,
      "text": "あり方とか資料のあり方とかもだから"
    },
    {
      "start": 790.24,
      "duration": 4.56,
      "text": "さっき井さんはそういうことは前例がない"
    },
    {
      "start": 792.279,
      "duration": 4.36,
      "text": "からどうちゃんと慎重にやった方がいいっ"
    },
    {
      "start": 794.8,
      "duration": 3.64,
      "text": "てことを多分言われたと思って私もそこは"
    },
    {
      "start": 796.639,
      "duration": 3.88,
      "text": "慎重にちゃんとやっていただいていいと"
    },
    {
      "start": 798.44,
      "duration": 3.92,
      "text": "思っているで最終的には出してもらいたい"
    },
    {
      "start": 800.519,
      "duration": 4.201,
      "text": "わけなんですけれどもただ前例がないから"
    },
    {
      "start": 802.36,
      "duration": 4.039,
      "text": "議長もさき方た難しいと思うんですがあの"
    },
    {
      "start": 804.72,
      "duration": 3.4,
      "text": "ちょっとそこはあのきちんと丁寧にやる"
    },
    {
      "start": 806.399,
      "duration": 3.56,
      "text": "ならやっていただいても構いません最終的"
    },
    {
      "start": 808.12,
      "duration": 4.64,
      "text": "に出ればいいと思ってるんであそこは"
    },
    {
      "start": 809.959,
      "duration": 8.68,
      "text": "ちゃんと慎重にやっていただきたいと思い"
    },
    {
      "start": 812.76,
      "duration": 11.319,
      "text": "ますあの部局の方で答弁あ休憩じゃじゃ"
    },
    {
      "start": 818.639,
      "duration": 5.44,
      "text": "休憩ねはいじゃあ休憩えお願いしますはい"
    }
  ]
