{
  "entries": [
    {
      "start": 29.92,
      "duration": 2.04,
      "text": "ね"
    },
    {
      "start": 51.36,
      "duration": 3.0,
      "text": "jeg"
    },
    {
      "start": 70.439,
      "duration": 4.761,
      "text": "えっとあのこの後ですねどの解決にって"
    },
    {
      "start": 73.479,
      "duration": 9.68,
      "text": "いきますけも"
    },
    {
      "start": 75.2,
      "duration": 7.959,
      "text": "えのさのについてはどこに"
    },
    {
      "start": 90.52,
      "duration": 6.36,
      "text": "再開しますここで先ほど保留しました日程"
    },
    {
      "start": 94.119,
      "duration": 6.801,
      "text": "第6から日程第15までの10件の保留を"
    },
    {
      "start": 96.88,
      "duration": 7.44,
      "text": "解き順次議題とし討論採決を行います6"
    },
    {
      "start": 100.92,
      "duration": 7.0,
      "text": "陳情第12号居住実態に議のある委員に"
    },
    {
      "start": 104.32,
      "duration": 7.56,
      "text": "対しリモート会議を終戦したかとあ終戦し"
    },
    {
      "start": 107.92,
      "duration": 7.4,
      "text": "たかを問うとともに万が一事実がなかった"
    },
    {
      "start": 111.88,
      "duration": 5.36,
      "text": "場合は発言の訂正を求める賃上書これから"
    },
    {
      "start": 115.32,
      "duration": 5.119,
      "text": "討論を行い"
    },
    {
      "start": 117.24,
      "duration": 6.239,
      "text": "ます本件に対する討論を終了することにご"
    },
    {
      "start": 120.439,
      "duration": 7.36,
      "text": "異議ありませんかご異議な認め討論を終了"
    },
    {
      "start": 123.479,
      "duration": 7.601,
      "text": "します直に採決します本件は起立採決をし"
    },
    {
      "start": 127.799,
      "duration": 7.601,
      "text": "ます本件についての厚生文教委員長の報告"
    },
    {
      "start": 131.08,
      "duration": 8.239,
      "text": "は不採択ですお諮りします本件は採択の上"
    },
    {
      "start": 135.4,
      "duration": 7.24,
      "text": "市及び教育委員会に送付することに賛成の"
    },
    {
      "start": 139.319,
      "duration": 3.321,
      "text": "皆さんの起立を求め"
    },
    {
      "start": 144.319,
      "duration": 5.841,
      "text": "ます立"
    },
    {
      "start": 146.8,
      "duration": 6.84,
      "text": "数立数"
    },
    {
      "start": 150.16,
      "duration": 3.48,
      "text": "て本件"
    },
    {
      "start": 154.2,
      "duration": 10.72,
      "text": "は風採択と決定しました6陳情6陳情第1"
    },
    {
      "start": 160.68,
      "duration": 7.559,
      "text": "号市議会の議員定数に関する陳情書本件は"
    },
    {
      "start": 164.92,
      "duration": 7.319,
      "text": "討論を行います初めに本件に反対の発言を"
    },
    {
      "start": 168.239,
      "duration": 4.0,
      "text": "許可します4番沖浦淳"
    },
    {
      "start": 176.239,
      "duration": 8.481,
      "text": "議員え第1号議会の議員定数に関する賃常"
    },
    {
      "start": 181.44,
      "duration": 7.079,
      "text": "書に対し会派未来の小金を代表して反対の"
    },
    {
      "start": 184.72,
      "duration": 7.239,
      "text": "立場から討論いたします小金市議会基本"
    },
    {
      "start": 188.519,
      "duration": 6.401,
      "text": "条例の議員定数に関する第21条には第1"
    },
    {
      "start": 191.959,
      "duration": 5.721,
      "text": "項議員定数はこの条例に規定した議会とし"
    },
    {
      "start": 194.92,
      "duration": 7.239,
      "text": "ての機能を果たすのにふさわしいものと"
    },
    {
      "start": 197.68,
      "duration": 7.8,
      "text": "することを基本としえ小金え市会議員定数"
    },
    {
      "start": 202.159,
      "duration": 6.681,
      "text": "条例に定めるものとする第2項議員定数の"
    },
    {
      "start": 205.48,
      "duration": 7.839,
      "text": "改正にあたっては姿勢の現状及び課題を"
    },
    {
      "start": 208.84,
      "duration": 7.56,
      "text": "十分に考慮し市民の意見をえ聴取した上で"
    },
    {
      "start": 213.319,
      "duration": 6.761,
      "text": "定めるものとするとありますえ議会運営"
    },
    {
      "start": 216.4,
      "duration": 8.16,
      "text": "委員会での本日尋常審査において当該条例"
    },
    {
      "start": 220.08,
      "duration": 6.76,
      "text": "第21条2項に定める市民意見の聴取に"
    },
    {
      "start": 224.56,
      "duration": 5.36,
      "text": "ついて議論がありましたまさにこの点に"
    },
    {
      "start": 226.84,
      "duration": 6.8,
      "text": "ついて我が会派未来の小金は4年前の議会"
    },
    {
      "start": 229.92,
      "duration": 6.319,
      "text": "基本条例検証等協議会において市民行長手"
    },
    {
      "start": 233.64,
      "duration": 6.64,
      "text": "の時期方法などが不明確であることが課題"
    },
    {
      "start": 236.239,
      "duration": 7.681,
      "text": "と考え市民移行長手の方法等について協議"
    },
    {
      "start": 240.28,
      "duration": 7.08,
      "text": "すべきと提案しましたがあこの提案に対し"
    },
    {
      "start": 243.92,
      "duration": 5.76,
      "text": "て唯一古賀市議会公明党会派が抜をつけに"
    },
    {
      "start": 247.36,
      "duration": 5.04,
      "text": "なった結果議題にも上がらず議論でき"
    },
    {
      "start": 249.68,
      "duration": 6.24,
      "text": "なかったことが本陳上審査で再び浮き彫り"
    },
    {
      "start": 252.4,
      "duration": 6.2,
      "text": "になったと考えますえただ事前の共通認識"
    },
    {
      "start": 255.92,
      "duration": 7.32,
      "text": "とはなっていないもののえ人気前半におい"
    },
    {
      "start": 258.6,
      "duration": 7.56,
      "text": "てえ議会としてえ市民困難会やあ校長会を"
    },
    {
      "start": 263.24,
      "duration": 5.08,
      "text": "開催したことからすれば市民市民の意見を"
    },
    {
      "start": 266.16,
      "duration": 5.319,
      "text": "聴取したものと捉えるのが相当であると"
    },
    {
      "start": 268.32,
      "duration": 6.68,
      "text": "考えていますえ日本賃所が求めている何名"
    },
    {
      "start": 271.479,
      "duration": 6.881,
      "text": "が適切なのか調査や検討を行うことには"
    },
    {
      "start": 275.0,
      "duration": 7.479,
      "text": "賛同いたしますえがあ第4回定例会までに"
    },
    {
      "start": 278.36,
      "duration": 9.8,
      "text": "一定の結論を得た上で令和7年え3月23"
    },
    {
      "start": 282.479,
      "duration": 8.72,
      "text": "日試行の執行の予定の小金市会議員選挙に"
    },
    {
      "start": 288.16,
      "duration": 6.72,
      "text": "反映させてほしいという点につき本陳情が"
    },
    {
      "start": 291.199,
      "duration": 6.601,
      "text": "提出された時点でえ長者調査や検討を行う"
    },
    {
      "start": 294.88,
      "duration": 6.12,
      "text": "時間は1年どころか実質9ヶ月もなくえ"
    },
    {
      "start": 297.8,
      "duration": 5.28,
      "text": "私たちがあ4年前に指摘した課題や定数"
    },
    {
      "start": 301.0,
      "duration": 4.8,
      "text": "のみならず報酬もセットで議論すべきと"
    },
    {
      "start": 303.08,
      "duration": 5.64,
      "text": "いう議会での意見も踏まえれば議会運営"
    },
    {
      "start": 305.8,
      "duration": 6.16,
      "text": "委員会で最初に議題とされた3月7日で"
    },
    {
      "start": 308.72,
      "duration": 6.44,
      "text": "さえも時間の余裕はないと私たちは考えて"
    },
    {
      "start": 311.96,
      "duration": 6.88,
      "text": "いましたえ本日陳情はその後も継続して"
    },
    {
      "start": 315.16,
      "duration": 6.039,
      "text": "審査され本日本会議採決となりますが残さ"
    },
    {
      "start": 318.84,
      "duration": 5.12,
      "text": "れた時間は3ヶ月程度しかなくこれでは"
    },
    {
      "start": 321.199,
      "duration": 6.44,
      "text": "十分な議論が行えるはずもありませんえ"
    },
    {
      "start": 323.96,
      "duration": 8.6,
      "text": "この状況は4年前え令和2年2022え"
    },
    {
      "start": 327.639,
      "duration": 8.721,
      "text": "2020年え2月日に採決された議員案第"
    },
    {
      "start": 332.56,
      "duration": 7.56,
      "text": "23号え小金市議会議員の定数条例の一部"
    },
    {
      "start": 336.36,
      "duration": 8.0,
      "text": "を改正する条例いわゆる議員提案による"
    },
    {
      "start": 340.12,
      "duration": 9.04,
      "text": "定数削減条例案そしてえ同年6月23日に"
    },
    {
      "start": 344.36,
      "duration": 8.76,
      "text": "採決された2正眼1号さらに老年12月"
    },
    {
      "start": 349.16,
      "duration": 7.319,
      "text": "21日に採決された2陳情150号と同じ"
    },
    {
      "start": 353.12,
      "duration": 7.28,
      "text": "でありますえ最初に挙げました議員提案の"
    },
    {
      "start": 356.479,
      "duration": 8.121,
      "text": "条例改正案つまり24名の議員数を2名"
    },
    {
      "start": 360.4,
      "duration": 8.16,
      "text": "削減して22名にする条例案が議論された"
    },
    {
      "start": 364.6,
      "duration": 7.28,
      "text": "令和元年2019年のことです7月31日"
    },
    {
      "start": 368.56,
      "duration": 6.84,
      "text": "の議会運営委員会ではあ議員定数の根拠を"
    },
    {
      "start": 371.88,
      "duration": 6.12,
      "text": "尋ねた質問に対してえ住民主と信頼の小金"
    },
    {
      "start": 375.4,
      "duration": 5.88,
      "text": "会派の提案議員自らが次のように答弁され"
    },
    {
      "start": 378.0,
      "duration": 6.68,
      "text": "ました客観的にふさわしい人数というのは"
    },
    {
      "start": 381.28,
      "duration": 7.199,
      "text": "非常に難しいえ24人という根拠もないだ"
    },
    {
      "start": 384.68,
      "duration": 6.48,
      "text": "から考えていかないといけないしえ22人"
    },
    {
      "start": 388.479,
      "duration": 5.84,
      "text": "という根拠もなこちらとしては示すことは"
    },
    {
      "start": 391.16,
      "duration": 6.159,
      "text": "できないとまさに22人の根拠がないまま"
    },
    {
      "start": 394.319,
      "duration": 6.72,
      "text": "提案したことを提案議員自らがお認めに"
    },
    {
      "start": 397.319,
      "duration": 7.6,
      "text": "なりましたえだからこそ議員定数削減に"
    },
    {
      "start": 401.039,
      "duration": 6.681,
      "text": "賛成派も反対派も小金市会としての議員"
    },
    {
      "start": 404.919,
      "duration": 5.56,
      "text": "定数の根拠を作る努力を行うべきとあると"
    },
    {
      "start": 407.72,
      "duration": 5.96,
      "text": "行うべきであると何度も討論で申し上げて"
    },
    {
      "start": 410.479,
      "duration": 6.881,
      "text": "きましたまたそのような状況で全人気を"
    },
    {
      "start": 413.68,
      "duration": 7.799,
      "text": "置いた反省点から回線を経た今人気が"
    },
    {
      "start": 417.36,
      "duration": 7.16,
      "text": "始まる際に我々未来の小金から定員え議員"
    },
    {
      "start": 421.479,
      "duration": 6.761,
      "text": "定数と報酬に関する特別委員会の設置を"
    },
    {
      "start": 424.52,
      "duration": 6.679,
      "text": "提案しましたこの提案に対して回線前にえ"
    },
    {
      "start": 428.24,
      "duration": 6.56,
      "text": "議員定数削減条例を議員提案された会派の"
    },
    {
      "start": 431.199,
      "duration": 6.361,
      "text": "うち小金市議会公明党会派及び情報公開"
    },
    {
      "start": 434.8,
      "duration": 7.04,
      "text": "小金会派の皆様にはご賛同いただきました"
    },
    {
      "start": 437.56,
      "duration": 7.88,
      "text": "があ自由民主党信頼の小金会派は特別委員"
    },
    {
      "start": 441.84,
      "duration": 7.199,
      "text": "会の設置は必要なく議会運営委員会の議会"
    },
    {
      "start": 445.44,
      "duration": 7.12,
      "text": "改革の議論で足りるとの理由で反対され"
    },
    {
      "start": 449.039,
      "duration": 5.72,
      "text": "結局回線直後に我々が提案した議員定数と"
    },
    {
      "start": 452.56,
      "duration": 6.24,
      "text": "補習に関する特別委員会の設置には至り"
    },
    {
      "start": 454.759,
      "duration": 8.401,
      "text": "ませんでしたえ我々未来の公が4名4名"
    },
    {
      "start": 458.8,
      "duration": 6.72,
      "text": "以外にも議員定数の改正に賛成反対ありで"
    },
    {
      "start": 463.16,
      "duration": 5.36,
      "text": "はなくしっかり議論をすべきという会派が"
    },
    {
      "start": 465.52,
      "duration": 5.959,
      "text": "ある中でえ我々から提案した特別委員会の"
    },
    {
      "start": 468.52,
      "duration": 5.56,
      "text": "設置はま現在の議員定数の課題に本気で"
    },
    {
      "start": 471.479,
      "duration": 4.56,
      "text": "向き合う必要があるとお考えであれば最大"
    },
    {
      "start": 474.08,
      "duration": 5.04,
      "text": "のチャンスだったではないでしょうかそれ"
    },
    {
      "start": 476.039,
      "duration": 5.921,
      "text": "から約4年間え議会改革の議論で足りると"
    },
    {
      "start": 479.12,
      "duration": 6.079,
      "text": "した外自民党信頼会派から議員点数に"
    },
    {
      "start": 481.96,
      "duration": 6.56,
      "text": "関する企業のの提案は今日に至るまで"
    },
    {
      "start": 485.199,
      "duration": 6.321,
      "text": "ついにありませんでしたえこのように議員"
    },
    {
      "start": 488.52,
      "duration": 6.28,
      "text": "定数の根拠を作るための提案姿勢や一致点"
    },
    {
      "start": 491.52,
      "duration": 6.44,
      "text": "を見出す努力もないままにえ次期市議会"
    },
    {
      "start": 494.8,
      "duration": 6.359,
      "text": "議員選挙まで半年となるこのタイミングで"
    },
    {
      "start": 497.96,
      "duration": 5.639,
      "text": "まさかあ再びえ前回のような議員提案で"
    },
    {
      "start": 501.159,
      "duration": 5.04,
      "text": "定数削減条例を提出することはないと思い"
    },
    {
      "start": 503.599,
      "duration": 5.04,
      "text": "ますがあ仮にそのようなことがあるとする"
    },
    {
      "start": 506.199,
      "duration": 5.68,
      "text": "なば単なる選挙前のパフォーマンスであり"
    },
    {
      "start": 508.639,
      "duration": 7.041,
      "text": "無責任であるとの阻はまれないものと先決"
    },
    {
      "start": 511.879,
      "duration": 6.321,
      "text": "ながら懸念申し上げますえ我々未来の小金"
    },
    {
      "start": 515.68,
      "duration": 6.239,
      "text": "は以前から議員定数に関する議論否定して"
    },
    {
      "start": 518.2,
      "duration": 6.8,
      "text": "いませんえむしろえ議員定数の改正に賛成"
    },
    {
      "start": 521.919,
      "duration": 6.561,
      "text": "反対関わらずえ小金市議会としての議員"
    },
    {
      "start": 525.0,
      "duration": 6.12,
      "text": "定数の根拠を作るための努力な努力や議論"
    },
    {
      "start": 528.48,
      "duration": 6.16,
      "text": "を行うべきであるとして常任委員会の再編"
    },
    {
      "start": 531.12,
      "duration": 6.52,
      "text": "や議員定数等に関する特別委員会の提案を"
    },
    {
      "start": 534.64,
      "duration": 5.639,
      "text": "行ってえきましたまそれは現在も変わらず"
    },
    {
      "start": 537.64,
      "duration": 6.16,
      "text": "公開の場で議論することに協力しますし"
    },
    {
      "start": 540.279,
      "duration": 7.361,
      "text": "その結果として議員定数の適正化であれば"
    },
    {
      "start": 543.8,
      "duration": 7.64,
      "text": "賛成いたしますえ小金市議会が行った市民"
    },
    {
      "start": 547.64,
      "duration": 6.84,
      "text": "の移行調査では令和2年度においても令和"
    },
    {
      "start": 551.44,
      "duration": 6.44,
      "text": "4年度においても議員定数や報酬の検討も"
    },
    {
      "start": 554.48,
      "duration": 6.359,
      "text": "去ることながら議会から行政への提案能力"
    },
    {
      "start": 557.88,
      "duration": 6.12,
      "text": "や市民の声を反映できる議会を望む行為の"
    },
    {
      "start": 560.839,
      "duration": 6.12,
      "text": "方がより多く寄せられていますそのような"
    },
    {
      "start": 564.0,
      "duration": 6.48,
      "text": "市民の付託に答えるために小金司会は何を"
    },
    {
      "start": 566.959,
      "duration": 6.721,
      "text": "すべきかそのためには難の議定数が適切な"
    },
    {
      "start": 570.48,
      "duration": 5.76,
      "text": "のかを議論すべきと考える点では本陳乗者"
    },
    {
      "start": 573.68,
      "duration": 6.04,
      "text": "と同じ思いであると押し図りますがこれ"
    },
    {
      "start": 576.24,
      "duration": 6.88,
      "text": "まで述べた理由により本身長の反対討論と"
    },
