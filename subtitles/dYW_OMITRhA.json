{
  "entries": [
    {
      "start": 61.44,
      "duration": 4.88,
      "text": "おはようございますおはようございます"
    },
    {
      "start": 63.48,
      "duration": 5.12,
      "text": "えっとそれで皆様お揃いのようですので"
    },
    {
      "start": 66.32,
      "duration": 5.76,
      "text": "これから厚生文教委員会に入る前の冒頭の"
    },
    {
      "start": 68.6,
      "duration": 6.96,
      "text": "協議会をえ開かせていただきますえっと皆"
    },
    {
      "start": 72.08,
      "duration": 7.56,
      "text": "さんお手元に本日の進行予定についてと紙"
    },
    {
      "start": 75.56,
      "duration": 7.559,
      "text": "があると思いますがえっと今回は"
    },
    {
      "start": 79.64,
      "duration": 5.36,
      "text": "え審査するのは6神城第7号の審査です"
    },
    {
      "start": 83.119,
      "duration": 3.881,
      "text": "けどももう質疑が終わってるということで"
    },
    {
      "start": 85.0,
      "duration": 5.52,
      "text": "採決のみということですけどもそちらで"
    },
    {
      "start": 87.0,
      "duration": 7.04,
      "text": "よろしかったでしょうかはいでそのその他"
    },
    {
      "start": 90.52,
      "duration": 6.32,
      "text": "がございますがその流れでよろしいですね"
    },
    {
      "start": 94.04,
      "duration": 4.52,
      "text": "進めていってはいありがとうございます"
    },
    {
      "start": 96.84,
      "duration": 5.8,
      "text": "それで"
    },
    {
      "start": 98.56,
      "duration": 7.04,
      "text": "ははいそれでははいあはいもさんどうぞ"
    },
    {
      "start": 102.64,
      "duration": 7.159,
      "text": "はいそれでですねちょっとできましたら"
    },
    {
      "start": 105.6,
      "duration": 7.72,
      "text": "あのどこかの今日の日程の中であのえ閉会"
    },
    {
      "start": 109.799,
      "duration": 6.081,
      "text": "中の日程についてのちょっと若干調整をお"
    },
    {
      "start": 113.32,
      "duration": 4.479,
      "text": "願いできればあそれその方のところで手を"
    },
    {
      "start": 115.88,
      "duration": 5.68,
      "text": "上げられるってことですそうそうかそこで"
    },
    {
      "start": 117.799,
      "duration": 6.28,
      "text": "手をあげんのそはいまこここで言っといて"
    },
    {
      "start": 121.56,
      "duration": 7.28,
      "text": "いただいてこれが終わった後でもし開くん"
    },
    {
      "start": 124.079,
      "duration": 4.761,
      "text": "であれば開ても結構ですし他でもできるん"
    },
    {
      "start": 128.879,
      "duration": 5.521,
      "text": "で前ぶれだけですね"
    },
    {
      "start": 131.68,
      "duration": 4.52,
      "text": "はいはいあのちょっと協議会はい"
    },
    {
      "start": 134.4,
      "duration": 7.04,
      "text": "エントリー受けましたので大丈夫ですお"
    },
    {
      "start": 136.2,
      "duration": 5.24,
      "text": "願いしたいと思いますではお願いします"
    },
    {
      "start": 142.239,
      "duration": 7.921,
      "text": "はいおはようございますおはようござい"
    },
    {
      "start": 144.879,
      "duration": 7.72,
      "text": "ますただいまから生委員会の会議開きます"
    },
    {
      "start": 150.16,
      "duration": 4.719,
      "text": "に本日の議事に入ります当委員会に付託さ"
    },
    {
      "start": 152.599,
      "duration": 5.521,
      "text": "れております案件は前回の委員会で保留と"
    },
    {
      "start": 154.879,
      "duration": 5.601,
      "text": "いたしました陳情一件です以上1件につき"
    },
    {
      "start": 158.12,
      "duration": 6.36,
      "text": "ましては厚生文教委員会審査予定表の通り"
    },
    {
      "start": 160.48,
      "duration": 7.52,
      "text": "行うことといたします直に6陳情第7号"
    },
    {
      "start": 164.48,
      "duration": 5.8,
      "text": "小金市議会に対し国民年金法第24条正し"
    },
    {
      "start": 168.0,
      "duration": 4.8,
      "text": "学教を削除する改正を求める意見書を国会"
    },
    {
      "start": 170.28,
      "duration": 4.56,
      "text": "に提出するよう求める陳情書を議題と"
    },
    {
      "start": 172.8,
      "duration": 7.92,
      "text": "いたします部局から発言がありましたら"
    },
    {
      "start": 174.84,
      "duration": 9.44,
      "text": "これを求めますこれから質疑を行いますえ"
    },
    {
      "start": 180.72,
      "duration": 7.72,
      "text": "はいそれでは再しますお測り"
    },
    {
      "start": 184.28,
      "duration": 6.44,
      "text": "いたしそっちですか再開しますあ再じゃ"
    },
    {
      "start": 188.44,
      "duration": 4.159,
      "text": "なくていいんですね本件につきまして委長"
    },
    {
      "start": 190.72,
      "duration": 4.72,
      "text": "報告に載せる意見要望がございましたら"
    },
    {
      "start": 192.599,
      "duration": 5.121,
      "text": "発言をお願いします以上で本件に対する"
    },
    {
      "start": 195.44,
      "duration": 5.12,
      "text": "質疑を終了することにご異議ありませんか"
    },
    {
      "start": 197.72,
      "duration": 6.28,
      "text": "なご異議なしと認めます従って質疑を終了"
    },
    {
      "start": 200.56,
      "duration": 8.44,
      "text": "いたしますこれから討論を行いますはい"
    },
    {
      "start": 204.0,
      "duration": 8.36,
      "text": "はい森さんはいあのなんであのできればあ"
    },
    {
      "start": 209.0,
      "duration": 5.959,
      "text": "簡単に本会議え本会議で本会議でやるあ"
    },
    {
      "start": 212.36,
      "duration": 6.56,
      "text": "ちょっと本会議でやることではないので"
    },
    {
      "start": 214.959,
      "duration": 6.64,
      "text": "ここでそうなんですかあのせていた"
    },
    {
      "start": 218.92,
      "duration": 4.8,
      "text": "えっと確認取ったり云っていうのを事務局"
    },
    {
      "start": 221.599,
      "duration": 5.961,
      "text": "とやんなきゃいけないんでゆですと明日"
    },
    {
      "start": 223.72,
      "duration": 5.92,
      "text": "通知しかなくてえあの文書で出すようにし"
    },
    {
      "start": 227.56,
      "duration": 6.48,
      "text": "たいと思うんですかめですかそうですか"
    },
    {
      "start": 229.64,
      "duration": 8.0,
      "text": "じゃああえ急急いで分かりましたじゃあ"
    },
    {
      "start": 234.04,
      "duration": 6.279,
      "text": "あの文章ではいほぼほぼまめてますそう"
    },
    {
      "start": 237.64,
      "duration": 5.92,
      "text": "ですか分かりましたあのちょっと結構あの"
    },
    {
      "start": 240.319,
      "duration": 5.241,
      "text": "調整が厳しいと思うんであのちょっと私も"
    },
    {
      "start": 243.56,
      "duration": 5.48,
      "text": "ぼと言わなかったんですけどはいそうです"
    },
    {
      "start": 245.56,
      "duration": 9.44,
      "text": "かじゃあちょっと一応言うとかていけない"
    },
    {
      "start": 249.04,
      "duration": 5.96,
      "text": "なと思ったので申し訳ないですじゃあ"
    },
    {
      "start": 256.04,
      "duration": 7.8,
      "text": "はいそうですね本会やっていただくとはい"
    },
    {
      "start": 259.199,
      "duration": 8.28,
      "text": "あの本分かりましたはいありがとうござい"
    },
    {
      "start": 263.84,
      "duration": 6.12,
      "text": "ますすいませんそれでは発言を撤回させて"
    },
    {
      "start": 267.479,
      "duration": 4.56,
      "text": "いただきます申し訳ございませんすいませ"
    },
    {
      "start": 269.96,
      "duration": 4.48,
      "text": "んありがとうございますはいはいそれでは"
    },
    {
      "start": 272.039,
      "duration": 4.961,
      "text": "本件に対する討論終了することにご異議"
    },
    {
      "start": 274.44,
      "duration": 4.199,
      "text": "ありませんかご異議ないて思います従って"
    },
    {
      "start": 277.0,
      "duration": 4.8,
      "text": "討論を終了いたし"
    },
    {
      "start": 278.639,
      "duration": 6.0,
      "text": "ますそれでは立ちに採決いたしますお諮り"
    },
    {
      "start": 281.8,
      "duration": 5.88,
      "text": "いたします本件はえ採択の上関係機関に"
    },
    {
      "start": 284.639,
      "duration": 5.28,
      "text": "検証を相することにご異議がありませんか"
    },
    {
      "start": 287.68,
      "duration": 5.0,
      "text": "ご異議がありますので本件を切立再決"
    },
    {
      "start": 289.919,
      "duration": 5.761,
      "text": "いたします本件は採択の上関係者に検証を"
    },
    {
      "start": 292.68,
      "duration": 8.04,
      "text": "送付することに賛成な皆さんの起立を求め"
    },
    {
      "start": 295.68,
      "duration": 6.88,
      "text": "ます起立少数従って本件は"
    },
    {
      "start": 300.72,
      "duration": 4.479,
      "text": "と決定いたしまし"
    },
    {
      "start": 302.56,
      "duration": 6.44,
      "text": "たなお意"
    },
    {
      "start": 305.199,
      "duration": 6.161,
      "text": "のも終りですはいで終わらしますね以上で"
    },
    {
      "start": 309.0,
      "duration": 6.08,
      "text": "本日の日程は全部終了いたしました本日"
    },
    {
      "start": 311.36,
      "duration": 7.399,
      "text": "以上で厚生文教委員会を陛下いたしまし"
    },
    {
      "start": 315.08,
      "duration": 7.92,
      "text": "てえっとそれでこれでも終わり"
    },
    {
      "start": 318.759,
      "duration": 4.241,
      "text": "な先ほどの森戸"
    },
    {
      "start": 323.199,
      "duration": 8.881,
      "text": "さん一応もう委員会終りなんでこれでもう"
    },
    {
      "start": 325.759,
      "duration": 8.88,
      "text": "はい文の方ははいはいなんか話話相談され"
    },
    {
      "start": 332.08,
      "duration": 5.959,
      "text": "たいことがあるとお伺いしておりますけど"
    },
    {
      "start": 334.639,
      "duration": 7.56,
      "text": "もここでやるかもしくはま他のところでも"
    },
    {
      "start": 338.039,
      "duration": 6.761,
      "text": "いいですけどどうでやるかですけど"
    },
    {
      "start": 342.199,
      "duration": 6.921,
      "text": "はい何をやるかとかは言っとかなくても"
    },
    {
      "start": 344.8,
      "duration": 5.72,
      "text": "いいですかえ次よですねはい夜ですま夜"
    },
    {
      "start": 349.12,
      "duration": 5.24,
      "text": "やっちゃってからにします"
    },
    {
      "start": 350.52,
      "duration": 6.56,
      "text": "かとりあえず何やるかも"
    },
    {
      "start": 354.36,
      "duration": 7.559,
      "text": "とうんそその他僕はストレートだと思うん"
    },
    {
      "start": 357.08,
      "duration": 8.16,
      "text": "ですけどもはいさんはい何はいうんえっと"
    },
    {
      "start": 361.919,
      "duration": 6.84,
      "text": "はいはいムトさんどうぞいやそれで何を"
    },
    {
      "start": 365.24,
      "duration": 7.16,
      "text": "あの協議したいかっていうことをから8月"
    },
    {
      "start": 368.759,
      "duration": 6.0,
      "text": "2日にあのあ皆さんいらっしゃらなくて"
    },
    {
      "start": 372.4,
      "duration": 4.76,
      "text": "いいあいやもうもういらっしゃらなくて"
    },
    {
      "start": 374.759,
      "duration": 4.041,
      "text": "いいですよはいあの会なん"
    },
    {
      "start": 377.16,
      "duration": 4.64,
      "text": "で"
    },
    {
      "start": 378.8,
      "duration": 3.0,
      "text": "はい"
    },
    {
      "start": 381.919,
      "duration": 10.241,
      "text": "はいあままもそういうことで"
    },
    {
      "start": 386.08,
      "duration": 9.08,
      "text": "はいあの8月2日の日程をあの決めたわけ"
    },
    {
      "start": 392.16,
      "duration": 6.879,
      "text": "ですけれどもちょっと色々な都合があると"
    },
    {
      "start": 395.16,
      "duration": 8.72,
      "text": "いうことが分かりましてあその点について"
    },
    {
      "start": 399.039,
      "duration": 8.201,
      "text": "のお若干のご協議をさせていただければと"
    },
    {
      "start": 403.88,
      "duration": 7.28,
      "text": "思っていましてあのま今ここでやるかそれ"
    },
    {
      "start": 407.24,
      "duration": 8.44,
      "text": "とも先に日程を進めて最終のところでやる"
    },
    {
      "start": 411.16,
      "duration": 8.0,
      "text": "かっていうことはあのまたご相談できれば"
    },
    {
      "start": 415.68,
      "duration": 3.48,
      "text": "と思っています"
    }
  ]
}