{
  "entries": [
    {
      "start": 88.84,
      "duration": 3.0,
      "text": "jeg"
    },
    {
      "start": 118.84,
      "duration": 3.0,
      "text": "JA"
    },
    {
      "start": 170.56,
      "duration": 5.64,
      "text": "いえいええよろしいですかはいはいます"
    },
    {
      "start": 174.319,
      "duration": 5.681,
      "text": "はいはい"
    },
    {
      "start": 176.2,
      "duration": 7.119,
      "text": "はいただいまから予算特別委員会の会議を"
    },
    {
      "start": 180.0,
      "duration": 6.599,
      "text": "ます本日は年長の私が委員長が選される"
    },
    {
      "start": 183.319,
      "duration": 5.961,
      "text": "まで委員長の職務を行いますたしに議題に"
    },
    {
      "start": 186.599,
      "duration": 5.36,
      "text": "入ります議題は当委員会の委員長の護成に"
    },
    {
      "start": 189.28,
      "duration": 5.0,
      "text": "ついてであります護選の方法については"
    },
    {
      "start": 191.959,
      "duration": 6.0,
      "text": "いかがいたしましょうかどなたか選出方法"
    },
    {
      "start": 194.28,
      "duration": 7.28,
      "text": "についてご意見がありませんか小林さん"
    },
    {
      "start": 197.959,
      "duration": 6.081,
      "text": "指名推薦でお願いしますただいま選出方法"
    },
    {
      "start": 201.56,
      "duration": 5.36,
      "text": "について指名推薦によるとのご意見があり"
    },
    {
      "start": 204.04,
      "duration": 6.32,
      "text": "ますが指名推により決定することにご異議"
    },
    {
      "start": 206.92,
      "duration": 6.319,
      "text": "ありませんか異議なしと認め申し上げまし"
    },
    {
      "start": 210.36,
      "duration": 6.92,
      "text": "た通り決定いたしますどの他ご推薦を"
    },
    {
      "start": 213.239,
      "duration": 8.28,
      "text": "いただけますか小林さんはいえ姿勢方針の"
    },
    {
      "start": 217.28,
      "duration": 7.64,
      "text": "質疑を聞いていましてもかなり予算委員会"
    },
    {
      "start": 221.519,
      "duration": 7.0,
      "text": "もえ先行きが不明ということなので"
    },
    {
      "start": 224.92,
      "duration": 5.76,
      "text": "えあの議長経験者でもあります井教子委員"
    },
    {
      "start": 228.519,
      "duration": 7.0,
      "text": "に委員長をお願いしたいと思い"
    },
    {
      "start": 230.68,
      "duration": 7.96,
      "text": "ますえただいま私井教委員長にとの推薦が"
    },
    {
      "start": 235.519,
      "duration": 6.881,
      "text": "ございましたお諮りいたします嵐教委員長"
    },
    {
      "start": 238.64,
      "duration": 6.4,
      "text": "に推薦するにご異議ありませんかご異議"
    },
    {
      "start": 242.4,
      "duration": 5.199,
      "text": "なしと認めます従ってただいま指名いたし"
    },
    {
      "start": 245.04,
      "duration": 5.64,
      "text": "ました通り選出することに決定いたしまし"
    },
    {
      "start": 247.599,
      "duration": 5.441,
      "text": "たそれでは私の方から一言ご挨拶を"
    },
    {
      "start": 250.68,
      "duration": 7.239,
      "text": "申し上げたいと思い"
    },
    {
      "start": 253.04,
      "duration": 9.039,
      "text": "ますえまあの3日間という長場になります"
    },
    {
      "start": 257.919,
      "duration": 7.521,
      "text": "ので1日1日緊張感を持ってえ簡潔な"
    },
    {
      "start": 262.079,
      "duration": 6.201,
      "text": "そしてえ活発なあ委員会にしていきたいと"
    },
    {
      "start": 265.44,
      "duration": 6.16,
      "text": "思っておりますので是非皆様のご協力を"
    },
    {
      "start": 268.28,
      "duration": 3.32,
      "text": "よろしくお願いいたします"
    },
    {
      "start": 275.0,
      "duration": 6.6,
      "text": "それではあそっ"
    },
    {
      "start": 278.08,
      "duration": 6.08,
      "text": "かそれではこれから副委長のご選を行い"
    },
    {
      "start": 281.6,
      "duration": 4.879,
      "text": "ますご選の方法についてはいかがいたし"
    },
    {
      "start": 284.16,
      "duration": 6.879,
      "text": "ましょうかどなたか選出方法についてご"
    },
    {
      "start": 286.479,
      "duration": 7.801,
      "text": "意見がありませんかえ安田さん指名推薦で"
    },
    {
      "start": 291.039,
      "duration": 5.6,
      "text": "お願いしますただいま選出方法について"
    },
    {
      "start": 294.28,
      "duration": 4.759,
      "text": "指名推薦によるとのご意見がありますが"
    },
    {
      "start": 296.639,
      "duration": 3.681,
      "text": "指名推薦により決定することにご異議あり"
    },
    {
      "start": 299.039,
      "duration": 3.561,
      "text": "ませんか"
    },
    {
      "start": 300.32,
      "duration": 5.28,
      "text": "ご異議なしと認めただいま申し上げました"
    },
    {
      "start": 302.6,
      "duration": 8.48,
      "text": "通り決定いたしますどの他かご推いただけ"
    },
    {
      "start": 305.6,
      "duration": 7.92,
      "text": "ますか田さんはいえっとこの度の予算特別"
    },
    {
      "start": 311.08,
      "duration": 5.72,
      "text": "委員長の選出にあたっては裏で大変"
    },
    {
      "start": 313.52,
      "duration": 7.84,
      "text": "走り回られていましたご尽力いただきまし"
    },
    {
      "start": 316.8,
      "duration": 8.8,
      "text": "たあの水谷子さんを推薦いたし"
    },
    {
      "start": 321.36,
      "duration": 7.119,
      "text": "ますただいま水谷委員を副長にの推薦が"
    },
    {
      "start": 325.6,
      "duration": 6.64,
      "text": "ございましたお諮りいし"
    },
    {
      "start": 328.479,
      "duration": 6.72,
      "text": "ますに選出することにご異議ありませんか"
    },
    {
      "start": 332.24,
      "duration": 5.079,
      "text": "ご異議なしと認めます従ってただいま指名"
    },
    {
      "start": 335.199,
      "duration": 4.84,
      "text": "いたしました通り選出することに決定"
    },
    {
      "start": 337.319,
      "duration": 4.921,
      "text": "いたしましたただいま副委長に選出され"
    },
    {
      "start": 340.039,
      "duration": 5.6,
      "text": "ました水谷高子委員のご挨拶をお願い"
    },
    {
      "start": 342.24,
      "duration": 5.32,
      "text": "いたしますインスタさんはいえご推薦"
    },
    {
      "start": 345.639,
      "duration": 5.84,
      "text": "いただきまた皆様ご承認いただきまして"
    },
    {
      "start": 347.56,
      "duration": 6.639,
      "text": "ありがとうございますえ昨年のえ予算特別"
    },
    {
      "start": 351.479,
      "duration": 5.241,
      "text": "委員会当初の予算の時は私委員長を務め"
    },
    {
      "start": 354.199,
      "duration": 5.881,
      "text": "させていただきましたがあの副委員長とし"
    },
    {
      "start": 356.72,
      "duration": 5.199,
      "text": "て支えていただいた嵐委"
    },
    {
      "start": 360.08,
      "duration": 3.88,
      "text": "はいあの今回あの交代ということになり"
    },
    {
      "start": 361.919,
      "duration": 4.361,
      "text": "ますがあのしっかりお支えしてですねあの"
    },
    {
      "start": 363.96,
      "duration": 5.679,
      "text": "充実した審議になるようにと思っており"
    },
    {
      "start": 366.28,
      "duration": 3.359,
      "text": "ますのでどうぞよろしくお願いいたし"
    },
    {
      "start": 371.8,
      "duration": 6.72,
      "text": "ます以上で予算特別委員会の会議を終了"
    },
    {
      "start": 375.52,
      "duration": 7.32,
      "text": "いたしますえそれではちょっと協議会を"
    },
    {
      "start": 378.52,
      "duration": 7.84,
      "text": "開かせていただきますえっとすでにあの議"
    },
    {
      "start": 382.84,
      "duration": 5.32,
      "text": "科委会でえ確認されたことなんですがあの"
    },
    {
      "start": 386.36,
      "duration": 3.64,
      "text": "ここでも確認してまいりたいと思いますの"
    },
    {
      "start": 388.16,
      "duration": 4.69,
      "text": "でお願いいたします"
    },
    {
      "start": 390.0,
      "duration": 4.08,
      "text": "ここでもう協会に入っちゃたいいですも"
    },
    {
      "start": 392.85,
      "duration": 4.15,
      "text": "[音楽]"
    },
    {
      "start": 394.08,
      "duration": 5.959,
      "text": "えっと議会委員会で確認されたことですが"
    },
    {
      "start": 397.0,
      "duration": 6.24,
      "text": "えっと2月15日の議会委員会で確認され"
    },
    {
      "start": 400.039,
      "duration": 6.801,
      "text": "ましたが一般会計投資予算の歳出の質疑に"
    },
    {
      "start": 403.24,
      "duration": 6.6,
      "text": "関しましては昨年同様全体を4区分に分け"
    },
    {
      "start": 406.84,
      "duration": 6.24,
      "text": "て行います詳細に関しましてはお手元に"
    },
    {
      "start": 409.84,
      "duration": 7.28,
      "text": "配布しております令和6年第1回定例会"
    },
    {
      "start": 413.08,
      "duration": 9.519,
      "text": "予算特別委員会新作分についての通りです"
    },
    {
      "start": 417.12,
      "duration": 9.28,
      "text": "え次に総合会議の質疑区分についてですえ"
    },
    {
      "start": 422.599,
      "duration": 6.801,
      "text": "昨年の決算委員会及び2月15日の議会運"
    },
    {
      "start": 426.4,
      "duration": 7.799,
      "text": "会においてご議論のありました歳入歳出"
    },
    {
      "start": 429.4,
      "duration": 7.68,
      "text": "予算事項別明細書117ページのえ総合"
    },
    {
      "start": 434.199,
      "duration": 6.68,
      "text": "教育会議に要する経費関連の質疑につき"
    },
    {
      "start": 437.08,
      "duration": 8.6,
      "text": "ましては令和6年第1回定例会予算特別"
    },
    {
      "start": 440.879,
      "duration": 7.801,
      "text": "委員会新作文についてのおりえ歳出第1"
    },
    {
      "start": 445.68,
      "duration": 5.44,
      "text": "区分での質疑となりますが質疑の内容に"
    },
    {
      "start": 448.68,
      "duration": 5.56,
      "text": "より教育委員会に答弁を求めるものについ"
    },
    {
      "start": 451.12,
      "duration": 6.359,
      "text": "ては歳出第4区分での質疑を行いたいと"
    },
    {
      "start": 454.24,
      "duration": 7.079,
      "text": "思いますまた総括質疑についてつきまして"
    },
    {
      "start": 457.479,
      "duration": 7.081,
      "text": "は姿勢における総合的な観点からの質疑"
    },
    {
      "start": 461.319,
      "duration": 7.361,
      "text": "及び令和6年第1会定例会予算特別委員会"
    },
    {
      "start": 464.56,
      "duration": 7.639,
      "text": "新作分についての資料の通り人件費行財政"
    },
    {
      "start": 468.68,
      "duration": 6.32,
      "text": "改革全般等の質疑を行う場であると考えて"
    },
    {
      "start": 472.199,
      "duration": 6.321,
      "text": "おります各委員に置かれましてはご協力の"
    },
    {
      "start": 475.0,
      "duration": 7.72,
      "text": "ほどよろしくお願いいたしますえ次にえ"
    },
    {
      "start": 478.52,
      "duration": 8.72,
      "text": "裏面の予算特別委員会かこ第1回定例会"
    },
    {
      "start": 482.72,
      "duration": 10.159,
      "text": "かこの区分別審査時間についてかこ過去4"
    },
    {
      "start": 487.24,
      "duration": 9.2,
      "text": "年文をご覧くださいえこのうち一般会計書"
    },
    {
      "start": 492.879,
      "duration": 7.16,
      "text": "予算の歳出に対する第1区分から第4区分"
    },
    {
      "start": 496.44,
      "duration": 7.759,
      "text": "までの質疑の合計時間数で見ますと令和4"
    },
    {
      "start": 500.039,
      "duration": 7.641,
      "text": "年は31時間35分でしたが0和5年は"
    },
    {
      "start": 504.199,
      "duration": 6.96,
      "text": "35時間41分となっておりましたまた"
    },
    {
      "start": 507.68,
      "duration": 7.68,
      "text": "総括質の時間数で見ますと令和5年につい"
    },
    {
      "start": 511.159,
      "duration": 6.8,
      "text": "てはえ3時間52分となっておりましたえ"
    },
    {
      "start": 515.36,
      "duration": 5.44,
      "text": "審査時間に関しましては各年度の予算の"
    },
    {
      "start": 517.959,
      "duration": 6.241,
      "text": "内容によるところも多々あると思いますが"
    },
    {
      "start": 520.8,
      "duration": 6.64,
      "text": "限られた時間においてえ活発かつ効率的な"
    },
    {
      "start": 524.2,
      "duration": 6.92,
      "text": "審査が進められますよう議事の進行に特段"
    },
    {
      "start": 527.44,
      "duration": 7.36,
      "text": "のご配慮ご協力につきまして委員長よりお"
    },
    {
      "start": 531.12,
      "duration": 6.88,
      "text": "願いを申し上げますえ部局の答弁体制に"
    },
    {
      "start": 534.8,
      "duration": 8.64,
      "text": "関しましては教育長については教育委員会"
    },
    {
      "start": 538.0,
      "duration": 9.8,
      "text": "に関係する審査を行う初日かこあ補正歳入"
    },
    {
      "start": 543.44,
      "duration": 7.959,
      "text": "えそれから5日目かこ第4区分え6日目え"
    },
    {
      "start": 547.8,
      "duration": 6.84,
      "text": "かこ総括の委員会に出席していただきその"
    },
    {
      "start": 551.399,
      "duration": 6.921,
      "text": "他は実績にて審査を聞いていただきたいと"
    },
    {
      "start": 554.64,
      "duration": 6.72,
      "text": "思いますまた説明については答弁が必要な"
    },
    {
      "start": 558.32,
      "duration": 6.4,
      "text": "際に入れ替わるようお願いいたしますえ"
    },
    {
      "start": 561.36,
      "duration": 7.36,
      "text": "資料説明につきましては本年においても各"
    },
    {
      "start": 564.72,
      "duration": 7.119,
      "text": "部長職からの資料懸命の報告は省略し副"
    },
    {
      "start": 568.72,
      "duration": 6.92,
      "text": "市長から事前に提出した通りです程度の"
    },
    {
      "start": 571.839,
      "duration": 6.961,
      "text": "発言にとめたいと思いますその後資料内容"
    },
    {
      "start": 575.64,
      "duration": 6.92,
      "text": "について議員があれば議事進行上の発言と"
    },
    {
      "start": 578.8,
      "duration": 5.36,
      "text": "してお受けいたしますえ何か他にござい"
    },
    {
      "start": 582.56,
      "duration": 6.36,
      "text": "ますでしょう"
    },
    {
      "start": 584.16,
      "duration": 7.6,
      "text": "かよしえそれでは以上で予算特別委員会"
    },
    {
      "start": 588.92,
      "duration": 6.4,
      "text": "協議会を終了いたしますどうぞよろしくお"
    },
    {
      "start": 591.76,
      "duration": 3.56,
      "text": "願いいたしますお疲れ様でし"
    },
    {
      "start": 598.12,
      "duration": 3.0,
      "text": "た"
    },
    {
      "start": 603.72,
      "duration": 3.0,
      "text": "あ"
    }
  ]
}