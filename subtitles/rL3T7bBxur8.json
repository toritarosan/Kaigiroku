{
  "entries": [
    {
      "start": 132.56,
      "duration": 3.0,
      "text": "じゃあ、お疲れ様です。あの、議会運営委員会協議会、あの、始めます。まず、あの、討論ありますか?"
    },
    {
      "start": 140.2,
      "duration": 4.44,
      "text": "なしですね。じゃあ、あの、採決態度は"
    },
    {
      "start": 142.28,
      "duration": 6.0,
      "text": "充前通りと、ま、いうことでよろしい"
    },
    {
      "start": 144.64,
      "duration": 7.08,
      "text": "でしょうか。で、あとその避難訓練の日程"
    },
    {
      "start": 148.28,
      "duration": 8.52,
      "text": "を、あの、確認したいと思うんですが、1"
    },
    {
      "start": 151.72,
      "duration": 8.519,
      "text": "月19日の午前、ああ、2月19日、2月"
    },
    {
      "start": 156.8,
      "duration": 6.68,
      "text": "19日の、えっと、午前10時から、え、"
    },
    {
      "start": 160.239,
      "duration": 6.0,
      "text": "90分で行うと、ま、いうことでご確認"
    },
    {
      "start": 163.48,
      "duration": 5.119,
      "text": "いただけますでしょうか?じゃあ、そう"
    },
    {
      "start": 166.239,
      "duration": 3.36,
      "text": "いうことで、あの、よろしくお願いします"
    },
    {
      "start": 168.599,
      "duration": 4.0,
      "text": "。"
    },
    {
      "start": 169.599,
      "duration": 3.0,
      "text": "で、あとは議長から何かありますか?今日の日程とかで。"
    },
    {
      "start": 174.8,
      "duration": 3.0,
      "text": "あ、あ、あ、えっと、ま、このまま順調に進んで、えっと、もし、えっと、議案"
    },
    {
      "start": 182.56,
      "duration": 1.92,
      "text": "607"
    },
    {
      "start": 184.159,
      "duration": 1.08,
      "text": "号、"
    },
    {
      "start": 184.48,
      "duration": 3.759,
      "text": "67号です。"
    },
    {
      "start": 185.239,
      "duration": 3.0,
      "text": "もう一緒に、あの、審議できるようであれば教授にやって、えっと、"
    },
    {
      "start": 189.239,
      "duration": 4.08,
      "text": "2日目は9"
    },
    {
      "start": 190.319,
      "duration": 3.0,
      "text": "回にしたいという風に考えてますが、いかがでしょうか?"
    },
    {
      "start": 194.64,
      "duration": 3.64,
      "text": "よろしいですか?"
    },
    {
      "start": 195.28,
      "duration": 3.0,
      "text": "はい。よろしいでしょうか?じゃ、そういうことでよろしくお願いします。"
    },
    {
      "start": 198.84,
      "duration": 6.479,
      "text": "あと中大付属中学校の主権者教育のあの"
    },
    {
      "start": 202.4,
      "duration": 5.119,
      "text": "モ子をそのあの廊下に貼"
    },
    {
      "start": 205.319,
      "duration": 4.92,
      "text": "るっていうことがあったので今日全部"
    },
    {
      "start": 207.519,
      "duration": 5.241,
      "text": "終わった後でどうですかねこれからだ"
    },
    {
      "start": 210.239,
      "duration": 4.56,
      "text": "昼休みとか3時休憩まで行くかどうか"
    },
    {
      "start": 212.76,
      "duration": 6.28,
      "text": "わかんないですけどなんかあんまり"
    },
    {
      "start": 214.799,
      "duration": 4.241,
      "text": "バタバタするので全部終わっ"
    },
    {
      "start": 219.56,
      "duration": 4.16,
      "text": "でどうですかいい"
    },
    {
      "start": 222.08,
      "duration": 2.48,
      "text": "ですか早くやった方が良ければ"
    },
    {
      "start": 223.72,
      "duration": 4.0,
      "text": "早い"
    },
    {
      "start": 224.56,
      "duration": 6.16,
      "text": "大丈夫ですかじゃあ全部終わった後にあ"
    },
    {
      "start": 227.72,
      "duration": 3.0,
      "text": "あの、ちょっと春作業をそれぞれ分担してやりたいと思いますので、あの、議会事務局の前に集まっていただくとモとかを用意しときますので、"
    },
    {
      "start": 239.599,
      "duration": 3.0,
      "text": "じゃ、そういうことでよろよろしいですかね?"
    },
    {
      "start": 242.879,
      "duration": 3.761,
      "text": "えっと、会の後になりますね。"
    },
    {
      "start": 245.0,
      "duration": 4.64,
      "text": "調査の協議会って、"
    },
    {
      "start": 246.64,
      "duration": 3.0,
      "text": "あ、開が終わっての協議会があるのかな?"
    },
    {
      "start": 250.079,
      "duration": 3.681,
      "text": "はい、ちょっと、"
    },
    {
      "start": 250.76,
      "duration": 3.0,
      "text": "あ、調査の協議会も終わってからっていう形になりますかね。"
    },
    {
      "start": 259.479,
      "duration": 3.0,
      "text": "だ、そのの間になんか入れるとなるとやっぱり休み時間にやるしかないと思うんで、"
    },
    {
      "start": 264.72,
      "duration": 3.0,
      "text": "わざわざ時間取るっていうわけにもね、なかなかいかないので"
    },
    {
      "start": 267.919,
      "duration": 3.0,
      "text": "調整入ってきたい"
    },
    {
      "start": 274.08,
      "duration": 3.0,
      "text": "いいですか?ちょっと終わった後でお昼休みとかやります。"
    },
    {
      "start": 281.16,
      "duration": 3.0,
      "text": "お昼休みもそれぞれなんかね、色々調整が入ったりとか"
    },
    {
      "start": 286.0,
      "duration": 3.0,
      "text": "あると思いますので、ちょっと終わったところでちょっとお声がけしますので、"
    },
    {
      "start": 290.84,
      "duration": 3.0,
      "text": "それでちょっと対応するっていうことでよろしくお願いします。えっと、あと皆さんから何かありますでしょうか?"
    },
    {
      "start": 302.96,
      "duration": 2.28,
      "text": "いい。なんか"
    },
    {
      "start": 304.44,
      "duration": 3.8,
      "text": "ない。"
    },
    {
      "start": 305.24,
      "duration": 3.0,
      "text": "はい。じゃあいいですか?これで終わって。じゃあ議会運営委員会協議会終わります。お疲れ様でした。"
    },
    {
      "start": 323.08,
      "duration": 3.239,
      "text": "はい。"
    }
  ]
}