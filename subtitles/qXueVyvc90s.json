{
  "entries": [
    {
      "start": 139.76,
      "duration": 5.68,
      "text": "が慣れて"
    },
    {
      "start": 141.28,
      "duration": 8.039,
      "text": "ましえでは皆さんお揃いですので初めて"
    },
    {
      "start": 145.44,
      "duration": 3.879,
      "text": "よろしいですねはい"
    },
    {
      "start": 150.39,
      "duration": 7.73,
      "text": "[笑い]"
    },
    {
      "start": 153.319,
      "duration": 4.801,
      "text": "ただいまから決算特別委員会の会議を開き"
    },
    {
      "start": 162.239,
      "duration": 10.961,
      "text": "ますえ本日は年長の私が委員長が補選さ"
    },
    {
      "start": 168.319,
      "duration": 4.881,
      "text": "れるまでえ委員長の職務を行い"
    },
    {
      "start": 176.08,
      "duration": 7.36,
      "text": "ますたしに議題に入ります"
    },
    {
      "start": 180.319,
      "duration": 5.601,
      "text": "議題は当委員会の委員長の護選についてで"
    },
    {
      "start": 183.44,
      "duration": 4.92,
      "text": "あります護選の方法についてはいかが"
    },
    {
      "start": 185.92,
      "duration": 6.36,
      "text": "いたしましょうかどなたか選出方法につい"
    },
    {
      "start": 188.36,
      "duration": 7.12,
      "text": "てご意見がありませんか斎藤さんえ指名"
    },
    {
      "start": 192.28,
      "duration": 5.8,
      "text": "推薦でお願いしますただいま選出方法に"
    },
    {
      "start": 195.48,
      "duration": 5.399,
      "text": "ついて指名推薦によるとのご意見があり"
    },
    {
      "start": 198.08,
      "duration": 4.04,
      "text": "ますが指名推薦により決定することにご"
    },
    {
      "start": 200.879,
      "duration": 4.601,
      "text": "異議ありません"
    },
    {
      "start": 202.12,
      "duration": 6.399,
      "text": "かご異議なしと認めただいま申し上げまし"
    },
    {
      "start": 205.48,
      "duration": 6.64,
      "text": "た通り決定いたしますどの他かご推薦お"
    },
    {
      "start": 208.519,
      "duration": 3.601,
      "text": "願いいたします大藤"
    },
    {
      "start": 215.56,
      "duration": 9.44,
      "text": "さんえ新え若手のホプ清水学議員を推薦"
    },
    {
      "start": 222.799,
      "duration": 2.201,
      "text": "いたし"
    },
    {
      "start": 225.12,
      "duration": 7.08,
      "text": "ますただいま清水学委員を委員長にとの"
    },
    {
      "start": 228.92,
      "duration": 6.08,
      "text": "推薦がございましたお諮りいたします清水"
    },
    {
      "start": 232.2,
      "duration": 7.16,
      "text": "学委員を委員長に推薦することにご異議"
    },
    {
      "start": 235.0,
      "duration": 6.12,
      "text": "ありませんかご異議なしと認めますって"
    },
    {
      "start": 239.36,
      "duration": 4.4,
      "text": "いし"
    },
    {
      "start": 241.12,
      "duration": 5.759,
      "text": "することに決定いたしましたただいま委員"
    },
    {
      "start": 243.76,
      "duration": 4.6,
      "text": "長に選出されました清水学委員のご挨拶を"
    },
    {
      "start": 246.879,
      "duration": 5.321,
      "text": "お願いいたし"
    },
    {
      "start": 248.36,
      "duration": 6.239,
      "text": "ますさんはいあのありがたいお言葉"
    },
    {
      "start": 252.2,
      "duration": 4.08,
      "text": "ありがとうございましたあの色々助けて"
    },
    {
      "start": 254.599,
      "duration": 7.04,
      "text": "いただきながらやっていきたいと思います"
    },
    {
      "start": 256.28,
      "duration": 5.359,
      "text": "のでどうぞ温かくよろしくお願いいたし"
    },
    {
      "start": 263.36,
      "duration": 8.679,
      "text": "ますこれで私のは終了いしました委員交す"
    },
    {
      "start": 268.72,
      "duration": 3.319,
      "text": "たいたし"
    },
    {
      "start": 280.4,
      "duration": 4.56,
      "text": "ますあ珍しいシトだと"
    },
    {
      "start": 295.56,
      "duration": 6.24,
      "text": "思う再開いたしますこれから副委長のご選"
    },
    {
      "start": 299.12,
      "duration": 4.4,
      "text": "を行います古の方法についてはいかが"
    },
    {
      "start": 301.8,
      "duration": 6.88,
      "text": "いたしましょう"
    },
    {
      "start": 303.52,
      "duration": 6.92,
      "text": "か出選出はいどなたか選出方法についてご"
    },
    {
      "start": 308.68,
      "duration": 4.959,
      "text": "意見がありませんかすいませんでしたはい"
    },
    {
      "start": 310.44,
      "duration": 6.72,
      "text": "山さんはい指名推薦でお願いし"
    },
    {
      "start": 313.639,
      "duration": 6.521,
      "text": "ますただいま選出方法について指名推薦に"
    },
    {
      "start": 317.16,
      "duration": 6.0,
      "text": "よるとのご意見がありますが指名推薦に"
    },
    {
      "start": 320.16,
      "duration": 5.039,
      "text": "よる決定することにご異議ありませんかご"
    },
    {
      "start": 323.16,
      "duration": 5.24,
      "text": "異議なしと認めただいま申し上げました"
    },
    {
      "start": 325.199,
      "duration": 5.481,
      "text": "通り決定いたしますどんなったかご推薦"
    },
    {
      "start": 328.4,
      "duration": 4.04,
      "text": "いただけますでしょうか"
    },
    {
      "start": 330.68,
      "duration": 6.68,
      "text": "さんはい"
    },
    {
      "start": 332.44,
      "duration": 9.879,
      "text": "え何があっても同じないようなあのとです"
    },
    {
      "start": 337.36,
      "duration": 8.24,
      "text": "ねですねベテランのあの水上ひをあのあの"
    },
    {
      "start": 342.319,
      "duration": 7.681,
      "text": "え推薦したいと思っておりますあの"
    },
    {
      "start": 345.6,
      "duration": 6.719,
      "text": "え冷静沈着でまあのこの決算委員会色々と"
    },
    {
      "start": 350.0,
      "duration": 4.28,
      "text": "あるかもしれませんけれどもままあの"
    },
    {
      "start": 352.319,
      "duration": 4.521,
      "text": "とんでもないことは多分もう怒らないと"
    },
    {
      "start": 354.28,
      "duration": 5.639,
      "text": "思いますけれどもあ何があってもですね"
    },
    {
      "start": 356.84,
      "duration": 7.56,
      "text": "あの委員長支えていただける"
    },
    {
      "start": 359.919,
      "duration": 7.0,
      "text": "願いいしただいま水上委員を副委員長にと"
    },
    {
      "start": 364.4,
      "duration": 5.6,
      "text": "の推薦がございましたお諮りいたします"
    },
    {
      "start": 366.919,
      "duration": 6.4,
      "text": "水上を副委長に選出することにご異議あり"
    },
    {
      "start": 370.0,
      "duration": 7.96,
      "text": "ませんかご異議なしと認めますしって"
    },
    {
      "start": 373.319,
      "duration": 7.121,
      "text": "ただいまめいししました通りえ選出する"
    },
    {
      "start": 377.96,
      "duration": 5.239,
      "text": "ことに決定いたしましたただいま副委長に"
    },
    {
      "start": 380.44,
      "duration": 4.28,
      "text": "選出されました水上のご挨拶をお願い"
    },
    {
      "start": 383.199,
      "duration": 6.44,
      "text": "いたし"
    },
    {
      "start": 384.72,
      "duration": 6.919,
      "text": "ますさんどうもありがとうございましたか"
    },
    {
      "start": 389.639,
      "duration": 4.12,
      "text": "といつも言われるんですけどま単に"
    },
    {
      "start": 391.639,
      "duration": 4.601,
      "text": "大人しいとぼとしてるっていうことでは"
    },
    {
      "start": 393.759,
      "duration": 5.84,
      "text": "ないかなという風に受け止めてるんです"
    },
    {
      "start": 396.24,
      "duration": 5.72,
      "text": "けれどもあのま清水さんとはあの街のどこ"
    },
    {
      "start": 399.599,
      "duration": 5.081,
      "text": "かでいつも会ってるような気がしてなんか"
    },
    {
      "start": 401.96,
      "duration": 6.359,
      "text": "いつもなんか見られてるような気がするの"
    },
    {
      "start": 404.68,
      "duration": 7.4,
      "text": "はあの気のせいかなとは思うんですけどま"
    },
    {
      "start": 408.319,
      "duration": 7.041,
      "text": "あの委員長支えてですねま重要な決算の"
    },
    {
      "start": 412.08,
      "duration": 8.959,
      "text": "審査になりますのであの皆さんの質疑を"
    },
    {
      "start": 415.36,
      "duration": 8.16,
      "text": "保証してあの民主的な手続きを踏んでに"
    },
    {
      "start": 421.039,
      "duration": 4.961,
      "text": "と思ますので皆さんのご協力よろしくお"
    },
    {
      "start": 423.52,
      "duration": 2.48,
      "text": "願いいし"
    },
    {
      "start": 426.24,
      "duration": 5.399,
      "text": "ます以上で決算特別委員会の会議を終了"
    },
    {
      "start": 429.4,
      "duration": 2.239,
      "text": "いたし"
    },
    {
      "start": 435.96,
      "duration": 6.919,
      "text": "ますはいえ決算特別委員会の協議メもお"
    },
    {
      "start": 439.879,
      "duration": 6.641,
      "text": "手元にあるかと思いますえ新作文について"
    },
    {
      "start": 442.879,
      "duration": 7.121,
      "text": "え歳出の質疑に関しましては8月28日の"
    },
    {
      "start": 446.52,
      "duration": 6.28,
      "text": "行われました議会委員会にて全体を4区分"
    },
    {
      "start": 450.0,
      "duration": 4.96,
      "text": "に分けて行うことと確認されています詳細"
    },
    {
      "start": 452.8,
      "duration": 5.56,
      "text": "に関しましては本日お配りしてあります令"
    },
    {
      "start": 454.96,
      "duration": 4.919,
      "text": "和6年第3回定例会決算特別委員会新作部"
    },
    {
      "start": 458.36,
      "duration": 5.519,
      "text": "についてご参照"
    },
    {
      "start": 459.879,
      "duration": 6.72,
      "text": "ください教育庁に出席についてです教育庁"
    },
    {
      "start": 463.879,
      "duration": 5.681,
      "text": "については教育委員会に関係する決算審査"
    },
    {
      "start": 466.599,
      "duration": 5.04,
      "text": "を行う日のみ委員会に出席いただきその他"
    },
    {
      "start": 469.56,
      "duration": 5.759,
      "text": "は自責にて審議を聞いていただきたいと"
    },
    {
      "start": 471.639,
      "duration": 6.761,
      "text": "思いますえその他え委員会の進行について"
    },
    {
      "start": 475.319,
      "duration": 5.921,
      "text": "は8月28日の議会運営委員会で確認した"
    },
    {
      "start": 478.4,
      "duration": 5.0,
      "text": "通りを行っていただきますよ皆様の委員の"
    },
    {
      "start": 481.24,
      "duration": 7.519,
      "text": "皆様に置かれましては格段のご配慮をお"
    },
    {
      "start": 483.4,
      "duration": 5.359,
      "text": "願いいたします以上です"
    }
  ]
}