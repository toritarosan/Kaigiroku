{
  "entries": [
    {
      "start": 24.8,
      "duration": 4.479,
      "text": "しますて言ったらあの"
    },
    {
      "start": 31.359,
      "duration": 3.0,
      "text": "け"
    },
    {
      "start": 70.4,
      "duration": 6.719,
      "text": "はい再開します遠藤"
    },
    {
      "start": 73.72,
      "duration": 6.52,
      "text": "さんでございます先ほど来森島議員の方"
    },
    {
      "start": 77.119,
      "duration": 4.96,
      "text": "からいかにもあの都の方自民党の都の方"
    },
    {
      "start": 80.24,
      "duration": 4.36,
      "text": "からお金が流れたというようなそういう"
    },
    {
      "start": 82.079,
      "duration": 4.801,
      "text": "こうそういうこと思わせるような発言が"
    },
    {
      "start": 84.6,
      "duration": 6.04,
      "text": "ございましたが一切そういうことはござい"
    },
    {
      "start": 86.88,
      "duration": 7.44,
      "text": "ませんご承ください"
    },
    {
      "start": 90.64,
      "duration": 6.92,
      "text": "森藤さんま今あの自民党議員からそういう"
    },
    {
      "start": 94.32,
      "duration": 6.88,
      "text": "発言がありましてま私はあのそのことはま"
    },
    {
      "start": 97.56,
      "duration": 6.68,
      "text": "公開の場であのはっきりあの発言をされた"
    },
    {
      "start": 101.2,
      "duration": 5.8,
      "text": "ことについては市民に伝えていきたいと"
    },
    {
      "start": 104.24,
      "duration": 7.159,
      "text": "あの誤解があるということで伝えていき"
    },
    {
      "start": 107.0,
      "duration": 4.399,
      "text": "たいということを述べておきます以上"
    },
    {
      "start": 114.96,
      "duration": 3.0,
      "text": "です"
    },
    {
      "start": 118.119,
      "duration": 7.161,
      "text": "長あもうあの終わったかと思いまし"
    },
    {
      "start": 121.64,
      "duration": 6.08,
      "text": "たえっと答弁いたしますまずあの一日保育"
    },
    {
      "start": 125.28,
      "duration": 5.56,
      "text": "園の"
    },
    {
      "start": 127.72,
      "duration": 5.8,
      "text": "えっとあり方検討のところのえごめん"
    },
    {
      "start": 130.84,
      "duration": 5.28,
      "text": "なさいね重要課題のところの書き方につい"
    },
    {
      "start": 133.52,
      "duration": 5.48,
      "text": "てご意見をいただいておりますがえ新税体"
    },
    {
      "start": 136.12,
      "duration": 7.68,
      "text": "の保育の質の向上というのはあの私が掲げ"
    },
    {
      "start": 139.0,
      "duration": 7.4,
      "text": "てる公約ですあのだからこれが直接全てに"
    },
    {
      "start": 143.8,
      "duration": 6.28,
      "text": "こうなんか通ずるというよりは結果的に"
    },
    {
      "start": 146.4,
      "duration": 6.24,
      "text": "あのそれに通るとは思いますがあのこれを"
    },
    {
      "start": 150.08,
      "duration": 9.0,
      "text": "書いてることはあの私自身の公約に基づい"
    },
    {
      "start": 152.64,
      "duration": 12.28,
      "text": "て書いておりますでえっと2問目です"
    },
    {
      "start": 159.08,
      "duration": 8.72,
      "text": "えっとま民間保育園えの方々がえま有方"
    },
    {
      "start": 164.92,
      "duration": 6.2,
      "text": "検討委員会からまあの辞任されたという"
    },
    {
      "start": 167.8,
      "duration": 5.88,
      "text": "ことを受けえま市はどう責任取るのかと"
    },
    {
      "start": 171.12,
      "duration": 5.08,
      "text": "いうことでございますがえっとま森さんも"
    },
    {
      "start": 173.68,
      "duration": 5.279,
      "text": "ね詳しいと思いますこの間のあのやり取り"
    },
    {
      "start": 176.2,
      "duration": 5.48,
      "text": "とかあの歴史的経過は見てこられたと思い"
    },
    {
      "start": 178.959,
      "duration": 5.041,
      "text": "ますのでえ私の方からあまり細かく"
    },
    {
      "start": 181.68,
      "duration": 4.8,
      "text": "申し上げませんがやはりあのこれまでの"
    },
    {
      "start": 184.0,
      "duration": 6.72,
      "text": "積み重ねていうものが色々あったんだろう"
    },
    {
      "start": 186.48,
      "duration": 7.08,
      "text": "なと思いますでえっとま相手がございます"
    },
    {
      "start": 190.72,
      "duration": 6.799,
      "text": "ので具体的にはあの申し上げにくいわけで"
    },
    {
      "start": 193.56,
      "duration": 9.399,
      "text": "ございますがえしっかりですねあのま保育"
    },
    {
      "start": 197.519,
      "duration": 7.961,
      "text": "を担っていただいてえおりますえ民間のえ"
    },
    {
      "start": 202.959,
      "duration": 5.161,
      "text": "方々事業者の方々にしっかり理解"
    },
    {
      "start": 205.48,
      "duration": 4.959,
      "text": "いただけるようにあの関係地構築について"
    },
    {
      "start": 208.12,
      "duration": 6.44,
      "text": "はあの取り組まないといけないと考えて"
    },
    {
      "start": 210.439,
      "duration": 6.681,
      "text": "おりますで次にえっとまその改めてえっと"
    },
    {
      "start": 214.56,
      "duration": 4.599,
      "text": "提訴された件についてでございますが今"
    },
    {
      "start": 217.12,
      "duration": 5.16,
      "text": "あの訴訟を起こされておりますのでこの件"
    },
    {
      "start": 219.159,
      "duration": 6.36,
      "text": "について言及はあのいたしませんえ次に"
    },
    {
      "start": 222.28,
      "duration": 5.8,
      "text": "都市計画道路の件でありますでえっとどう"
    },
    {
      "start": 225.519,
      "duration": 5.561,
      "text": "適切に対応するのかということもあの聞か"
    },
    {
      "start": 228.08,
      "duration": 5.439,
      "text": "れておりますがえっと主張報告にあのま"
    },
    {
      "start": 231.08,
      "duration": 4.519,
      "text": "関係じますのでえこの件については答弁を"
    },
    {
      "start": 233.519,
      "duration": 5.72,
      "text": "差し換えさせていただきますあの他の方の"
    },
    {
      "start": 235.599,
      "duration": 5.0,
      "text": "質問も同様にえっと答弁はあのできており"
    },
    {
      "start": 239.239,
      "duration": 5.56,
      "text": "ません"
    },
    {
      "start": 240.599,
      "duration": 7.041,
      "text": "で気候機器えの対策に含めてうんと世界の"
    },
    {
      "start": 244.799,
      "duration": 5.08,
      "text": "動き政府の動きを見てどのような削減目標"
    },
    {
      "start": 247.64,
      "duration": 4.84,
      "text": "をかける必要があるのかということであり"
    },
    {
      "start": 249.879,
      "duration": 5.241,
      "text": "ますがこれ今具体的に数値は答えられませ"
    },
    {
      "start": 252.48,
      "duration": 5.8,
      "text": "んがあのもうご指摘をいただいてきました"
    },
    {
      "start": 255.12,
      "duration": 6.92,
      "text": "ようにあのま現在はあのあまりにも低い"
    },
    {
      "start": 258.28,
      "duration": 6.12,
      "text": "数値のままで来ておりますでえこれについ"
    },
    {
      "start": 262.04,
      "duration": 5.439,
      "text": "てはえっとま世界の動きもそうですけども"
    },
    {
      "start": 264.4,
      "duration": 5.88,
      "text": "国の動きにえっとしっかり合わせてえっと"
    },
    {
      "start": 267.479,
      "duration": 5.56,
      "text": "数値目標を再設定する必要があるとと考え"
    },
    {
      "start": 270.28,
      "duration": 5.4,
      "text": "ておりますまちょっと懸念なのはですね"
    },
    {
      "start": 273.039,
      "duration": 5.681,
      "text": "アメリカがあのパリ協定からあの離脱を"
    },
    {
      "start": 275.68,
      "duration": 4.959,
      "text": "いたしましたあの排出大国の1つである"
    },
    {
      "start": 278.72,
      "duration": 5.36,
      "text": "アメリカが抜けたということはあの非常に"
    },
    {
      "start": 280.639,
      "duration": 7.081,
      "text": "大きなことでありますまとはいえですね"
    },
    {
      "start": 284.08,
      "duration": 6.24,
      "text": "あの我々は我々としてえ日本という国の中"
    },
    {
      "start": 287.72,
      "duration": 6.28,
      "text": "でそして小安は小がねとしてえっとやる"
    },
    {
      "start": 290.32,
      "duration": 5.719,
      "text": "べきことを地道にやり続けることがあの"
    },
    {
      "start": 294.0,
      "duration": 3.84,
      "text": "成果を上げることだと考えておりますので"
    },
    {
      "start": 296.039,
      "duration": 4.961,
      "text": "えしっかり取り組んでまいりたいと思い"
    },
    {
      "start": 297.84,
      "duration": 5.72,
      "text": "ますで次にえっと平和についてでござい"
    },
    {
      "start": 301.0,
      "duration": 4.68,
      "text": "ますま具体性感じられないとかあのま施策"
    },
    {
      "start": 303.56,
      "duration": 4.639,
      "text": "が貧弱だとかま色々ごご指摘をいただい"
    },
    {
      "start": 305.68,
      "duration": 6.56,
      "text": "てるところではありますえ言ってません"
    },
    {
      "start": 308.199,
      "duration": 8.28,
      "text": "でしたっけあ脆弱文章が貧弱あ文章が貧弱"
    },
    {
      "start": 312.24,
      "duration": 7.72,
      "text": "あすいませんあのえ文章が貧弱だとあのご"
    },
    {
      "start": 316.479,
      "duration": 7.361,
      "text": "指摘をいただいておりますでえっと核壁"
    },
    {
      "start": 319.96,
      "duration": 5.64,
      "text": "禁止条約へのえっとま批准の署名にねあの"
    },
    {
      "start": 323.84,
      "duration": 4.56,
      "text": "証明活動どうかということでございますが"
    },
    {
      "start": 325.6,
      "duration": 4.56,
      "text": "ちょっと今あのうんともすんとも言えませ"
    },
    {
      "start": 328.4,
      "duration": 5.239,
      "text": "んのでえっとま"
    },
    {
      "start": 330.16,
      "duration": 5.879,
      "text": "あすいませんえっと明確にお答えしにくい"
    },
    {
      "start": 333.639,
      "duration": 4.801,
      "text": "ところもございますのでまずはえそういう"
    },
    {
      "start": 336.039,
      "duration": 6.321,
      "text": "えご提案があのありましたということを"
    },
    {
      "start": 338.44,
      "duration": 6.319,
      "text": "あのもく止めさせていただきますで"
    },
    {
      "start": 342.36,
      "duration": 4.52,
      "text": "えっとまさっきあの触れていただいたよう"
    },
    {
      "start": 344.759,
      "duration": 4.521,
      "text": "にですねあのデジタル資料館あのこれ共同"
    },
    {
      "start": 346.88,
      "duration": 4.64,
      "text": "事業としてやっておりますがあの市民の皆"
    },
    {
      "start": 349.28,
      "duration": 5.4,
      "text": "さんの方でえっと今作っていただいており"
    },
    {
      "start": 351.52,
      "duration": 6.519,
      "text": "ますで合わせてえっとま多地域で"
    },
    {
      "start": 354.68,
      "duration": 5.88,
      "text": "ネットワークを組んででえっと今年度来年"
    },
    {
      "start": 358.039,
      "duration": 5.16,
      "text": "かな来年えっと和サミットっていうのを"
    },
    {
      "start": 360.56,
      "duration": 4.759,
      "text": "あのこのた地域で開催する予定でま年とし"
    },
    {
      "start": 363.199,
      "duration": 4.12,
      "text": "てもま当然26種の中に入っておりますの"
    },
    {
      "start": 365.319,
      "duration": 4.72,
      "text": "で関わっていきたいということでござい"
    },
    {
      "start": 367.319,
      "duration": 5.481,
      "text": "ます改めてこの戦後80年っていうことを"
    },
    {
      "start": 370.039,
      "duration": 5.921,
      "text": "あどのようにね受け止めえ主としてえ何を"
    },
    {
      "start": 372.8,
      "duration": 4.679,
      "text": "発信していくのかあの私もですねあの"
    },
    {
      "start": 375.96,
      "duration": 5.84,
      "text": "やはりこの"
    },
    {
      "start": 377.479,
      "duration": 8.321,
      "text": "うんとま第2世界大戦ま太平洋戦争あの"
    },
    {
      "start": 381.8,
      "duration": 5.64,
      "text": "この戦争のやっぱりこう経とかなぜえもう"
    },
    {
      "start": 385.8,
      "duration": 3.6,
      "text": "負けると分かったこの戦争を起こして"
    },
    {
      "start": 387.44,
      "duration": 4.28,
      "text": "しまったのかとかえっとここから学ぶこと"
    },
    {
      "start": 389.4,
      "duration": 5.28,
      "text": "ははあの多いですしそっから反省すべき"
    },
    {
      "start": 391.72,
      "duration": 4.56,
      "text": "こと一日本人として感じておりますのでえ"
    },
    {
      "start": 394.68,
      "duration": 5.12,
      "text": "しっかりそういったものをですねえっと"
    },
    {
      "start": 396.28,
      "duration": 6.52,
      "text": "今後未来のえま子供たち日本人に継承して"
    },
    {
      "start": 399.8,
      "duration": 6.839,
      "text": "いけるようにあの何をすべきかあの考え"
    },
    {
      "start": 402.8,
      "duration": 5.839,
      "text": "たいと思いますでまたあのそれを考えて"
    },
    {
      "start": 406.639,
      "duration": 4.441,
      "text": "いくえま市民を増やすということですね"
    },
    {
      "start": 408.639,
      "duration": 5.761,
      "text": "そういったことをあの何ができるか考え"
    },
    {
      "start": 411.08,
      "duration": 4.799,
      "text": "たいと思いますでえっと防災行政無線"
    },
    {
      "start": 414.4,
      "duration": 3.6,
      "text": "鳴らさないかということでございますが"
    },
    {
      "start": 415.879,
      "duration": 5.241,
      "text": "あのすいませんこれもあのまずご意見とし"
    },
    {
      "start": 418.0,
      "duration": 5.0,
      "text": "てご提案としてめさせてますで最後の"
    },
    {
      "start": 421.12,
      "duration": 3.84,
      "text": "ところはすいませんやはりあの政方針の"
    },
    {
      "start": 423.0,
      "duration": 5.4,
      "text": "質疑として私はなじまないと思いますので"
    },
    {
      "start": 424.96,
      "duration": 9.799,
      "text": "ここは答弁を差しさせていただき"
    },
    {
      "start": 428.4,
      "duration": 9.6,
      "text": "ます森さんえ1点目でありますがあのこの"
    },
    {
      "start": 434.759,
      "duration": 6.521,
      "text": "文章なんですがま市長が公約に掲げられた"
    },
    {
      "start": 438.0,
      "duration": 7.28,
      "text": "というのはあのそうなんですがあの後に"
    },
    {
      "start": 441.28,
      "duration": 6.599,
      "text": "続く文章はその小金市立保育園の方検討"
    },
    {
      "start": 445.28,
      "duration": 5.96,
      "text": "委員会を立ち上げという風になってるわけ"
    },
    {
      "start": 447.879,
      "duration": 9.801,
      "text": "ですよねということであれば当然その設置"
    },
    {
      "start": 451.24,
      "duration": 9.28,
      "text": "条例にあるあの文言があの来るのが当然だ"
    },
    {
      "start": 457.68,
      "duration": 7.479,
      "text": "ではないかという風に思っておりまして"
    },
    {
      "start": 460.52,
      "duration": 7.88,
      "text": "これま私なんかが読めばねえっとあその"
    },
    {
      "start": 465.159,
      "duration": 6.201,
      "text": "検討委員会で保育の質の向上までやるのか"
    },
    {
      "start": 468.4,
      "duration": 6.84,
      "text": "ということに受け止められてしまうんです"
    },
    {
      "start": 471.36,
      "duration": 8.76,
      "text": "よこれはなのでそうではなく公立保育園の"
    },
    {
      "start": 475.24,
      "duration": 8.6,
      "text": "あり方の検討についてあのこの検討委の中"
    },
    {
      "start": 480.12,
      "duration": 7.32,
      "text": "でま議論を重ねるんだという風にしないと"
    },
    {
      "start": 483.84,
      "duration": 6.56,
      "text": "ですねでその結果としてその保育の質の"
    },
    {
      "start": 487.44,
      "duration": 6.36,
      "text": "向上をどうするあにあのつなげていくん"
    },
    {
      "start": 490.4,
      "duration": 6.72,
      "text": "だっていうのがね私は本来の文章としては"
    },
    {
      "start": 493.8,
      "duration": 7.079,
      "text": "あり方だと思っていましてちょっとこの"
    },
    {
      "start": 497.12,
      "duration": 6.799,
      "text": "文章はですねあの間違って捉えられる恐れ"
    },
    {
      "start": 500.879,
      "duration": 6.561,
      "text": "があります是非あの訂正をしていただき"
    },
    {
      "start": 503.919,
      "duration": 6.161,
      "text": "たいなという風に思いますがえいかが"
    },
    {
      "start": 507.44,
      "duration": 6.8,
      "text": "でしょうか見解を伺います"
    },
    {
      "start": 510.08,
      "duration": 9.04,
      "text": "それであのちょっと冒頭のですねあの有方"
    },
    {
      "start": 514.24,
      "duration": 10.92,
      "text": "検討委員会のその専門職の皆さんの辞職の"
    },
    {
      "start": 519.12,
      "duration": 10.719,
      "text": "問題でありますで私は是非あのえやっぱり"
    },
    {
      "start": 525.16,
      "duration": 10.679,
      "text": "えこの文章を見ててですねうんま本当に"
    },
    {
      "start": 529.839,
      "duration": 9.12,
      "text": "これまでの色々な経過のものがあのあの"
    },
    {
      "start": 535.839,
      "duration": 5.521,
      "text": "思いがすごいいっぱい出ていてですねあ"
    },
    {
      "start": 538.959,
      "duration": 6.56,
      "text": "やっぱりそうだよなっていう風に思う"
    },
    {
      "start": 541.36,
      "duration": 7.039,
      "text": "ところもありましたであのその点からね何"
    },
    {
      "start": 545.519,
      "duration": 6.921,
      "text": "でも民間を入れ入れたらいいとかいうこと"
    },
    {
      "start": 548.399,
      "duration": 7.521,
      "text": "を言われるんだけどそこのやっぱりあの"
    },
    {
      "start": 552.44,
      "duration": 8.959,
      "text": "仕訳っていうかあのきちっとやるべきだっ"
    },
    {
      "start": 555.92,
      "duration": 10.039,
      "text": "たんじゃないですかねであのその点でね"
    },
    {
      "start": 561.399,
      "duration": 7.201,
      "text": "やっぱりこの専門職として民間事業者から"
    },
    {
      "start": 565.959,
      "duration": 5.88,
      "text": "入れていくっていうのにはこの馴染ま"
    },
    {
      "start": 568.6,
      "duration": 6.88,
      "text": "なかった保育園のあり方検討委員会にはと"
    },
    {
      "start": 571.839,
      "duration": 6.601,
      "text": "いう風に思うわけでまその点でどうなのか"
    },
    {
      "start": 575.48,
      "duration": 6.919,
      "text": "ということとそれからこの意見所の"
    },
    {
      "start": 578.44,
      "duration": 8.32,
      "text": "取り扱いについてですねあのどうされるお"
    },
    {
      "start": 582.399,
      "duration": 8.12,
      "text": "つもりなのかということさそしてですね私"
    },
    {
      "start": 586.76,
      "duration": 6.72,
      "text": "はま今日あのこの大の場で市長から謝罪が"
    },
    {
      "start": 590.519,
      "duration": 5.961,
      "text": "あるかなと思ったんですが今質問してもま"
    },
    {
      "start": 593.48,
      "duration": 6.76,
      "text": "何ら謝罪もないんですが"
    },
    {
      "start": 596.48,
      "duration": 6.52,
      "text": "えま謝罪っていうかねなんていうかま私は"
    },
    {
      "start": 600.24,
      "duration": 4.88,
      "text": "そうだと思うんですよ市があの失礼な態度"
    },
    {
      "start": 603.0,
      "duration": 6.24,
      "text": "を取ってるんじゃないかって言われてん"
    },
    {
      "start": 605.12,
      "duration": 6.64,
      "text": "ですよ公立保育園と民間保育園のこう比較"
    },
    {
      "start": 609.24,
      "duration": 5.88,
      "text": "をされて公立保育園の方がいいっていう"
    },
    {
      "start": 611.76,
      "duration": 5.639,
      "text": "ことについてですねあのなんら市の方から"
    },
    {
      "start": 615.12,
      "duration": 6.08,
      "text": "はアドバイスがなかったじゃないか"
    },
    {
      "start": 617.399,
      "duration": 7.521,
      "text": "アドバイスがされていないということを"
    },
    {
      "start": 621.2,
      "duration": 7.12,
      "text": "言われていてですねまもしそれが誤解で"
    },
    {
      "start": 624.92,
      "duration": 5.2,
      "text": "あればちゃんとその誤解は解く必要あるし"
    },
    {
      "start": 628.32,
      "duration": 6.519,
      "text": "あのこの"
    },
    {
      "start": 630.12,
      "duration": 8.08,
      "text": "文書が出され辞任された後民間保育園の"
    },
    {
      "start": 634.839,
      "duration": 8.12,
      "text": "方々とはお話をなさったんでしょうか市長"
    },
    {
      "start": 638.2,
      "duration": 8.319,
      "text": "自身が話をされて関係修復に向けてですね"
    },
    {
      "start": 642.959,
      "duration": 9.32,
      "text": "あの何らかの行動を起こされたのかねえ"
    },
    {
      "start": 646.519,
      "duration": 10.12,
      "text": "その点についてあの見解を伺います"
    },
    {
      "start": 652.279,
      "duration": 7.601,
      "text": "えまこれまでの積み重ねがあったとしても"
    },
    {
      "start": 656.639,
      "duration": 6.721,
      "text": "まああの今回の事件について"
    },
    {
      "start": 659.88,
      "duration": 6.399,
      "text": "がまがあ事件というかこの検討委員会が1"
    },
    {
      "start": 663.36,
      "duration": 7.919,
      "text": "つの景気になったことは事実であってです"
    },
    {
      "start": 666.279,
      "duration": 8.921,
      "text": "ねやはり明確にですね市長からあの直接お"
    },
    {
      "start": 671.279,
      "duration": 7.401,
      "text": "会いされてですねあのお話をされるまた"
    },
    {
      "start": 675.2,
      "duration": 7.079,
      "text": "あのということが必要なんではないかと"
    },
    {
      "start": 678.68,
      "duration": 7.88,
      "text": "思いますがえその点でどうでしょうかそれ"
    },
    {
      "start": 682.279,
      "duration": 9.36,
      "text": "からあのま訴訟についてはあま今これから"
    },
    {
      "start": 686.56,
      "duration": 9.839,
      "text": "行うことなので答えはあ差し控えたいと"
    },
    {
      "start": 691.639,
      "duration": 8.44,
      "text": "いうことでま答弁拒否をされますがあの"
    },
    {
      "start": 696.399,
      "duration": 7.481,
      "text": "なぜ保護が保護者がですねここまでやら"
    },
    {
      "start": 700.079,
      "duration": 7.161,
      "text": "なければならなかったのか是非私はあの"
    },
    {
      "start": 703.88,
      "duration": 6.88,
      "text": "本当に考えて欲しいですね子供の権利が"
    },
    {
      "start": 707.24,
      "duration": 8.8,
      "text": "本当に保証されている小金氏と言えるのか"
    },
    {
      "start": 710.76,
      "duration": 8.639,
      "text": "法律も判決もこれを無視した形でですね"
    },
    {
      "start": 716.04,
      "duration": 6.479,
      "text": "あのここまであの来られるっていうのはが"
    },
    {
      "start": 719.399,
      "duration": 7.041,
      "text": "ねあの保護者が立ち上がらなければなら"
    },
    {
      "start": 722.519,
      "duration": 8.361,
      "text": "ない思いを考えた時にですね本当に今の"
    },
    {
      "start": 726.44,
      "duration": 9.16,
      "text": "古賀年始の保育行政のあり方はあの問題"
    },
    {
      "start": 730.88,
      "duration": 7.959,
      "text": "ありです是非ですねこの例は7年度姿勢"
    },
    {
      "start": 735.6,
      "duration": 6.96,
      "text": "方針に向かってま姿勢方針なわけですが"
    },
    {
      "start": 738.839,
      "duration": 6.481,
      "text": "この2025年度ねあの9月に条例改正"
    },
    {
      "start": 742.56,
      "duration": 6.76,
      "text": "するっておっしゃるんですが私は本来は9"
    },
    {
      "start": 745.32,
      "duration": 9.6,
      "text": "月は遅いと思ってますえ5月に申が出たと"
    },
    {
      "start": 749.32,
      "duration": 9.48,
      "text": "たら少なくとも6月にですねあの定例会の"
    },
    {
      "start": 754.92,
      "duration": 7.88,
      "text": "ま最終ぐらいまでに条例を作り提案をして"
    },
    {
      "start": 758.8,
      "duration": 8.52,
      "text": "いただけないかなと思いますというのはと"
    },
    {
      "start": 762.8,
      "duration": 9.88,
      "text": "9月に提案をされて10月の1日からまた"
    },
    {
      "start": 767.32,
      "duration": 9.0,
      "text": "あの来年度のあ再来年度の入賞募集が"
    },
    {
      "start": 772.68,
      "duration": 6.68,
      "text": "スタートをするわけでま9月1か月間だけ"
    },
    {
      "start": 776.32,
      "duration": 6.68,
      "text": "で議論ができるかどうかということがあ"
    },
    {
      "start": 779.36,
      "duration": 7.479,
      "text": "ますあということもあるのでできる限り"
    },
    {
      "start": 783.0,
      "duration": 8.6,
      "text": "早くですね条例改正を提案していただけ"
    },
    {
      "start": 786.839,
      "duration": 9.161,
      "text": "ないかということについてあの見解を伺い"
    },
    {
      "start": 791.6,
      "duration": 6.84,
      "text": "ますそれからえっと2つ目の都市計画道路"
    },
    {
      "start": 796.0,
      "duration": 6.24,
      "text": "の問題ですまこれ視聴報告で答え"
    },
    {
      "start": 798.44,
      "duration": 7.32,
      "text": "るっていうことですがま本当にあの私は"
    },
    {
      "start": 802.24,
      "duration": 7.039,
      "text": "ですねこの独自検証のあり方はもう大問題"
    },
    {
      "start": 805.76,
      "duration": 7.28,
      "text": "だと思いますね何度も見直しを求めていき"
    },
    {
      "start": 809.279,
      "duration": 9.8,
      "text": "ましたがまそういう声には耳を貸して"
    },
    {
      "start": 813.04,
      "duration": 10.08,
      "text": "いただけずえまどこまこの検証問題検証"
    },
    {
      "start": 819.079,
      "duration": 7.721,
      "text": "自体がですねあの本当に市民から見ても"
    },
    {
      "start": 823.12,
      "duration": 7.76,
      "text": "おかしいとで市民からも要請文が来ている"
    },
    {
      "start": 826.8,
      "duration": 7.88,
      "text": "んじゃないですかこの検証のあり方につい"
    },
    {
      "start": 830.88,
      "duration": 7.879,
      "text": "てはやっぱり問題があるというそういう"
    },
    {
      "start": 834.68,
      "duration": 6.719,
      "text": "文書もあの寄せられていると思います市長"
    },
    {
      "start": 838.759,
      "duration": 6.841,
      "text": "はそれを受け止められてえどういう風に"
    },
    {
      "start": 841.399,
      "duration": 6.281,
      "text": "考えていらっしゃるのかまたあのま中止に"
    },
    {
      "start": 845.6,
      "duration": 5.52,
      "text": "なるのかどういう要望書になるのか分かり"
    },
    {
      "start": 847.68,
      "duration": 7.92,
      "text": "ませんが先ほども説明会など開くべきだと"
    },
    {
      "start": 851.12,
      "duration": 9.04,
      "text": "いう声がありましたがあのま私はですねま"
    },
    {
      "start": 855.6,
      "duration": 8.239,
      "text": "そういうことも含めてあの関係者また権利"
    },
    {
      "start": 860.16,
      "duration": 7.119,
      "text": "者などを含めてですねあのきちっと説明を"
    },
    {
      "start": 863.839,
      "duration": 6.321,
      "text": "していただきたいと思いますえその点は"
    },
    {
      "start": 867.279,
      "duration": 6.201,
      "text": "要望をしておきたいと思いますで気候機器"
    },
    {
      "start": 870.16,
      "duration": 8.919,
      "text": "の問題でありますがちょっと具体的な目標"
    },
    {
      "start": 873.48,
      "duration": 9.279,
      "text": "は今日出されておりませんがまあのただ"
    },
    {
      "start": 879.079,
      "duration": 6.961,
      "text": "あ低い数値のままではだめだということで"
    },
    {
      "start": 882.759,
      "duration": 6.041,
      "text": "ありますで国の動きなども見ていくという"
    },
    {
      "start": 886.04,
      "duration": 7.28,
      "text": "ことですが先ほども申し上げましたように"
    },
    {
      "start": 888.8,
      "duration": 9.0,
      "text": "国は2019年度ではなく2013年度日"
    },
    {
      "start": 893.32,
      "duration": 8.24,
      "text": "でえ60%削減と言っていますでこれでは"
    },
    {
      "start": 897.8,
      "duration": 7.44,
      "text": "え世界の流れにも逆行していますまあの"
    },
    {
      "start": 901.56,
      "duration": 8.079,
      "text": "アメリカの大統領はですねこのパリ協定"
    },
    {
      "start": 905.24,
      "duration": 7.12,
      "text": "からの離脱とですね石炭火力についてえ"
    },
    {
      "start": 909.639,
      "duration": 6.081,
      "text": "石炭エネルギーについてまどんどん使って"
    },
    {
      "start": 912.36,
      "duration": 8.68,
      "text": "いくんだというま公言をされておりますで"
    },
    {
      "start": 915.72,
      "duration": 10.16,
      "text": "こうした中で日本も石炭力に頼りえ頼ると"
    },
    {
      "start": 921.04,
      "duration": 8.64,
      "text": "いうこととそれから原発をですね再稼働と"
    },
    {
      "start": 925.88,
      "duration": 8.16,
      "text": "新規建設を狙っています"
    },
    {
      "start": 929.68,
      "duration": 9.079,
      "text": "これまでの原発依存を低減するという方向"
    },
    {
      "start": 934.04,
      "duration": 8.599,
      "text": "性からま交代をするという状況であります"
    },
    {
      "start": 938.759,
      "duration": 6.921,
      "text": "でこうした状況をですねやはり1日も早く"
    },
    {
      "start": 942.639,
      "duration": 6.801,
      "text": "克服していく必要がありますえそのための"
    },
    {
      "start": 945.68,
      "duration": 10.279,
      "text": "小金師としての省エネ対策また"
    },
    {
      "start": 949.44,
      "duration": 11.28,
      "text": "あ自然エネルギーのお再生するえその補助"
    },
    {
      "start": 955.959,
      "duration": 8.641,
      "text": "を増やすなどしてですねええ原発に頼ら"
    },
    {
      "start": 960.72,
      "duration": 5.359,
      "text": "ないえ火力に頼らない石炭火力に頼らない"
    },
    {
      "start": 964.6,
      "duration": 5.52,
      "text": "そうした"
    },
    {
      "start": 966.079,
      "duration": 6.961,
      "text": "あ対応を小金としても検討していただき"
    },
    {
      "start": 970.12,
      "duration": 5.959,
      "text": "たいと思っておりますがその点での小金の"
    },
    {
      "start": 973.04,
      "duration": 8.76,
      "text": "姿勢あ小金士の姿勢はいかがでしょうか"
    },
    {
      "start": 976.079,
      "duration": 9.921,
      "text": "見解を伺いますで2つあ5点目のえ今年の"
    },
    {
      "start": 981.8,
      "duration": 9.64,
      "text": "戦後80年の問題でありますが是非ですね"
    },
    {
      "start": 986.0,
      "duration": 8.839,
      "text": "あのま担当家などとも相談しあの検討して"
    },
    {
      "start": 991.44,
      "duration": 7.8,
      "text": "いただきたいと思います本来ならこの来"
    },
    {
      "start": 994.839,
      "duration": 7.601,
      "text": "年度予算の中でこれまで議会で様々な提案"
    },
    {
      "start": 999.24,
      "duration": 6.24,
      "text": "をしてきましたが平和事業の拡充について"
    },
    {
      "start": 1002.44,
      "duration": 7.44,
      "text": "ですね予算化をしていただきたかったです"
    },
    {
      "start": 1005.48,
      "duration": 7.88,
      "text": "がこれまでとなんら変わらないえ予算とも"
    },
    {
      "start": 1009.88,
      "duration": 6.48,
      "text": "なっておりますえま私が提案したことは"
    },
    {
      "start": 1013.36,
      "duration": 5.719,
      "text": "本当にさやかなことで予算がなくても"
    },
    {
      "start": 1016.36,
      "duration": 5.08,
      "text": "できることですでそういうことであればは"
    },
    {
      "start": 1019.079,
      "duration": 6.401,
      "text": "ですね是非"
    },
    {
      "start": 1021.44,
      "duration": 8.2,
      "text": "あの実現に向けてあの動いていただきたい"
    },
    {
      "start": 1025.48,
      "duration": 9.359,
      "text": "と思いますしえ今年3月10日の平和の日"
    },
    {
      "start": 1029.64,
      "duration": 10.399,
      "text": "を皮切りにですね是非あの実現あ何らかの"
    },
    {
      "start": 1034.839,
      "duration": 7.521,
      "text": "市民的なあ声も市民の声も聞いて平和行政"
    },
    {
      "start": 1040.039,
      "duration": 5.441,
      "text": "の拡充を進めていただきたいんですが"
    },
    {
      "start": 1042.36,
      "duration": 5.719,
      "text": "いかがでしょうかで政治とお金の問題に"
    },
    {
      "start": 1045.48,
      "duration": 5.28,
      "text": "ついてでありますま市長からは答弁でき"
    },
    {
      "start": 1048.079,
      "duration": 5.84,
      "text": "ないということでありました私は市長自身"
    },
    {
      "start": 1050.76,
      "duration": 5.72,
      "text": "について伺っています企業や団体からの"
    },
    {
      "start": 1053.919,
      "duration": 6.281,
      "text": "献金は受けていないということでよろしい"
    },
    {
      "start": 1056.48,
      "duration": 7.04,
      "text": "ですかとで私たちね市議会議員選挙の時に"
    },
    {
      "start": 1060.2,
      "duration": 6.76,
      "text": "もあのとある企業などはね回ってこられ"
    },
    {
      "start": 1063.52,
      "duration": 7.68,
      "text": "ますよあの人中見舞だっていうことでで"
    },
    {
      "start": 1066.96,
      "duration": 6.839,
      "text": "もちろん私は受け取りませんようんであの"
    },
    {
      "start": 1071.2,
      "duration": 6.16,
      "text": "それは当然のこと"
    },
    {
      "start": 1073.799,
      "duration": 7.041,
      "text": "であえいやいやいやで共産党は受け取らな"
    },
    {
      "start": 1077.36,
      "duration": 3.48,
      "text": "いって分かってると思"
    },
    {
      "start": 1081.559,
      "duration": 6.36,
      "text": "れでだから私たちにあのそんなことはな"
    },
    {
      "start": 1085.52,
      "duration": 6.84,
      "text": "いってことはないんですよ常にそういう"
    },
    {
      "start": 1087.919,
      "duration": 7.601,
      "text": "企業株式会社名であの人中見舞を持ってこ"
    },
    {
      "start": 1092.36,
      "duration": 6.799,
      "text": "られるっていうことはあるわけでまそれは"
    },
    {
      "start": 1095.52,
      "duration": 6.92,
      "text": "あのまほらまそれは受け取っちゃいけない"
    },
    {
      "start": 1099.159,
      "duration": 5.041,
      "text": "と思うしまあの市長は政治資金パーティー"
    },
    {
      "start": 1102.44,
      "duration": 6.64,
      "text": "はやってらっしゃるないと思いますけれど"
    },
    {
      "start": 1104.2,
      "duration": 8.2,
      "text": "もあのそういう献金を受け取らず潔な綺麗"
    },
    {
      "start": 1109.08,
      "duration": 7.16,
      "text": "な政治をやるべきだとこれまでそういう"
    },
    {
      "start": 1112.4,
      "duration": 6.88,
      "text": "献金を受け取ってま政治がですねやはり"
    },
    {
      "start": 1116.24,
      "duration": 6.36,
      "text": "あの大企業優遇の政治になってきてい"
    },
    {
      "start": 1119.28,
      "duration": 7.32,
      "text": "るっていうところに私は大きな問題がある"
    },
    {
      "start": 1122.6,
      "duration": 7.88,
      "text": "と思っていますまここで述べると夜中まで"
    },
    {
      "start": 1126.6,
      "duration": 7.079,
      "text": "でも喋りますから述べませんがあの是非"
    },
    {
      "start": 1130.48,
      "duration": 5.92,
      "text": "ですねその点はですね市長としてやっぱり"
    },
    {
      "start": 1133.679,
      "duration": 5.601,
      "text": "明確に市民の前に明らかにしておくべきだ"
    },
    {
      "start": 1136.4,
      "duration": 5.56,
      "text": "とこれだけ問題になってることですから非"
    },
    {
      "start": 1139.28,
      "duration": 7.0,
      "text": "え答弁を"
    },
    {
      "start": 1141.96,
      "duration": 7.52,
      "text": "求めはい再質問いただいたところだけ答弁"
    },
    {
      "start": 1146.28,
      "duration": 5.04,
      "text": "をいたしますまずあのうんと一保育園の"
    },
    {
      "start": 1149.48,
      "duration": 5.559,
      "text": "この"
    },
    {
      "start": 1151.32,
      "duration": 6.28,
      "text": "えっと重要課題なところのタイトルのけ方"
    },
    {
      "start": 1155.039,
      "duration": 6.481,
      "text": "について再度あの頂いておりますえ"
    },
    {
      "start": 1157.6,
      "duration": 8.24,
      "text": "繰り返し申し上げますがえっと私が1番"
    },
    {
      "start": 1161.52,
      "duration": 6.76,
      "text": "あのこの保育の分野でえっと長期的に実現"
    },
    {
      "start": 1165.84,
      "duration": 5.719,
      "text": "しなければならないと考えてるのは市全体"
    },
    {
      "start": 1168.28,
      "duration": 6.04,
      "text": "の保育の質の維持と向上あ維持え質の維持"
    },
    {
      "start": 1171.559,
      "duration": 5.401,
      "text": "向上えその仕組みづくりだということなん"
    },
    {
      "start": 1174.32,
      "duration": 4.359,
      "text": "ですでそれはそれで公約に掲げさせて"
    },
    {
      "start": 1176.96,
      "duration": 3.64,
      "text": "いただいておりますのであのここの"
    },
    {
      "start": 1178.679,
      "duration": 6.841,
      "text": "タイトルにはあの入れさせていただいて"
    },
    {
      "start": 1180.6,
      "duration": 7.959,
      "text": "ますただ今回そのこの4ち4つの重要課題"
    },
    {
      "start": 1185.52,
      "duration": 5.88,
      "text": "にあの書いてある内容についてはあの今の"
    },
    {
      "start": 1188.559,
      "duration": 5.161,
      "text": "進捗を書いておりますのでまそこが多少"
    },
    {
      "start": 1191.4,
      "duration": 4.96,
      "text": "その書いてあることと内容とタイトルと"
    },
    {
      "start": 1193.72,
      "duration": 5.04,
      "text": "内容とあの完全にこうリンクしないよねと"
    },
    {
      "start": 1196.36,
      "duration": 4.16,
      "text": "いうご指摘についてはあの当てはまる部分"
    },
    {
      "start": 1198.76,
      "duration": 7.12,
      "text": "もあるかもしれませんがあのここを訂正"
    },
    {
      "start": 1200.52,
      "duration": 9.639,
      "text": "するつもりはございませんで次に"
    },
    {
      "start": 1205.88,
      "duration": 7.72,
      "text": "うんと有田検討委員会のえま民間保育園の"
    },
    {
      "start": 1210.159,
      "duration": 3.441,
      "text": "方々に対して"
    },
    {
      "start": 1213.76,
      "duration": 5.44,
      "text": "えっとまず意見書の取り扱いについて少し"
    },
    {
      "start": 1217.08,
      "duration": 6.28,
      "text": "尋ねられておりますがこれについてはあの"
    },
    {
      "start": 1219.2,
      "duration": 6.12,
      "text": "文書で回答しておりますで合わせてうんと"
    },
    {
      "start": 1223.36,
      "duration": 3.76,
      "text": "民間保育の方々とお会いしたのかという"
    },
    {
      "start": 1225.32,
      "duration": 6.239,
      "text": "ことでございますが"
    },
    {
      "start": 1227.12,
      "duration": 7.08,
      "text": "あのま都開けてからですねえやはりお会い"
    },
    {
      "start": 1231.559,
      "duration": 5.12,
      "text": "をしてちゃんと話をしたいという申しをし"
    },
    {
      "start": 1234.2,
      "duration": 3.4,
      "text": "てるところでございますまだあの実現はし"
    },
    {
      "start": 1236.679,
      "duration": 4.761,
      "text": "ておりませ"
    },
    {
      "start": 1237.6,
      "duration": 8.439,
      "text": "んでえっと次"
    },
    {
      "start": 1241.44,
      "duration": 8.359,
      "text": "にえっとま新たな手え訴訟をね起こされ"
    },
    {
      "start": 1246.039,
      "duration": 5.76,
      "text": "てる件についてえっとまこのの内容につい"
    },
    {
      "start": 1249.799,
      "duration": 5.281,
      "text": "てま答弁できないことは変わりはありませ"
    },
    {
      "start": 1251.799,
      "duration": 5.88,
      "text": "んがすいませんさっきあの森さんがえっと"
    },
    {
      "start": 1255.08,
      "duration": 4.16,
      "text": "コの保育行政はあり方がひどいということ"
    },
    {
      "start": 1257.679,
      "duration": 3.441,
      "text": "をおっしゃいました"
    },
    {
      "start": 1259.24,
      "duration": 4.08,
      "text": "でえっとちょっとここは言い方を書いて"
    },
    {
      "start": 1261.12,
      "duration": 4.52,
      "text": "いただいて保育強請っていうと職員も全部"
    },
    {
      "start": 1263.32,
      "duration": 5.719,
      "text": "含んでしまいますので今こういうことに"
    },
    {
      "start": 1265.64,
      "duration": 5.519,
      "text": "なってる責任は私にありますからあの市来"
    },
    {
      "start": 1269.039,
      "duration": 4.281,
      "text": "市長はひどいということは言っていただい"
    },
    {
      "start": 1271.159,
      "duration": 5.241,
      "text": "て結構なんですけどちょっと保育行政って"
    },
    {
      "start": 1273.32,
      "duration": 5.239,
      "text": "くってしまうと職員全体を含めてしまう"
    },
    {
      "start": 1276.4,
      "duration": 4.04,
      "text": "そういう風な捉え方をしてしまいますので"
    },
    {
      "start": 1278.559,
      "duration": 3.561,
      "text": "あのそれだけはちょっと勘弁していただき"
    },
    {
      "start": 1280.44,
      "duration": 4.479,
      "text": "たいと思い"
    },
    {
      "start": 1282.12,
      "duration": 5.799,
      "text": "ますでえっと条例スケジュールは変える"
    },
    {
      "start": 1284.919,
      "duration": 6.76,
      "text": "予定はありませんで気候機器につきまして"
    },
    {
      "start": 1287.919,
      "duration": 6.841,
      "text": "はええとまえ様々な世界もしくは日本の"
    },
    {
      "start": 1291.679,
      "duration": 6.48,
      "text": "動きはございますがまずは公案手としての"
    },
    {
      "start": 1294.76,
      "duration": 7.32,
      "text": "これまでのあの大きな流れ方針えは変わり"
    },
    {
      "start": 1298.159,
      "duration": 6.76,
      "text": "はありませんでえ今回え計画のえっと目標"
    },
    {
      "start": 1302.08,
      "duration": 4.88,
      "text": "数値をあの変更するということはえっと"
    },
    {
      "start": 1304.919,
      "duration": 4.12,
      "text": "やはりえっと数値が低かったのでその目標"
    },
    {
      "start": 1306.96,
      "duration": 6.64,
      "text": "数値を上げるということでございますです"
    },
    {
      "start": 1309.039,
      "duration": 6.12,
      "text": "のでえ今後のま社会を見据えたあのま流れ"
    },
    {
      "start": 1313.6,
      "duration": 3.76,
      "text": "や動きっていうのは小whe種として"
    },
    {
      "start": 1315.159,
      "duration": 5.681,
      "text": "変えるつもりはございませんのでえ主とし"
    },
    {
      "start": 1317.36,
      "duration": 5.16,
      "text": "てえ自得可能な社会世界に向けたえコア熱"
    },
    {
      "start": 1320.84,
      "duration": 3.64,
      "text": "として果たすべき役割をしっかり果たして"
    },
    {
      "start": 1322.52,
      "duration": 4.36,
      "text": "いくあのこういう方向性でえ変わりは"
    },
    {
      "start": 1324.48,
      "duration": 5.319,
      "text": "ございませんで平和関係につきましては"
    },
    {
      "start": 1326.88,
      "duration": 5.56,
      "text": "あのご意見としてえ受けたまりますで最後"
    },
    {
      "start": 1329.799,
      "duration": 4.88,
      "text": "の部分なんですけどあの企業団体からの"
    },
    {
      "start": 1332.44,
      "duration": 5.2,
      "text": "寄付は受けてません個人しか受けてません"
    },
    {
      "start": 1334.679,
      "duration": 4.841,
      "text": "でこれ答えることがこの姿勢方針に対する"
    },
    {
      "start": 1337.64,
      "duration": 4.0,
      "text": "質疑が何でもありになってしまうのは私は"
    },
    {
      "start": 1339.52,
      "duration": 4.36,
      "text": "怖いと思いましてだから答えないっていう"
    },
    {
      "start": 1341.64,
      "duration": 4.8,
      "text": "ことを申し上げた次第ですあのそれだけは"
    },
    {
      "start": 1343.88,
      "duration": 7.36,
      "text": "申し上げておき"
    },
    {
      "start": 1346.44,
      "duration": 9.04,
      "text": "ます森戸さんはいえま今お答えをいただき"
    },
    {
      "start": 1351.24,
      "duration": 6.919,
      "text": "ましたがま是非ですねあのああの文書に"
    },
    {
      "start": 1355.48,
      "duration": 5.92,
      "text": "ついてはあのま私はちょっとこういう書き"
    },
    {
      "start": 1358.159,
      "duration": 6.921,
      "text": "方は誤解与えるなということは申し上げて"
    },
    {
      "start": 1361.4,
      "duration": 6.92,
      "text": "おきますえで2点目の問題はま経過は"
    },
    {
      "start": 1365.08,
      "duration": 6.4,
      "text": "分かりましたま保育行政ではなく市長が"
    },
    {
      "start": 1368.32,
      "duration": 6.8,
      "text": "悪いと言ってくれということでありまして"
    },
    {
      "start": 1371.48,
      "duration": 7.12,
      "text": "しかしまそれは市長がトップとして決める"
    },
    {
      "start": 1375.12,
      "duration": 9.12,
      "text": "わけですがそれをやっぱり支えているのが"
    },
    {
      "start": 1378.6,
      "duration": 10.84,
      "text": "行政職の皆さんでありましてえ効あの裁判"
    },
    {
      "start": 1384.24,
      "duration": 7.6,
      "text": "の結果に対する対応についてもま集団的な"
    },
    {
      "start": 1389.44,
      "duration": 7.0,
      "text": "議論で作られているんだろうという風には"
    },
    {
      "start": 1391.84,
      "duration": 7.88,
      "text": "思いますがまあ一般的にあのやっぱり保育"
    },
    {
      "start": 1396.44,
      "duration": 5.2,
      "text": "行政として問題があるというのは当然そう"
    },
    {
      "start": 1399.72,
      "duration": 5.079,
      "text": "言わざるを得ないんじゃないんですかで"
    },
    {
      "start": 1401.64,
      "duration": 8.8,
      "text": "それを決めてるのは市来市長で市来市長が"
    },
    {
      "start": 1404.799,
      "duration": 5.641,
      "text": "悪いというのは当然でありましてあの"
    },
    {
      "start": 1410.76,
      "duration": 5.24,
      "text": "あの一般的にそういう風に言うんじゃない"
    },
    {
      "start": 1413.039,
      "duration": 6.24,
      "text": "ですか私はね保育園の職場のあの保育士"
    },
    {
      "start": 1416.0,
      "duration": 7.0,
      "text": "さんにはあの責任はないと思っています"
    },
    {
      "start": 1419.279,
      "duration": 6.681,
      "text": "しかし政策決定をしているのはあの部長職"
    },
    {
      "start": 1423.0,
      "duration": 7.2,
      "text": "である皆さんであり市長そのトップである"
    },
    {
      "start": 1425.96,
      "duration": 8.48,
      "text": "市長であるわけであのそうしたね今の構造"
    },
    {
      "start": 1430.2,
      "duration": 7.479,
      "text": "からすればあのやっぱりあの保育行政と"
    },
    {
      "start": 1434.44,
      "duration": 6.88,
      "text": "いうことは言わざるおえないなというふに"
    },
    {
      "start": 1437.679,
      "duration": 6.641,
      "text": "私は思いますまあのもう1回私も勉強させ"
    },
    {
      "start": 1441.32,
      "duration": 6.04,
      "text": "ていただいてまその言い方が問題があった"
    },
    {
      "start": 1444.32,
      "duration": 6.68,
      "text": "としたらまたどこかで訂正なりはさせて"
    },
    {
      "start": 1447.36,
      "duration": 6.12,
      "text": "いただきますが現時点での私の見解はそう"
    },
    {
      "start": 1451.0,
      "duration": 5.72,
      "text": "いうことでありますので述べておきたいと"
    },
    {
      "start": 1453.48,
      "duration": 5.28,
      "text": "思いますえま気候機器分かりました是非"
    },
    {
      "start": 1456.72,
      "duration": 6.0,
      "text": "あの目標数値を上げるということであり"
    },
    {
      "start": 1458.76,
      "duration": 7.399,
      "text": "ますえ自然再生エネルギー省エネ問題含め"
    },
    {
      "start": 1462.72,
      "duration": 8.16,
      "text": "てですねやっぱり抜本的な対策を取って"
    },
    {
      "start": 1466.159,
      "duration": 8.24,
      "text": "原発や火力え石油火力に頼らないえそう"
    },
    {
      "start": 1470.88,
      "duration": 6.039,
      "text": "いう持続可能なあ小金の街を作って"
    },
    {
      "start": 1474.399,
      "duration": 7.681,
      "text": "いただきたいということは強く申し上げて"
    },
    {
      "start": 1476.919,
      "duration": 7.24,
      "text": "おきますで平和の問題もま是非え意見とし"
    },
    {
      "start": 1482.08,
      "duration": 4.839,
      "text": "て受け止めるということでありますので"
    },
    {
      "start": 1484.159,
      "duration": 6.361,
      "text": "前向きにお願いしたいと思いますであの私"
    },
    {
      "start": 1486.919,
      "duration": 5.36,
      "text": "姿勢方針っていうのはねあの私たちいつも"
    },
    {
      "start": 1490.52,
      "duration": 5.08,
      "text": "言うんですよこういうこと書いてないじゃ"
    },
    {
      "start": 1492.279,
      "duration": 5.201,
      "text": "ないかとねあいうわけですよ例えば市民"
    },
    {
      "start": 1495.6,
      "duration": 4.199,
      "text": "生活を守るっていうこと書いてないじゃ"
    },
    {
      "start": 1497.48,
      "duration": 5.919,
      "text": "ないかとでそのことについてどう思うん"
    },
    {
      "start": 1499.799,
      "duration": 6.521,
      "text": "だっていうことを常に聞いてますよだから"
    },
    {
      "start": 1503.399,
      "duration": 5.88,
      "text": "姿勢方針にないから聞いちゃいけないって"
    },
    {
      "start": 1506.32,
      "duration": 6.4,
      "text": "ことじゃないと思うんですよでそれは地方"
    },
    {
      "start": 1509.279,
      "duration": 6.721,
      "text": "政治家としてね今回の問題っていうのは"
    },
    {
      "start": 1512.72,
      "duration": 5.8,
      "text": "政治姿勢が問われる問題なんですよ企業や"
    },
    {
      "start": 1516.0,
      "duration": 6.52,
      "text": "団体献金を受け取っているかどうかって"
    },
    {
      "start": 1518.52,
      "duration": 7.879,
      "text": "いうことを含めてねそれは当然ですねあの"
    },
    {
      "start": 1522.52,
      "duration": 6.92,
      "text": "市民の前に明らかにするってこは市長が"
    },
    {
      "start": 1526.399,
      "duration": 5.561,
      "text": "潔癖で潔癖っていうかね清潔な市長であ"
    },
    {
      "start": 1529.44,
      "duration": 6.0,
      "text": "るってことを証明することなんですから"
    },
    {
      "start": 1531.96,
      "duration": 7.439,
      "text": "なんらね答弁を拒否するようなねことでも"
    },
    {
      "start": 1535.44,
      "duration": 7.44,
      "text": "ないしあのということだと思いますのでま"
    },
    {
      "start": 1539.399,
      "duration": 6.64,
      "text": "私はそういうもで質問させていただきます"
    },
    {
      "start": 1542.88,
      "duration": 7.88,
      "text": "共産党はずっとねここにないことを質問し"
    },
    {
      "start": 1546.039,
      "duration": 7.481,
      "text": "たことはいくらでもありますよねでもあの"
    },
    {
      "start": 1550.76,
      "duration": 6.08,
      "text": "共産党だけじゃないと思うんですよ平和"
    },
    {
      "start": 1553.52,
      "duration": 7.12,
      "text": "行政のこと書いてそうでどう考えるんだと"
    },
    {
      "start": 1556.84,
      "duration": 7.28,
      "text": "かねそういうことあるんですよそれはだっ"
    },
    {
      "start": 1560.64,
      "duration": 8.48,
      "text": "て勢方針だけがね"
    },
    {
      "start": 1564.12,
      "duration": 6.84,
      "text": "あの市の行政に関わる問題ではないし市長"
    },
    {
      "start": 1569.12,
      "duration": 6.64,
      "text": "としての政治姿勢っていうのがあるわけ"
    },
    {
      "start": 1570.96,
      "duration": 8.319,
      "text": "ですからね議長ということであのまそう"
    },
    {
      "start": 1575.76,
      "duration": 6.48,
      "text": "いうことでえま是非今日今お答えいただき"
    },
    {
      "start": 1579.279,
      "duration": 6.321,
      "text": "ましたのであのご無理を言ったかもしれ"
    },
    {
      "start": 1582.24,
      "duration": 5.24,
      "text": "ませんが大変あの明確になりましたので"
    },
    {
      "start": 1585.6,
      "duration": 5.28,
      "text": "良かったなと思っておりますありがとう"
    },
    {
      "start": 1587.48,
      "duration": 3.4,
      "text": "ございましたです"
    },
    {
