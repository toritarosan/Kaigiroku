    {
      "start": 108.32,
      "duration": 5.68,
      "text": "いただきましたいくつか質問を実はしよう"
    },
    {
      "start": 110.84,
      "duration": 7.0,
      "text": "と思っていたんですけれどもあの皆様の"
    },
    {
