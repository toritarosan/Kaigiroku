    },
    {
      "start": 123.32,
      "duration": 6.12,
      "text": "ますやっぱりこの担当のこう今までのこう"
    },
    {
      "start": 127.399,
      "duration": 4.241,
      "text": "あり方というのは問題があるかなっていう"
    },
    {
      "start": 129.44,
      "duration": 5.76,
      "text": "風には思ってるところではありますが"
    },
    {
      "start": 131.64,
      "duration": 7.12,
      "text": "しかしその時間のない中でがしかしあの"
    },
    {
      "start": 135.2,
      "duration": 6.119,
