    {
      "start": 574.56,
      "duration": 8.719,
      "text": "ね都市旅館への貢献になるのかなとえこ"
    },
    {
      "start": 579.12,
      "duration": 9.159,
      "text": "公園のがの積極的な活用の貢献に"
    },
    {
      "start": 583.279,
      "duration": 10.12,
      "text": "そのどうしてそれが元々の野川や公園が"
    },
    {
      "start": 588.279,
      "duration": 8.0,
      "text": "コンクリートのえ道路が通る道に変わって"
    },
    {
      "start": 593.399,
      "duration": 6.041,
      "text": "貢献という発想になるのかなというのが"
    },
    {
      "start": 596.279,
      "duration": 6.881,
      "text": "ちょっと私はですねあのつめなくてですね"
    },
    {
      "start": 599.44,
      "duration": 5.8,
      "text": "まこの項目の意味や意図っというのの説明"
    },
    {
      "start": 603.16,
      "duration": 6.799,
      "text": "をまいただきたいところではあったんです"
    },
    {
      "start": 605.24,
      "duration": 5.599,
      "text": "けれどもえっとま次回次回質問したいとえ"
    },
    {
      "start": 609.959,
      "duration": 3.921,
      "text": "思い"
    },
    {
      "start": 610.839,
      "duration": 6.481,
      "text": "ますで"
    },
    {
      "start": 613.88,
      "duration": 6.959,
      "text": "えっとそれでですねそのまアンケートの"
    },
    {
      "start": 617.32,
      "duration": 5.56,
      "text": "聞き方や説明の仕方によってはえっと指的"
    },
    {
      "start": 620.839,
      "duration": 4.601,
      "text": "になる可能性があるので必ずそうならない"
    },
    {
      "start": 622.88,
      "duration": 4.56,
      "text": "ようにということはですねあのまこれまで"
    },
    {
      "start": 625.44,
      "duration": 5.48,
      "text": "も申し上げてきてますけれども繰り返し"
    },
    {
      "start": 627.44,
      "duration": 6.16,
      "text": "申し上げますそして申し上げるものの"
    },
    {
      "start": 630.92,
      "duration": 6.28,
      "text": "やはり同期あ同期付けじゃなくてあの"
    },
    {
      "start": 633.6,
      "duration": 6.16,
      "text": "重み付けやえ環境とか緑とか文化の評価"
    },
    {
      "start": 637.2,
      "duration": 3.92,
      "text": "っていうのは本当に複雑で難しいものだと"
    },
    {
      "start": 639.76,
      "duration": 3.0,
      "text": "え思い"
    },
    {
      "start": 641.12,
      "duration": 6.959,
      "text": "ます"
    },
    {
      "start": 642.76,
      "duration": 9.28,
      "text": "そのま自然えっと自然やまそこに住む人の"
    },
    {
      "start": 648.079,
      "duration": 6.32,
      "text": "生活を失って代わりに道路を得るという"
    },
    {
      "start": 652.04,
      "duration": 5.08,
      "text": "あの道路作る場合はまそういう選択になる"
    },
    {
      "start": 654.399,
      "duration": 5.24,
      "text": "わけですからあの道路があることによって"
    },
    {
      "start": 657.12,
      "duration": 5.839,
      "text": "便利になる面が出てくるというのはまある"
    },
    {
      "start": 659.639,
      "duration": 5.841,
      "text": "意味当然でありましてでそこをですね1つ"
    },
    {
      "start": 662.959,
      "duration": 5.801,
      "text": "のメリットという風に強調していたらです"
    },
    {
      "start": 665.48,
      "duration": 6.159,
      "text": "ねま道路が必要という風にミスリードする"
    },
    {
      "start": 668.76,
      "duration": 7.199,
      "text": "ことにえなりかねないということは明白だ"
    },
    {
      "start": 671.639,
      "duration": 7.561,
      "text": "と考えますえっとまたですねあとこれまで"
    },
    {
      "start": 675.959,
      "duration": 5.361,
      "text": "の質疑の中でこのやり方が適切に定まって"
    },
    {
      "start": 679.2,
      "duration": 4.56,
      "text": "いない検討されていない状況も明らかに"
    },
    {
      "start": 681.32,
      "duration": 5.4,
      "text": "なりましてまこのようなやり"
    },
    {
      "start": 683.76,
      "duration": 5.519,
      "text": "方のままでいいのかどうかこれで決めて"
    },
    {
      "start": 686.72,
      "duration": 5.359,
      "text": "いけるのかというのはなかなか判断が"
    },
    {
      "start": 689.279,
      "duration": 7.24,
      "text": "難しいというより決められないのではない"
    },
    {
      "start": 692.079,
      "duration": 7.921,
      "text": "かという風に私は考えますえということを"
    },
    {
      "start": 696.519,
      "duration": 7.601,
      "text": "申し上げたいとえ思いますそしてですね"
    },
    {
      "start": 700.0,
      "duration": 8.04,
      "text": "そのま検証結果検証を行っていくわけです"
    },
    {
      "start": 704.12,
      "duration": 7.6,
      "text": "けれどもこういうそのこういわゆる行政的"
    },
    {
      "start": 708.04,
      "duration": 7.08,
      "text": "な評価のみになるのではなくてまそれを"
    },
    {
      "start": 711.72,
      "duration": 6.119,
      "text": "行うとしてもですね市長の政治的な判断が"
    },
    {
      "start": 715.12,
      "duration": 5.08,
      "text": "ま最終的には必要になってくるとえ思い"
    },
    {
      "start": 717.839,
      "duration": 5.12,
      "text": "ますあの"
    },
    {
      "start": 720.2,
      "duration": 3.639,
      "text": "市長は最終的に総合的な判断を下すとま"
    },
    {
      "start": 722.959,
      "duration": 3.721,
      "text": "そこの"
    },
    {
      "start": 723.839,
      "duration": 5.041,
      "text": "スケジュールや書いてありますしこれまで"
    },
    {
      "start": 726.68,
      "duration": 5.08,
      "text": "もそう述べてますけれどもましっかりと"
    },
    {
      "start": 728.88,
      "duration": 5.12,
      "text": "ですねあの白市長が誕生した時の公約に"
    },
    {
      "start": 731.76,
      "duration": 6.36,
      "text": "沿って判断をするべきだということはです"
    },
    {
      "start": 734.0,
      "duration": 6.079,
      "text": "ねまあ今回も改めてえ述べたいと思います"
    },
    {
      "start": 738.12,
      "duration": 4.719,
      "text": "で改めて"
    },
    {
      "start": 740.079,
      "duration": 6.281,
      "text": "えっとですね市長の公約についてです"
    },
    {
      "start": 742.839,
      "duration": 6.081,
      "text": "けれどもえっと東京都に二路線の中小要請"
    },
    {
      "start": 746.36,
      "duration": 6.52,
      "text": "を行うことでありましたがま今も実行でき"
    },
    {
      "start": 748.92,
      "duration": 5.919,
      "text": "てないことに関してはま市民のえ方々で"
    },
    {
      "start": 752.88,
      "duration": 4.36,
      "text": "起こってる方がたくさんいらっしゃいます"
    },
    {
      "start": 754.839,
      "duration": 5.921,
      "text": "ま本日も聴者がたくさんいらっしゃって"
    },
    {
      "start": 757.24,
      "duration": 7.039,
      "text": "感心が依然として高いですここであのま"
    },
    {
      "start": 760.76,
      "duration": 5.6,
      "text": "改めて確認ですけどもえっと東京都の中止"
    },
    {
      "start": 764.279,
      "duration": 5.24,
      "text": "の要請を行うという公約は変わっていない"
    },
    {
      "start": 766.36,
      "duration": 5.52,
      "text": "ということで良かどうかえまた中止の要請"
    },
    {
      "start": 769.519,
      "duration": 6.721,
      "text": "を行うための検証ということで間違いない"
    },
    {
      "start": 771.88,
      "duration": 4.36,
      "text": "かちょっとこれだけ聞かせてください以上"
    },
    {
      "start": 776.92,
      "duration": 5.84,
      "text": "ですえ公はあのま大さおっしゃった"
    },
    {
      "start": 781.0,
      "duration": 3.48,
      "text": "おっしゃっていただいた通りの内容のもの"
    },
    {
      "start": 782.76,
      "duration": 4.0,
      "text": "でございますま当然それは変わっており"
    },
    {
      "start": 784.48,
      "duration": 4.88,
      "text": "ませんでこの検証につきましてはあの"
    },
    {
      "start": 786.76,
      "duration": 5.319,
      "text": "先ほど来答弁えしてますしまこれまでも"
    },
    {
      "start": 789.36,
      "duration": 5.4,
      "text": "議会で答弁してきましたがえその中心"
    },
    {
      "start": 792.079,
      "duration": 5.921,
      "text": "見直しの要望をするということをえ"
    },
    {
      "start": 794.76,
      "duration": 6.199,
      "text": "突き詰めていった時にマスタープランのに"
    },
    {
      "start": 798.0,
      "duration": 5.92,
      "text": "の内容に沿ってえま検証する必要性がある"
    },
    {
      "start": 800.959,
      "duration": 4.521,
      "text": "と私たちは判断しておりますのでえま検証"
    },
    {
      "start": 803.92,
      "duration": 4.76,
      "text": "してるということでご理解いただきたいと"
    },
    {
      "start": 805.48,
      "duration": 3.2,
      "text": "思います"
    },
    {
      "start": 813.76,
      "duration": 6.12,
      "text": "以上で本件に対する質疑を終了することに"
    },
    {
      "start": 817.12,
      "duration": 5.519,
      "text": "ご異議ありませんかりご異議なしと認め"
    },
    {
      "start": 819.88,
      "duration": 7.84,
      "text": "ます従って本件に対する質疑を終了いたし"
    },
