    },
    {
      "start": 143.599,
      "duration": 6.401,
      "text": "はしていますでその上で今こういう状況で"
    },
    {
      "start": 147.2,
      "duration": 5.08,
      "text": "あるっていうのはちょっとあの大丈夫かな"
    },
    {
      "start": 150.0,
      "duration": 6.04,
