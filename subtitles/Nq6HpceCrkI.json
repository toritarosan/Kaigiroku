    },
    {
      "start": 152.28,
      "duration": 6.44,
      "text": "ますでえ9月の第3家定例会の9月13日"
    },
    {
      "start": 156.04,
      "duration": 7.199,
      "text": "にあの改めて出し直していうことでござい"
    },
    {
      "start": 158.72,
      "duration": 7.28,
      "text": "ますがその時にあのやっぱり課長以下あの"
    },
