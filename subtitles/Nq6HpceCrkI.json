      "start": 166.0,
      "duration": 6.28,
      "text": "いうのが"
    },
    {
      "start": 168.04,
      "duration": 8.559,
      "text": "あの本当に感じるところではありますで"
    },
    {
      "start": 172.28,
      "duration": 6.52,
      "text": "え9月13日には納得するものが出てくる"
    },
    {
      "start": 176.599,
      "duration": 3.761,
      "text": "かどうかそれもちょっと不安であるところ"
    },
    {
      "start": 178.8,
      "duration": 4.799,
      "text": "はあるんですけれども"
    },
    {
      "start": 180.36,
      "duration": 10.0,
      "text": "あの職員の努力に期待したいと思っており"
    },
    {
      "start": 183.599,
