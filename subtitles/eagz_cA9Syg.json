{
  "entries": [
    {
      "start": 54.12,
      "duration": 3.0,
      "text": "ご"
    },
    {
      "start": 60.16,
      "duration": 3.0,
      "text": "JA"
    },
    {
      "start": 104.56,
      "duration": 3.0,
      "text": "な"
    },
    {
      "start": 124.039,
      "duration": 7.441,
      "text": "再開しますの再開いたしますお諮りします"
    },
    {
      "start": 128.039,
      "duration": 5.92,
      "text": "ただ今までの議事の進行状況から考えて"
    },
    {
      "start": 131.48,
      "duration": 5.68,
      "text": "しばらく時間延長することにご異議あり"
    },
    {
      "start": 133.959,
      "duration": 6.56,
      "text": "ませんかご異議なしと認めしばらく時間"
    },
    {
      "start": 137.16,
      "duration": 7.4,
      "text": "延長をいたしますここで先ほど保留しまし"
    },
    {
      "start": 140.519,
      "duration": 8.321,
      "text": "た追加日程第1から追加日程第9までの9"
    },
    {
      "start": 144.56,
      "duration": 9.319,
      "text": "の保留を解き順次議題とし討論採決を行い"
    },
    {
      "start": 148.84,
      "duration": 9.24,
      "text": "ます案第48号多様な人材の地方議会への"
    },
    {
      "start": 153.879,
      "duration": 8.121,
      "text": "参画促進を求める意見書本件は討論を行い"
    },
    {
      "start": 158.08,
      "duration": 8.239,
      "text": "ます初めに本件に反対のものの発言を許可"
    },
    {
      "start": 162.0,
      "duration": 4.319,
      "text": "します16番水上浩"
    },
    {
      "start": 173.599,
      "duration": 8.881,
      "text": "議員え議員案第48号多様な人材の地方"
    },
    {
      "start": 178.4,
      "duration": 7.6,
      "text": "議会への画促進を求める意見書に日本共産"
    },
    {
      "start": 182.48,
      "duration": 7.399,
      "text": "党を代表して反対の討論を行いますえ地方"
    },
    {
      "start": 186.0,
      "duration": 6.959,
      "text": "議員の成りて足の問題などに安心して議員"
    },
    {
      "start": 189.879,
      "duration": 6.881,
      "text": "に立候補しえ議員活動が続けることが"
    },
    {
      "start": 192.959,
      "duration": 7.321,
      "text": "できる環境を整えることや男女共同三角の"
    },
    {
      "start": 196.76,
      "duration": 6.559,
      "text": "推進ハラスメント防止のための取り組みは"
    },
    {
      "start": 200.28,
      "duration": 7.28,
      "text": "大切であり議会としても検討していく必要"
    },
    {
      "start": 203.319,
      "duration": 9.28,
      "text": "があると考えますしかし本意見所の厚生"
    },
    {
      "start": 207.56,
      "duration": 7.679,
      "text": "年金へ地方議員がえ地方議会議員が加入"
    },
    {
      "start": 212.599,
      "duration": 6.801,
      "text": "できるための法整備を図ることについては"
    },
    {
      "start": 215.239,
      "duration": 7.961,
      "text": "え賛同できません地方議員年金制度を廃止"
    },
    {
      "start": 219.4,
      "duration": 7.399,
      "text": "する際に私たち日本共産党はすでに制度が"
    },
    {
      "start": 223.2,
      "duration": 8.2,
      "text": "維持延長できない段階であり廃止の方向で"
    },
    {
      "start": 226.799,
      "duration": 8.28,
      "text": "検討が必要え廃止しても掛金の返済や受給"
    },
    {
      "start": 231.4,
      "duration": 6.88,
      "text": "決定者への給付など一定の公的負担はえ"
    },
    {
      "start": 235.079,
      "duration": 6.041,
      "text": "避けられないよって国民住民の理解が得"
    },
    {
      "start": 238.28,
      "duration": 6.36,
      "text": "られるようにすべきでありえ関係者間の"
    },
    {
      "start": 241.12,
      "duration": 7.44,
      "text": "議論にとめず広く国民の前にオープンにし"
    },
    {
      "start": 244.64,
      "duration": 7.599,
      "text": "てえ議論を重ねるべきえ地方議員の人材"
    },
    {
      "start": 248.56,
      "duration": 6.84,
      "text": "確保のため廃止した後の新たな年金制度"
    },
    {
      "start": 252.239,
      "duration": 6.68,
      "text": "など何らかのものが必要との声もあるが"
    },
    {
      "start": 255.4,
      "duration": 7.079,
      "text": "これも国民的議論の上でえ検討されるべき"
    },
    {
      "start": 258.919,
      "duration": 7.601,
      "text": "であるなどの考えを示してえ地方議員年金"
    },
    {
      "start": 262.479,
      "duration": 8.521,
      "text": "制度の廃止に賛成してきました現在の国民"
    },
    {
      "start": 266.52,
      "duration": 8.92,
      "text": "年金やえ厚生年金など公的年金制度の財源"
    },
    {
      "start": 271.0,
      "duration": 7.84,
      "text": "は非保険者の保険料と国庫負担金えそして"
    },
    {
      "start": 275.44,
      "duration": 6.759,
      "text": "保険料を積み立てた積み立て金の運用益で"
    },
    {
      "start": 278.84,
      "duration": 7.04,
      "text": "え構成されていますこのうちサラリーマン"
    },
    {
      "start": 282.199,
      "duration": 6.961,
      "text": "などが加入する厚生年金の保険料の半額は"
    },
    {
      "start": 285.88,
      "duration": 6.68,
      "text": "え経営者事業者が負担する仕組みとなって"
    },
    {
      "start": 289.16,
      "duration": 7.28,
      "text": "おりえよって地方議員が厚生年金に加入"
    },
    {
      "start": 292.56,
      "duration": 7.479,
      "text": "することはえ各自治体が年金保険料の半分"
    },
    {
      "start": 296.44,
      "duration": 8.039,
      "text": "をえ負担することになりえその財源は市民"
    },
    {
      "start": 300.039,
      "duration": 7.761,
      "text": "の税金で国民的議論や合意が必要とえなる"
    },
    {
      "start": 304.479,
      "duration": 7.241,
      "text": "のではないでしょうか地方議員の年金制度"
    },
    {
      "start": 307.8,
      "duration": 8.08,
      "text": "のあり方については国民誰も誰もが安心し"
    },
    {
      "start": 311.72,
      "duration": 7.24,
      "text": "て暮らせる年金制度を確立する国民的議論"
    },
    {
      "start": 315.88,
      "duration": 6.48,
      "text": "の中で検討されるべきであり単に議員の"
    },
    {
      "start": 318.96,
      "duration": 7.72,
      "text": "年金のみの議論でえ済ませる問題ではあり"
    },
    {
      "start": 322.36,
      "duration": 7.88,
      "text": "ませんえさらには勤労者を始め広く国民の"
    },
    {
      "start": 326.68,
      "duration": 7.639,
      "text": "賛成権がえ保障されることが前提でなけれ"
    },
    {
      "start": 330.24,
      "duration": 7.44,
      "text": "ばえならないと考えますえこの間老後には"
    },
    {
      "start": 334.319,
      "duration": 7.44,
      "text": "年金だけでは暮らせず2000万円が必要"
    },
    {
      "start": 337.68,
      "duration": 7.48,
      "text": "などと年金問題が大きな問題となりました"
    },
    {
      "start": 341.759,
      "duration": 6.841,
      "text": "そしてマクロ経済スライドで年金は減らさ"
    },
    {
      "start": 345.16,
      "duration": 6.52,
      "text": "れることへの国民の批判が大きく広がって"
    },
    {
      "start": 348.6,
      "duration": 6.319,
      "text": "います国民年金だけでは暮らせないことは"
    },
    {
      "start": 351.68,
      "duration": 7.04,
      "text": "明らかであり生活できる国民年金にして"
    },
    {
      "start": 354.919,
      "duration": 7.161,
      "text": "いくことなど年金制度全体の底上げ改革が"
    },
    {
      "start": 358.72,
      "duration": 6.52,
      "text": "必要ですえこうした検討もないままでは"
    },
    {
      "start": 362.08,
      "duration": 6.32,
      "text": "国民には給付葛藤をしつけながらえ地方"
    },
    {
      "start": 365.24,
      "duration": 6.399,
      "text": "議員にはお手盛りとの批判は避がいものと"
    },
    {
      "start": 368.4,
      "duration": 6.4,
      "text": "考えます本来は今後の支援のあり方などに"
    },
    {
      "start": 371.639,
      "duration": 6.241,
      "text": "ついてえ国民的議論や合意を得る努力を"
    },
    {
      "start": 374.8,
      "duration": 6.04,
      "text": "行いえ関係者官でもよく議論を行うことが"
    },
    {
      "start": 377.88,
      "duration": 6.92,
      "text": "必要ですえこうした状況を踏まえることも"
    },
    {
      "start": 380.84,
      "duration": 7.04,
      "text": "なく厚生年金加入を求めるえ内容を含み"
    },
    {
      "start": 384.8,
      "duration": 6.76,
      "text": "検証を停止することはえ問題があるという"
    },
    {
      "start": 387.88,
      "duration": 3.68,
      "text": "ことを述べて討論を終わります"
    },
    {
      "start": 399.759,
      "duration": 8.041,
      "text": "次に本件に反対のものの発言を許可します"
    },
    {
      "start": 404.24,
      "duration": 3.56,
      "text": "7番安田稽古"
    },
    {
      "start": 417.96,
      "duration": 8.359,
      "text": "議員銀48号多様な人材の地方議会への"
    },
    {
      "start": 422.759,
      "duration": 5.761,
      "text": "三角促進を求める意見書に対しえ成華者"
    },
    {
      "start": 426.319,
      "duration": 3.841,
      "text": "ネットワークとして反対の立場で討論し"
    },
    {
      "start": 428.52,
      "duration": 5.92,
      "text": "ます"
    },
    {
      "start": 430.16,
      "duration": 8.479,
      "text": "え本意見書の官位である地方議会への多様"
    },
    {
      "start": 434.44,
      "duration": 7.56,
      "text": "で優位な人材確保のための環境整備及び"
    },
    {
      "start": 438.639,
      "duration": 7.0,
      "text": "主権者教育や男女共同三角の推進について"
    },
    {
      "start": 442.0,
      "duration": 7.52,
      "text": "は大いに賛同するところですしかしながら"
    },
    {
      "start": 445.639,
      "duration": 7.721,
      "text": "議員の厚生年金の加入については事業主は"
    },
    {
      "start": 449.52,
      "duration": 8.16,
      "text": "体市民であり地方財政措置は国民負担と"
    },
    {
      "start": 453.36,
      "duration": 8.0,
      "text": "なります旧地方議会議員年金制度の負担が"
    },
    {
      "start": 457.68,
      "duration": 7.28,
      "text": "続いている中で新たな公費負担に対する"
    },
    {
      "start": 461.36,
      "duration": 7.44,
      "text": "住民の理解が得られているとは言えず賛成"
    },
    {
      "start": 464.96,
      "duration": 8.0,
      "text": "することはできません2011年の地方"
    },
    {
      "start": 468.8,
      "duration": 8.16,
      "text": "議会議員年金制度の廃止にあたり東京生活"
    },
    {
      "start": 472.96,
      "duration": 8.32,
      "text": "者ネットワークは財政破綻による制度廃止"
    },
    {
      "start": 476.96,
      "duration": 9.079,
      "text": "に対し多額の公費投入の是正を求めるとと"
    },
    {
      "start": 481.28,
      "duration": 9.08,
      "text": "と同時に年金の一元化など公的年金の抜本"
    },
    {
      "start": 486.039,
      "duration": 7.72,
      "text": "改正を主張してきました地方議員が退職後"
    },
    {
      "start": 490.36,
      "duration": 7.119,
      "text": "の年金に不安を抱えそのことが担い手不足"
    },
    {
      "start": 493.759,
      "duration": 7.44,
      "text": "になっているとの主張に関してはそもそも"
    },
    {
      "start": 497.479,
      "duration": 7.921,
      "text": "急場に至るような公的年金制度そのものが"
    },
    {
      "start": 501.199,
      "duration": 8.641,
      "text": "問題であり国民年金だけではとても老後の"
    },
    {
      "start": 505.4,
      "duration": 8.6,
      "text": "安心にはなり得ずまた暮らしの不安は議員"
    },
    {
      "start": 509.84,
      "duration": 7.92,
      "text": "だけの問題ではありません少子高齢化社会"
    },
    {
      "start": 514.0,
      "duration": 6.959,
      "text": "において公的年金制度の抜本改正に"
    },
    {
      "start": 517.76,
      "duration": 6.04,
      "text": "取り組むことが必要でありそれこそが議会"
    },
    {
      "start": 520.959,
      "duration": 7.281,
      "text": "の果たすべき責任だと考え"
    },
    {
      "start": 523.8,
      "duration": 9.76,
      "text": "ます多様で優位な地方議員を増やすために"
    },
    {
      "start": 528.24,
      "duration": 8.96,
      "text": "は改めて議会の役割とは何かまた議員は"
    },
    {
      "start": 533.56,
      "duration": 9.12,
      "text": "どうあるべきかについて地方自治を担う"
    },
    {
      "start": 537.2,
      "duration": 9.48,
      "text": "二元代表性の一億を担う議会の役割として"
    },
    {
      "start": 542.68,
      "duration": 7.399,
      "text": "報酬等も含め批判を恐れず市民とともに"
    },
    {
      "start": 546.68,
      "duration": 7.12,
      "text": "根本から議論する必要があると考え"
    },
    {
      "start": 550.079,
      "duration": 6.961,
      "text": "ますライフステージの一時期政治に参画"
    },
    {
      "start": 553.8,
      "duration": 6.52,
      "text": "することが有意義であると思える社会を"
    },
    {
      "start": 557.04,
      "duration": 7.56,
      "text": "目指すことを表明しえ生活者ネットワーク"
    },
    {
      "start": 560.32,
      "duration": 4.28,
      "text": "の反対討論とします"
    },
    {
      "start": 573.399,
      "duration": 7.321,
      "text": "次に本件に反対のものの発言を許可します"
    },
    {
      "start": 577.399,
      "duration": 3.321,
      "text": "8番酒井越子"
    },
    {
      "start": 590.839,
      "duration": 7.201,
      "text": "議員"
    },
    {
      "start": 592.56,
      "duration": 9.92,
      "text": "はいはい議員案第48号多様な人材の地方"
    },
    {
      "start": 598.04,
      "duration": 8.919,
      "text": "議会へのを求める意見書に反対の立場から"
    },
    {
      "start": 602.48,
      "duration": 8.56,
      "text": "討論しますまず本意見書には最近の地方"
    },
    {
      "start": 606.959,
      "duration": 7.681,
      "text": "選挙において議員の成りて不足が申告化し"
    },
    {
      "start": 611.04,
      "duration": 7.0,
      "text": "ているとあります議員の成りて不足が不足"
    },
    {
      "start": 614.64,
      "duration": 7.72,
      "text": "している体議会はありますが小金思議会の"
    },
    {
      "start": 618.04,
      "duration": 9.039,
      "text": "実情とは異なります小金市議会議員定数"
    },
    {
      "start": 622.36,
      "duration": 10.24,
      "text": "24に対する立補者数は2021年は36"
    },
    {
      "start": 627.079,
      "duration": 9.361,
      "text": "人2017年は30人2013年は35人"
    },
    {
      "start": 632.6,
      "duration": 9.08,
      "text": "2009年は28人2005年は34人"
    },
    {
      "start": 636.44,
      "duration": 9.12,
      "text": "2001人は年は30人1997年は35"
    },
    {
      "start": 641.68,
      "duration": 7.88,
      "text": "人でした定数を上回る立補者数が続いて"
    },
    {
      "start": 645.56,
      "duration": 7.64,
      "text": "おり小金市議会議員の成りて不足が申告化"
    },
    {
      "start": 649.56,
      "duration": 7.279,
      "text": "しているとは言えないのは明白です地方自"
    },
    {
      "start": 653.2,
      "duration": 6.52,
      "text": "法では議会は当該地方公共団体の公益に"
    },
    {
      "start": 656.839,
      "duration": 5.921,
      "text": "関することについて意見書を提出すること"
    },
    {
      "start": 659.72,
      "duration": 6.4,
      "text": "ができると定めていますが小金市議会議員"
    },
    {
      "start": 662.76,
      "duration": 6.48,
      "text": "選挙には当てはまらない最近の地方選挙を"
    },
    {
      "start": 666.12,
      "duration": 6.56,
      "text": "前提とした意見書には疑問があり"
    },
    {
      "start": 669.24,
      "duration": 8.24,
      "text": "ます続いて本議案に反対する理由を述べ"
    },
    {
      "start": 672.68,
      "duration": 8.56,
      "text": "ます本議案では現在国民年金の非保険者で"
    },
    {
      "start": 677.48,
      "duration": 7.28,
      "text": "ある地方議会議員を厚生年金に加入させる"
    },
    {
      "start": 681.24,
      "duration": 7.399,
      "text": "ことを早急に実現することを強く求めて"
    },
    {
      "start": 684.76,
      "duration": 8.44,
      "text": "いる点に反対ですその理由を2点述べます"
    },
    {
      "start": 688.639,
      "duration": 8.801,
      "text": "反対第1の理由です年金制度は国民全体の"
    },
    {
      "start": 693.2,
      "duration": 7.56,
      "text": "課題であり地方機会議員の年金問題だけを"
    },
    {
      "start": 697.44,
      "duration": 7.68,
      "text": "法改正してまで優先するものではないから"
    },
    {
      "start": 700.76,
      "duration": 8.36,
      "text": "です厚生年金保険の非保険者は厚生年金"
    },
    {
      "start": 705.12,
      "duration": 7.719,
      "text": "保険の適用を受ける会社に勤務する70歳"
    },
    {
      "start": 709.12,
      "duration": 6.839,
      "text": "未満で加入条件を満たしている方です"
    },
    {
      "start": 712.839,
      "duration": 7.24,
      "text": "つまり費用者であることが要件とされてい"
    },
    {
      "start": 715.959,
      "duration": 7.361,
