      "text": "求め"
    },
    {
      "start": 1398.0,
      "duration": 7.799,
      "text": "ます"
    },
    {
      "start": 1400.679,
      "duration": 10.081,
      "text": "はいはいはい起立起立"
    },
    {
      "start": 1405.799,
      "duration": 8.12,
      "text": "少数本件は秘訣と決定いたしましたお諮り"
    },
    {
      "start": 1410.76,
      "duration": 7.08,
      "text": "しますお手元にご配布してあります通り"
    },
    {
      "start": 1413.919,
      "duration": 6.88,
      "text": "追加日程第1及び追加日程第2の2件を"
    },
    {
      "start": 1417.84,
      "duration": 6.12,
      "text": "日程に追加し順次議題としますこれにご"
    },
    {
      "start": 1420.799,
      "duration": 7.281,
      "text": "異議ありませんかご異議なしと認め追加"
    },
    {
      "start": 1423.96,
      "duration": 7.76,
      "text": "日程第1及び追加日程第2の2件を日程に"
    },
    {
      "start": 1428.08,
      "duration": 7.719,
      "text": "追加し順次議題とすることを決定しました"
    },
    {
      "start": 1431.72,
      "duration": 7.48,
      "text": "追加日程第1閉会中継続審査案件を議題と"
    },
    {
      "start": 1435.799,
      "duration": 7.081,
      "text": "いたします各常任委員会委員長議会運営"
    },
    {
      "start": 1439.2,
      "duration": 7.4,
      "text": "委員会委員長及び各特別委員会委員長から"
    },
    {
      "start": 1442.88,
      "duration": 8.039,
      "text": "委員会において審査調査中の事件につき"
    },
    {
      "start": 1446.6,
      "duration": 7.959,
