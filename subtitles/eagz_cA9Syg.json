    {
      "start": 1489.48,
      "duration": 6.76,
      "text": "た場合は議長にごご一任いただくことにご"
    },
    {
      "start": 1493.2,
      "duration": 6.56,
      "text": "異議ありませんかご異議なしと認めただ今"
    },
    {
      "start": 1496.24,
      "duration": 7.6,
      "text": "申し上げました通り行うと決定いたしまし"
    },
    {
      "start": 1499.76,
      "duration": 8.039,
      "text": "た重ねてお諮りしますなお閉会中に議員"
    },
    {
      "start": 1503.84,
