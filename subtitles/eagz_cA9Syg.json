    {
      "start": 1461.4,
      "duration": 7.32,
      "text": "認め閉会中継続審査案件一覧表の通り継続"
    },
    {
      "start": 1465.679,
      "duration": 6.12,
      "text": "審査とすることと決定いたしました追加"
    },
    {
      "start": 1468.72,
      "duration": 6.079,
      "text": "日程第2議員の派遣についてを議題と"
    },
    {
      "start": 1471.799,
      "duration": 7.12,
      "text": "いたしますお諮りします地方自治法第"
    },
    {
      "start": 1474.799,
      "duration": 7.561,
      "text": "100条第13項及び会議規則第120条"
    },
    {
      "start": 1478.919,
      "duration": 6.961,
      "text": "の規定に基づきお手元に配布しました議員"
    },
    {
      "start": 1482.36,
      "duration": 7.12,
      "text": "の派遣についての通り閉会中に議員派遣を"
