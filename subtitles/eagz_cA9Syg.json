      "text": "派遣を行う必要が生じた場合その日次場所"
    },
    {
      "start": 1507.799,
      "duration": 6.921,
      "text": "目的及び派遣議員名等については議長にご"
    },
    {
      "start": 1511.88,
      "duration": 5.159,
      "text": "一任いただくことにご異議ありませんかご"
    },
    {
      "start": 1514.72,
      "duration": 6.52,
      "text": "異議なしと認めただいま申し上げました"
    },
    {
      "start": 1517.039,
      "duration": 7.24,
      "text": "通り行うことと決定いたしました以上で今"
    },
    {
      "start": 1521.24,
