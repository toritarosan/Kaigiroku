{
  "entries": [
    {
      "start": 110.2,
      "duration": 7.519,
      "text": "ますかそれではお集まりですので始めて"
    },
    {
      "start": 113.56,
      "duration": 7.879,
      "text": "よろしいでしょうかはいじゃえはいはい"
    },
    {
      "start": 117.719,
      "duration": 3.72,
      "text": "じゃあ行きましょう"
    },
    {
      "start": 122.6,
      "duration": 7.439,
      "text": "ただ今から予算特別委員会の会議を開き"
    },
    {
      "start": 125.399,
      "duration": 8.361,
      "text": "ます本日は年長の私が委員長がご選される"
    },
    {
      "start": 130.039,
      "duration": 6.92,
      "text": "まで委員長の職務を行います直に議題に"
    },
    {
      "start": 133.76,
      "duration": 6.0,
      "text": "入ります議題は当委員会の委員長の護選に"
    },
    {
      "start": 136.959,
      "duration": 5.761,
      "text": "ついてであります護選の方法については"
    },
    {
      "start": 139.76,
      "duration": 8.08,
      "text": "いかがいたしましょうかどなたか選出方法"
    },
    {
      "start": 142.72,
      "duration": 6.12,
      "text": "についてご意見ありませんかはい議名でお"
    },
    {
      "start": 147.84,
      "duration": 4.64,
      "text": "願いし"
    },
    {
      "start": 148.84,
      "duration": 6.679,
      "text": "ます出方法について指名推薦によるとのご"
    },
    {
      "start": 152.48,
      "duration": 6.039,
      "text": "意見がありますがありますが指名推薦に"
    },
    {
      "start": 155.519,
      "duration": 5.72,
      "text": "より決定することにご異議ありませんかご"
    },
    {
      "start": 158.519,
      "duration": 5.761,
      "text": "異議なしと認めただいま申し上げました"
    },
    {
      "start": 161.239,
      "duration": 7.64,
      "text": "通り決定いたしますどなたかご推薦"
    },
    {
      "start": 164.28,
      "duration": 7.52,
      "text": "いただけますか田議員はいえっとま建設"
    },
    {
      "start": 168.879,
      "duration": 5.44,
      "text": "環境委員会で長く2年間一緒にやらせて"
    },
    {
      "start": 171.8,
      "duration": 5.32,
      "text": "もらってましてま委員長の職務をですね"
    },
    {
      "start": 174.319,
      "duration": 5.28,
      "text": "しっかりやってるところを1番間近で見て"
    },
    {
      "start": 177.12,
      "duration": 6.56,
      "text": "きましたえ予算の委員長にも適任だと思い"
    },
    {
      "start": 179.599,
      "duration": 9.72,
      "text": "ますえさんをえ推薦し"
    },
    {
      "start": 183.68,
      "duration": 9.279,
      "text": "ますただいま古畑俊男委員を委員長にとの"
    },
    {
      "start": 189.319,
      "duration": 6.521,
      "text": "推薦がございましたお諮りいたします古畑"
    },
    {
      "start": 192.959,
      "duration": 6.481,
      "text": "俊男委員を委員長に選出することにご異議"
    },
    {
      "start": 195.84,
      "duration": 6.319,
      "text": "ありませんかご異議なしと認めます従って"
    },
    {
      "start": 199.44,
      "duration": 5.76,
      "text": "ただいま指名いたしました通り選出する"
    },
    {
      "start": 202.159,
      "duration": 6.841,
      "text": "ことに決定をいたしましたただいま委員長"
    },
    {
      "start": 205.2,
      "duration": 6.56,
      "text": "に選出されました古畑俊委員のご挨拶をお"
    },
    {
      "start": 209.0,
      "duration": 2.76,
      "text": "願いいたします"
    },
    {
      "start": 213.4,
      "duration": 9.199,
      "text": "え大変なあの席をせりまして誠にありがと"
    },
    {
      "start": 217.92,
      "duration": 7.239,
      "text": "ございますえ第6回補正ということでえ"
    },
    {
      "start": 222.599,
      "duration": 7.681,
      "text": "非常に盛たくさんではございますけれども"
    },
    {
      "start": 225.159,
      "duration": 7.0,
      "text": "え円滑なえ技術進行とえ公平構成に務めて"
    },
    {
      "start": 230.28,
      "duration": 4.4,
      "text": "いきたいと参りますのでどうぞよろしくお"
    },
    {
      "start": 232.159,
      "duration": 2.521,
      "text": "願いいたし"
    },
    {
      "start": 234.76,
      "duration": 10.039,
      "text": "ますこれで私の職務は終了いしました委た"
    },
    {
      "start": 240.439,
      "duration": 4.36,
      "text": "しばらく休憩いたします"
    },
    {
      "start": 289.759,
      "duration": 7.44,
      "text": "再開いたしますこれから副委員長のご選を"
    },
    {
      "start": 293.639,
      "duration": 6.521,
      "text": "行います選の方法についてはいかがいたし"
    },
    {
      "start": 297.199,
      "duration": 7.081,
      "text": "ましょうかどなたか選出方法につい"
    },
    {
      "start": 300.16,
      "duration": 8.16,
      "text": "ご意見がありますか渡辺"
    },
    {
      "start": 304.28,
      "duration": 6.24,
      "text": "委員はいあ委員会委員会ですかはい指名"
    },
    {
      "start": 308.32,
      "duration": 6.64,
      "text": "推薦でお願いし"
    },
    {
      "start": 310.52,
      "duration": 7.679,
      "text": "ますただいま選出方法について指名推薦に"
    },
    {
      "start": 314.96,
      "duration": 7.12,
      "text": "よるとのご意見がありますが指名推薦に"
    },
    {
      "start": 318.199,
      "duration": 7.12,
      "text": "よる指名推薦により決定することにご異議"
    },
    {
      "start": 322.08,
      "duration": 6.239,
      "text": "ありませんかご異なしと認めただいま"
    },
    {
      "start": 325.319,
      "duration": 5.121,
      "text": "申し上げた通り決定いたしますどなたか"
    },
    {
      "start": 328.319,
      "duration": 3.401,
      "text": "推薦いただけますか"
    },
    {
      "start": 330.44,
      "duration": 4.64,
      "text": "渡辺"
    },
    {
      "start": 331.72,
      "duration": 7.36,
      "text": "委員はいえそれではあの若手新人であり"
    },
    {
      "start": 335.08,
      "duration": 9.6,
      "text": "ながら小金を担う逸材だと信頼をしており"
    },
    {
      "start": 339.08,
      "duration": 9.959,
      "text": "ますえ河野浅委もえ推薦させていただき"
    },
    {
      "start": 344.68,
      "duration": 8.079,
      "text": "ますただいま河野浅見委員を副委員長にと"
    },
    {
      "start": 349.039,
      "duration": 7.361,
      "text": "の推薦がございましたお諮りいたします"
    },
    {
      "start": 352.759,
      "duration": 7.121,
      "text": "河野浅委員を副委員長に選出することにご"
    },
    {
      "start": 356.4,
      "duration": 6.6,
      "text": "異議ありませんかご異議なしと認めます"
    },
    {
      "start": 359.88,
      "duration": 6.039,
      "text": "従ってただいま指名いたしました通り選出"
    },
    {
      "start": 363.0,
      "duration": 7.44,
      "text": "することに決定いたしましたただいま副"
    },
    {
      "start": 365.919,
      "duration": 9.081,
      "text": "委員長に選出された川のすいません河野浅"
    },
    {
      "start": 370.44,
      "duration": 8.36,
      "text": "委員のご挨拶をお願いいたしますはいはい"
    },
    {
      "start": 375.0,
      "duration": 6.84,
      "text": "え大変過分すぎるお言葉を頂戴いたしまし"
    },
    {
      "start": 378.8,
      "duration": 5.44,
      "text": "て大変恐縮しておりますえ先ほどのですね"
    },
    {
      "start": 381.84,
      "duration": 6.32,
      "text": "質疑を聞いておりましても今回の生予さん"
    },
    {
      "start": 384.24,
      "duration": 7.079,
      "text": "なかなか重要な案件が多く多いなと感じて"
    },
    {
      "start": 388.16,
      "duration": 6.439,
      "text": "いるところですでもですね私もですね当選"
    },
    {
      "start": 391.319,
      "duration": 5.561,
      "text": "1期目の新人でございますこちらに"
    },
    {
      "start": 394.599,
      "duration": 8.081,
      "text": "いらっしゃいますですねベテランの大先輩"
    },
    {
      "start": 396.88,
      "duration": 9.0,
      "text": "方にはあのスムーズな疑似の議事の運営に"
    },
    {
      "start": 402.68,
      "duration": 5.359,
      "text": "ですねあのご協力いただけますようにお"
    },
    {
      "start": 405.88,
      "duration": 3.84,
      "text": "願い申し上げて私自身もしっかりと頑張っ"
    },
    {
      "start": 408.039,
      "duration": 3.921,
      "text": "てまいりますのでどうぞよろしくお願い"
    },
    {
      "start": 409.72,
      "duration": 2.24,
      "text": "いたし"
    },
    {
      "start": 412.0,
      "duration": 6.24,
      "text": "ます以上で予算特別委員会の会議を終了"
    },
    {
      "start": 416.039,
      "duration": 5.961,
      "text": "いたしますご苦労様でし"
    },
    {
      "start": 418.24,
      "duration": 3.76,
      "text": "たはい大丈夫"
    }
  ]
}