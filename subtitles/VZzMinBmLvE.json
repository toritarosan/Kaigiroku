{
  "entries": [
    {
      "start": 62.48,
      "duration": 4.84,
      "text": "はいじゃああの全員お揃いのようでござい"
    },
    {
      "start": 64.96,
      "duration": 4.56,
      "text": "ますのであのちょっと早いですけど始め"
    },
    {
      "start": 67.32,
      "duration": 5.2,
      "text": "ちゃってよろしいですかねはい"
    },
    {
      "start": 69.52,
      "duration": 3.0,
      "text": "はい"
    },
    {
      "start": 74.36,
      "duration": 7.04,
      "text": "はい再開いたします休憩前に引き続き質疑"
    },
    {
      "start": 77.52,
      "duration": 9.44,
      "text": "を行いますはい浦淳"
    },
    {
      "start": 81.4,
      "duration": 10.52,
      "text": "さんはいえっとですねえ今あの午前中陳情"
    },
    {
      "start": 86.96,
      "duration": 4.96,
      "text": "者の陳述も伺いまして"
    },
    {
      "start": 92.36,
      "duration": 9.759,
      "text": "数ありますんでえままとめてと"
    },
    {
      "start": 97.28,
      "duration": 6.36,
      "text": "いう形でえ質疑をしたいと思いますえっと"
    },
    {
      "start": 102.119,
      "duration": 6.081,
      "text": "ですね"
    },
    {
      "start": 103.64,
      "duration": 8.6,
      "text": "えま大きくはまえっと2つあるのかなと"
    },
    {
      "start": 108.2,
      "duration": 8.72,
      "text": "思ってましてまあの今回あの報告の方で"
    },
    {
      "start": 112.24,
      "duration": 10.12,
      "text": "ですねえ入札が不調になったというご報告"
    },
    {
      "start": 116.92,
      "duration": 8.799,
      "text": "でしたでまではなかなかあ"
    },
    {
      "start": 122.36,
      "duration": 5.679,
      "text": "その触れられないというか多分ご答弁え"
    },
    {
      "start": 125.719,
      "duration": 6.561,
      "text": "なかなかできないのかなと思ってるこう"
    },
    {
      "start": 128.039,
      "duration": 9.881,
      "text": "いう状況でございますでその不調に至った"
    },
    {
      "start": 132.28,
      "duration": 9.2,
      "text": "その原因と分析っていうのはあましっかり"
    },
    {
      "start": 137.92,
      "duration": 6.64,
      "text": "やっていただいてえま一旦冷戦になって"
    },
    {
      "start": 141.48,
      "duration": 6.92,
      "text": "ですねえしっかりやっていただいてまあの"
    },
    {
      "start": 144.56,
      "duration": 7.6,
      "text": "その大体1ヶ月ぐらいというその期間は出"
    },
    {
      "start": 148.4,
      "duration": 8.44,
      "text": "てますけもをあのねえゆっくりゆっくり"
    },
    {
      "start": 152.16,
      "duration": 7.439,
      "text": "やっててもおその良くないとあまり多くの"
    },
    {
      "start": 156.84,
      "duration": 5.16,
      "text": "時間をかけるのもあれだし接続もダメだし"
    },
    {
      "start": 159.599,
      "duration": 5.36,
      "text": "ということでまそこら辺の部分というのは"
    },
    {
      "start": 162.0,
      "duration": 5.519,
      "text": "ああの是非あの行政に私どもってなかなか"
    },
    {
      "start": 164.959,
      "duration": 6.841,
      "text": "これタッチできない部分でもありますんで"
    },
    {
      "start": 167.519,
      "duration": 6.64,
      "text": "あの是非あのえよろしくお願いしますと"
    },
    {
      "start": 171.8,
      "duration": 8.32,
      "text": "いうことでまずえ一言申し上げたいと思い"
    },
    {
      "start": 174.159,
      "duration": 11.281,
      "text": "ますでえその上でですねえっとえこの7"
    },
    {
      "start": 180.12,
      "duration": 10.679,
      "text": "陳情第9号でございますえこのVEの提案"
    },
    {
      "start": 185.44,
      "duration": 11.079,
      "text": "及びその範囲とまえ広告の実施時期期限え"
    },
    {
      "start": 190.799,
      "duration": 9.601,
      "text": "等のま話ででこれがですねえっとおまご"
    },
    {
      "start": 196.519,
      "duration": 9.321,
      "text": "提案をいただいてるというようなあ感じで"
    },
    {
      "start": 200.4,
      "duration": 9.36,
      "text": "ございますでえっとなかなかじゃあここの"
    },
    {
      "start": 205.84,
      "duration": 8.0,
      "text": "ご提案いただいてるものをですねえじゃあ"
    },
    {
      "start": 209.76,
      "duration": 7.28,
      "text": "あいかがですかと言ったところで多分今"
    },
    {
      "start": 213.84,
      "duration": 6.679,
      "text": "その詳細についてはお答ええできないのか"
    },
    {
      "start": 217.04,
      "duration": 5.04,
      "text": "なと今の流れだとねで思ってましてで"
    },
    {
      "start": 220.519,
      "duration": 6.841,
      "text": "えっと"
    },
    {
      "start": 222.08,
      "duration": 8.76,
      "text": "このえ陳情がですねえっとま出されたのが"
    },
    {
      "start": 227.36,
      "duration": 5.56,
      "text": "1月の末ということでまこの時期だっっ"
    },
    {
      "start": 230.84,
      "duration": 4.959,
      "text": "たらまだなんか色々できたのかなと思った"
    },
    {
      "start": 232.92,
      "duration": 6.599,
      "text": "今日この時点に至ってはえ先ほど言った今"
    },
    {
      "start": 235.799,
      "duration": 7.681,
      "text": "え入札上でこれからまた再広告をすると"
    },
    {
      "start": 239.519,
      "duration": 6.841,
      "text": "いういう段階においてですねえまえこう"
    },
    {
      "start": 243.48,
      "duration": 9.759,
      "text": "その答弁しづらい状況になっているのかな"
    },
    {
      "start": 246.36,
      "duration": 12.52,
      "text": "ということでございますでえ私はここのこ"
    },
    {
      "start": 253.239,
      "duration": 9.281,
      "text": "ま調査をするにあたってえっとま例えば"
    },
    {
      "start": 258.88,
      "duration": 9.72,
      "text": "同じようなその経験をしているま庁舎なり"
    },
    {
      "start": 262.52,
      "duration": 8.48,
      "text": "え大きなその公共事業のそのえリカバリー"
    },
    {
      "start": 268.6,
      "duration": 8.68,
      "text": "をどのようどのような形でやってったかと"
    },
    {
      "start": 271.0,
      "duration": 10.6,
      "text": "いうことであのえこのVEの提案の範囲を"
    },
    {
      "start": 277.28,
      "duration": 8.44,
      "text": "こうなんあの色々こう変更してえやってた"
    },
    {
      "start": 281.6,
      "duration": 8.76,
      "text": "経緯があるのかどうかまあの近隣のその"
    },
    {
      "start": 285.72,
      "duration": 7.28,
      "text": "状況とかえを色々調査をました上でですね"
    },
    {
      "start": 290.36,
      "duration": 5.24,
      "text": "えこの答えっていうのは出していきたいと"
    },
    {
      "start": 293.0,
      "duration": 4.919,
      "text": "思うんですけどもうあのこの時点なんで"
    },
    {
      "start": 295.6,
      "duration": 5.84,
      "text": "えっと資要求とかできませんもんねでき"
    },
    {
      "start": 297.919,
      "duration": 7.361,
      "text": "ないですねすいませんえっとまそうなん"
    },
    {
      "start": 301.44,
      "duration": 8.72,
      "text": "ですよねでえっとそれでねえっとこの今の"
    },
    {
      "start": 305.28,
      "duration": 9.32,
      "text": "タイミングでそう今のタイミングでまこれ"
    },
    {
      "start": 310.16,
      "duration": 9.36,
      "text": "をねえまあのこのえ提案されてるこの陳情"
    },
    {
      "start": 314.6,
      "duration": 7.08,
      "text": "者の方はあの建設業の方とまあのご自身で"
    },
    {
      "start": 319.52,
      "duration": 5.32,
      "text": "ま表明されてますんで多分あのこれは言っ"
    },
    {
      "start": 321.68,
      "duration": 7.2,
      "text": "て大丈夫だと思いますけどもえっとまその"
    },
    {
      "start": 324.84,
      "duration": 7.24,
      "text": "方がもしかしたらいわゆるあのそのえ入札"
    },
    {
      "start": 328.88,
      "duration": 6.56,
      "text": "のその参加当事者になる可能性もなくは"
    },
    {
      "start": 332.08,
      "duration": 6.52,
      "text": "ないわけですよねでえっとそれでえその"
    },
    {
      "start": 335.44,
      "duration": 6.68,
      "text": "提案を受けて私どもがこれこのタイミング"
    },
    {
      "start": 338.6,
      "duration": 6.2,
      "text": "でえまそれがいいとか悪いとか僕は"
    },
    {
      "start": 342.12,
      "duration": 6.079,
      "text": "ちょっと調査しないとそこら辺は"
    },
    {
      "start": 344.8,
      "duration": 5.76,
      "text": "おいなかなか判断できないかなという風に"
    },
    {
      "start": 348.199,
      "duration": 5.321,
      "text": "は思ってますけれどもま丸とかバをこの"
    },
    {
      "start": 350.56,
      "duration": 6.24,
      "text": "タイミングでえするっていうのはまある"
    },
    {
      "start": 353.52,
      "duration": 7.28,
      "text": "意味そういうものに加担していくことにも"
    },
    {
      "start": 356.8,
      "duration": 8.72,
      "text": "なりかねないのかなという懸念をを一応"
    },
    {
      "start": 360.8,
      "duration": 8.2,
      "text": "持っておりますというまあことを表明して"
    },
    {
      "start": 365.52,
      "duration": 9.56,
      "text": "えおきますが一応あの部局についてはえ"
    },
    {
      "start": 369.0,
      "duration": 8.8,
      "text": "この中身にえついてえあのそのなんかえ"
    },
    {
      "start": 375.08,
      "duration": 4.48,
      "text": "どのどんなまこういう風に変えた時にどう"
    },
    {
      "start": 377.8,
      "duration": 4.08,
      "text": "いう影響が出る出ないとかそういうのも"
    },
    {
      "start": 379.56,
      "duration": 6.4,
      "text": "含めてなかなか詳細っというのはお答え"
    },
    {
      "start": 381.88,
      "duration": 7.879,
      "text": "できないえま状況であるかどうかっていう"
    },
    {
      "start": 385.96,
      "duration": 7.2,
      "text": "のを間の質問としてえ出したいと思います"
    },
    {
      "start": 389.759,
      "duration": 7.28,
      "text": "はい完ええももう1点"
    },
    {
      "start": 393.16,
      "duration": 9.319,
      "text": "あごめんごめんに忘れ"
    },
    {
      "start": 397.039,
      "duration": 10.681,
      "text": "ないうんでえっとまもう1点なんですけも"
    },
    {
      "start": 402.479,
      "duration": 7.961,
      "text": "あの今日そのいわゆるま見直し案えという"
    },
    {
      "start": 407.72,
      "duration": 7.0,
      "text": "ことでえ尋常者の方が"
    },
    {
      "start": 410.44,
      "duration": 9.28,
      "text": "るるご説明いただいたものというのはえま"
    },
    {
      "start": 414.72,
      "duration": 9.4,
      "text": "私の感覚ではあるんですけどもま実はえ"
    },
    {
      "start": 419.72,
      "duration": 8.28,
      "text": "小金行政が1番初めにこういう案はいかが"
    },
    {
      "start": 424.12,
      "duration": 7.4,
      "text": "ですかって出したこととと外に出るんです"
    },
    {
      "start": 428.0,
      "duration": 6.639,
      "text": "よね実はでえっと全部ではないと思います"
    },
    {
      "start": 431.52,
      "duration": 6.119,
      "text": "あのえ例えばLGとか多分あの陳情者の方"
    },
    {
      "start": 434.639,
      "duration": 5.24,
      "text": "目さないと思いますんでえっとそういう"
    },
    {
      "start": 437.639,
      "duration": 6.441,
      "text": "ところではなくてじゃあどこが酷似してる"
    },
    {
      "start": 439.879,
      "duration": 7.521,
      "text": "かというのはえまそうま面心が望ましいと"
    },
    {
      "start": 444.08,
      "duration": 8.64,
      "text": "多分表明されていたそん時のま認証か市長"
    },
    {
      "start": 447.4,
      "duration": 8.0,
      "text": "だだったですけもとあとえっと発注方式も"
    },
    {
      "start": 452.72,
      "duration": 6.039,
      "text": "最初はデザインビルドだったんですよねで"
    },
    {
      "start": 455.4,
      "duration": 6.32,
      "text": "えこの点はすごい酷似してるただじゃあ"
    },
    {
      "start": 458.759,
      "duration": 7.481,
      "text": "デザインビルドの件に対してはま初めて"
    },
    {
      "start": 461.72,
      "duration": 9.479,
      "text": "その基本設計え行え基本設計の業者の施工"
    },
    {
      "start": 466.24,
      "duration": 8.6,
      "text": "査先行とか色々物々のえ予算があ出たえ"
    },
    {
      "start": 471.199,
      "duration": 5.241,
      "text": "平成30年の第2回の定例会6月ですねで"
    },
    {
      "start": 474.84,
      "duration": 6.639,
      "text": "ここで"
    },
    {
      "start": 476.44,
      "duration": 8.039,
      "text": "えっとえ不決議えがあってですねでこの"
    },
    {
      "start": 481.479,
      "duration": 7.4,
      "text": "デザインビルドの発注方式をえ再検討しろ"
    },
    {
      "start": 484.479,
      "duration": 10.041,
      "text": "とでえっとそのえ議論の中では議会の方"
    },
    {
      "start": 488.879,
      "duration": 10.28,
      "text": "からえこのデザインビルドはあまある意味"
    },
    {
      "start": 494.52,
      "duration": 9.399,
      "text": "えその春行時期スケジュールありきの発注"
    },
    {
      "start": 499.159,
      "duration": 8.401,
      "text": "方式だとで透明性と競争性にかけるという"
    },
    {
      "start": 503.919,
      "duration": 8.48,
      "text": "ご意見があある議員の方からは出たと思い"
    },
    {
      "start": 507.56,
      "duration": 8.479,
      "text": "ますでえ多分あのそこをねえ猛反対して"
    },
    {
      "start": 512.399,
      "duration": 5.961,
      "text": "否定した人は多分ま議会の中ではあんまり"
    },
    {
      "start": 516.039,
      "duration": 6.401,
      "text": "いなかったと思うんですよねで"
    },
    {
      "start": 518.36,
      "duration": 8.44,
      "text": "えっと僕らその体決議には会派としては"
    },
    {
      "start": 522.44,
      "duration": 8.88,
      "text": "えっと反対はしまししたけどえっとまそれ"
    },
    {
      "start": 526.8,
      "duration": 9.599,
      "text": "がまあの2決議は過半数超えたのでまそれ"
    },
    {
      "start": 531.32,
      "duration": 10.0,
      "text": "が決議が通ってえそれをま市長は考えた上"
    },
    {
      "start": 536.399,
      "duration": 7.68,
      "text": "でえ個別発方式になってるとだこれは"
    },
    {
      "start": 541.32,
      "duration": 5.16,
      "text": "えっとどういう何を言いたいかっていうと"
    },
    {
      "start": 544.079,
      "duration": 5.601,
      "text": "これ別に行政が全部そういう風にやってき"
    },
    {
      "start": 546.48,
      "duration": 7.359,
      "text": "たわけじゃなくて議会だって関与してこう"
    },
    {
      "start": 549.68,
      "duration": 7.92,
      "text": "いう形に今なっているということですよね"
    },
    {
      "start": 553.839,
      "duration": 6.401,
      "text": "ということでこれ事実あのま僕がこれ自論"
    },
    {
      "start": 557.6,
      "duration": 5.64,
      "text": "てるだけだとあれなんでだここら辺の事実"
    },
    {
      "start": 560.24,
      "duration": 6.599,
      "text": "関係というかえっとそれはご答弁ください"
    },
    {
      "start": 563.24,
      "duration": 9.0,
      "text": "でもう1点えなんですけれども"
    },
    {
      "start": 566.839,
      "duration": 6.761,
      "text": "あとそのまシステムの話ですけれども"
    },
    {
      "start": 572.24,
      "duration": 6.64,
      "text": "えっと"
    },
    {
      "start": 573.6,
      "duration": 10.28,
      "text": "その1番最初はですねえま行政の方針はえ"
    },
    {
      "start": 578.88,
      "duration": 8.68,
      "text": "全てえ面心構造が望ましいということだっ"
    },
    {
      "start": 583.88,
      "duration": 6.639,
      "text": "たと思いますでえまだそれは決定はして"
    },
    {
      "start": 587.56,
      "duration": 7.36,
      "text": "なかったけれどもそのタイミングでえっと"
    },
    {
      "start": 590.519,
      "duration": 10.0,
      "text": "市民団体の方からあえっと要望書が出てえ"
    },
    {
      "start": 594.92,
      "duration": 12.72,
      "text": "おりましてえこれが平成えっと"
    },
    {
      "start": 600.519,
      "duration": 9.801,
      "text": "だ平成30年の何月かがちょっと思い出せ"
    },
    {
      "start": 607.64,
      "duration": 5.8,
      "text": "ないなあごめんなさいあ後でえ分かったら"
    },
    {
      "start": 610.32,
      "duration": 5.32,
      "text": "出ますえっとそれがですねえっといわゆる"
    },
    {
      "start": 613.44,
      "duration": 7.04,
      "text": "あの今回"
    },
    {
      "start": 615.64,
      "duration": 8.759,
      "text": "えっとえ住民投票条例のその証明活動され"
    },
    {
      "start": 620.48,
      "duration": 9.24,
      "text": "ていた市民団体さんとま一緒のとろからの"
    },
    {
      "start": 624.399,
      "duration": 5.321,
      "text": "要望書だったとでその中でえっと"
    },
    {
      "start": 630.76,
      "duration": 5.48,
      "text": "えっとまその要望書の中であのどんなこと"
    },
    {
      "start": 633.88,
      "duration": 6.959,
      "text": "が書かれてたかていうとこの耐震システム"
    },
    {
      "start": 636.24,
      "duration": 8.599,
      "text": "のえことに関してはですねえっと面心"
    },
    {
      "start": 640.839,
      "duration": 9.161,
      "text": "構造適用部分の宿元と書いてあるんですよ"
    },
    {
      "start": 644.839,
      "duration": 8.961,
      "text": "を求められているとでえっとまえっと議会"
    },
    {
      "start": 650.0,
      "duration": 7.2,
      "text": "の方も多分あのそういうこうまこれは"
    },
    {
      "start": 653.8,
      "duration": 4.44,
      "text": "申し入れだったかななんかこうええ"
    },
    {
      "start": 657.2,
      "duration": 4.72,
      "text": "いわゆる"
    },
    {
      "start": 658.24,
      "duration": 7.44,
