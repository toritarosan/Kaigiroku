      "start": 1180.52,
      "duration": 9.24,
      "text": "そのまいわゆるこの案になればもう絶対的"
    },
    {
      "start": 1185.0,
      "duration": 7.32,
      "text": "にえ大丈夫なんだというものっていうのは"
    },
    {
      "start": 1189.76,
      "duration": 5.72,
      "text": "まいわゆるこういうあの民主的な手続きを"
    },
    {
      "start": 1192.32,
      "duration": 6.96,
      "text": "やってる以上はですねえ僕はあの必ずしも"
    },
    {
      "start": 1195.48,
      "duration": 7.679,
      "text": "そういうものってえまないのかなと"
    },
    {
      "start": 1199.28,
      "duration": 8.399,
      "text": "いうのも思ってますのでえま例えばえっと"
    },
    {
      "start": 1203.159,
      "duration": 8.441,
      "text": "ま先ほどその近所者の方からえ私の案なら"
    },
    {
      "start": 1207.679,
      "duration": 6.921,
      "text": "必ず大殺があるとかですねえ今の現えその"
    },
    {
      "start": 1211.6,
      "duration": 9.079,
      "text": "設計業者以上のものを私は出せるとかです"
    },
    {
      "start": 1214.6,
      "duration": 8.72,
      "text": "ねまあのそういうことをねえまがえ本当に"
    },
    {
      "start": 1220.679,
      "duration": 5.321,
      "text": "そうそうなのかどうかっていうのはあのま"
    },
    {
      "start": 1223.32,
      "duration": 6.239,
      "text": "ご自身のご意見としてえ言われていると"
    },
    {
      "start": 1226.0,
      "duration": 7.84,
      "text": "いう形でま私はま受け止めてますという"
    },
    {
      "start": 1229.559,
      "duration": 7.641,
      "text": "ことでえまあのそれに基づいてえこの陳情"
    },
    {
      "start": 1233.84,
      "duration": 6.28,
      "text": "の審査もしていきたいなと思っております"
    },
    {
      "start": 1237.2,
      "duration": 6.32,
      "text": "え全部意見になりますけれども以上"
    },
    {
      "start": 1240.12,
      "duration": 5.76,
      "text": "です議事進行小林さんいいですかじゃ議事"
    },
    {
      "start": 1243.52,
      "duration": 5.8,
      "text": "進行森田さんあの最後の最後になってね"
    },
    {
      "start": 1245.88,
      "duration": 6.56,
      "text": "その2000え2000何年か18年"
    },
    {
      "start": 1249.32,
      "duration": 6.28,
      "text": "ぐらいのえ申し入れ市民の申し入れを出し"
    },
    {
      "start": 1252.44,
      "duration": 6.52,
      "text": "てきてですねあの言われるのは何なんだと"
    },
    {
      "start": 1255.6,
      "duration": 7.16,
      "text": "思いますねそれであの"
    },
    {
      "start": 1258.96,
      "duration": 7.68,
      "text": "そのことについてあのそのことも反映市の"
    },
    {
      "start": 1262.76,
      "duration": 9.32,
      "text": "政策に反映をしたのかという質疑に対して"
    },
    {
      "start": 1266.64,
      "duration": 7.76,
      "text": "あの係長さんかなの方からはあ主さんから"
    },
    {
      "start": 1272.08,
      "duration": 6.76,
      "text": "あのそれも反映したっていうことなんです"
    },
    {
      "start": 1274.4,
      "duration": 8.2,
      "text": "がそのじゃあ根拠は何ですか反映したと"
    },
    {
      "start": 1278.84,
      "duration": 6.64,
      "text": "いうねあの根拠って客観的にあるんですか"
    },
    {
      "start": 1282.6,
      "duration": 6.64,
      "text": "私たちにま私たちというかこの市民団体に"
    },
    {
      "start": 1285.48,
      "duration": 7.0,
      "text": "はですね1度も皆さんの意見をしました"
    },
    {
      "start": 1289.24,
      "duration": 6.48,
      "text": "なんていうね回答はないんですよねここ"
    },
    {
      "start": 1292.48,
      "duration": 5.76,
      "text": "だけ取り出してですね何かあたかも市民が"
    },
    {
      "start": 1295.72,
      "duration": 5.28,
      "text": "ねその要請したからやったんだみたいな"
    },
    {
      "start": 1298.24,
      "duration": 6.4,
      "text": "言い方っていうのは私は違うと思うんです"
    },
    {
      "start": 1301.0,
      "duration": 9.12,
      "text": "よねやっぱり最終的には議会が決めてる"
    },
    {
      "start": 1304.64,
      "duration": 11.0,
      "text": "わけですよそのあの今の現行のね福祉会館"
    },
    {
      "start": 1310.12,
      "duration": 8.2,
      "text": "があの耐震構造長者は面心構造っていうね"
    },
    {
      "start": 1315.64,
      "duration": 6.24,
      "text": "だからちょっとね先ほどそういう風に言わ"
    },
    {
      "start": 1318.32,
      "duration": 6.68,
      "text": "れですが反映したんだ反映したというね"
    },
    {
      "start": 1321.88,
      "duration": 4.76,
      "text": "会議録などを含めてですねあの提出して"
    },
    {
      "start": 1325.0,
      "duration": 4.24,
      "text": "いただきたいと思うんですちょっと待っ"
    },
    {
      "start": 1326.64,
      "duration": 6.84,
      "text": "じゃないとね終わらないですよ今日そんな"
    },
    {
      "start": 1329.24,
      "duration": 7.88,
      "text": "ね事実と違うことをねあの言われるのはね"
    },
    {
      "start": 1333.48,
      "duration": 6.6,
      "text": "私は本当に心外であのちょっと委員長ね"
    },
    {
      "start": 1337.12,
      "duration": 6.84,
      "text": "そこは整理していただきたいと思い"
    },
    {
      "start": 1340.08,
      "duration": 8.68,
      "text": "ますはいあのじゃ沖浦さんねえっとすい"
    },
    {
      "start": 1343.96,
      "duration": 7.24,
      "text": "ませんえっと私の発言の"
    },
    {
      "start": 1348.76,
      "duration": 5.399,
      "text": "をとらまえてその昔のことをいきなり今"
    },
    {
      "start": 1351.2,
      "duration": 4.92,
      "text": "言ってっていうま話なんですけど私昔から"
    },
    {
      "start": 1354.159,
      "duration": 4.481,
      "text": "これ言ってますんでまいつからとは言え"
    },
    {
      "start": 1356.12,
      "duration": 5.28,
      "text": "ないけど相当昔から言ってるんでそれは"
    },
    {
      "start": 1358.64,
      "duration": 5.039,
      "text": "えっとあの今日あのいきなり出したわけで"
    },
    {
      "start": 1361.4,
      "duration": 4.68,
      "text": "はございませんということでえそれはあの"
    },
    {
      "start": 1363.679,
      "duration": 6.24,
      "text": "お伝えしときたいと思いますはい議進行"
    },
    {
      "start": 1366.08,
      "duration": 6.0,
      "text": "渡辺大さんあのあのま委員長に整理お願い"
    },
    {
      "start": 1369.919,
      "duration": 4.24,
      "text": "するわけですけれどもあのきちんと公式"
    },
    {
      "start": 1372.08,
      "duration": 4.4,
      "text": "答弁で言われる以上はあのエビデンスに"
    },
    {
      "start": 1374.159,
      "duration": 4.561,
      "text": "関してはきちんと示してあのいただきたい"
    },
    {
      "start": 1376.48,
      "duration": 5.199,
      "text": "という風にあの思うんですねで当時のこと"
    },
    {
      "start": 1378.72,
      "duration": 5.92,
      "text": "を振り返ってみるとあの西岡全市長の元で"
    },
    {
      "start": 1381.679,
      "duration": 5.681,
      "text": "ですねま調査問題がかなり混乱をしていた"
    },
    {
      "start": 1384.64,
      "duration": 5.279,
      "text": "ということでま具体的にと日もさっちも"
    },
    {
      "start": 1387.36,
      "duration": 5.64,
      "text": "いかない状況になっている時に私の記憶に"
    },
    {
      "start": 1389.919,
      "duration": 6.12,
      "text": "間違いがなければ当時のあの自民党に所属"
    },
    {
      "start": 1393.0,
      "duration": 5.919,
      "text": "されていた市議会議員の方から一定の考え"
    },
    {
      "start": 1396.039,
      "duration": 4.961,
      "text": "方の案が示されれたんですねで私ま言って"
    },
    {
      "start": 1398.919,
      "duration": 5.0,
      "text": "みるとその時に示されたその自民党さんの"
    },
    {
      "start": 1401.0,
      "duration": 5.48,
      "text": "方から持ち込まれた案に関してそれがをゼ"
    },
    {
      "start": 1403.919,
      "duration": 4.601,
      "text": "とした私とか共産党さんはそれはゼとし"
    },
    {
      "start": 1406.48,
      "duration": 4.52,
      "text": "なかったんですがそれをゼとした議員が"
    },
    {
      "start": 1408.52,
      "duration": 5.159,
      "text": "多数になりそれを西岡市長に当時の市に"
    },
    {
      "start": 1411.0,
      "duration": 4.96,
      "text": "申し出たんですねでその申し出たをま具体"
    },
    {
      "start": 1413.679,
      "duration": 5.24,
      "text": "的に言えば西岡市長が全部そのままほぼ丸"
    },
    {
      "start": 1415.96,
      "duration": 5.56,
      "text": "のみしたのが実は今の現行案のベースは"
    },
    {
      "start": 1418.919,
      "duration": 4.681,
      "text": "そこにあるわけでしてそれから考えると"
    },
    {
      "start": 1421.52,
      "duration": 4.44,
      "text": "なんか市民団体の話を聞いたみたいなこと"
    },
    {
      "start": 1423.6,
      "duration": 4.079,
      "text": "言われると非常に和感があって市民団体の"
    },
    {
      "start": 1425.96,
      "duration": 3.76,
      "text": "方もきょとんとするんじゃないですか話は"
    },
    {
      "start": 1427.679,
      "duration": 5.24,
      "text": "聞いていただいたことはなかったなと自民"
    },
    {
      "start": 1429.72,
      "duration": 5.439,
      "text": "党さんが持ち出したあの案に関して当時の"
    },
    {
      "start": 1432.919,
      "duration": 4.521,
      "text": "西科市長が丸のみをして今のものが始まっ"
    },
    {
      "start": 1435.159,
      "duration": 4.841,
      "text": "ているというのが正しい歴史だったと"
    },
    {
      "start": 1437.44,
      "duration": 4.8,
      "text": "正しい歴史は止と読むんですがねあのだっ"
    },
    {
      "start": 1440.0,
      "duration": 3.679,
      "text": "たという風に思うのでちょっとねあの都合"
    },
    {
      "start": 1442.24,
      "duration": 3.039,
      "text": "のいいところだけもし言われるんだったら"
    },
    {
      "start": 1443.679,
      "duration": 4.281,
      "text": "ちょっとじゃあその今さっき森戸さんも"
    },
    {
      "start": 1445.279,
      "duration": 5.441,
      "text": "要求されましたけどちょっと疑似録とか公"
    },
    {
      "start": 1447.96,
      "duration": 4.68,
      "text": "文書で示してくださいよ市民団体から出し"
    },
    {
      "start": 1450.72,
      "duration": 3.959,
      "text": "たものに関してそのようにいたしますて公"
    },
    {
      "start": 1452.64,
      "duration": 4.039,
      "text": "文書あるんですかあれ疑似録あるんですか"
    },
    {
      "start": 1454.679,
      "duration": 4.441,
      "text": "ちゃんと出してくださいよエビデンスも"
    },
    {
      "start": 1456.679,
      "duration": 4.401,
      "text": "示さないでねあのそういうことをね答弁"
    },
    {
      "start": 1459.12,
      "duration": 4.439,
      "text": "及ばれるっての全くよくわからないですよ"
    },
    {
      "start": 1461.08,
      "duration": 4.599,
      "text": "ねあのその点はきちんとねあの1つ1つ"
    },
    {
      "start": 1463.559,
      "duration": 4.041,
      "text": "あのあの巨匠を求めていきますよ我々大事"
    },
    {
      "start": 1465.679,
      "duration": 3.801,
      "text": "なところだからそのでたらめなことを言わ"
    },
    {
      "start": 1467.6,
      "duration": 3.4,
      "text": "れないようにするとにもねあのちゃんと"
    },
    {
      "start": 1469.48,
      "duration": 3.72,
      "text": "あのあのエビデンス示していただくように"
    },
    {
      "start": 1471.0,
      "duration": 6.52,
      "text": "委長整理してくださいはいえっと技術進行"
    },
    {
      "start": 1473.2,
      "duration": 8.44,
      "text": "が今3人の方から出ましたであの企画政策"
    },
    {
      "start": 1477.52,
      "duration": 8.0,
      "text": "さの答弁の中で確か私の記憶の範囲では"
    },
    {
      "start": 1481.64,
      "duration": 7.039,
      "text": "そのあの沖浦委員の質問に対してその議会"
    },
    {
      "start": 1485.52,
      "duration": 5.96,
      "text": "からの声もあったしそのして市民団体の声"
    },
    {
      "start": 1488.679,
      "duration": 4.641,
      "text": "もあったみたいな両方並立させて答えられ"
    },
    {
      "start": 1491.48,
      "duration": 4.319,
      "text": "てるかなっていう風にはメモとして書い"
    },
    {
      "start": 1493.32,
      "duration": 4.76,
      "text": "てるんですけれどもそれら踏まえて"
    },
    {
      "start": 1495.799,
      "duration": 5.441,
      "text": "ちょっと補足ってありますかあので確かに"
    },
    {
      "start": 1498.08,
      "duration": 4.92,
      "text": "あのそのえこういったことがあったという"
    },
    {
      "start": 1501.24,
      "duration": 6.28,
      "text": "ようなことはある程度は説明した方がいい"
    },
    {
      "start": 1503.0,
      "duration": 7.399,
      "text": "のかなとそですよ2018年11"
    },
    {
      "start": 1507.52,
      "duration": 4.72,
      "text": "月自民党さんのは丸飲みしたんでしょだ"
    },
    {
      "start": 1510.399,
      "duration": 5.76,
      "text": "その前の話なんてだって聞いてなかった"
    },
    {
      "start": 1512.24,
      "duration": 7.08,
      "text": "じゃないそれはあまでも新行動を出現し"
    },
    {
      "start": 1516.159,
      "duration": 5.64,
      "text": "なさいよって話なんですそれはもう自民党"
    },
    {
      "start": 1519.32,
      "duration": 6.52,
      "text": "が出てきちゃってるから民党ちょっとま"
    },
    {
      "start": 1521.799,
      "duration": 4.041,
      "text": "あのおにいたれいです"
    },
    {
      "start": 1525.96,
      "duration": 6.24,
      "text": "かんで水さんわかんそいなかったじゃい"
    },
    {
      "start": 1529.24,
      "duration": 5.96,
      "text": "なかったじゃないいない人がんいない人が"
    },
    {
      "start": 1532.2,
      "duration": 6.24,
      "text": "んでわか説明してください規則発言でやん"
    },
    {
      "start": 1535.2,
      "duration": 7.68,
      "text": "ないでね局の方てってくださいどうですか"
    },
    {
      "start": 1538.44,
      "duration": 4.44,
      "text": "部局の方は的に説明して"
    },
    {
      "start": 1544.279,
      "duration": 5.041,
      "text": "くださいなんか取ってつけてさ市民団体が"
    },
    {
      "start": 1547.399,
      "duration": 5.52,
      "text": "いちょっとエビデンス示してください何月"
    },
    {
      "start": 1549.32,
      "duration": 5.32,
      "text": "何日付けの何だとか読だとか行ったのかて"
    },
    {
      "start": 1552.919,
      "duration": 4.041,
      "text": "いうことを言ってくださいそうでしょだっ"
    },
    {
      "start": 1554.64,
      "duration": 6.2,
      "text": "て自民さんのの丸みだったん"
    },
    {
      "start": 1556.96,
      "duration": 3.88,
      "text": "でしょなしてないじゃ"
    },
    {
      "start": 1561.44,
      "duration": 6.76,
      "text": "ないだあの時は西岡君から私はも何度も何"
    },
    {
      "start": 1565.279,
      "duration": 5.601,
      "text": "度も総面心にしてくれって頼まれたなんで"
    },
    {
      "start": 1568.2,
      "duration": 6.64,
      "text": "た勝なる視聴室に呼び出されてちょっと"
    },
    {
      "start": 1570.88,
      "duration": 5.56,
      "text": "あの身にするんだって説されたんだおて"
    },
    {
      "start": 1574.84,
      "duration": 3.36,
      "text": "くださいあのまだ休憩取ってないので休憩"
    },
    {
      "start": 1576.44,
      "duration": 3.4,
      "text": "取った方がいいですかどうですか休憩取り"
    },
    {
      "start": 1578.2,
      "duration": 5.199,
      "text": "ましょうかはいじゃあすいません休憩すみ"
    },
    {
      "start": 1579.84,
      "duration": 3.559,
      "text": "ますそう"
    }
  ]
}