      "start": 624.959,
      "duration": 5.601,
      "text": "を審査いたしましたので、その審査の概要"
    },
    {
      "start": 627.76,
      "duration": 7.96,
      "text": "と結果につきましてご報告申し上げます。"
    },
    {
      "start": 630.56,
      "duration": 9.839,
      "text": "なお7賃61号武蔵小金駅北口駅前東地区"
    },
    {
      "start": 635.72,
      "duration": 6.76,
      "text": "第1種市街地再開発事業計画に市民のため"
    },
    {
      "start": 640.399,
      "duration": 6.521,
      "text": "の公共フロアー設置を盛り込むことを"
    },
    {
      "start": 642.48,
      "duration": 8.359,
      "text": "求める賃常書及び7賃常第102号武蔵"
    },
    {
      "start": 646.92,
