    },
    {
      "start": 383.759,
      "duration": 8.521,
      "text": "状況報告は前回、え、令和7年第3回定例"
    },
    {
      "start": 388.88,
      "duration": 7.96,
      "text": "会報告後から、え、本年11月7日までに"
    },
    {
      "start": 392.28,
      "duration": 7.88,
