    },
    {
      "start": 526.56,
      "duration": 6.08,
      "text": "たのでその審査の概要と結果につきまして"
    },
    {
      "start": 529.44,
      "duration": 7.399,
      "text": "、え、ご報告申し上げます。え、なお7賃"
    },
    {
      "start": 532.64,
      "duration": 7.28,
      "text": "第23号市議会への、え、生願書及び賃常"
    },
    {
      "start": 536.839,
      "duration": 6.921,
      "text": "書に関してオンライン提出を可能とする"
    },
    {
      "start": 539.92,
      "duration": 6.68,
      "text": "ことを求める賃常書につきましては継続"
    },
    {
      "start": 543.76,
      "duration": 5.56,
      "text": "審査と、え、決定しております。え、また"
    },
    {
      "start": 546.6,
      "duration": 6.359,
