      "text": "と考えて"
    },
    {
      "start": 155.48,
      "duration": 7.399,
      "text": "よしでょか来年の9月以降と考えて"
    },
    {
      "start": 160.239,
      "duration": 2.64,
      "text": "よろしいでしょう"
    },
    {
      "start": 163.879,
