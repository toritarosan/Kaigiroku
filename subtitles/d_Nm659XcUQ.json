    },
    {
      "start": 241.2,
      "duration": 3.399,
      "text": "資格情報のお知らせ"
    },
    {
      "start": 249.959,
      "duration": 4.36,
      "text": "のコピーを提出するの"
    },
    {
      "start": 255.16,
      "duration": 12.56,
      "text": "かなのかそれで有効なのか伺います伺い"
    },
    {
      "start": 262.919,
      "duration": 8.881,
      "text": "ます以上です保険年金"
    },
    {
      "start": 267.72,
      "duration": 6.4,
      "text": "課長認の影響についてでございますがま"
    },
    {
      "start": 271.8,
      "duration": 6.88,
      "text": "あのご質問者おっしゃられた通り来年9月"
    },
    {
      "start": 274.12,
      "duration": 6.799,
      "text": "以降保険所の更新が変わりますのでえ資格"
    },
    {
      "start": 278.68,
      "duration": 4.799,
      "text": "確認書お送りさせていただくようなことに"
    },
    {
      "start": 280.919,
      "duration": 5.28,
      "text": "なるんですけれども先ほど説明させて"
    },
    {
      "start": 283.479,
      "duration": 5.801,
      "text": "いただいた通り12月2日以降につきまし"
    },
    {
      "start": 286.199,
      "duration": 6.0,
      "text": "てはえ新規の保険所の発行がなくなると"
    },
    {
      "start": 289.28,
      "duration": 5.56,
      "text": "いうような状況がございますのでえ影響が"
    },
    {
      "start": 292.199,
      "duration": 4.361,
      "text": "いつになるというのでなかなか9月以降か"
    },
    {
      "start": 294.84,
      "duration": 3.96,
      "text": "どうかというのはちょっと答弁としては"
    },
    {
      "start": 296.56,
      "duration": 3.96,
      "text": "難しいのかなというところでご理解"
    },
    {
      "start": 298.8,
      "duration": 3.839,
      "text": "いただきたいと思い"
    },
    {
      "start": 300.52,
      "duration": 4.76,
      "text": "それから学校行事の関係でございます"
    },
    {
      "start": 302.639,
      "duration": 5.161,
      "text": "けれどもこちらはある意味学校の判断と"
    },
    {
      "start": 305.28,
      "duration": 4.52,
      "text": "いうことになりますので私どもとして答弁"
    },
    {
      "start": 307.8,
      "duration": 3.88,
      "text": "が難しいということでご理解いただきたい"
    },
    {
      "start": 309.8,
      "duration": 6.399,
      "text": "と思います以上"
    },
    {
      "start": 311.68,
      "duration": 7.48,
      "text": "ですはい学校教育部長です学校教育部長え"
    },
    {
      "start": 316.199,
      "duration": 5.321,
      "text": "確かに現在にえ修学旅行等につきましては"
    },
    {
      "start": 319.16,
      "duration": 5.759,
      "text": "え保険証のコピー等を使っているとこで"
    },
    {
      "start": 321.52,
      "duration": 5.92,
      "text": "ございますがえ今後につきましてはえ各"
    },
    {
      "start": 324.919,
      "duration": 5.0,
      "text": "状況等調査しながらどうするか検討して"
    },
    {
      "start": 327.44,
      "duration": 4.84,
      "text": "いかなけばならないという風に検討すると"
    },
    {
      "start": 329.919,
      "duration": 2.361,
      "text": "でござい"
    },
    {
      "start": 333.6,
      "duration": 3.4,
      "text": "ます高木"
    },
    {
      "start": 346.72,
      "duration": 6.759,
      "text": "さんも目で"
    },
    {
      "start": 350.72,
      "duration": 10.199,
      "text": "い"
    },
    {
      "start": 353.479,
      "duration": 7.44,
      "text": "に本木案の3問目で1点確認いたしますほ"
    },
    {
      "start": 360.96,
      "duration": 4.079,
      "text": "の平"
    },
    {
      "start": 366.08,
      "duration": 4.44,
      "text": "に本木の提案にあたっ"
    },
    {
      "start": 379.52,
      "duration": 5.799,
      "text": "て具体的なことはまだ固まっていないと"
    },
    {
      "start": 382.8,
      "duration": 8.76,
      "text": "いうことでしょう"
    },
    {
      "start": 385.319,
      "duration": 6.241,
      "text": "かないいうこで"
    },
    {
      "start": 392.0,
      "duration": 5.949,
      "text": "固まっていないということであれ"
    },
    {
      "start": 394.56,
      "duration": 3.389,
      "text": "[音楽]"
    },
    {
      "start": 400.36,
      "duration": 6.6,
      "text": "ば2も目であげたことについ"
    },
    {
      "start": 403.8,
      "duration": 3.16,
      "text": "て2"
    },
    {
      "start": 407.28,
      "duration": 6.28,
      "text": "点2点で2点について"
    },
    {
      "start": 415.22,
      "duration": 11.18,
      "text": "[音楽]"
    },
    {
      "start": 420.08,
      "duration": 12.76,
      "text": "検討がさるのかいつ頃までにどのような"
    },
    {
      "start": 426.4,
      "duration": 7.479,
      "text": "検討がされるのか伺って終わります伺って"
    },
    {
      "start": 432.84,
      "duration": 5.4,
      "text": "終わり"
    },
    {
      "start": 433.879,
      "duration": 4.361,
      "text": "ます以上です"
    },
    {
      "start": 457.599,
      "duration": 6.761,
      "text": "国民健康保険係長です国民健康保険係長"
    },
    {
      "start": 461.56,
      "duration": 5.72,
      "text": "はいでは高議員のえっと3問目でござい"
    },
    {
      "start": 464.36,
      "duration": 4.839,
      "text": "ますえっとま具体的なことが固まってい"
    },
    {
      "start": 467.28,
      "duration": 5.72,
      "text": "ないかどうかというご指摘でございました"
    },
    {
      "start": 469.199,
      "duration": 7.201,
      "text": "けれどもま今後ま事務方としますとえっと"
    },
    {
      "start": 473.0,
      "duration": 5.639,
      "text": "まず12月の2日に向けてまそれ以降"
    },
    {
      "start": 476.4,
      "duration": 4.919,
      "text": "先ほど申し上げたような新規で加入され国"
    },
    {
      "start": 478.639,
      "duration": 4.761,
      "text": "に加入された方たちに向けてま資格確認書"
    },
    {
      "start": 481.319,
      "duration": 4.081,
      "text": "あるいはえっと資格情報通知書ですね"
    },
    {
      "start": 483.4,
      "duration": 4.639,
      "text": "こちらを発行するま準備をしてるところで"
    },
    {
      "start": 485.4,
      "duration": 5.56,
      "text": "ございましてま今後はこのえっと補正予算"
    },
    {
      "start": 488.039,
      "duration": 6.041,
