    },
    {
      "start": 113.6,
      "duration": 7.36,
      "text": "行いますさん高木さんはいはい高木さん"
    },
    {
      "start": 123.68,
      "duration": 3.52,
      "text": "2問目2点伺い"
    },
    {
      "start": 142.239,
      "duration": 7.761,
      "text": "ます1点目資格確認書の影響が具体的に"
    },
