{
  "entries": [
    {
      "start": 116.92,
      "duration": 6.72,
      "text": "再開します休憩中に議委員をしていますの"
    },
    {
      "start": 120.56,
      "duration": 5.68,
      "text": "で議会運委員長の報告を求めます3番岸田"
    },
    {
      "start": 123.64,
      "duration": 2.6,
      "text": "正委員"
    },
    {
      "start": 130.959,
      "duration": 5.121,
      "text": "長本日議会運営委員会を開催いたしました"
    },
    {
      "start": 134.239,
      "duration": 5.521,
      "text": "のでその結果につきましてご報告いたし"
    },
    {
      "start": 136.08,
      "duration": 7.879,
      "text": "ます市長から令和7年2月12日付けで"
    },
    {
      "start": 139.76,
      "duration": 8.44,
      "text": "議案第22号令和6年度小金市一般会計"
    },
    {
      "start": 143.959,
      "duration": 7.961,
      "text": "補正予算第9回かこ図がえ2月14日付け"
    },
    {
      "start": 148.2,
      "duration": 6.56,
      "text": "でえ視聴報告が送付されましたのでその"
    },
    {
      "start": 151.92,
      "duration": 5.72,
      "text": "取扱について協議いたしましたその結果"
    },
    {
      "start": 154.76,
      "duration": 6.64,
      "text": "議案第22号については本日の本会議に"
    },
    {
      "start": 157.64,
      "duration": 6.08,
      "text": "上程し説明質疑後予算委員会に付託視聴"
    },
    {
      "start": 161.4,
      "duration": 4.64,
      "text": "報告については本日の本会議で所定の"
    },
    {
      "start": 163.72,
      "duration": 4.68,
      "text": "手続きを取ることと決定いたしました以上"
    },
    {
      "start": 166.04,
      "duration": 4.52,
      "text": "で議会運営委員会の報告を終了いたします"
    },
    {
      "start": 168.4,
      "duration": 4.88,
      "text": "議会運営委員長の報告に対して質疑はあり"
    },
    {
      "start": 170.56,
      "duration": 5.399,
      "text": "ませんか質疑を終了することにご異あり"
    },
    {
      "start": 173.28,
      "duration": 6.0,
      "text": "ませんかご異議なしと認め質疑を終了し"
    },
    {
      "start": 175.959,
      "duration": 6.041,
      "text": "議会委員長の報告を終了しますおりします"
    },
    {
      "start": 179.28,
      "duration": 5.48,
      "text": "議委員長の報告通り決定することにご異議"
    },
    {
      "start": 182.0,
      "duration": 6.879,
      "text": "ありませんかご異議なしと認め議会運委員"
    },
    {
      "start": 184.76,
      "duration": 7.16,
      "text": "長の報告通り決定しました日程第1議案第"
    },
    {
      "start": 188.879,
      "duration": 6.121,
      "text": "22号令和6年度古賀年始一般会計補正"
    },
    {
      "start": 191.92,
      "duration": 5.679,
      "text": "予算かこ第9回を議題とします提案理由の"
    },
    {
      "start": 195.0,
      "duration": 6.879,
      "text": "説明を求めます"
    },
    {
      "start": 197.599,
      "duration": 7.881,
      "text": "長議案第22号令和6年度小金市一般会計"
    },
    {
      "start": 201.879,
      "duration": 6.321,
      "text": "補正予算かこ第9回をご提案申し上げます"
    },
    {
      "start": 205.48,
      "duration": 6.119,
      "text": "本案は繰越し名拒否の補正をするもので"
    },
    {
      "start": 208.2,
      "duration": 6.399,
      "text": "ありますこの繰越し費の追加は第1票"
    },
    {
      "start": 211.599,
      "duration": 5.321,
      "text": "繰越し明許費補正の通りであります以上の"
    },
    {
      "start": 214.599,
      "duration": 4.36,
      "text": "通り補正するため本案を提出するもので"
    },
    {
      "start": 216.92,
      "duration": 3.599,
      "text": "あります左部につきましては担当部長から"
    },
    {
      "start": 218.959,
      "duration": 5.601,
      "text": "説明させていただきますのでよろしくご"
    },
    {
      "start": 220.519,
      "duration": 4.041,
      "text": "審議の上ご異ありますようお願い申し上げ"
    },
    {
      "start": 225.48,
      "duration": 6.319,
      "text": "ますごめなさ企画財政部"
    },
    {
      "start": 228.519,
      "duration": 6.121,
      "text": "長それでは細部につきましてご説明いたし"
    },
    {
      "start": 231.799,
      "duration": 6.481,
      "text": "ます予算書本文の1ページをお開き"
    },
    {
      "start": 234.64,
      "duration": 6.4,
      "text": "ください第9回補正予算を編成する項目に"
    },
    {
      "start": 238.28,
      "duration": 5.92,
      "text": "つきましては第1以上の繰越し明許費の"
    },
    {
      "start": 241.04,
      "duration": 6.559,
      "text": "補正の1項目でございますそれではえ2"
    },
    {
      "start": 244.2,
      "duration": 6.959,
      "text": "ページをお開きください第1票繰越し明許"
    },
    {
      "start": 247.599,
      "duration": 7.48,
      "text": "費補正1件を追加するものでございます"
    },
    {
      "start": 251.159,
      "duration": 7.281,
      "text": "指導第136号線電線共同校設置委託量に"
    },
    {
      "start": 255.079,
      "duration": 5.321,
      "text": "つきましては事業の進捗状況から年度内に"
    },
    {
      "start": 258.44,
      "duration": 6.36,
      "text": "事業が完了しない見込みであるため"
    },
    {
      "start": 260.4,
      "duration": 6.84,
      "text": "繰り越すもので55.5額に104.5が"
    },
    {
      "start": 264.8,
      "duration": 5.72,
      "text": "とからの未収入特定財源となるもので"
    },
    {
      "start": 267.24,
      "duration": 6.76,
      "text": "ございますなお繰越し名拒否の詳細につき"
    },
    {
      "start": 270.52,
      "duration": 6.92,
      "text": "ましては3ページ資料1繰越し明許費の"
    },
    {
      "start": 274.0,
      "duration": 6.72,
      "text": "内訳についてを後ほどご覧くださいまた4"
    },
    {
      "start": 277.44,
      "duration": 7.36,
      "text": "ページ資料2工事1図え経過等につきまし"
    },
    {
      "start": 280.72,
      "duration": 7.759,
      "text": "た56ページ資料3指導第136号線電線"
    },
    {
      "start": 284.8,
      "duration": 6.16,
      "text": "共同校設置事業概要を後ほどご覧ください"
    },
    {
      "start": 288.479,
      "duration": 5.44,
      "text": "以上で説明とさせていただきよろしくご"
    },
    {
      "start": 290.96,
      "duration": 6.519,
      "text": "審議の上ご議決賜わりますよう願い"
    },
    {
      "start": 293.919,
      "duration": 7.56,
      "text": "申し上げますこれから質疑を行うこととし"
    },
    {
      "start": 297.479,
      "duration": 6.921,
      "text": "ますが本は議長をく2人の委員で構成する"
    },
    {
      "start": 301.479,
      "duration": 5.641,
      "text": "予算特別委員会に付託し審査する予定です"
    },
    {
      "start": 304.4,
      "duration": 6.12,
      "text": "本会議では対抗的な質疑を行うなど議事の"
    },
    {
      "start": 307.12,
      "duration": 4.76,
      "text": "進行に特段のご協力をお願いいたします"
    },
    {
      "start": 310.52,
      "duration": 4.239,
      "text": "質疑を行い"
    },
    {
      "start": 311.88,
      "duration": 6.08,
      "text": "ます質疑を終了することにご意見ありませ"
    },
    {
      "start": 314.759,
      "duration": 6.321,
      "text": "んかご異議なしと認め質疑を終了しますお"
    },
    {
      "start": 317.96,
      "duration": 5.6,
      "text": "分かりします本件は予算特別委員会に付託"
    },
    {
      "start": 321.08,
      "duration": 5.32,
      "text": "することにご異議ありませんかご異議なし"
    },
    {
      "start": 323.56,
      "duration": 7.479,
      "text": "と認め本件は予算特別委員会に付託する"
    },
    {
      "start": 326.4,
      "duration": 8.6,
      "text": "ことと決定しました日程第2を行います長"
    },
    {
      "start": 331.039,
      "duration": 6.041,
      "text": "の報告を求めます議事進行議事進行はい"
    },
    {
      "start": 335.0,
      "duration": 5.96,
      "text": "安田"
    },
    {
      "start": 337.08,
      "duration": 6.239,
      "text": "さん視聴報告に関しましてえ生活者"
    },
    {
      "start": 340.96,
      "duration": 6.48,
      "text": "ネットワークとして意見を申し上げますえ"
    },
    {
      "start": 343.319,
      "duration": 9.921,
      "text": "視聴報告の内容はこれまで白井市長がえ"
    },
    {
      "start": 347.44,
      "duration": 10.08,
      "text": "掲げてきた公約をえひすいますえこの視聴"
    },
    {
      "start": 353.24,
      "duration": 7.679,
      "text": "報告がえもうすでにえホームページで公表"
    },
    {
      "start": 357.52,
      "duration": 6.56,
      "text": "されたことを誠に遺憾に思っております"
    },
    {
      "start": 360.919,
      "duration": 6.481,
      "text": "私たち生活者ネットワークはえ市長の公約"
    },
    {
      "start": 364.08,
      "duration": 7.08,
      "text": "を指示しえそれそしてその市長公約を実現"
    },
    {
      "start": 367.4,
      "duration": 7.28,
      "text": "するためにこのえ検証が必要ということを"
    },
    {
      "start": 371.16,
      "duration": 7.36,
      "text": "信じてえ認めてきましたしかしこの内容は"
    },
    {
      "start": 374.68,
      "duration": 7.079,
      "text": "え到底え納得できるものではありません"
    },
    {
      "start": 378.52,
      "duration": 5.72,
      "text": "このままの内容でえこの視聴報告を行う"
    },
    {
      "start": 381.759,
      "duration": 5.601,
      "text": "ことは断じて許されないと生活な"
    },
    {
      "start": 384.24,
      "duration": 3.12,
      "text": "ネットワークは考えてい"
    },
    {
      "start": 387.479,
      "duration": 10.84,
      "text": "ます視聴報告は議長撤回してください市長"
    },
    {
      "start": 392.479,
      "duration": 11.321,
      "text": "撤回してください議長取計お願いし"
    },
    {
      "start": 398.319,
      "duration": 5.481,
      "text": "ますえ議事進行として議長として受け止め"
    },
    {
      "start": 405.08,
      "duration": 5.839,
      "text": "ます片山さんあはいあの安田さん"
    },
    {
      "start": 408.16,
      "duration": 6.039,
      "text": "おっしゃる通りでですねあのこの主張報告"
    },
    {
      "start": 410.919,
      "duration": 6.761,
      "text": "についてはこれあの本来はですねあの1月"
    },
    {
      "start": 414.199,
      "duration": 6.521,
      "text": "24日のこの初日のところでこの検証結果"
    },
    {
      "start": 417.68,
      "duration": 5.799,
      "text": "も出てるわけですからあのあの検証のね"
    },
    {
      "start": 420.72,
      "duration": 5.12,
      "text": "結果の案としてももうすでにこうずっと"
    },
    {
      "start": 423.479,
      "duration": 5.16,
      "text": "こう報告されてるわけですよですのでこう"
    },
    {
      "start": 425.84,
      "duration": 5.0,
      "text": "いったあの総合的判断は最初に示して"
    },
    {
      "start": 428.639,
      "duration": 5.0,
      "text": "欲しいということをずっとあの議会の方で"
    },
    {
      "start": 430.84,
      "duration": 4.759,
      "text": "も訴えておりましたしかしこのあの日程に"
    },
    {
      "start": 433.639,
      "duration": 4.481,
      "text": "なったというのは今日本当は議会運営会の"
    },
    {
      "start": 435.599,
      "duration": 5.32,
      "text": "一定だったんですよねそれをですねこう"
    },
    {
      "start": 438.12,
      "duration": 5.4,
      "text": "変更してまでこうやって本会議を開いて"
    },
    {
      "start": 440.919,
      "duration": 5.0,
      "text": "このような長国を行うということだったん"
    },
    {
      "start": 443.52,
      "duration": 5.04,
      "text": "ですがこれは2月14日になってようやく"
    },
    {
      "start": 445.919,
      "duration": 6.161,
      "text": "配られてる視聴国ですねでしかもですね"
    },
    {
      "start": 448.56,
      "duration": 6.56,
      "text": "内容がとんでもないこの公約と全く真逆の"
    },
    {
      "start": 452.08,
      "duration": 5.559,
      "text": "ようなことのですね視聴法が配られてると"
    },
    {
      "start": 455.12,
      "duration": 5.519,
      "text": "いうことについてはこれは私たちの会派と"
    },
    {
      "start": 457.639,
      "duration": 5.921,
      "text": "しましては姿勢方針の時の質疑でもですね"
    },
    {
      "start": 460.639,
      "duration": 5.12,
      "text": "まずは市民に説明をして欲しいと市民説明"
    },
    {
      "start": 463.56,
      "duration": 5.84,
      "text": "会を行わないのかということを申し上げて"
    },
    {
      "start": 465.759,
      "duration": 5.761,
      "text": "おりますこの要望あのこの3月中には東京"
    },
    {
      "start": 469.4,
      "duration": 4.359,
      "text": "都に要望を出すということを市長は"
    },
    {
      "start": 471.52,
      "duration": 6.04,
      "text": "おっしゃってましたけれどもこれはですね"
    },
    {
      "start": 473.759,
      "duration": 6.12,
      "text": "市民説明会を行って市民に説明した上での"
    },
    {
      "start": 477.56,
      "duration": 4.68,
      "text": "要望じゃないかということはもし上げて"
    },
    {
      "start": 479.879,
      "duration": 5.6,
      "text": "おりましたそれをですね今回の視聴報告で"
    },
    {
      "start": 482.24,
      "duration": 5.56,
      "text": "はこれ真逆の公約と真逆ですからま建設し"
    },
    {
      "start": 485.479,
      "duration": 4.041,
      "text": "てくださいとあの道路作ってくださいと"
    },
    {
      "start": 487.8,
      "duration": 4.88,
      "text": "そういう要望をするような内容になって"
    },
    {
      "start": 489.52,
      "duration": 6.119,
      "text": "ますよねそれをですね今こうやってあの"
    },
    {
      "start": 492.68,
      "duration": 5.28,
      "text": "このような形で今日はあの市長国としてら"
    },
    {
      "start": 495.639,
      "duration": 5.0,
      "text": "れてやるということについてはとても容認"
    },
    {
      "start": 497.96,
      "duration": 6.359,
      "text": "できませんそれこそ容認できませんねこれ"
    },
    {
      "start": 500.639,
      "duration": 6.761,
      "text": "はですね一刻も早くまずは撤回をしてあの"
    },
    {
      "start": 504.319,
      "duration": 5.6,
      "text": "作り直すま説明説明会を行った上で"
    },
    {
      "start": 507.4,
      "duration": 5.04,
      "text": "作り直すべきだと私は思っております今日"
    },
    {
      "start": 509.919,
      "duration": 5.04,
      "text": "はですねこうやってあの証拠国をこの場で"
    },
    {
      "start": 512.44,
      "duration": 4.599,
      "text": "行うようなこういったあの状況じゃないと"
    },
    {
      "start": 514.959,
      "duration": 4.121,
      "text": "思っておりますねそしてまたあの今日は"
    },
    {
      "start": 517.039,
      "duration": 4.68,
      "text": "あのこの後に市長国の後に市長がなんか"
    },
    {
      "start": 519.08,
      "duration": 5.12,
      "text": "発言するというようなことであの先ほど"
    },
    {
      "start": 521.719,
      "duration": 5.081,
      "text": "議会運営会でも確認をしましたけれどもま"
    },
    {
      "start": 524.2,
      "duration": 5.6,
      "text": "ペーパーがもう配られてますこのペーパー"
    },
    {
      "start": 526.8,
      "duration": 5.68,
      "text": "もですねこれあの主張報告の内容とも全く"
    },
    {
      "start": 529.8,
      "duration": 5.56,
      "text": "こう違うじゃないですかこのようなことを"
    },
    {
      "start": 532.48,
      "duration": 5.799,
      "text": "ですね発言するということをこれあの市長"
    },
    {
      "start": 535.36,
      "duration": 6.08,
      "text": "の中あの市長部局の中でちゃんと確認され"
    },
    {
      "start": 538.279,
      "duration": 5.881,
      "text": "てるんですかこういったあの長国との違う"
    },
    {
      "start": 541.44,
      "duration": 5.24,
      "text": "ようなことについて発言をするということ"
    },
    {
      "start": 544.16,
      "duration": 4.64,
      "text": "について私は大変大きな問題があると思っ"
    },
    {
      "start": 546.68,
      "duration": 5.279,
      "text": "てありますのでこれはですねしっかりと"
    },
    {
      "start": 548.8,
      "duration": 6.92,
      "text": "この市長国まずは作り直してほしい撤回し"
    },
    {
      "start": 551.959,
      "duration": 6.401,
      "text": "てまずはきちんとした形に作り直して行と"
    },
    {
      "start": 555.72,
      "duration": 6.32,
      "text": "いうことを議長に申し上げたいと思い"
    },
    {
      "start": 558.36,
      "duration": 5.88,
      "text": "ますあ議事進行上の発言として議長として"
    },
    {
      "start": 562.04,
      "duration": 4.56,
      "text": "受け止めますはい議事進行市さんはい"
    },
    {
      "start": 564.24,
      "duration": 5.64,
      "text": "えっと今色々議事進行出ておりますけれど"
    },
    {
      "start": 566.6,
      "duration": 7.16,
      "text": "もまだ私たち表の場この技の場において"
    },
    {
      "start": 569.88,
      "duration": 6.92,
      "text": "視聴報告まだ聞いておりませんのでえまず"
    },
    {
      "start": 573.76,
      "duration": 5.72,
      "text": "この報告を聞いてから視聴報告あと視聴"
    },
    {
      "start": 576.8,
      "duration": 5.24,
      "text": "発言があるかと思いますので聞いてからの"
    },
    {
      "start": 579.48,
      "duration": 6.68,
      "text": "発言を私たちは審査すべきだと思います"
    },
    {
      "start": 582.04,
      "duration": 7.6,
      "text": "以上ですえ議事進行上の発言として議長と"
    },
    {
      "start": 586.16,
      "duration": 6.359,
      "text": "して受け止めますあのはいえ膨張席はあの"
    },
    {
      "start": 589.64,
      "duration": 7.319,
      "text": "静粛にお願いしますはいえ議事進行渡辺"
    },
    {
      "start": 592.519,
      "duration": 8.041,
      "text": "大蔵さんえっとですねあの今この市民市長"
    },
    {
      "start": 596.959,
      "duration": 5.601,
      "text": "報告の内容に関してはえ一定のご発言が"
    },
    {
      "start": 600.56,
      "duration": 4.68,
      "text": "あったんですけれどももう14日の日には"
    },
    {
      "start": 602.56,
      "duration": 5.2,
      "text": "ですね配布をされておりましてえ市役所の"
    },
    {
      "start": 605.24,
      "duration": 4.36,
      "text": "ホームページにも載っておりますのでもし"
    },
    {
      "start": 607.76,
      "duration": 5.44,
      "text": "まだ読んでいないでこの周に望んでる方が"
    },
    {
      "start": 609.6,
      "duration": 5.799,
      "text": "いるとしたら相当不勉強で驚く次第であの"
    },
    {
      "start": 613.2,
      "duration": 4.52,
      "text": "ありますまそれは一言申し述べておきたい"
    },
    {
      "start": 615.399,
      "duration": 4.801,
      "text": "と思いますあのつまり我々はも全部読んで"
    },
    {
      "start": 617.72,
      "duration": 4.6,
      "text": "おりますけれどもでそれでですねあのこれ"
    },
    {
      "start": 620.2,
      "duration": 5.48,
      "text": "議長にも地震向上申し上げたいのはあの"
    },
    {
      "start": 622.32,
      "duration": 6.28,
      "text": "条例違反のものについてですね市民小金市"
    },
    {
      "start": 625.68,
      "duration": 5.68,
      "text": "の市民参加条例があるんですねで第1次"
    },
    {
      "start": 628.6,
      "duration": 5.479,
      "text": "検証と第2次検証が行われまして例えば"
    },
    {
      "start": 631.36,
      "duration": 5.56,
      "text": "その総合的判断の案なるものが作られて"
    },
    {
      "start": 634.079,
      "duration": 5.121,
      "text": "ですねそれに対して市民参加条例に基づい"
    },
    {
      "start": 636.92,
      "duration": 4.64,
      "text": "てパブリックコメントが実施されたりえ"
    },
    {
      "start": 639.2,
      "duration": 4.96,
      "text": "十分な回数の市民説明会が実施されたり"
    },
    {
      "start": 641.56,
      "duration": 5.12,
      "text": "市民移行調査などがですねえ実施をされる"
    },
    {
      "start": 644.16,
      "duration": 4.799,
      "text": "とでその上で何らかの形でアウトプットさ"
    },
    {
      "start": 646.68,
      "duration": 4.52,
      "text": "れるのは分かるんですが市民参加条例上の"
    },
    {
      "start": 648.959,
      "duration": 5.44,
      "text": "手続きに関して言うと1次検証2次検証が"
    },
    {
      "start": 651.2,
      "duration": 5.639,
      "text": "終わって総合的判断がくだされるまで全く"
    },
    {
      "start": 654.399,
      "duration": 5.12,
      "text": "市民参加の手続きは取られておりませんで"
    },
    {
      "start": 656.839,
      "duration": 5.641,
      "text": "ま実質的にはこの市民参加条例のですねを"
    },
    {
      "start": 659.519,
      "duration": 5.041,
      "text": "没却する内容であのあの提出されてると"
    },
    {
      "start": 662.48,
      "duration": 4.28,
      "text": "いう風に思わざ得ないんですねでして擬似"
    },
    {
      "start": 664.56,
      "duration": 4.399,
      "text": "進行上申し上げたいのはですねこれから"
    },
    {
      "start": 666.76,
      "duration": 3.8,
      "text": "そのような市民参加条例の手続きが取られ"
    },
    {
      "start": 668.959,
      "duration": 3.961,
      "text": "ていないようなものをこのまり読み上げる"
    },
    {
      "start": 670.56,
      "duration": 4.32,
      "text": "ことは非常に不適切でありますので一旦"
    },
    {
      "start": 672.92,
      "duration": 5.159,
      "text": "撤回していただい"
    },
    {
      "start": 674.88,
      "duration": 6.04,
      "text": "て一旦撤回していただいて必要な手続きを"
    },
    {
      "start": 678.079,
      "duration": 5.44,
      "text": "きちと踏んでいただきたい西岡市長がです"
    },
    {
      "start": 680.92,
      "duration": 4.68,
      "text": "ね市長の時に白井さんが何を発言してたか"
    },
    {
      "start": 683.519,
      "duration": 4.521,
      "text": "今私の手元に全部その議事録があるんです"
    },
    {
      "start": 685.6,
      "duration": 4.88,
      "text": "けれども西岡市長がいろんなことを言われ"
    },
    {
      "start": 688.04,
      "duration": 3.88,
      "text": "たものに対してですねそれは精神論だとか"
    },
    {
      "start": 690.48,
      "duration": 4.359,
      "text": "なんだかんだ言ってどうだとか言ってです"
    },
    {
      "start": 691.92,
      "duration": 6.8,
      "text": "ねとにかく体もつきまくってんですねで私"
    },
    {
      "start": 694.839,
      "duration": 6.641,
      "text": "がねまあただね考えてくださいよ西岡市長"
    },
    {
      "start": 698.72,
      "duration": 4.799,
      "text": "は不十分だったけれども市長である自分が"
    },
    {
      "start": 701.48,
      "duration": 3.88,
      "text": "納得できないものは進めるなっていうこと"
    },
    {
      "start": 703.519,
      "duration": 5.361,
      "text": "を東京都に要望してたんです"
    },
    {
      "start": 705.36,
      "duration": 6.12,
      "text": "よ私は西岡さんとはねあのかなり論戦して"
    },
    {
      "start": 708.88,
      "duration": 4.88,
      "text": "きたけれど少なくとも西岡市長は不十分だ"
    },
    {
      "start": 711.48,
      "duration": 4.72,
      "text": "けどあの防波堤を張ってたんですよその"
    },
    {
      "start": 713.76,
      "duration": 5.24,
      "text": "防波堤が不十分だと言って攻め立ててた"
    },
    {
      "start": 716.2,
      "duration": 5.319,
      "text": "あなたが防波堤きすんですかここで市民"
    },
    {
      "start": 719.0,
      "duration": 4.519,
      "text": "さんの手続きもなくありえないでしょ"
    },
    {
      "start": 721.519,
      "duration": 6.481,
      "text": "さっき冒頭安田さんが言われたの本当そう"
    },
    {
      "start": 723.519,
      "duration": 7.081,
      "text": "思いますよ私はえこれはね議長ねあの"
    },
    {
      "start": 728.0,
      "duration": 4.44,
      "text": "きちんとねあの市民参加条例に基づく"
    },
    {
      "start": 730.6,
      "duration": 5.12,
      "text": "手続きは全く取られてないってことはも"
    },
    {
      "start": 732.44,
      "duration": 5.44,
      "text": "本当に有識問題で認められませんよそ休憩"
    },
    {
      "start": 735.72,
      "duration": 4.16,
      "text": "取っていただいて撤回一旦撤回して"
    },
    {
      "start": 737.88,
      "duration": 3.959,
      "text": "いただいてねできちんとそういう手続きを"
    },
    {
      "start": 739.88,
      "duration": 4.399,
      "text": "きちんと取っていただくということをあの"
    },
    {
      "start": 741.839,
      "duration": 5.44,
      "text": "進めていただきたいもう本当これ古賀の"
    },
    {
      "start": 744.279,
      "duration": 5.841,
      "text": "市民参加制度のあのなんて言うのか崩壊"
    },
    {
      "start": 747.279,
      "duration": 5.081,
      "text": "もう有"
    },
    {
      "start": 750.12,
      "duration": 4.12,
      "text": "もう最近たださパブリックコメント制度も"
    },
    {
      "start": 752.36,
      "duration": 3.56,
      "text": "ねなんかに抜きみたいに使われてね"
    },
    {
      "start": 754.24,
      "duration": 4.48,
      "text": "パブリックコメントでどんないい件でだっ"
    },
    {
      "start": 755.92,
      "duration": 5.96,
      "text": "て採用しない本当ねこれどうなってんです"
    },
    {
      "start": 758.72,
      "duration": 6.119,
      "text": "か私はね市民参加条例古賀士の条例大変"
    },
    {
      "start": 761.88,
      "duration": 5.6,
      "text": "優れた条例なんですよところがねそのね"
    },
    {
      "start": 764.839,
      "duration": 5.0,
      "text": "市民参加条例を運用する人がどうしようも"
    },
    {
      "start": 767.48,
      "duration": 6.359,
      "text": "ないとここまで広くなるのかと情けなです"
    },
    {
      "start": 769.839,
      "duration": 6.161,
      "text": "よ本当情けなだちゃんとね白市ね市議会"
    },
    {
      "start": 773.839,
      "duration": 4.12,
      "text": "議員の頃はもうプロセス重視と言い続けて"
    },
    {
      "start": 776.0,
      "duration": 4.44,
      "text": "た市長なんだからちゃんと市民参加の"
    },
    {
      "start": 777.959,
      "duration": 4.44,
      "text": "プロセスを取って出し直して一てください"
    },
    {
      "start": 780.44,
      "duration": 4.72,
      "text": "当たり前だと思いますこれは当たり前だ"
    },
    {
      "start": 782.399,
      "duration": 6.041,
      "text": "はいよろしくお願いしますえ議事進行上の"
    },
    {
      "start": 785.16,
      "duration": 6.56,
      "text": "意見として議長として受け止めますあのえ"
    },
    {
      "start": 788.44,
      "duration": 5.04,
      "text": "あの膨張席あの静かに規則に沿ってえお"
    },
    {
      "start": 791.72,
      "duration": 6.16,
      "text": "願いしたいと思い"
    },
    {
      "start": 793.48,
      "duration": 7.599,
      "text": "ます静かにお願いいたしますえあのあの"
    },
    {
      "start": 797.88,
      "duration": 6.0,
      "text": "議会はあの言論の負ですのであの議長とし"
    },
    {
      "start": 801.079,
      "duration": 4.641,
      "text": "てはまず市長発言あ市長報告したいと言っ"
    },
    {
      "start": 803.88,
      "duration": 4.84,
      "text": "てるんですから報告させたいと思っており"
    },
    {
      "start": 805.72,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 811.68,
      "duration": 8.8,
      "text": "じゃあ以上で"
    },
    {
      "start": 813.32,
      "duration": 7.16,
      "text": "えじゃここで閉めちゃ長の報告を求めます"
    },
    {
      "start": 822.12,
      "duration": 7.24,
      "text": "どうぞえ本日は貴重な時間にえ視聴報告と"
    },
    {
      "start": 826.6,
      "duration": 6.72,
      "text": "してえ発言をお許しいただきありがとう"
    },
    {
      "start": 829.36,
      "duration": 8.24,
      "text": "ございます令和7年2月12日に優先整備"
    },
    {
      "start": 833.32,
      "duration": 7.879,
      "text": "路線の検証について報告書及び優先整備"
    },
    {
      "start": 837.6,
      "duration": 7.32,
      "text": "路線の検証について編を行政報告資料とし"
    },
    {
      "start": 841.199,
      "duration": 7.121,
      "text": "て建設環境委員会に提出をしたところです"
    },
    {
      "start": 844.92,
      "duration": 7.96,
      "text": "当該報告書等を踏まえた私の総合的判断に"
    },
    {
      "start": 848.32,
      "duration": 8.319,
      "text": "ついて報告させていただきます1東京に"
    },
    {
      "start": 852.88,
      "duration": 8.56,
      "text": "おける都市計画道路の整備方針かこ第4次"
    },
    {
      "start": 856.639,
      "duration": 9.56,
      "text": "事業化計画策定後の経過について小金都市"
    },
    {
      "start": 861.44,
      "duration": 8.36,
      "text": "計画道路341号線及び3411号線他"
    },
    {
      "start": 866.199,
      "duration": 7.961,
      "text": "以下2路線と言いますは東京における都市"
    },
    {
      "start": 869.8,
      "duration": 6.92,
      "text": "計画道路の整備方針第4次事業化計画で"
    },
    {
      "start": 874.16,
      "duration": 5.64,
      "text": "将来都市計画道路ネットワークの検証に"
    },
    {
      "start": 876.72,
      "duration": 5.679,
      "text": "より必要性が確認され優先整備路政に選定"
    },
    {
      "start": 879.8,
      "duration": 5.279,
      "text": "されましたこのことを景気に二路政による"
    },
    {
      "start": 882.399,
      "duration": 5.321,
      "text": "環境等への影響に関する懸念等が高まり"
    },
    {
      "start": 885.079,
      "duration": 7.32,
      "text": "市民及び市議会から多数の意見が寄せられ"
    },
    {
      "start": 887.72,
      "duration": 9.44,
      "text": "ています一方野田半島地震を始め近年頻発"
    },
    {
      "start": 892.399,
      "duration": 7.961,
      "text": "する自然災害から早急の早急な防災性格保"
    },
    {
      "start": 897.16,
      "duration": 8.64,
      "text": "の必要性も指摘されると様々な意見もあり"
    },
    {
      "start": 900.36,
      "duration": 8.599,
      "text": "ます本師にとって国分事外線派と野川の"
    },
    {
      "start": 905.8,
      "duration": 7.56,
      "text": "自然及びその豊かな自然環境から生み出さ"
    },
    {
      "start": 908.959,
      "duration": 7.68,
      "text": "れる文化は掛け替えのない財産宝であり"
    },
    {
      "start": 913.36,
      "duration": 6.2,
      "text": "都市の均衡で宅地開発が進む利便性の高い"
    },
    {
      "start": 916.639,
      "duration": 7.721,
      "text": "地域であるからこそ豊かな自然の保全が"
    },
    {
      "start": 919.56,
      "duration": 7.959,
      "text": "一層重要です私の令和6年度政方針では"
    },
    {
      "start": 924.36,
      "duration": 5.8,
      "text": "東京都に対し事業家の中止を求める要望書"
    },
    {
      "start": 927.519,
      "duration": 6.201,
      "text": "を提出するなど適切に対応していきたいと"
    },
    {
      "start": 930.16,
      "duration": 7.039,
      "text": "していましたまた小金都市計画マスター"
    },
    {
      "start": 933.72,
      "duration": 6.4,
      "text": "プランでは都市計画道路の見直しについて"
    },
    {
      "start": 937.199,
      "duration": 6.401,
      "text": "社会経済情勢及び地域の街づくりの変化"
    },
    {
      "start": 940.12,
      "duration": 5.92,
      "text": "などを踏まえ東京都及び関係士と連携して"
    },
    {
      "start": 943.6,
      "duration": 4.599,
      "text": "都市計画道路の検証を行い必要に応じて"
    },
    {
      "start": 946.04,
      "duration": 5.96,
      "text": "見すべきものは見直していきますとして"
    },
    {
      "start": 948.199,
      "duration": 7.921,
      "text": "いることから事業について施工者である"
    },
    {
      "start": 952.0,
      "duration": 7.44,
      "text": "東京都に要望するためには関係自治体に"
    },
    {
      "start": 956.12,
      "duration": 7.839,
      "text": "根拠を明確にして説明する必要があり"
    },
    {
      "start": 959.44,
      "duration": 7.56,
      "text": "検証作業に着手しました検証にあたっては"
    },
    {
      "start": 963.959,
      "duration": 6.401,
      "text": "次期事業化計画の策定を視野に都市計画"
    },
    {
      "start": 967.0,
      "duration": 7.399,
      "text": "道路の役割と機能に着目した検証かこ1次"
    },
    {
      "start": 970.36,
      "duration": 8.44,
      "text": "検証及び二路線固有の地域的課題に着目し"
    },
    {
      "start": 974.399,
      "duration": 7.8,
      "text": "た検証か2次検証により2路線に関わる"
    },
    {
      "start": 978.8,
      "duration": 7.399,
      "text": "必要性及び合理性について評価しました"
    },
    {
      "start": 982.199,
      "duration": 7.681,
      "text": "なお令和6年11月に東京都から小金都市"
    },
    {
      "start": 986.199,
      "duration": 8.521,
      "text": "計画道路3411号線他にかかるオープン"
    },
    {
      "start": 989.88,
      "duration": 8.0,
      "text": "ハウスで自然環境の影響考慮したえ協力案"
    },
    {
      "start": 994.72,
      "duration": 8.479,
      "text": "による整備案が示されてい"
    },
    {
      "start": 997.88,
      "duration": 8.879,
      "text": "ます2検証結果についてこ1小金都市計画"
    },
    {
      "start": 1003.199,
      "duration": 6.56,
      "text": "道路3411号線につい"
    },
    {
      "start": 1006.759,
      "duration": 5.56,
      "text": "て一次検証により都市権都市館"
    },
    {
      "start": 1009.759,
      "duration": 7.041,
      "text": "ネットワークの形成救急医療施設への"
    },
    {
      "start": 1012.319,
      "duration": 7.44,
      "text": "アクセス向上交通建設戦へのアクセス向上"
    },
    {
      "start": 1016.8,
      "duration": 5.2,
      "text": "避難場所へのアクセス向上"
    },
    {
      "start": 1019.759,
      "duration": 7.44,
      "text": "炎症者団体の"
    },
    {
      "start": 1022.0,
      "duration": 10.48,
      "text": "形成災害時の代替機能生活道路の安全性"
    },
    {
      "start": 1027.199,
      "duration": 9.36,
      "text": "向上等に効果が認められ多線と必要性が"
    },
    {
      "start": 1032.48,
      "duration": 10.0,
      "text": "高いことが確認されましたまた二次検証に"
    },
    {
      "start": 1036.559,
      "duration": 9.76,
      "text": "より必要性については交通機能防災機能"
    },
    {
      "start": 1042.48,
      "duration": 4.88,
      "text": "空間機能の各項目の多くで必要性が確認さ"
    },
    {
      "start": 1046.319,
      "duration": 6.401,
      "text": "れまし"
    },
    {
      "start": 1047.36,
      "duration": 8.48,
      "text": "た例えば交通機能の観点では地域の大きな"
    },
    {
      "start": 1052.72,
      "duration": 5.839,
      "text": "課題である通貨交通の減少にすることが"
    },
    {
      "start": 1055.84,
      "duration": 2.719,
      "text": "確認されてい"
    },
    {
      "start": 1060.6,
      "duration": 10.36,
      "text": "ます防災機能の観点では当該路線の整備に"
    },
    {
      "start": 1065.48,
      "duration": 9.04,
      "text": "より国分寺外線派及び武蔵野公園による"
    },
    {
      "start": 1070.96,
      "duration": 6.079,
      "text": "東町5丁目周辺の一方編集が解消され南側"
    },
    {
      "start": 1074.52,
      "duration": 7.399,
      "text": "からの消防活動に貢献するととも"
    },
    {
      "start": 1077.039,
      "duration": 8.921,
      "text": "に避難場所と接続第1次緊急輸送道路との"
    },
    {
      "start": 1081.919,
      "duration": 7.481,
      "text": "接続第2次救急医療機関へのアクセス向上"
    },
    {
      "start": 1085.96,
      "duration": 7.68,
      "text": "及び主要炎症社団体の位置付けがある点で"
    },
    {
      "start": 1089.4,
      "duration": 7.32,
      "text": "必要性が認められました合理性については"
    },
    {
      "start": 1093.64,
      "duration": 7.24,
      "text": "国分事外線席静かにしてください武蔵野"
    },
    {
      "start": 1096.72,
      "duration": 6.0,
      "text": "公園の動植物自然再生事業コミュニティへ"
    },
    {
      "start": 1100.88,
      "duration": 5.32,
      "text": "の影響等が認められまし"
    },
    {
      "start": 1102.72,
      "duration": 6.36,
      "text": "た環境に対する影響については一定の影響"
    },
    {
      "start": 1106.2,
      "duration": 8.28,
      "text": "はあるものの動植物への影響の範囲は限定"
    },
    {
      "start": 1109.08,
      "duration": 8.2,
      "text": "的であり多くの種の生存は維持され事業"
    },
    {
      "start": 1114.48,
      "duration": 8.319,
      "text": "実施区域外にも同質の環境が広く分布する"
    },
    {
      "start": 1117.28,
      "duration": 8.36,
      "text": "ため主要な生息生育の場は存し残存しえ"
    },
    {
      "start": 1122.799,
      "duration": 4.441,
      "text": "生物の総互関係への影響は維持されると"
    },
    {
      "start": 1125.64,
      "duration": 6.12,
      "text": "評価されてい"
    },
    {
      "start": 1127.24,
      "duration": 9.319,
      "text": "ますかこ2小金都市計画道路341号戦に"
    },
    {
      "start": 1131.76,
      "duration": 8.56,
      "text": "ついて一次検証により当該路線は3区間に"
    },
    {
      "start": 1136.559,
      "duration": 7.761,
      "text": "分割し検証したところ区間の相対的な必要"
    },
    {
      "start": 1140.32,
      "duration": 6.96,
      "text": "性は一応ではないことが分かりましたまた"
    },
    {
      "start": 1144.32,
      "duration": 8.0,
      "text": "各区間によって必要性が確認された項目は"
    },
    {
      "start": 1147.28,
      "duration": 8.84,
      "text": "異なります二次検証の必要性では交通機能"
    },
    {
      "start": 1152.32,
      "duration": 7.96,
      "text": "防災機能空間機能の各項目の多くで必要性"
    },
    {
      "start": 1156.12,
      "duration": 9.28,
      "text": "が確認されました例えば交通機能の観点で"
    },
    {
      "start": 1160.28,
      "duration": 7.68,
      "text": "は周辺道路の交通渋滞の解消及び生活道路"
    },
    {
      "start": 1165.4,
      "duration": 4.24,
      "text": "への通過車両が減少する効果が確認されて"
    },
    {
      "start": 1167.96,
      "duration": 6.44,
      "text": "います"
    },
    {
      "start": 1169.64,
      "duration": 8.44,
      "text": "空間機動の観点では景観形成都市緑化及び"
    },
    {
      "start": 1174.4,
      "duration": 8.04,
      "text": "環境負荷の低減で効果が確認されましたが"
    },
    {
      "start": 1178.08,
      "duration": 7.839,
      "text": "文化的資源の保全活用地域活性では影響が"
    },
    {
      "start": 1182.44,
      "duration": 8.92,
      "text": "懸念される結果となりましたまた合理性で"
    },
    {
      "start": 1185.919,
      "duration": 8.721,
      "text": "は国分事外線派能力化景観地形"
    },
    {
      "start": 1191.36,
      "duration": 5.199,
      "text": "コミュニティ生産緑地及び地域資源につい"
    },
    {
      "start": 1194.64,
      "duration": 8.12,
      "text": "て影響が認められまし"
    },
    {
      "start": 1196.559,
      "duration": 9.48,
      "text": "たなお外派等の環境への影響は3つの広報"
    },
    {
      "start": 1202.76,
      "duration": 7.72,
      "text": "案ごとに異なり動植物の調査も実施されて"
    },
    {
      "start": 1206.039,
      "duration": 4.441,
      "text": "いないため検証による評価は難しいと考え"
    },
    {
      "start": 1210.52,
      "duration": 8.0,
      "text": "ます3総合的判断にあたって考慮すべき"
    },
    {
      "start": 1214.4,
      "duration": 8.32,
      "text": "事項について総合的判断にあたっては次の"
    },
    {
      "start": 1218.52,
      "duration": 7.68,
      "text": "2点についてコールしましたかこ1環境の"
    },
    {
      "start": 1222.72,
      "duration": 7.199,
      "text": "影響にかかる専門家の見解について検証の"
    },
    {
      "start": 1226.2,
      "duration": 6.28,
      "text": "過程では小金都市計画審議及び一般社団"
    },
    {
      "start": 1229.919,
      "duration": 5.441,
      "text": "法人都市計画コンサルタント協会の学経験"
    },
    {
      "start": 1232.48,
      "duration": 6.4,
      "text": "者の意見を聴取し客観性を確保してきまし"
    },
    {
      "start": 1235.36,
      "duration": 7.72,
      "text": "たが自然環境についても専門家に聞くべき"
    },
    {
      "start": 1238.88,
      "duration": 8.159,
      "text": "との意見を受け理学博士である高槻誠氏に"
    },
    {
      "start": 1243.08,
      "duration": 7.479,
      "text": "東京都が委託した道路概略検討の動植物の"
    },
    {
      "start": 1247.039,
      "duration": 6.681,
      "text": "予測評価の結果等に関する分析を依頼し"
    },
    {
      "start": 1250.559,
      "duration": 7.081,
      "text": "専門家の見地からの意見を聴取しました"
    },
    {
      "start": 1253.72,
      "duration": 8.52,
      "text": "その結果高槻からは環境にかかる問題点と"
    },
    {
      "start": 1257.64,
      "duration": 8.72,
      "text": "して計画との整合性豊かな自然の存在"
    },
    {
      "start": 1262.24,
      "duration": 8.12,
      "text": "アンブレラ種である他の存在川の生息を"
    },
    {
      "start": 1266.36,
      "duration": 7.96,
      "text": "支える青流魚類等及び金蘭銀intoの"
    },
    {
      "start": 1270.36,
      "duration": 7.679,
      "text": "生育について指摘がありましたさらに当該"
    },
    {
      "start": 1274.32,
      "duration": 6.839,
      "text": "検討では基調種の保護が必要とされてい"
    },
    {
      "start": 1278.039,
      "duration": 6.481,
      "text": "ますが評価のほとんどが生息する生育する"
    },
    {
      "start": 1281.159,
      "duration": 5.721,
      "text": "と予測するとなっており問題なしとされて"
    },
    {
      "start": 1284.52,
      "duration": 4.519,
      "text": "いる評価に疑問を抱いてるとの見解が示さ"
    },
    {
      "start": 1286.88,
      "duration": 5.84,
      "text": "れましたまた"
    },
    {
      "start": 1289.039,
      "duration": 7.561,
      "text": "令和5年に東京都生物多様性地域戦略が"
    },
    {
      "start": 1292.72,
      "duration": 5.68,
      "text": "策定されたことを踏まえ連続性及び"
    },
    {
      "start": 1296.6,
      "duration": 3.84,
      "text": "ネイチャーポジティブの考えを取り入れた"
    },
    {
      "start": 1298.4,
      "duration": 3.6,
      "text": "アセスメントを改めて実施すべきであると"
    },
    {
      "start": 1300.44,
      "duration": 6.119,
      "text": "の指摘を受けまし"
    },
    {
      "start": 1302.0,
      "duration": 9.2,
      "text": "たかこに大規模災害に対する備について令"
    },
    {
      "start": 1306.559,
      "duration": 7.72,
      "text": "和6年1月に発生したの半島地震では甚大"
    },
    {
      "start": 1311.2,
      "duration": 8.079,
      "text": "な人的被害建物被害及びインフラ被害が"
    },
    {
      "start": 1314.279,
      "duration": 8.681,
      "text": "発生しました国土交通省では半島身踏まえ"
    },
    {
      "start": 1319.279,
      "duration": 6.961,
      "text": "首都直下が首都直家地震等の大規模災害へ"
    },
    {
      "start": 1322.96,
      "duration": 6.199,
      "text": "の備えを強化する観点から被害を防止軽減"
    },
    {
      "start": 1326.24,
      "duration": 6.0,
      "text": "するための事前対策の方向性を令和6年7"
    },
    {
      "start": 1329.159,
      "duration": 6.721,
      "text": "月に取りまとめていますこれにより事前"
    },
    {
      "start": 1332.24,
      "duration": 7.799,
      "text": "防災の観点で国民の生命と財産を守る防災"
    },
    {
      "start": 1335.88,
      "duration": 8.52,
      "text": "インフラの充実強化を計画的戦略的に推進"
    },
    {
      "start": 1340.039,
      "duration": 8.52,
      "text": "及び災害リスクを踏まえた事前防災の"
    },
    {
      "start": 1344.4,
      "duration": 6.8,
      "text": "街づくりを推進との考えが示されました"
    },
    {
      "start": 1348.559,
      "duration": 5.681,
      "text": "さらに首都直下地震で想定される"
    },
    {
      "start": 1351.2,
      "duration": 5.88,
      "text": "マグニチュード7程度の地震が30年以内"
    },
    {
      "start": 1354.24,
      "duration": 7.319,
      "text": "に発生する確率が70%と予測されてい"
    },
    {
      "start": 1357.08,
      "duration": 8.079,
      "text": "ます市は野半島地震を始め阪神淡路大震災"
    },
    {
      "start": 1361.559,
      "duration": 6.881,
      "text": "東日本大震災等の教訓を踏まえ災害対策の"
    },
    {
      "start": 1365.159,
      "duration": 6.561,
      "text": "あらゆる施策を通じて市民の生命身体及び"
    },
    {
      "start": 1368.44,
      "duration": 7.88,
      "text": "財産を災害から保護しその安全を確保する"
    },
    {
      "start": 1371.72,
      "duration": 8.48,
      "text": "とともに被災後の市民生活の再建及び安定"
    },
    {
      "start": 1376.32,
      "duration": 5.56,
      "text": "並びに都市の復興を図るた最大の努力をら"
    },
    {
      "start": 1380.2,
      "duration": 7.2,
      "text": "なければなりませ"
    },
    {
      "start": 1381.88,
      "duration": 9.76,
      "text": "ん4総合的判断について総合的判断は"
    },
    {
      "start": 1387.4,
      "duration": 6.92,
      "text": "検ととに自然環境に関する学経験者の見解"
    },
    {
      "start": 1391.64,
      "duration": 7.48,
      "text": "及び自然災害に対する対策の必要性を鑑み"
    },
    {
      "start": 1394.32,
      "duration": 9.2,
      "text": "て判断しましたこ1小金都市計画道路"
    },
    {
      "start": 1399.12,
      "duration": 7.2,
      "text": "3411号線について本路線は検証報告書"
    },
    {
      "start": 1403.52,
      "duration": 5.759,
      "text": "を踏まえると必要性を否定できませんが"
    },
    {
      "start": 1406.32,
      "duration": 6.52,
      "text": "自然環境保護の観点から課題が残り"
    },
    {
      "start": 1409.279,
      "duration": 7.041,
      "text": "このため環境に対する影響の提言に向けた"
    },
    {
      "start": 1412.84,
      "duration": 6.6,
      "text": "強の設計内容について見直しを求める必要"
    },
    {
      "start": 1416.32,
      "duration": 7.479,
      "text": "がありますこのように判断した理由は次の"
    },
    {
      "start": 1419.44,
      "duration": 7.599,
      "text": "通りです検証において一次検証では都市館"
    },
    {
      "start": 1423.799,
      "duration": 6.281,
      "text": "ネットワークの形成生活道路の安全性向上"
    },
    {
      "start": 1427.039,
      "duration": 8.64,
      "text": "等相対的に必要性が高いことが確認された"
    },
    {
      "start": 1430.08,
      "duration": 8.599,
      "text": "ものの2次検証では国分事外派公園の川を"
    },
    {
      "start": 1435.679,
      "duration": 6.841,
      "text": "一体とした貴重な自然環境等に影響が認め"
    },
    {
      "start": 1438.679,
      "duration": 7.721,
      "text": "ことが分かりました本の宝である国分寺"
    },
    {
      "start": 1442.52,
      "duration": 7.08,
      "text": "外線派周辺の野川と野武蔵野公園が一体と"
    },
    {
      "start": 1446.4,
      "duration": 7.12,
      "text": "なった自然環境及び生活文化への影響が"
    },
    {
      "start": 1449.6,
      "duration": 6.199,
      "text": "懸念されますが元半島地震以降さらに"
    },
    {
      "start": 1453.52,
      "duration": 6.12,
      "text": "高まっている防災インフラの重要性を考慮"
    },
    {
      "start": 1455.799,
      "duration": 7.841,
      "text": "すると県民士との防災協定締結かこ総合"
    },
    {
      "start": 1459.64,
      "duration": 7.36,
      "text": "応援体制に基づく効果的な地域の防災性の"
    },
    {
      "start": 1463.64,
      "duration": 7.36,
      "text": "向上にもしする路線であり年の地域課題で"
    },
    {
      "start": 1467.0,
      "duration": 7.24,
      "text": "ある通貨交通の解ととに市民の安全及び"
    },
    {
      "start": 1471.0,
      "duration": 7.76,
      "text": "生命財産を守る自治体の責務から当該道路"
    },
    {
      "start": 1474.24,
      "duration": 8.319,
      "text": "の必要性は否めませんこのため小金都市"
    },
    {
      "start": 1478.76,
      "duration": 6.0,
      "text": "計画マスタープランに基づき東京及び関係"
    },
    {
      "start": 1482.559,
      "duration": 5.6,
      "text": "士に見直しを前提とした連携を申し入れる"
    },
    {
      "start": 1484.76,
      "duration": 9.399,
      "text": "ことはこんなんであると考えましたしかし"
    },
    {
      "start": 1488.159,
      "duration": 12.841,
      "text": "当該周辺は国分寺外線派の生体系野川の体"
    },
    {
      "start": 1494.159,
      "duration": 10.681,
      "text": "系び草原の体系が3のをして多様な生物が"
    },
    {
      "start": 1501.0,
      "duration": 9.36,
      "text": "生息する貴重な生息環境は保全しなければ"
    },
    {
      "start": 1504.84,
      "duration": 10.559,
      "text": "なりません京都でを自然再生事業が実施さ"
    },
    {
      "start": 1510.36,
      "duration": 5.039,
      "text": "れている地域でもあり古のみなら"
    },
    {
      "start": 1516.76,
      "duration": 7.48,
      "text": "ず案が最適とされていますが自然環境等へ"
    },
    {
      "start": 1520.84,
      "duration": 4.079,
      "text": "の影響は否定できないため施者である京都"
    },
    {
      "start": 1524.24,
      "duration": 6.4,
      "text": "に"
    },
    {
      "start": 1524.919,
      "duration": 10.36,
      "text": "大に配置を見直すなな環境響の減を図る"
    },
    {
      "start": 1530.64,
      "duration": 9.2,
      "text": "設計及び施工計画を行うとともに東京都"
    },
    {
      "start": 1535.279,
      "duration": 8.161,
      "text": "生物多様性地域戦略行動方針に沿って整備"
    },
    {
      "start": 1539.84,
      "duration": 6.559,
      "text": "後も整備前の生体系が保全されるよう"
    },
    {
      "start": 1543.44,
      "duration": 7.0,
      "text": "動植物の調査地下推移の一定期間の"
    },
    {
      "start": 1546.399,
      "duration": 7.601,
      "text": "モニタリング等必要な対策を求めますまた"
    },
    {
      "start": 1550.44,
      "duration": 6.959,
      "text": "道路事業が完了し防災性の向上が図られる"
    },
    {
      "start": 1554.0,
      "duration": 4.88,
      "text": "までの間早期に地域の防災性にする"
    },
    {
      "start": 1557.399,
      "duration": 5.481,
      "text": "取り組みとともに"
    },
    {
      "start": 1558.88,
      "duration": 7.6,
      "text": "住民の生活再建及びコミュニティへの影響"
    },
    {
      "start": 1562.88,
      "duration": 7.48,
      "text": "もあることから地域住民の生活に十分配慮"
    },
    {
      "start": 1566.48,
      "duration": 7.439,
      "text": "した丁寧な対応を求めます自然環境への"
    },
    {
      "start": 1570.36,
      "duration": 8.16,
      "text": "影響等については現時点で市民の懸念が"
    },
    {
      "start": 1573.919,
      "duration": 10.64,
      "text": "残っていますこのため東京都セル多"
    },
    {
      "start": 1578.52,
      "duration": 11.279,
      "text": "地域よ発言してますよの努力及び丁寧な"
    },
    {
      "start": 1584.559,
      "duration": 9.281,
      "text": "対応を求めますなお本は当該路線の整備に"
    },
    {
      "start": 1589.799,
      "duration": 8.0,
      "text": "関する自然環境への影響づり等について"
    },
    {
      "start": 1593.84,
      "duration": 7.8,
      "text": "東京都と継続して連携していくこととし"
    },
    {
      "start": 1597.799,
      "duration": 8.961,
      "text": "ます2小金都市計画"
    },
    {
      "start": 1601.64,
      "duration": 7.84,
      "text": "道路341号線について本の線は構造に"
    },
    {
      "start": 1606.76,
      "duration": 5.32,
      "text": "よる具体的な動植物等への影響が不明の"
    },
    {
      "start": 1609.48,
      "duration": 6.559,
      "text": "ため判断することが困難んですが国分事"
    },
    {
      "start": 1612.08,
      "duration": 7.52,
      "text": "外線派の影響が明らかであるため事業家の"
    },
    {
      "start": 1616.039,
      "duration": 6.321,
      "text": "手続きは一旦中止することが妥当だと考え"
    },
    {
      "start": 1619.6,
      "duration": 7.0,
      "text": "このように判断した理由は次の通りです"
    },
    {
      "start": 1622.36,
      "duration": 6.36,
      "text": "検証では本路線は東西の近隣士と接続して"
    },
    {
      "start": 1626.6,
      "duration": 5.4,
      "text": "いることから都市館ネットワーク機能上の"
    },
    {
      "start": 1628.72,
      "duration": 6.04,
      "text": "重要性は高いとされる一方で必要性につい"
    },
    {
      "start": 1632.0,
      "duration": 6.64,
      "text": "ては区間によって差があり一応ではない"
    },
    {
      "start": 1634.76,
      "duration": 7.0,
      "text": "ことが分かりました当該区間は国分事外線"
    },
    {
      "start": 1638.64,
      "duration": 6.96,
      "text": "派を斜めに中断する路線であり地形を"
    },
    {
      "start": 1641.76,
      "duration": 6.96,
      "text": "踏まえた後報既存道路との関係地域への"
    },
    {
      "start": 1645.6,
      "duration": 7.16,
      "text": "影響等について不明な点があり小金都市"
    },
    {
      "start": 1648.72,
      "duration": 7.559,
      "text": "計画道路341号線と同様に本市の宝で"
    },
    {
      "start": 1652.76,
      "duration": 7.08,
      "text": "ある国分寺外線波形周辺の環境及び生活"
    },
    {
      "start": 1656.279,
      "duration": 7.161,
      "text": "文化への影響が懸念されます加えて当該"
    },
    {
      "start": 1659.84,
      "duration": 5.52,
      "text": "路線と並行する連絡通り及びその他の代替"
    },
    {
      "start": 1663.44,
      "duration": 4.64,
      "text": "する道路ネットワークについても検討する"
    },
    {
      "start": 1665.36,
      "duration": 5.559,
      "text": "必要がありますが連絡通りは都市計画道路"
    },
    {
      "start": 1668.08,
      "duration": 6.4,
      "text": "ではないため既存の街づくりを踏まえた"
    },
    {
      "start": 1670.919,
      "duration": 7.801,
      "text": "調査が必要ですこのように現時点において"
    },
    {
      "start": 1674.48,
      "duration": 7.079,
      "text": "周辺道路現場の地形条件生活文への等の"
    },
    {
      "start": 1678.72,
      "duration": 6.36,
      "text": "観点から十分な検討が行われてるとは言い"
    },
    {
      "start": 1681.559,
      "duration": 6.641,
      "text": "がいと考えますこれらの内容が整理される"
    },
    {
      "start": 1685.08,
      "duration": 7.16,
      "text": "までは事業化の手続きは一旦中止を求める"
    },
    {
      "start": 1688.2,
      "duration": 7.8,
      "text": "こととします報告は以上ですここで昼食の"
    },
    {
      "start": 1692.24,
      "duration": 3.76,
      "text": "ため概ね1時間休憩いたし"
    },
    {
      "start": 1703.32,
      "duration": 10.12,
      "text": "ますえ再開は何時でしょう"
    },
    {
      "start": 1707.12,
      "duration": 6.32,
      "text": "かじゃあ15分ね1時15分再開"
    }
  ]
}