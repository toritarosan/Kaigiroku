    },
    {
      "start": 148.519,
      "duration": 5.8,
      "text": "から発言がありましたらこれを求めます"
    },
    {
      "start": 150.92,
      "duration": 6.92,
      "text": "特にないですはいこれから質疑を行い"
    },
    {
      "start": 154.319,
      "duration": 6.361,
      "text": "ます以上で本件に対する現時点での質疑を"
    },
    {
      "start": 157.84,
      "duration": 6.16,
      "text": "終了することにご異議ありませんかご異議"
    },
    {
      "start": 160.68,
      "duration": 8.0,
      "text": "なしと認め本件に対する現時点での質疑を"
    },
    {
      "start": 164.0,
      "duration": 8.239,
      "text": "終了いたしますここで小金市地域公共交通"
    },
    {
      "start": 168.68,
      "duration": 6.16,
      "text": "計画策定に対し建設環境委員会からの提言"
    },
    {
      "start": 172.239,
      "duration": 4.28,
      "text": "について委員長から読み上げさせて"
    },
    {
      "start": 174.84,
      "duration": 6.319,
      "text": "いただき"
    },
    {
      "start": 176.519,
      "duration": 9.8,
      "text": "ます小金地域公共交通計画策定に対する"
    },
    {
      "start": 181.159,
      "duration": 8.881,
      "text": "提言本市では令和5年2023年に小市"
    },
    {
      "start": 186.319,
      "duration": 7.961,
      "text": "地域公共交通活性化協議会を設置し"
    },
    {
      "start": 190.04,
      "duration": 7.839,
      "text": "て地域における需要に応じた住民の生活に"
    },
    {
      "start": 194.28,
      "duration": 8.16,
      "text": "必要なマス党のサービス等の旅客輸送の"
    },
    {
      "start": 197.879,
      "duration": 8.28,
      "text": "確保その他旅客の利便の増進を図り地域の"
    },
    {
      "start": 202.44,
      "duration": 8.04,
      "text": "実情に即した輸送サービスの実現に必要な"
    },
    {
      "start": 206.159,
      "duration": 8.761,
      "text": "協議を行い令和5年度2023年度から令"
    },
    {
      "start": 210.48,
      "duration": 9.52,
      "text": "和6年度2024年度にかけて小金地域"
    },
    {
      "start": 214.92,
      "duration": 10.36,
      "text": "公共交通計画令和7年度2025年度から"
    },
    {
      "start": 220.0,
      "duration": 8.68,
      "text": "令和14年度2032年度の8加年の策定"
    },
    {
      "start": 225.28,
      "duration": 7.4,
      "text": "に向けた検討が進められて"
    },
    {
      "start": 228.68,
      "duration": 7.399,
      "text": "いる市議会建設環境委員会においても重要"
    },
    {
      "start": 232.68,
      "duration": 6.639,
      "text": "な計画であると捉えて所管事務調査に位置"
    },
    {
      "start": 236.079,
      "duration": 4.601,
      "text": "づけて地域公共交通に関する調査を進めて"
    },
    {
      "start": 239.319,
      "duration": 5.601,
      "text": "きた"
    },
    {
      "start": 240.68,
      "duration": 8.08,
      "text": "しかし令和6年2024年7月16日に"
    },
    {
      "start": 244.92,
      "duration": 8.2,
      "text": "本市の地域公共交通の重心的役割を果たし"
    },
    {
      "start": 248.76,
      "duration": 9.12,
      "text": "ている小金市コミュニティバスコバス以下"
    },
    {
      "start": 253.12,
      "duration": 9.16,
      "text": "コバスという東町循環及び中町循環につい"
    },
    {
      "start": 257.88,
      "duration": 8.84,
      "text": "て運行を委託事業者より令和9年2027"
    },
    {
      "start": 262.28,
      "duration": 8.84,
      "text": "年3月末を持って運行住宅を終了する旨の"
    },
    {
      "start": 266.72,
      "duration": 8.479,
      "text": "申し入れがありこれまで死都運行委託事業"
    },
    {
      "start": 271.12,
      "duration": 8.919,
      "text": "者による協議が行われてきたしかしながら"
    },
    {
      "start": 275.199,
      "duration": 8.241,
      "text": "令和6年2024年11月8日現状維持は"
    },
    {
      "start": 280.039,
      "duration": 7.201,
      "text": "困難であることが確認されたよって交通"
    },
    {
      "start": 283.44,
      "duration": 7.24,
      "text": "形態が大きく変更される見込みから迅速に"
    },
    {
      "start": 287.24,
      "duration": 8.04,
      "text": "持続可能な交通ネットワークを再構築する"
    },
    {
      "start": 290.68,
      "duration": 8.519,
      "text": "ため令和9年度2027年度からの運行を"
    },
    {
      "start": 295.28,
      "duration": 7.56,
      "text": "目指した交通ネットワーク再編事業に"
    },
    {
      "start": 299.199,
      "duration": 7.481,
      "text": "取り組むことがから示されたこうした状況"
    },
    {
      "start": 302.84,
      "duration": 8.079,
      "text": "を踏まえ本市における地域公共交通施策"
    },
    {
      "start": 306.68,
      "duration": 7.64,
      "text": "推進の一条としていただきたく市議会建設"
    },
    {
      "start": 310.919,
      "duration": 9.161,
      "text": "環境委員会として下記の事項について提言"
    },
    {
      "start": 314.32,
      "duration": 9.4,
      "text": "を行うものである期1ココバス運行事業に"
    },
    {
      "start": 320.08,
      "duration": 5.88,
      "text": "かかる協議についてコバスは機関バスの"
    },
    {
      "start": 323.72,
      "duration": 6.8,
      "text": "保管的役割である"
    },
    {
      "start": 325.96,
      "duration": 8.72,
      "text": "が本市においては市民生活に不可欠な交通"
    },
    {
      "start": 330.52,
      "duration": 8.08,
      "text": "インフラであり特に東町循環及び中町循環"
    },
    {
      "start": 334.68,
      "duration": 8.48,
      "text": "は機関バス路線が少ない地域であるため"
    },
    {
      "start": 338.6,
      "duration": 8.64,
      "text": "交通風原地域交通空白地域を作らないよう"
    },
    {
      "start": 343.16,
      "duration": 9.08,
      "text": "継続運行に向けてあらゆる対策を取り最大"
    },
    {
      "start": 347.24,
      "duration": 9.28,
      "text": "限の努力を行うことその一方で継続運行が"
    },
    {
      "start": 352.24,
      "duration": 8.48,
      "text": "困難な場合に備えて令和7年度2025"
    },
    {
      "start": 356.52,
      "duration": 8.6,
      "text": "年度の早い段階で運行委託事業者との協議"
    },
    {
      "start": 360.72,
      "duration": 9.199,
      "text": "の結論を得て新たな交通手段や運行形態と"
    },
    {
      "start": 365.12,
      "duration": 7.96,
      "text": "なる大体策の大外策の具体的検討実施を"
    },
    {
      "start": 369.919,
      "duration": 7.361,
      "text": "行い市民の移動手段を確保することを"
    },
    {
      "start": 373.08,
      "duration": 8.679,
      "text": "求めるその際には利用者や市民市議会への"
    },
    {
      "start": 377.28,
      "duration": 8.919,
      "text": "丁寧な説明を行いその意見を尊重して基本"
    },
    {
      "start": 381.759,
      "duration": 9.041,
      "text": "方針に掲げる地公共交通をみんなで"
    },
    {
      "start": 386.199,
      "duration": 8.641,
      "text": "守り育てるために丁寧に検討に決定する"
    },
    {
      "start": 390.8,
      "duration": 8.08,
      "text": "こと2マスタープランを保管する施策の"
    },
    {
      "start": 394.84,
      "duration": 8.72,
      "text": "実施について現在策定しているマスター"
    },
    {
      "start": 398.88,
      "duration": 8.159,
      "text": "プランは市全体の地域公共交通の理念や"
    },
    {
      "start": 403.56,
      "duration": 6.56,
      "text": "方向性を示すものであり交通ネットワーク"
    },
    {
      "start": 407.039,
      "duration": 8.121,
      "text": "再編事業の協議結果によって"
    },
    {
      "start": 410.12,
      "duration": 9.759,
      "text": "は個別的に深掘りした施策を実施する必要"
    },
    {
      "start": 415.16,
      "duration": 8.879,
      "text": "があるその際には前子的に特に高半な市民"
    },
    {
      "start": 419.879,
      "duration": 8.961,
      "text": "ニーズをつめるようしっかりとした現状"
    },
    {
      "start": 424.039,
      "duration": 9.72,
      "text": "把握を行うことまた交通空白地域の考え方"
    },
    {
      "start": 428.84,
      "duration": 8.88,
      "text": "においては保特有の国分寺外線派などの"
    },
    {
      "start": 433.759,
      "duration": 7.72,
      "text": "高定差や多くの利用者が見込める場合には"
    },
    {
      "start": 437.72,
      "duration": 8.96,
      "text": "夜間休日などの時間帯による空白も考慮"
    },
    {
      "start": 441.479,
      "duration": 9.641,
      "text": "すること地域公共交通施策は交通分野の"
    },
    {
      "start": 446.68,
      "duration": 8.56,
      "text": "課題解決のみならず街づくりや観光福祉"
    },
    {
      "start": 451.12,
      "duration": 8.919,
      "text": "教育等の様々な分野にも大きく関係して"
    },
    {
      "start": 455.24,
      "duration": 9.0,
      "text": "いる今後の超高齢化社会人口減少社会に"
    },
    {
      "start": 460.039,
      "duration": 8.56,
      "text": "おける地域社会の活力の維持向上のため"
    },
    {
      "start": 464.24,
      "duration": 6.359,
      "text": "地域全体を見据えた地域戦略の一環として"
    },
    {
      "start": 468.599,
      "duration": 6.6,
      "text": "今に検討する"
    },
    {
      "start": 470.599,
      "duration": 8.241,
      "text": "こと3運転子不足対策についてバス等の"
    },
    {
      "start": 475.199,
      "duration": 7.481,
      "text": "地域公共交通に従事する運転手などの賃金"
    },
    {
      "start": 478.84,
      "duration": 8.079,
      "text": "は他職種と比較して低いことが指摘されて"
    },
    {
      "start": 482.68,
      "duration": 7.919,
      "text": "いる市民の生活インフラである地域公共"
    },
    {
      "start": 486.919,
      "duration": 8.801,
      "text": "交通の担い手であるバスやタクシーの運転"
    },
    {
      "start": 490.599,
      "duration": 9.361,
      "text": "し不足が深刻な状況は全国的な課題であり"
    },
    {
      "start": 495.72,
      "duration": 8.52,
      "text": "国で早急な施策を検討して検討することが"
    },
    {
      "start": 499.96,
      "duration": 8.359,
      "text": "必要であることから国及び東京都に対応を"
    },
    {
      "start": 504.24,
      "duration": 9.4,
      "text": "求めること基礎自治体としても運転手の"
    },
    {
      "start": 508.319,
      "duration": 9.28,
      "text": "賃金態など労働環境の処遇改善を後押し"
    },
    {
      "start": 513.64,
      "duration": 7.839,
      "text": "する支援や2種免許取得費用の補助制度の"
    },
    {
      "start": 517.599,
      "duration": 7.561,
      "text": "創設や市が協力しての運転手募集"
    },
    {
      "start": 521.479,
      "duration": 8.521,
      "text": "フォーラムや公共施設への募集案内掲示"
    },
    {
      "start": 525.16,
      "duration": 8.88,
      "text": "など交通事業者の人材確保に対する効果的"
    },
    {
      "start": 530.0,
      "duration": 8.64,
      "text": "な施策を検討すること"
    },
    {
      "start": 534.04,
      "duration": 9.32,
      "text": "4地域公共交通に対する市民ニーズの把握"
    },
    {
      "start": 538.64,
      "duration": 8.48,
      "text": "及び情報発信について基本方針にある地域"
    },
    {
      "start": 543.36,
      "duration": 7.44,
      "text": "公共交通をみんなで守り育てる町とする"
    },
    {
      "start": 547.12,
      "duration": 7.88,
      "text": "ためには市民が自分ごととして地域公共"
    },
    {
      "start": 550.8,
      "duration": 8.159,
      "text": "交通を捉えることが必要である現状でも"
    },
    {
      "start": 555.0,
      "duration": 7.839,
      "text": "地域困難会を複数回開催しているが参加者"
    },
    {
      "start": 558.959,
      "duration": 7.401,
      "text": "は少数にとまっていることを鑑み小金バス"
    },
    {
      "start": 562.839,
      "duration": 6.961,
      "text": "フェスを継続的に実施するとともに"
    },
    {
      "start": 566.36,
      "duration": 8.039,
      "text": "オープンハウスや地域会議等の手段を用い"
    },
    {
      "start": 569.8,
      "duration": 7.96,
      "text": "て行政が地域に出向き積極的に地域公共の"
    },
    {
      "start": 574.399,
      "duration": 8.56,
      "text": "情報発信を行うこと地公共"
    },
    {
      "start": 577.76,
      "duration": 10.319,
      "text": "公5地域公共で交通言わなかっあすいませ"
    },
    {
      "start": 582.959,
      "duration": 9.32,
      "text": "んに積極的に地公共交通の情報発信を行う"
    },
    {
      "start": 588.079,
      "duration": 8.801,
      "text": "こと失礼しました5地域や民間との連携に"
    },
    {
      "start": 592.279,
      "duration": 8.56,
      "text": "ついて場合によっては福祉策民間企業に"
    },
    {
      "start": 596.88,
      "duration": 9.32,
      "text": "おける送迎など地域のあらゆるリソースを"
    },
    {
      "start": 600.839,
      "duration": 9.881,
      "text": "最電源に活用し行政地域民間が連携し地域"
    },
    {
      "start": 606.2,
      "duration": 8.8,
      "text": "公共交通を支える仕組みを検討構築する"
    },
    {
      "start": 610.72,
      "duration": 8.44,
      "text": "こと特にバス運転士が高齢化により令和"
    },
    {
      "start": 615.0,
      "duration": 8.36,
      "text": "12年2030年には3割も減少すること"
    },
    {
      "start": 619.16,
      "duration": 7.48,
      "text": "や共愛道路が多い本市特有の状況を"
    },
    {
      "start": 623.36,
      "duration": 9.08,
      "text": "踏まえれば今後はタクシー事業者の協力の"
    },
    {
      "start": 626.64,
      "duration": 9.84,
      "text": "重要性なども認識し今日を行うこと6新た"
    },
    {
      "start": 632.44,
      "duration": 7.88,
      "text": "な地域公共交通の施策について移動する"
    },
    {
      "start": 636.48,
      "duration": 8.159,
      "text": "権利は基本的人権の1つであり全ての人に"
    },
    {
      "start": 640.32,
      "duration": 8.48,
      "text": "保障されるべきである地域公共交通は市民"
    },
    {
      "start": 644.639,
      "duration": 7.961,
      "text": "生活を支える重要な交通インフラであり誰"
    },
    {
      "start": 648.8,
      "duration": 7.96,
      "text": "もが安全で安心して移動できるよう常に"
    },
    {
      "start": 652.6,
      "duration": 10.4,
      "text": "時代に即し未来を見据えた検討が必要で"
    },
    {
      "start": 656.76,
      "duration": 10.6,
      "text": "ある今後も新たな公共交通を検討研究実証"
    },
    {
      "start": 663.0,
      "duration": 8.2,
      "text": "実験を行っている自治体と情報共有を行い"
    },
    {
      "start": 667.36,
      "duration": 4.84,
      "text": "本市にとって有用な交通手段の把握に"
