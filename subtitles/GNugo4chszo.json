    {
      "start": 697.76,
      "duration": 2.36,
      "text": "でござい"
    },
    {
      "start": 700.399,
      "duration": 7.841,
      "text": "ますお諮りいたしますただいま読み上げ"
    },
    {
      "start": 704.279,
