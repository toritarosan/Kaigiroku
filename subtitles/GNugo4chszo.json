    {
      "start": 120.399,
      "duration": 5.64,
      "text": "はいはいはいじゃあ"
    },
    {
      "start": 123.84,
      "duration": 4.839,
      "text": "ましょうおはようございますおはよう"
    },
    {
      "start": 126.039,
      "duration": 6.041,
      "text": "ございますただいまから建設環境委員会の"
    },
    {
      "start": 128.679,
      "duration": 6.601,
      "text": "会議を開きます直に本日の議事に入ります"
    },
    {
      "start": 132.08,
      "duration": 6.239,
