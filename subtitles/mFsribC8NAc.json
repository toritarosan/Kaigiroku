{
  "entries": [
    {
      "start": 82.68,
      "duration": 6.72,
      "text": "えただいまから予算特別委員会の会議を"
    },
    {
      "start": 85.68,
      "duration": 6.759,
      "text": "開きます本日は年長の私が委員長が補選さ"
    },
    {
      "start": 89.4,
      "duration": 5.719,
      "text": "れるまでで委員長の職務を行いますたしに"
    },
    {
      "start": 92.439,
      "duration": 5.761,
      "text": "議題に入ります議題は当委員会の委員長の"
    },
    {
      "start": 95.119,
      "duration": 5.521,
      "text": "護選についてであります護選の方法につい"
    },
    {
      "start": 98.2,
      "duration": 6.08,
      "text": "てはいかがいたしましょうかどなたか選出"
    },
    {
      "start": 100.64,
      "duration": 7.36,
      "text": "方法についてご意見がありませんか片山"
    },
    {
      "start": 104.28,
      "duration": 4.879,
      "text": "さんあこれ委員会ですかはいはい指名推薦"
    },
    {
      "start": 108.0,
      "duration": 4.92,
      "text": "でお願いいたし"
    },
    {
      "start": 109.159,
      "duration": 6.32,
      "text": "ますただいま選出方法について指名推薦に"
    },
    {
      "start": 112.92,
      "duration": 5.799,
      "text": "いるとのご意見がありますが指名推により"
    },
    {
      "start": 115.479,
      "duration": 5.68,
      "text": "決定することにご異議ありませんかなしご"
    },
    {
      "start": 118.719,
      "duration": 5.08,
      "text": "異議なしと認めただいま申し上げました"
    },
    {
      "start": 121.159,
      "duration": 6.761,
      "text": "通り決定いたしますどの他がご推薦"
    },
    {
      "start": 123.799,
      "duration": 7.601,
      "text": "いただけますでしょうか片山さんはいえ"
    },
    {
      "start": 127.92,
      "duration": 6.44,
      "text": "多分今回初めてのあれですかね予算委員会"
    },
    {
      "start": 131.4,
      "duration": 5.0,
      "text": "委長となるのかと思うんですがあの安田"
    },
    {
      "start": 134.36,
      "duration": 4.12,
      "text": "敬子さんに是非ともお願いしたいと思って"
    },
    {
      "start": 136.4,
      "duration": 4.6,
      "text": "おりますあの安田さん是非ともよろしくお"
    },
    {
      "start": 138.48,
      "duration": 2.52,
      "text": "願いいたし"
    },
    {
      "start": 141.44,
      "duration": 7.04,
      "text": "ますただいま安田稽古議員を委員長にての"
    },
    {
      "start": 145.36,
      "duration": 6.04,
      "text": "推薦がございましたお諮りいたしますえ"
    },
    {
      "start": 148.48,
      "duration": 6.08,
      "text": "安田向委員を委員長に選出することにご"
    },
    {
      "start": 151.4,
      "duration": 6.0,
      "text": "異議ありませんかしご異議なしと認めます"
    },
    {
      "start": 154.56,
      "duration": 5.56,
      "text": "従ってただいま指名いたしました通り選出"
    },
    {
      "start": 157.4,
      "duration": 5.72,
      "text": "することに決定いたしましたただいま委員"
    },
    {
      "start": 160.12,
      "duration": 6.36,
      "text": "長に選出されました安田慶子委員のご挨拶"
    },
    {
      "start": 163.12,
      "duration": 6.479,
      "text": "をお願いいたします安田さんはい"
    },
    {
      "start": 166.48,
      "duration": 6.399,
      "text": "えっと推薦いただきありがとうございます"
    },
    {
      "start": 169.599,
      "duration": 5.961,
      "text": "あの私もあの人気あと少し残すところで"
    },
    {
      "start": 172.879,
      "duration": 5.841,
      "text": "ありますけれどもあの委員長という大役は"
    },
    {
      "start": 175.56,
      "duration": 6.599,
      "text": "まだ未経験でありますえ先輩の皆様方にご"
    },
    {
      "start": 178.72,
      "duration": 5.799,
      "text": "指導いただきながらえ議事の運営をりなく"
    },
    {
      "start": 182.159,
      "duration": 6.281,
      "text": "進めていきたいと考えておりますので是非"
    },
    {
      "start": 184.519,
      "duration": 3.921,
      "text": "ご協力のほどよろしくお願いいたし"
    },
    {
      "start": 190.72,
      "duration": 5.799,
      "text": "ますこれで私の職務は終了いたしました"
    },
    {
      "start": 193.879,
      "duration": 5.64,
      "text": "委員長と交代するためしばらく休憩いたし"
    },
    {
      "start": 196.519,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 216.12,
      "duration": 5.8,
      "text": "再開いたしますこれから区委員長のご選を"
    },
    {
      "start": 219.159,
      "duration": 5.16,
      "text": "行いますえご選の方法についてはいかが"
    },
    {
      "start": 221.92,
      "duration": 7.519,
      "text": "いたしましょうかどなたか選出方法につい"
    },
    {
      "start": 224.319,
      "duration": 8.241,
      "text": "てご意見がありませんかはいえガさん指名"
    },
    {
      "start": 229.439,
      "duration": 6.16,
      "text": "推薦でお願いいたしますただいま選出方法"
    },
    {
      "start": 232.56,
      "duration": 5.519,
      "text": "について指名推薦によるとのご意見があり"
    },
    {
      "start": 235.599,
      "duration": 4.64,
      "text": "ますが指名推薦により決定することにご"
    },
    {
      "start": 238.079,
      "duration": 4.36,
      "text": "異議ありませんか"
    },
    {
      "start": 240.239,
      "duration": 5.161,
      "text": "ご異議なしと認めただいま申し上げました"
    },
    {
      "start": 242.439,
      "duration": 6.561,
      "text": "通り決定いたしますどなたかご推薦"
    },
    {
      "start": 245.4,
      "duration": 8.399,
      "text": "いただけますかはいいさんあの一応委員会"
    },
    {
      "start": 249.0,
      "duration": 9.079,
      "text": "なんであ失礼し大変失礼しました"
    },
    {
      "start": 253.799,
      "duration": 10.561,
      "text": "えっと大変あの人柄も真面目で真摯でえ"
    },
    {
      "start": 258.079,
      "duration": 9.4,
      "text": "さらに経験のある方でえ初めての印象を"
    },
    {
      "start": 264.36,
      "duration": 5.92,
      "text": "務める安田さんをしっかりと補佐して"
    },
    {
      "start": 267.479,
      "duration": 4.481,
      "text": "いただけると思います鈴木さんを推薦し"
    },
    {
      "start": 270.28,
      "duration": 5.96,
      "text": "たいと思いますのでよろしくお願いいたし"
    },
    {
      "start": 271.96,
      "duration": 7.76,
      "text": "ますただいま鈴木茂夫委員を副委員長にと"
    },
    {
      "start": 276.24,
      "duration": 7.08,
      "text": "の推薦がございましたえお諮りいたします"
    },
    {
      "start": 279.72,
      "duration": 7.4,
      "text": "鈴木茂夫委員を副委員長に選出することに"
    },
    {
      "start": 283.32,
      "duration": 6.68,
      "text": "ご異議ありませんかご異議なしと認めます"
    },
    {
      "start": 287.12,
      "duration": 5.68,
      "text": "従ってただいま指名いたしました通り選出"
    },
    {
      "start": 290.0,
      "duration": 6.199,
      "text": "することに決定いたしましたただいま副"
    },
    {
      "start": 292.8,
      "duration": 4.959,
      "text": "委員長に選出された鈴木し委員のご挨拶を"
    },
    {
      "start": 296.199,
      "duration": 5.121,
      "text": "お願いいたし"
    },
    {
      "start": 297.759,
      "duration": 5.72,
      "text": "ますえとあのあるえ推薦の言葉をいただき"
    },
    {
      "start": 301.32,
      "duration": 6.04,
      "text": "ましてえ副委員長務めさせていただくこと"
    },
    {
      "start": 303.479,
      "duration": 5.801,
      "text": "になりましたあのまえっと委員長支え円滑"
    },
    {
      "start": 307.36,
      "duration": 4.36,
      "text": "な委員会の運営に務めてまいりたいと思い"
    },
    {
      "start": 309.28,
      "duration": 5.08,
      "text": "ますので委員各位の皆様におかれましても"
    },
    {
      "start": 311.72,
      "duration": 4.64,
      "text": "円滑なえ議事の運営ということでご協力"
    },
    {
      "start": 314.36,
      "duration": 4.2,
      "text": "いただければということでよろしくお願い"
    },
    {
      "start": 316.36,
      "duration": 2.2,
      "text": "いたし"
    },
    {
      "start": 319.36,
      "duration": 6.8,
      "text": "ますありがとうございます以上で予算特別"
    },
    {
      "start": 323.12,
      "duration": 5.359,
      "text": "委員会の会議を終了いたしますありがとう"
    },
    {
      "start": 326.16,
      "duration": 2.319,
      "text": "ございまし"
    },
    {
      "start": 328.639,
      "duration": 4.041,
      "text": "たJA"
    }
  ]
}