    {
      "start": 264.96,
      "duration": 4.16,
      "text": "はいお諮りいたします本件については議長"
    },
    {
      "start": 267.36,
      "duration": 5.04,
      "text": "の諮問の通り決定することにご異議あり"
    },
    {
      "start": 269.12,
      "duration": 6.56,
      "text": "ませんかご異議なしと認めます従って本件"
    },
    {
      "start": 272.4,
      "duration": 6.2,
      "text": "は議長の諮問の通り決定いたしました次に"
