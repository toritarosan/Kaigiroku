    {
      "start": 230.599,
      "duration": 4.72,
      "text": "ますはい"
    },
    {
      "start": 231.4,
      "duration": 6.679,
      "text": "局長はいえ本日までに決定しております"
    },
    {
      "start": 235.319,
      "duration": 5.801,
      "text": "議員派遣につきましてはお手元の資料の"
    },
    {
      "start": 238.079,
      "duration": 7.08,
      "text": "通りとなっております本件につきましては"
    },
    {
      "start": 241.12,
      "duration": 7.52,
      "text": "説明質委員会負託を省略して即決するまた"
    },
    {
      "start": 245.159,
      "duration": 6.44,
