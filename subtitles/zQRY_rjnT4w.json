    },
    {
      "start": 53.84,
      "duration": 4.679,
      "text": "でしょうかはいはいそれではえっと議員"
    },
    {
      "start": 56.239,
      "duration": 5.921,
      "text": "提出議案の討論採決について伺ってまいり"
    },
    {
      "start": 58.519,
      "duration": 6.241,
      "text": "ます自由自民党自由民主と信頼の古賀姉"
    },
    {
      "start": 62.16,
      "duration": 6.44,
      "text": "さんはいはいはい"
    },
    {
      "start": 64.76,
      "duration": 5.92,
      "text": "うんと悩んだ挙げ句なしですはい"
    },
    {
      "start": 68.6,
      "duration": 4.519,
      "text": "ありがとうございますえ未来の小金も討論"
    },
    {
      "start": 70.68,
      "duration": 3.68,
      "text": "なしでございますはい子供の権利を守るか"
    },
    {
      "start": 73.119,
      "duration": 7.201,
      "text": "さんはい"
    },
    {
      "start": 74.36,
      "duration": 9.2,
      "text": "えっと議案第29号のあの太陽光パネルの"
    },
    {
      "start": 80.32,
      "duration": 7.2,
      "text": "はいえ現象ですねこちらに賛成討論高木"
    },
    {
      "start": 83.56,
      "duration": 7.519,
      "text": "賛成高はい一見ありがとうございますはい"
    },
    {
      "start": 87.52,
      "duration": 8.84,
      "text": "じゃ日本共産党さんはいええっと議案第"
    },
    {
      "start": 91.079,
      "duration": 11.481,
      "text": "27号え反対討論です子供通制度ね反対"
    },
    {
      "start": 96.36,
      "duration": 10.64,
      "text": "はい意見おコメトさんよして議員案第31"
    },
    {
      "start": 102.56,
      "duration": 10.239,
      "text": "号大学学費の負担軽減を求める意見所にえ"
    },
    {
      "start": 107.0,
      "duration": 9.759,
      "text": "討論小林反対反対反対で小林さんはい意見"
    },
    {
      "start": 112.799,
      "duration": 7.92,
      "text": "はいではえ金を面白くする解さはい討論"
    },
    {
      "start": 116.759,
      "duration": 7.761,
      "text": "ありませんおはいえと単独会派他お願いし"
    },
    {
      "start": 120.719,
      "duration": 8.32,
      "text": "ます会派討論ありませんおということは"
    },
    {
      "start": 124.52,
      "duration": 7.2,
      "text": "全体で3件のみということですかねこんな"
    },
    {
      "start": 129.039,
      "duration": 7.041,
      "text": "に時間があるのに皆さんゆかしいですね"
    },
    {
      "start": 131.72,
      "duration": 6.799,
      "text": "そんなそ無理して言わなくはいではいえ回"
    },
    {
      "start": 136.08,
      "duration": 2.439,
      "text": "入ってり"
    },
    {
      "start": 141.08,
      "duration": 5.159,
      "text": "ますただいまから議会委員会の会議を開き"
    },
    {
      "start": 144.16,
      "duration": 4.12,
      "text": "ます直に議事に入ります当委員会に付託さ"
    },
    {
      "start": 146.239,
      "duration": 4.401,
      "text": "れております案件は議長の指紋事項一件で"
    },
    {
      "start": 148.28,
      "duration": 4.039,
      "text": "あります議長からお手元に議会運営委員会"
    },
    {
      "start": 150.64,
      "duration": 3.64,
      "text": "協議事項が提示されておりますのでその"
    },
    {
      "start": 152.319,
      "duration": 4.28,
      "text": "順序に従って順次協議をしてまいりたいと"
    },
    {
      "start": 154.28,
      "duration": 4.239,
      "text": "思います議会運営に関する議長の諮問事項"
    },
    {
      "start": 156.599,
      "duration": 5.041,
      "text": "についてを議題といたしますはめに競技"
    },
    {
      "start": 158.519,
      "duration": 5.281,
      "text": "事故1青函陳情の追加分の2先委員会に"
    },
    {
      "start": 161.64,
      "duration": 3.76,
      "text": "ついて行います議長の新聞案が示されて"
    },
    {
      "start": 163.8,
      "duration": 4.96,
      "text": "おりますので議長から説明をお願いいたし"
    },
    {
      "start": 165.4,
      "duration": 7.199,
      "text": "ますはい6月19日の午後5時までに"
    },
    {
      "start": 168.76,
      "duration": 6.559,
      "text": "受け付けました西岸陳情は新城11件です"
    },
    {
      "start": 172.599,
      "duration": 8.441,
      "text": "細部につきましては事務局から説明します"
    },
    {
      "start": 175.319,
      "duration": 8.881,
      "text": "局長はいえ6陳情第18号から6第28号"
    },
    {
      "start": 181.04,
      "duration": 6.96,
      "text": "までの先委員会につきましてはお手元の"
    },
    {
      "start": 184.2,
      "duration": 6.759,
      "text": "正眼陳情の委員会付託あ委員会委員会出し"
    },
    {
      "start": 188.0,
      "duration": 5.799,
      "text": "ました追加付託予定表かこ案の通りで"
    },
    {
      "start": 190.959,
      "duration": 6.56,
      "text": "ございますえなお発言申し出につきまして"
    },
    {
      "start": 193.799,
      "duration": 6.481,
      "text": "は委員会え前日の生後までに発言申し出が"
    },
    {
      "start": 197.519,
      "duration": 5.041,
      "text": "できますことを申し添えておきます以上の"
    },
    {
      "start": 200.28,
      "duration": 5.319,
      "text": "通り付託するというのが議長の諮問案で"
    },
    {
      "start": 202.56,
      "duration": 5.8,
      "text": "ございます議長及び事務局の説明は終わり"
    },
    {
      "start": 205.599,
      "duration": 5.881,
      "text": "ましたご意見ご質疑とございます"
    },
    {
      "start": 208.36,
      "duration": 5.959,
      "text": "かはいお諮りいたします本件についてはお"
    },
    {
      "start": 211.48,
      "duration": 4.88,
      "text": "手元に配布されております付託予定表かこ"
    },
    {
      "start": 214.319,
      "duration": 5.12,
      "text": "案の通り決定することにご異議ありません"
    },
    {
      "start": 216.36,
      "duration": 5.64,
      "text": "かご異議なしと認め正眼陳情の付託先委員"
    },
    {
      "start": 219.439,
      "duration": 5.281,
      "text": "会についてはお手元の予定表の通りと決定"
    },
    {
      "start": 222.0,
      "duration": 5.0,
      "text": "いたしました次に協議事項括弧に議員の"
    },
    {
      "start": 224.72,
      "duration": 3.799,
      "text": "派遣について行います議長の指紋案が示さ"
    },
    {
      "start": 227.0,
      "duration": 3.599,
      "text": "れておりますので議長から説明をお願い"
    },
    {
      "start": 228.519,
      "duration": 2.881,
      "text": "いたしますはいえ事務局から説明いたし"
