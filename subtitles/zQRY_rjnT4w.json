    {
      "start": 248.64,
      "duration": 7.599,
      "text": "中に議員派遣が生じた場合などについて"
    },
    {
      "start": 251.599,
      "duration": 7.6,
      "text": "その日次場所目的及び派遣議員名等は議長"
    },
    {
      "start": 256.239,
      "duration": 5.72,
      "text": "にご一任願いたいというのが議長の諮問案"
    },
    {
      "start": 259.199,
      "duration": 5.761,
      "text": "でございますはい議長及び事務局の説明は"
    },
    {
      "start": 261.959,
      "duration": 5.401,
      "text": "終わりましたご意見ご質疑等ございますか"
