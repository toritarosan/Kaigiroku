    {
      "start": 405.8,
      "duration": 6.519,
      "text": "配りしました議会報告会の開催のえチラシ"
    },
    {
      "start": 409.28,
      "duration": 6.0,
      "text": "をえ1人え100枚ということでお配りし"
    },
    {
      "start": 412.319,
      "duration": 5.6,
      "text": "ておりますのでえそれぞれにあの拡散をお"
