    {
      "start": 308.32,
      "duration": 5.4,
      "text": "預言をございますかはいえ以上で当委員会"
    },
    {
      "start": 312.12,
      "duration": 3.799,
      "text": "に付託されております案件の審査は全て"
    },
    {
      "start": 313.72,
      "duration": 4.56,
      "text": "終了いたしましたこれで議会委員会の会議"
