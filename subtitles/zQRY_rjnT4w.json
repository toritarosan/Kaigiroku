    {
      "start": 415.28,
      "duration": 7.08,
      "text": "願いいたしますえっとまたまリマインド"
    },
    {
      "start": 417.919,
      "duration": 9.161,
      "text": "ですけれども8月のええっと"
    },
    {
      "start": 422.36,
      "duration": 8.0,
      "text": "えっと20あごめんなさいえすいません"
    },
    {
      "start": 427.08,
