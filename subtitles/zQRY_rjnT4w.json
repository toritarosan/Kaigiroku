    {
      "start": 343.0,
      "duration": 5.8,
      "text": "にえホームページに公開したいと思って"
    },
    {
      "start": 345.8,
      "duration": 7.679,
      "text": "おりますで公表文書の内容は例年通りで"
    },
    {
      "start": 348.8,
      "duration": 9.48,
      "text": "ございますえまず収入支出報告書それから"
    },
    {
      "start": 353.479,
      "duration": 8.081,
      "text": "支出長所え収入支出整理簿それから最後が"
    },
    {
      "start": 358.28,
      "duration": 5.96,
      "text": "え領収書等の映しでございますえそれから"
    },
    {
      "start": 361.56,
      "duration": 6.16,
      "text": "議長交際費の支出打ち分けについても"
    },
    {
      "start": 364.24,
      "duration": 6.16,
      "text": "同じく公表したいと思っておりますえ報告"
    },
    {
      "start": 367.72,
      "duration": 5.599,
      "text": "は以上でございますはい以上の件について"
    },
    {
      "start": 370.4,
      "duration": 7.6,
      "text": "ご意見ご質疑とございますかよろしいです"
    },
    {
      "start": 373.319,
      "duration": 8.32,
      "text": "かはい片山副委員長はいえっとこれあの"
    },
    {
      "start": 378.0,
      "duration": 5.039,
      "text": "議会法にも次の議会法に乗せるということ"
    },
    {
      "start": 381.639,
      "duration": 5.68,
      "text": "になるんでしたっ"
    },
    {
      "start": 383.039,
      "duration": 7.521,
      "text": "けです長はいえおっしゃる通りでえと今回"
    },
    {
      "start": 387.319,
      "duration": 8.081,
      "text": "のえと会合にあの掲載するでございます"
    },
    {
      "start": 390.56,
      "duration": 8.44,
      "text": "以上ですはい他にございますかよはいそれ"
    },
    {
      "start": 395.4,
      "duration": 7.68,
      "text": "では次3番議会報告会についてでござい"
    },
    {
      "start": 399.0,
      "duration": 6.8,
      "text": "ますはい安はいいいですよね座ったままで"
    },
    {
      "start": 403.08,
      "duration": 6.2,
      "text": "座えっとすいません本日あの皆さんにお"
