    },
    {
      "start": 1216.48,
      "duration": 7.48,
      "text": "です市民の生活と営業に心を寄せた"
    },
    {
      "start": 1220.44,
      "duration": 7.119,
      "text": "さらなる支援が必要だったと考えますえ"
    },
    {
      "start": 1223.96,
      "duration": 6.68,
      "text": "今後の市民生活への支援強化を求めてえ"
    },
    {
      "start": 1227.559,
      "duration": 3.081,
      "text": "討論を終わります"
    },
    {
      "start": 1241.799,
      "duration": 8.801,
      "text": "次に本件に賛成のもの発言を許可します"
    },
    {
      "start": 1246.159,
      "duration": 4.441,
      "text": "17番渡辺富子議員"
    },
    {
      "start": 1253.71,
      "duration": 3.099,
      "text": "[音楽]"
    },
    {
      "start": 1261.24,
      "duration": 8.6,
      "text": "議案第32号一般会計補正予算第2"
    },
    {
      "start": 1265.52,
      "duration": 8.159,
      "text": "回えのにつきましてえ市議会公明党を代表"
    },
    {
      "start": 1269.84,
      "duration": 7.88,
      "text": "して賛成の立場から討論を行います本補正"
    },
    {
      "start": 1273.679,
      "duration": 6.88,
      "text": "予算には国や東京都が物価高等対策や"
    },
    {
      "start": 1277.72,
      "duration": 6.28,
      "text": "子育て支援策として用意した財源を"
    },
    {
      "start": 1280.559,
      "duration": 7.0,
      "text": "キャッチし他世代の市民生活を守るための"
    },
    {
      "start": 1284.0,
      "duration": 5.24,
      "text": "予算が盛り込まれており有効的な活用を"
    },
    {
      "start": 1287.559,
      "duration": 6.441,
      "text": "期待いたします"
    },
    {
      "start": 1289.24,
      "duration": 8.28,
      "text": "中でも公明党が子供若者政策として全国で"
    },
    {
      "start": 1294.0,
      "duration": 6.84,
      "text": "行ったアンケート調査をもに2022年"
    },
    {
      "start": 1297.52,
      "duration": 7.519,
      "text": "11月に発表した子育て応援トータル"
    },
    {
      "start": 1300.84,
      "duration": 8.24,
      "text": "プランに基づき政府が2023年12月に"
    },
    {
      "start": 1305.039,
      "duration": 7.401,
      "text": "閣議決定した子供未来戦略加速化プランの"
    },
    {
      "start": 1309.08,
      "duration": 7.839,
      "text": "本格実施に向けての全身の一歩が含まれて"
    },
    {
      "start": 1312.44,
      "duration": 7.76,
      "text": "おります同プランには結婚妊娠出産から"
    },
    {
      "start": 1316.919,
      "duration": 7.721,
      "text": "子供が社会に育つまでの切れ目ない支援策"
    },
    {
      "start": 1320.2,
      "duration": 9.12,
      "text": "が示されており今後実行する子供若者政策"
    },
    {
      "start": 1324.64,
      "duration": 8.32,
      "text": "を一元化した政府の子供真ん中実行計画"
    },
    {
      "start": 1329.32,
      "duration": 7.04,
      "text": "2024にも具体的内容が盛り込まれて"
    },
    {
      "start": 1332.96,
      "duration": 6.76,
      "text": "いるものです本補正予算に計上されている"
    },
    {
      "start": 1336.36,
      "duration": 7.28,
      "text": "経費の中では子供家庭センター運営に"
    },
    {
      "start": 1339.72,
      "duration": 7.8,
      "text": "要する経費として親子遊び広場ゆりかごに"
    },
    {
      "start": 1343.64,
      "duration": 7.12,
      "text": "おける地域子育て相談機関設置事業があり"
    },
    {
      "start": 1347.52,
      "duration": 6.88,
      "text": "ます安心して子供を産み育てることが"
    },
    {
      "start": 1350.76,
      "duration": 8.0,
      "text": "できるよう全ての妊婦子供子育て家庭を"
    },
    {
      "start": 1354.4,
      "duration": 7.84,
      "text": "支援する伴奏型相談支援体制を作り状況に"
    },
    {
      "start": 1358.76,
      "duration": 7.039,
      "text": "よっては専門機関につなげるもので子供が"
    },
    {
      "start": 1362.24,
      "duration": 7.28,
      "text": "18歳になるまで括り付け相談機関として"
    },
    {
      "start": 1365.799,
      "duration": 7.48,
      "text": "継続しての支援が期待できますまた多様な"
    },
    {
      "start": 1369.52,
      "duration": 7.92,
      "text": "他社との関わりの機械喪失事業では"
    },
    {
      "start": 1373.279,
      "duration": 8.64,
      "text": "2026年から始まる誰でも通園制度実施"
    },
    {
      "start": 1377.44,
      "duration": 9.44,
      "text": "に向けて幼稚園保育園の今課題の共有にも"
    },
    {
      "start": 1381.919,
      "duration": 9.76,
      "text": "なるものと考えます一方保育施策保育施設"
    },
    {
      "start": 1386.88,
      "duration": 8.279,
      "text": "運営事業継続支援金事業でえ自衛調理に"
    },
    {
      "start": 1391.679,
      "duration": 7.321,
      "text": "おける食材費補助が計上されておりますが"
    },
    {
      "start": 1395.159,
      "duration": 6.64,
      "text": "物価高等に苦しむのはお弁当を自賛するご"
    },
    {
      "start": 1399.0,
      "duration": 7.159,
      "text": "家庭においても変わるものではありません"
    },
    {
      "start": 1401.799,
      "duration": 7.641,
      "text": "今後は幼稚園などに通われお弁当や自宅で"
    },
    {
      "start": 1406.159,
      "duration": 6.361,
      "text": "お昼を食べているご家庭に対する食材費の"
    },
    {
      "start": 1409.44,
      "duration": 6.359,
      "text": "補助についても検討するべきであることは"
    },
    {
      "start": 1412.52,
      "duration": 8.48,
      "text": "申し上げておきます提案されたいずれの"
    },
    {
      "start": 1415.799,
      "duration": 8.88,
      "text": "施策も市民生活を守り孤立し不安を抱えた"
    },
    {
      "start": 1421.0,
      "duration": 6.84,
      "text": "抱えた子育て家庭に寄り添う支援であり誰"
    },
    {
      "start": 1424.679,
      "duration": 7.36,
      "text": "1人取り残されない社会の実現に向けた"
    },
    {
      "start": 1427.84,
      "duration": 8.56,
      "text": "大きな前進となることから本補正"
    },
    {
      "start": 1432.039,
      "duration": 8.201,
      "text": "予算本補正予算経常の意義に賛同し賛成"
    },
    {
      "start": 1436.4,
      "duration": 3.84,
      "text": "討論といたします"
    },
    {
      "start": 1451.279,
      "duration": 6.921,
      "text": "次に本件に賛成なのもの発言を許可します"
    },
    {
      "start": 1454.88,
      "duration": 3.32,
      "text": "6番水谷貴子"
    },
    {
      "start": 1461.72,
      "duration": 7.559,
      "text": "議員"
    },
    {
      "start": 1463.76,
      "duration": 8.639,
      "text": "オ議案第32号令和6年度古一般会計補正"
    },
    {
      "start": 1469.279,
      "duration": 6.721,
      "text": "予算第2回について小金を面白くする回と"
    },
    {
      "start": 1472.399,
      "duration": 8.28,
      "text": "して賛成の立場から討論する今回の補正"
    },
    {
      "start": 1476.0,
      "duration": 8.52,
      "text": "予算は国やとの交付金補助金を活用し物価"
    },
    {
      "start": 1480.679,
      "duration": 7.0,
      "text": "高等等の影響を受ける市民や事業者を支援"
    },
    {
      "start": 1484.52,
      "duration": 6.92,
      "text": "する予算であり賛成するその主な理由を3"
    },
    {
      "start": 1487.679,
      "duration": 6.841,
      "text": "点述べるまず1点目として多様な他社との"
    },
    {
      "start": 1491.44,
      "duration": 6.2,
      "text": "関わりの機会の創出事業が新設されたこと"
    },
    {
      "start": 1494.52,
      "duration": 7.039,
      "text": "を評価するこれまで小金を面白くする回と"
    },
    {
      "start": 1497.64,
      "duration": 6.919,
      "text": "して未衆園児とその保護者が地域と"
    },
    {
      "start": 1501.559,
      "duration": 5.6,
      "text": "つながり子育てする仕組みづくりに積極的"
    },
    {
      "start": 1504.559,
      "duration": 6.12,
      "text": "に取り組んで欲しいとしていわゆるみんな"
    },
    {
      "start": 1507.159,
      "duration": 7.24,
      "text": "の保育園や毎保育園制度などの活用をしに"
    },
    {
      "start": 1510.679,
      "duration": 7.921,
      "text": "提案してきておりえ昨年度国からは誰でも"
    },
    {
      "start": 1514.399,
      "duration": 7.041,
      "text": "通園制度が示された際思考などに積極的に"
    },
    {
      "start": 1518.6,
      "duration": 6.199,
      "text": "手を上げてほしいと提案してきたが保育の"
    },
    {
      "start": 1521.44,
      "duration": 6.04,
      "text": "現場では保育室の確保や保育士の配置等の"
    },
    {
      "start": 1524.799,
      "duration": 7.36,
      "text": "課題があることから難しいとの見解であっ"
    },
    {
      "start": 1527.48,
      "duration": 8.6,
      "text": "た今回国に先行してとがせ創設した本事業"
    },
    {
      "start": 1532.159,
      "duration": 6.721,
      "text": "では施設の回収費等も含まれていることや"
    },
    {
      "start": 1536.08,
      "duration": 6.16,
      "text": "費用負担が都の1010であることなど"
    },
    {
      "start": 1538.88,
      "duration": 6.2,
      "text": "利用しやすいスキームが示されたことでえ"
    },
    {
      "start": 1542.24,
      "duration": 6.48,
      "text": "これを前向きに受け止めて"
    },
    {
      "start": 1545.08,
      "duration": 7.44,
      "text": "いる失礼しました示されたことでこれを"
    },
    {
      "start": 1548.72,
      "duration": 6.8,
      "text": "活用したいという民間幼稚園等とも調整し"
    },
    {
      "start": 1552.52,
      "duration": 6.279,
      "text": "ながら早期に実現されることを前向きに"
    },
    {
      "start": 1555.52,
      "duration": 6.72,
      "text": "受け止めているまたえ2点目と"
    },
    {
      "start": 1558.799,
      "duration": 6.48,
      "text": "認証保育書の修繕費に対する補助金制度の"
    },
    {
      "start": 1562.24,
      "duration": 6.88,
      "text": "創設についても評価しているこの補助金に"
    },
    {
      "start": 1565.279,
      "duration": 7.921,
      "text": "関する陳情を審査する中で近隣士の状況の"
    },
    {
      "start": 1569.12,
      "duration": 8.12,
      "text": "調査等を行い国の制度である認可保育園に"
    },
    {
      "start": 1573.2,
      "duration": 7.04,
      "text": "対し本市が行ってきた補助金制度ととの"
    },
    {
      "start": 1577.24,
      "duration": 6.679,
      "text": "制度である認証保育書に対する補助金制度"
    },
    {
      "start": 1580.24,
      "duration": 6.84,
      "text": "等の内容を考慮すれば本補助金の創設は"
    },
    {
      "start": 1583.919,
      "duration": 7.321,
      "text": "必要であると考えるもので今回それが実現"
    },
    {
      "start": 1587.08,
      "duration": 8.079,
      "text": "されることを評価しているそして3点目は"
    },
    {
      "start": 1591.24,
      "duration": 7.76,
      "text": "学校給食費については食材費の高等などが"
    },
    {
      "start": 1595.159,
      "duration": 7.361,
      "text": "続く中栄養士などの現場の職員のご努力が"
    },
    {
      "start": 1599.0,
      "duration": 7.12,
      "text": "続いてきたそうした中今般との1/2の"
    },
    {
      "start": 1602.52,
      "duration": 6.84,
      "text": "補助金を活用することで物価高等分を補填"
    },
    {
      "start": 1606.12,
      "duration": 7.0,
      "text": "し保護者負担を増やすことなくおいしく"
    },
    {
      "start": 1609.36,
      "duration": 6.6,
      "text": "安全な給食を提供し続けることを評価する"
    },
    {
      "start": 1613.12,
      "duration": 5.72,
      "text": "さらに既に実施している学校で公表を得て"
    },
    {
      "start": 1615.96,
      "duration": 6.199,
      "text": "いる別室指導の拡充やエデュケーション"
    },
    {
      "start": 1618.84,
      "duration": 8.68,
      "text": "アシスタントの配置と学校教育環境の充実"
    },
    {
      "start": 1622.159,
      "duration": 9.161,
      "text": "に活用するものでえ歓迎する最後に国から"
    },
    {
      "start": 1627.52,
      "duration": 6.84,
      "text": "示された定額減税及びそれを補足する給付"
    },
    {
      "start": 1631.32,
      "duration": 6.12,
      "text": "金制度については地方自治体の事務負担が"
    },
    {
      "start": 1634.36,
      "duration": 6.12,
      "text": "非常に大きく疑問を感じざるを得ないが"
    },
    {
      "start": 1637.44,
      "duration": 5.839,
      "text": "時間がない中で懸命に対応されている職員"
    },
    {
      "start": 1640.48,
      "duration": 6.84,
      "text": "の皆様には感謝申し上げる以上をもって"
    },
    {
      "start": 1643.279,
      "duration": 4.041,
      "text": "賛成の討論とする"
    },
    {
      "start": 1652.36,
      "duration": 7.319,
      "text": "以上で討論を終了します本件については"
    },
    {
      "start": 1656.08,
      "duration": 7.8,
      "text": "起立採決をします本件についての予算特別"
    },
    {
      "start": 1659.679,
      "duration": 8.041,
      "text": "委員長の報告は原案可決ですお諮りします"
    },
    {
      "start": 1663.88,
      "duration": 7.2,
      "text": "本件は原案の通り可決することに賛成の皆"
    },
    {
      "start": 1667.72,
      "duration": 3.36,
      "text": "さんの起立を求め"
    },
    {
      "start": 1672.159,
      "duration": 4.961,
      "text": "ます員立"
    },
    {
      "start": 1675.0,
      "duration": 4.2,
      "text": "全員本"
    },
    {
      "start": 1677.12,
      "duration": 5.72,
      "text": "は定しまし"
    },
    {
      "start": 1679.2,
      "duration": 7.04,
      "text": "たお諮りしますお手元にご配布してあり"
    },
    {
      "start": 1682.84,
      "duration": 7.0,
      "text": "ます通り追加日程第1から追加日程第18"
    },
    {
      "start": 1686.24,
      "duration": 6.439,
      "text": "までの18件を日程に追加し順次議題とし"
    },
    {
      "start": 1689.84,
      "duration": 6.4,
      "text": "ますこれにご異議ありませんかご異議なし"
    },
    {
      "start": 1692.679,
      "duration": 7.281,
      "text": "と認め追加日程第1から追加日程第18"
    },
    {
      "start": 1696.24,
      "duration": 7.84,
      "text": "までの18件を日程に追加し順次議題と"
    },
    {
      "start": 1699.96,
      "duration": 7.439,
      "text": "することと決定しました追加日程第1小金"
    },
    {
      "start": 1704.08,
      "duration": 7.4,
      "text": "市議会議員の政治倫理に関する条例第5条"
    },
    {
      "start": 1707.399,
      "duration": 8.64,
      "text": "の弁名についてを議題といたします14番"
    },
    {
      "start": 1711.48,
      "duration": 4.559,
      "text": "古畑俊議員の登壇を求め"
    },
    {
      "start": 1724.0,
      "duration": 3.2,
      "text": "ますはい"
    },
    {
      "start": 1731.919,
      "duration": 9.36,
      "text": "どうぞ小金深海議員の政治倫理に関する"
    },
    {
      "start": 1736.08,
      "duration": 9.36,
      "text": "条例第5条に基づく弁名をいたしますこと"
    },
    {
      "start": 1741.279,
      "duration": 9.601,
      "text": "の発端は今回市民から出された政務活動費"
    },
    {
      "start": 1745.44,
      "duration": 8.959,
      "text": "の情報公開を求める陳情書の指摘内容が私"
    },
    {
      "start": 1750.88,
      "duration": 6.36,
      "text": "古畑俊男が会派ニュースとして発行した"
    },
    {
      "start": 1754.399,
      "duration": 7.0,
      "text": "ものが対象になっているのではないかと"
    },
    {
      "start": 1757.24,
      "duration": 9.0,
      "text": "いう指摘が開放でありましたこのことに"
    },
    {
      "start": 1761.399,
      "duration": 9.76,
      "text": "より今回私は初当選以来令和3年度から3"
    },
    {
      "start": 1766.24,
      "duration": 8.0,
      "text": "年間にわり活動費における安分ルールを"
    },
    {
      "start": 1771.159,
      "duration": 7.52,
      "text": "知らなかったことから会派ニュース発行"
    },
    {
      "start": 1774.24,
      "duration": 9.159,
      "text": "経費について公費の重とが適切ではない"
    },
    {
      "start": 1778.679,
      "duration": 8.48,
      "text": "部分にも政務活動費を充当して収支報告を"
    },
    {
      "start": 1783.399,
      "duration": 6.441,
      "text": "していたと認識するに至りました誠に"
    },
    {
      "start": 1787.159,
      "duration": 7.481,
      "text": "申し訳ございませんでし"
    },
    {
      "start": 1789.84,
      "duration": 5.8,
      "text": "た以下政務活動費の変換額について説明"
    },
    {
      "start": 1794.64,
      "duration": 5.84,
      "text": "いたし"
    },
    {
      "start": 1795.64,
      "duration": 9.759,
      "text": "ますまず政務活動費として公費の重東が"
    },
    {
      "start": 1800.48,
      "duration": 10.16,
      "text": "適切ではなかった見出し部分と自己紹介等"
    },
    {
      "start": 1805.399,
      "duration": 9.28,
