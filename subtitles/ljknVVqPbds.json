    },
    {
      "start": 112.28,
      "duration": 5.839,
      "text": "再開します休憩中に議会運委員会を開催し"
    },
    {
      "start": 115.52,
      "duration": 6.32,
      "text": "ていますので議会運委員長の報告を求め"
    },
    {
      "start": 118.119,
      "duration": 3.721,
      "text": "ます3番岸田"
    },
    {
      "start": 125.0,
      "duration": 5.56,
      "text": "長休憩中に議会営委員会を開催いたしまし"
    },
    {
      "start": 128.44,
      "duration": 6.519,
      "text": "たのでその結果についてご報告いたします"
    },
    {
      "start": 130.56,
      "duration": 8.08,
      "text": "初めに令和6年6月19日付けで14番"
    },
    {
      "start": 134.959,
      "duration": 6.081,
      "text": "古畑俊議員から議長宛てに弁名申し出書が"
    },
    {
      "start": 138.64,
      "duration": 5.319,
      "text": "提出されましたのでその取り扱いについて"
    },
    {
      "start": 141.04,
      "duration": 5.64,
      "text": "協議いたしましたその結果本件については"
    },
    {
      "start": 143.959,
      "duration": 6.56,
      "text": "本日の本会議に上帝し議題とすることと"
    },
    {
      "start": 146.68,
      "duration": 6.639,
      "text": "決定いたしました次に議員提出議案と意見"
    },
    {
      "start": 150.519,
      "duration": 5.121,
      "text": "書15件決議2件が提出されましたので"
    },
    {
      "start": 153.319,
      "duration": 6.521,
      "text": "その取り扱いについて協議いたしました"
    },
    {
      "start": 155.64,
      "duration": 7.16,
      "text": "その結果議案第17号から議案第33号の"
    },
    {
      "start": 159.84,
      "duration": 6.52,
      "text": "計17件につきましては本日の本会議に"
    },
    {
      "start": 162.8,
      "duration": 5.88,
      "text": "上帝し説明質疑委員会負託を省略し即決"
    },
    {
      "start": 166.36,
      "duration": 4.84,
      "text": "することと決定いたしました以上で議会"
    },
    {
      "start": 168.68,
      "duration": 4.52,
      "text": "運営委員会の報告を終了いたします議会"
    },
    {
      "start": 171.2,
      "duration": 4.56,
      "text": "運営委員長の報告に対して議はありません"
    },
    {
      "start": 173.2,
      "duration": 6.28,
      "text": "か質疑を終了することにご異議ありません"
    },
    {
      "start": 175.76,
      "duration": 5.72,
      "text": "かご異議なしと認め質疑を終了し議会委員"
    },
    {
      "start": 179.48,
      "duration": 5.8,
      "text": "長のの報告を終了し"
    },
    {
      "start": 181.48,
      "duration": 6.6,
      "text": "ますお諮りします議会運委員長の報告通り"
    },
    {
      "start": 185.28,
      "duration": 5.319,
      "text": "決定することにご異議ありませんかご議"
    },
    {
      "start": 188.08,
      "duration": 5.92,
      "text": "なしの認め議会運営委員長の報告通り決定"
    },
    {
      "start": 190.599,
      "duration": 8.161,
      "text": "しましたここで先ほど保留しました日程第"
    },
    {
      "start": 194.0,
      "duration": 7.92,
      "text": "1日程第2日程第4日程第5日程第8から"
    },
    {
      "start": 198.76,
