{
  "entries": [
    {
      "start": 35.559,
      "duration": 3.801,
      "text": "それではあのこの後開催し"
    },
    {
      "start": 57.68,
      "duration": 4.24,
      "text": "ますはいじゃ行きましょう"
    },
    {
      "start": 63.239,
      "duration": 6.721,
      "text": "再開します市長より発言がありますはい"
    },
    {
      "start": 66.32,
      "duration": 6.76,
      "text": "市長え調整にお時間をえいただくことと"
    },
    {
      "start": 69.96,
      "duration": 6.0,
      "text": "なりえまとに申し訳ございませんえ視聴"
    },
    {
      "start": 73.08,
      "duration": 5.039,
      "text": "報告の中でご指摘をいだいた部分について"
    },
    {
      "start": 75.96,
      "duration": 3.519,
      "text": "えま様々なご意見をいただいたところで"
    },
    {
      "start": 78.119,
      "duration": 5.201,
      "text": "あります"
    },
    {
      "start": 79.479,
      "duration": 6.121,
      "text": "え整理が必要でございますのでえそのお"
    },
    {
      "start": 83.32,
      "duration": 6.08,
      "text": "時間をいただきた存じ"
    },
    {
      "start": 85.6,
      "duration": 6.559,
      "text": "ますえ今後の日程続きの日程につきまして"
    },
    {
      "start": 89.4,
      "duration": 5.92,
      "text": "はえ議長と相談をさせていただきます"
    },
    {
      "start": 92.159,
      "duration": 6.561,
      "text": "よろしくお願いいたしますただいま市長"
    },
    {
      "start": 95.32,
      "duration": 6.28,
      "text": "報告の質疑の途中ですが保留と本日の会議"
    },
    {
      "start": 98.72,
      "duration": 5.52,
      "text": "は議事の都合によりこの程度にとめこれを"
    },
    {
      "start": 101.6,
      "duration": 5.0,
      "text": "持って宴会することにご異議ありませんか"
    },
    {
      "start": 104.24,
      "duration": 5.04,
      "text": "ご異議なしと認め宴会することと決定し"
    },
    {
      "start": 106.6,
      "duration": 5.68,
      "text": "ました本日は本日はこれを持って宴会し"
    },
    {
      "start": 109.28,
      "duration": 3.0,
      "text": "ます"
    }
  ]
}