      "text": "感じてましてであのま前回1年前も確か"
    },
    {
      "start": 493.0,
      "duration": 6.12,
      "text": "出されたあの条例だったと思うんですが今"
    },
    {
      "start": 496.08,
      "duration": 6.16,
      "text": "前提条件も変わっているっていうあの状況"
    },
    {
      "start": 499.12,
      "duration": 6.919,
      "text": "もありで私たちの会派のところはですね"
    },
    {
      "start": 502.24,
      "duration": 6.6,
      "text": "議案送付前に市長から一応メールであの"
    },
    {
      "start": 506.039,
      "duration": 5.28,
      "text": "出しますって話はあったんですがま今日は"
    },
    {
      "start": 508.84,
      "duration": 6.559,
      "text": "ある程度のよろしくお願いしたいという"
    },
    {
      "start": 511.319,
      "duration": 7.041,
      "text": "ことであの簡単な説明を受けましたただ"
    },
    {
      "start": 515.399,
      "duration": 5.64,
      "text": "あの今あの議会会議中であの今日も予算"
    },
    {
      "start": 518.36,
      "duration": 7.08,
      "text": "特別委員会がま開かれるっていうことに"
    },
    {
      "start": 521.039,
      "duration": 7.641,
      "text": "なるとま本来であれば予算特別委員会また"
    },
    {
      "start": 525.44,
      "duration": 5.72,
      "text": "公生文教委員会などでましっかり質疑を"
    },
    {
      "start": 528.68,
      "duration": 5.68,
      "text": "する必要がある案件だっていう風に思うん"
    },
    {
      "start": 531.16,
      "duration": 6.72,
      "text": "ですねだからこれがですねこういうその"
    },
    {
      "start": 534.36,
      "duration": 6.24,
      "text": "あの最終本会議あの即決みたいな形で出て"
    },
    {
      "start": 537.88,
      "duration": 5.16,
      "text": "くるのはちょっとねね提案姿勢としては"
    },
    {
      "start": 540.6,
      "duration": 5.239,
      "text": "問題あるんじゃないかなっていう風にあの"
    },
    {
      "start": 543.04,
      "duration": 5.799,
      "text": "感じてるんですがその辺ちょっとあの部局"
    },
    {
      "start": 545.839,
      "duration": 5.56,
      "text": "としてはどういう風に考えてるのかあと"
    },
    {
      "start": 548.839,
      "duration": 7.161,
      "text": "市長からあのこういう送付されてます"
    },
    {
      "start": 551.399,
      "duration": 7.321,
      "text": "けれども今回のそのえっと案件については"
    },
    {
      "start": 556.0,
      "duration": 6.279,
      "text": "要するに可決するっていう見通しを持って"
    },
    {
      "start": 558.72,
      "duration": 6.799,
      "text": "あの提案されてるのかどうか前回はあの方"
    },
    {
      "start": 562.279,
      "duration": 6.201,
      "text": "検討委員会については否決されていて"
    },
    {
      "start": 565.519,
      "duration": 5.841,
      "text": "私たちも前回と同じ態度を取るかっていう"
    },
    {
      "start": 568.48,
      "duration": 5.72,
      "text": "のはまだあの結論出てないんですね前提"
    },
    {
      "start": 571.36,
      "duration": 5.88,
      "text": "条件も関わってるのでそういう中である"
    },
    {
      "start": 574.2,
      "duration": 5.319,
      "text": "程度のそのあのなんていうかあの可決の"
    },
    {
      "start": 577.24,
      "duration": 4.08,
      "text": "見通し持たれて提案されてい"
    },
    {
      "start": 579.519,
      "duration": 3.961,
      "text": "るっていうことなのかどうかその辺"
    },
    {
      "start": 581.32,
      "duration": 4.56,
      "text": "ちょっと市長から何か聞いていることが"
    },
    {
      "start": 583.48,
      "duration": 3.76,
      "text": "あれば伺いたいと思うんですがいかが"
    },
    {
      "start": 585.88,
      "duration": 4.36,
      "text": "でしょう"
    },
    {
      "start": 587.24,
      "duration": 3.0,
      "text": "か"
    },
    {
      "start": 590.36,
      "duration": 7.76,
      "text": "ない総"
    },
    {
      "start": 592.959,
      "duration": 7.841,
      "text": "部長はいえっとまずあの案第31号につき"
    },
    {
      "start": 598.12,
      "duration": 5.92,
      "text": "ましては4月尾ということでございまして"
    },
    {
      "start": 600.8,
      "duration": 5.56,
      "text": "えっとこの時期の提案でございますのでえ"
    },
    {
      "start": 604.04,
      "duration": 5.84,
      "text": "えっと日程を考えますと即決ということで"
    },
    {
      "start": 606.36,
      "duration": 7.599,
      "text": "お願いをしてございますえそれから市長"
    },
    {
      "start": 609.88,
      "duration": 6.24,
      "text": "からは今後責任を持って各会派に説明に"
    },
    {
      "start": 613.959,
      "duration": 4.88,
      "text": "回らせていただきたいと聞いてございます"
    },
    {
      "start": 616.12,
      "duration": 5.48,
      "text": "のでよろしくお願いいたしますそれから"
    },
    {
      "start": 618.839,
      "duration": 5.521,
      "text": "最後でございますが可決についてえ努力を"
    },
    {
      "start": 621.6,
      "duration": 5.919,
      "text": "させて精一杯の努力をさせていただきたい"
    },
    {
      "start": 624.36,
      "duration": 7.56,
      "text": "ということでございます以上です"
    },
    {
      "start": 627.519,
      "duration": 7.601,
      "text": "はいま一応あの総務部長からあの説明が"
    },
    {
      "start": 631.92,
      "duration": 7.0,
      "text": "ありましたけれどもやっぱり本来であれば"
    },
    {
      "start": 635.12,
      "duration": 8.279,
      "text": "もう丁寧にやっぱりその説明するなり本来"
    },
    {
      "start": 638.92,
      "duration": 7.64,
      "text": "であれば私はまあの予算特別委員会にあの"
    },
    {
      "start": 643.399,
      "duration": 6.601,
      "text": "付託をするとかという形で進めるべきだっ"
    },
    {
      "start": 646.56,
      "duration": 5.68,
      "text": "たと思うんですがあの各会派回ってま説明"
    },
    {
      "start": 650.0,
      "duration": 4.8,
      "text": "するっていうことだったんですがちょっと"
    },
    {
      "start": 652.24,
      "duration": 4.76,
      "text": "進め方としては非常に接続だなっていう"
    },
    {
      "start": 654.8,
      "duration": 7.64,
      "text": "ことはちょっと意見として申し上げておき"
    },
    {
      "start": 657.0,
      "duration": 8.079,
      "text": "たいと思います以上ですかはい福長はいあ"
    },
    {
      "start": 662.44,
      "duration": 5.199,
      "text": "はいあの今水上さんが質疑してくださった"
    },
    {
      "start": 665.079,
      "duration": 6.961,
      "text": "わけなんですけれどもあの私もですねこの"
    },
    {
      "start": 667.639,
      "duration": 7.361,
      "text": "あの3030号というか31号ですね30"
    },
    {
      "start": 672.04,
      "duration": 5.919,
      "text": "号については全くあの出すも出さないも話"
    },
    {
      "start": 675.0,
      "duration": 6.16,
      "text": "もなかったと思いますけれどもえで31号"
    },
    {
      "start": 677.959,
      "duration": 6.521,
      "text": "についてはあのなんかあの自転車置場で"
    },
    {
      "start": 681.16,
      "duration": 5.96,
      "text": "後ろにからあの市長がな声かけてちょっと"
    },
    {
      "start": 684.48,
      "duration": 5.4,
      "text": "立ち話なんだけどありけどう思うみたいな"
    },
    {
      "start": 687.12,
      "duration": 6.12,
      "text": "そん中ぐらいしかですよねあの聞いてない"
    },
    {
      "start": 689.88,
      "duration": 5.84,
      "text": "んですねであのまこれですねえきちんと"
    },
    {
      "start": 693.24,
      "duration": 4.76,
      "text": "やっぱりこういったものについてはあの"
    },
    {
      "start": 695.72,
      "duration": 5.16,
      "text": "中身はこういうものであるとかですねまた"
    },
    {
      "start": 698.0,
      "duration": 6.12,
      "text": "あの議案送付する前に本来は議案を送付"
    },
    {
      "start": 700.88,
      "duration": 5.6,
      "text": "する前にこれあの各担当からですね"
    },
    {
      "start": 704.12,
      "duration": 4.56,
      "text": "きちんとした説明をすべきだと私は思って"
    },
    {
      "start": 706.48,
      "duration": 4.159,
      "text": "ますでまたこれ予算もあるわけですから"
    },
    {
      "start": 708.68,
      "duration": 5.159,
      "text": "この予算も含めてやっぱりきちんとした"
    },
    {
      "start": 710.639,
      "duration": 7.44,
      "text": "説明がされるべきだと思いますあのそれが"
    },
    {
      "start": 713.839,
      "duration": 7.841,
      "text": "ねなかったのについてはですねまあの今え"
    },
    {
      "start": 718.079,
      "duration": 5.641,
      "text": "これからえ各会派に回りますということで"
    },
    {
      "start": 721.68,
      "duration": 4.48,
      "text": "はあったんですがなぜそういうことになっ"
    },
    {
      "start": 723.72,
      "duration": 5.239,
      "text": "てしまったのかということについてはどの"
    },
    {
      "start": 726.16,
      "duration": 4.799,
      "text": "ようにあの把握されてるんでしょうかあの"
    },
    {
      "start": 728.959,
      "duration": 4.761,
      "text": "まこれちょっとねこないだも指定条例で"
    },
    {
      "start": 730.959,
      "duration": 4.281,
      "text": "そういった色々と揉めとあのあったわけな"
    },
    {
      "start": 733.72,
      "duration": 4.44,
      "text": "んですけれどもそういったことがあり"
    },
    {
      "start": 735.24,
      "duration": 6.32,
      "text": "ながらもですねまたこういった形でこの"
    },
    {
      "start": 738.16,
      "duration": 5.679,
      "text": "原案送付前のまきちんとした説明がない"
    },
    {
      "start": 741.56,
      "duration": 5.68,
      "text": "まま送付されるというようなことについて"
    },
    {
      "start": 743.839,
      "duration": 5.881,
      "text": "は私はちょっとですねまあ一あのま前回と"
    },
    {
      "start": 747.24,
      "duration": 4.68,
      "text": "違うのはね一応あの予告はだってことは"
    },
    {
      "start": 749.72,
      "duration": 4.559,
      "text": "ありますよこういったものを送付したいっ"
    },
    {
      "start": 751.92,
      "duration": 5.039,
      "text": "ていう意向は聞いてますただですね"
    },
    {
      "start": 754.279,
      "duration": 4.8,
      "text": "やっぱりそれ意行だけじゃなくってあの"
    },
    {
      "start": 756.959,
      "duration": 4.56,
      "text": "もし即決を求めるんであればですね"
    },
    {
      "start": 759.079,
      "duration": 4.921,
      "text": "なおさらきちんとした説明をすべきだと"
    },
    {
      "start": 761.519,
      "duration": 4.601,
      "text": "思うんですよでそういったことも含めての"
    },
    {
      "start": 764.0,
      "duration": 4.639,
      "text": "予告をすべきだと思うんですねま今後"
    },
    {
      "start": 766.12,
      "duration": 4.8,
      "text": "きちんとあの回らせていただいてあの"
    },
    {
      "start": 768.639,
      "duration": 5.961,
      "text": "きちんとして説明をしますとかそういった"
    },
    {
      "start": 770.92,
      "duration": 5.24,
      "text": "風なことをすべきなんではないでしょうか"
    },
    {
      "start": 774.6,
      "duration": 5.84,
      "text": "でです"
    },
    {
      "start": 776.16,
      "duration": 7.479,
      "text": "ねでまたあのえあの今日予備日ということ"
    },
    {
      "start": 780.44,
      "duration": 6.959,
      "text": "で今日あの本会議もあの開けるわけですよ"
    },
    {
      "start": 783.639,
      "duration": 5.801,
      "text": "であのまえあの厚生文教委員会もですね"
    },
    {
      "start": 787.399,
      "duration": 5.081,
      "text": "予算委員会も残ってるということもあり"
    },
    {
      "start": 789.44,
      "duration": 5.199,
      "text": "ましてま今日ですね予算あの本会議を開い"
    },
    {
      "start": 792.48,
      "duration": 4.599,
      "text": "て委員会付託ということについてはなぜ"
    },
    {
      "start": 794.639,
      "duration": 4.841,
      "text": "やらなかったのかということについては"
    },
    {
      "start": 797.079,
      "duration": 5.601,
      "text": "改めて確認をしておきたいと思いますあの"
    },
    {
      "start": 799.48,
      "duration": 6.32,
      "text": "まやっぱり即決というのはかなりこうなん"
    },
    {
      "start": 802.68,
      "duration": 5.519,
      "text": "乱暴なというかですねあのこういったあの"
    },
    {
      "start": 805.8,
      "duration": 4.96,
      "text": "かなり重たい案件についてはきちんとした"
    },
    {
      "start": 808.199,
      "duration": 5.361,
      "text": "質疑が私は必要だと思っておりますであの"
    },
    {
      "start": 810.76,
      "duration": 4.56,
      "text": "今会議中にというあの今定例会議中にと"
    },
    {
      "start": 813.56,
      "duration": 5.279,
      "text": "いうような思いについては分かります"
    },
    {
      "start": 815.32,
      "duration": 7.199,
      "text": "けれどもえであればですねなおさらあの"
    },
    {
      "start": 818.839,
      "duration": 6.12,
      "text": "しっかりとしたま丁寧な説明とあとえこの"
    },
    {
      "start": 822.519,
      "duration": 4.161,
      "text": "議会の方で審議をする時間を持つという"
    },
    {
      "start": 824.959,
      "duration": 5.961,
      "text": "ことが重要なんではないかと思っており"
    },
    {
      "start": 826.68,
      "duration": 6.599,
      "text": "ますで全くこのま1年前に出された条例か"
    },
    {
      "start": 830.92,
      "duration": 4.56,
      "text": "もしれませんけれどもま先ほど公さん"
    },
    {
      "start": 833.279,
      "duration": 5.081,
      "text": "おっしゃったような前提が変わってるんで"
    },
    {
      "start": 835.48,
      "duration": 7.4,
      "text": "はないかということではあるんですが私は"
    },
    {
      "start": 838.36,
      "duration": 7.719,
      "text": "ですねこのの前提がどういう風な前提とし"
    },
    {
      "start": 842.88,
      "duration": 5.959,
      "text": "てこの条例が出されてるのかということが"
    },
    {
      "start": 846.079,
      "duration": 6.12,
      "text": "非常にこう大きな問題だと思っております"
    },
    {
      "start": 848.839,
      "duration": 5.92,
      "text": "あの私たちがですね考えるような前提で"
    },
    {
      "start": 852.199,
      "duration": 4.801,
      "text": "ないとすればですねこれあの大変私は"
    },
    {
      "start": 854.759,
      "duration": 4.2,
      "text": "大きな問題だと思っておりますのであの"
    },
    {
      "start": 857.0,
      "duration": 4.56,
      "text": "どのような態度を取るかということについ"
    },
    {
      "start": 858.959,
      "duration": 4.961,
      "text": "ては一定検討しなければいけないという風"
    },
    {
      "start": 861.56,
      "duration": 6.6,
      "text": "に考えておりますそういったこともあり"
    },
    {
      "start": 863.92,
      "duration": 6.719,
      "text": "まして非常にこのあのえ簡単に出すような"
    },
    {
      "start": 868.16,
      "duration": 4.479,
      "text": "議案ではないのではないかということから"
    },
    {
      "start": 870.639,
      "duration": 3.921,
      "text": "ですねまどのような考えを持ってるかはお"
    },
    {
      "start": 872.639,
      "duration": 4.88,
      "text": "伺いしておきたいと思い"
    },
    {
      "start": 874.56,
      "duration": 6.959,
      "text": "ます総務"
    },
    {
      "start": 877.519,
      "duration": 5.56,
      "text": "長はいまずあの事前の説明についてご意見"
    },
    {
      "start": 881.519,
      "duration": 3.601,
      "text": "をいただきましたこちらにつきましては"
    },
    {
      "start": 883.079,
      "duration": 4.801,
      "text": "真摯に受け止めさせていただいてしっかり"
    },
    {
      "start": 885.12,
      "duration": 8.0,
      "text": "え市長それから担当部局に伝えさせて"
    },
    {
      "start": 887.88,
      "duration": 7.56,
      "text": "いただきますえそれからあのま即決のこと"
    },
    {
      "start": 893.12,
      "duration": 4.639,
      "text": "でござい改めてでございますがあの送らせ"
    },
    {
      "start": 895.44,
      "duration": 4.68,
      "text": "ていただいた時期それから日程を考えまし"
    },
    {
      "start": 897.759,
      "duration": 6.0,
      "text": "てえ即決ということででお願いをさせて"
    },
    {
      "start": 900.12,
      "duration": 7.2,
      "text": "いただいてございますまたあのルルえっと"
    },
    {
      "start": 903.759,
      "duration": 5.721,
      "text": "いいた意見につきましては師匠が今後責任"
    },
    {
      "start": 907.32,
      "duration": 3.959,
      "text": "を持って各会派に回らせていただくという"
    },
    {
      "start": 909.48,
      "duration": 4.279,
      "text": "ことでございますのでその中でしっかり"
    },
    {
      "start": 911.279,
      "duration": 6.441,
      "text": "説明をするということかと思ってござい"
    },
    {
      "start": 913.759,
      "duration": 7.44,
      "text": "ます以上です今日なぜはいただ長だから"
    },
    {
      "start": 917.72,
      "duration": 5.119,
      "text": "今日なぜこの今日本会議を開いてしなかっ"
    },
    {
      "start": 921.199,
      "duration": 4.601,
      "text": "たんですかっていうことをお聞きしており"
    },
    {
      "start": 922.839,
      "duration": 6.721,
      "text": "ますはい総"
    },
    {
      "start": 925.8,
      "duration": 6.68,
      "text": "部長はいあの通常この会に送らせて"
    },
    {
      "start": 929.56,
      "duration": 5.199,
      "text": "いただいて大変あの申し訳なく思うわけで"
    },
    {
      "start": 932.48,
      "duration": 4.4,
      "text": "ございますが通常この時期に送らせて"
    },
    {
      "start": 934.759,
      "duration": 4.0,
      "text": "いただいた案件につきましては日程を考え"
    },
    {
      "start": 936.88,
      "duration": 3.72,
      "text": "ましと即決ということでお願いしてると"
    },
    {
      "start": 938.759,
      "duration": 4.56,
      "text": "思ってございますのでえそのように"
    },
    {
      "start": 940.6,
      "duration": 5.28,
      "text": "よろしくお願いいたしますはいはい西副"
    },
    {
      "start": 943.319,
      "duration": 6.0,
      "text": "委員長はいえっとですねただ今日ですね"
    },
    {
      "start": 945.88,
      "duration": 5.84,
      "text": "あの予算特別委員会も厚生文教委員会も"
    },
    {
      "start": 949.319,
      "duration": 6.601,
      "text": "開かれるわんですよそういったところへの"
    },
    {
      "start": 951.72,
      "duration": 6.64,
      "text": "ですねあの説明あのま特にま委員長とかに"
    },
    {
      "start": 955.92,
      "duration": 4.839,
      "text": "もなると思うんですけれどもあのそちらに"
    },
    {
      "start": 958.36,
      "duration": 5.44,
      "text": "ついては何かしらそういったこういった"
    },
    {
      "start": 960.759,
      "duration": 5.801,
      "text": "あの議案についてま予算であるとかまた"
    },
    {
      "start": 963.8,
      "duration": 5.64,
      "text": "厚生文教の委会で本来は審議すべきような"
    },
    {
      "start": 966.56,
      "duration": 5.959,
      "text": "議案なのけれどもそこをですね委員会開か"
    },
    {
      "start": 969.44,
      "duration": 6.48,
      "text": "れてるのにあのそれだけど即決だっていう"
    },
    {
      "start": 972.519,
      "duration": 3.401,
      "text": "ことについては説明されてるんです"
    },
    {
      "start": 980.519,
      "duration": 9.161,
      "text": "かはい総務部長はいあのま今日はあの予算"
    },
    {
      "start": 986.12,
      "duration": 5.8,
      "text": "の審議があるわけでございますがまあの"
    },
    {
      "start": 989.68,
      "duration": 4.2,
      "text": "ルールその中でしっかり説明するものは"
    },
    {
      "start": 991.92,
      "duration": 5.359,
      "text": "説明させていただくということかなと思っ"
    },
    {
      "start": 993.88,
      "duration": 5.56,
      "text": "てございますの審の中で説明をする"
    },
    {
      "start": 997.279,
      "duration": 5.161,
      "text": "ちょっとどうことちょっとちょっと今の"
    },
    {
      "start": 999.44,
      "duration": 8.0,
      "text": "はいすいません山長はいちょっとあの今の"
    },
    {
      "start": 1002.44,
      "duration": 7.24,
      "text": "総務部長の説明がなんかあのえっと予算の"
    },
    {
      "start": 1007.44,
      "duration": 3.839,
      "text": "予算委の時に説明があるんですかなんか"
    },
    {
      "start": 1009.68,
      "duration": 2.959,
      "text": "しっかり説明されるというようなことを今"
    },
    {
      "start": 1011.279,
      "duration": 3.601,
      "text": "おっしゃってましたけど一体どういうこと"
    },
    {
      "start": 1012.639,
      "duration": 5.2,
      "text": "なんでしょうかで公生文教委員会の中でも"
    },
    {
      "start": 1014.88,
      "duration": 5.959,
      "text": "何かそういったことはあるんでしょう"
    },
    {
      "start": 1017.839,
      "duration": 3.0,
      "text": "か"
    },
    {
      "start": 1022.319,
      "duration": 5.72,
      "text": "はい総務部長あのこれ繰り返しになります"
    },
    {
      "start": 1025.28,
      "duration": 5.639,
      "text": "けどこの時期に総させていただくという"
    },
    {
      "start": 1028.039,
      "duration": 5.8,
      "text": "ことは通常であればあの日程を考えますと"
    },
    {
      "start": 1030.919,
      "duration": 4.681,
      "text": "即決でお願いするというのが私どもの理解"
    },
    {
      "start": 1033.839,
      "duration": 3.12,
      "text": "でございますのですいませんよろしくお"
    },
    {
      "start": 1035.6,
      "duration": 4.68,
      "text": "願いいたし"
    },
    {
      "start": 1036.959,
      "duration": 6.48,
      "text": "ますちょっとじゃあまいいやだけすいませ"
    },
    {
      "start": 1040.28,
      "duration": 6.919,
      "text": "んね何回も申し訳ないですねはいあの今の"
    },
    {
      "start": 1043.439,
      "duration": 6.041,
      "text": "ですね総部長のあのこれまそこまでしかね"
    },
    {
      "start": 1047.199,
      "duration": 5.321,
      "text": "あの答弁できないのかもしれまませけれど"
    },
    {
      "start": 1049.48,
      "duration": 6.4,
      "text": "もこういったあの進行にとかですねやり方"
    },
    {
      "start": 1052.52,
      "duration": 5.72,
      "text": "についてはありえないですあの今あの市長"
    },
    {
      "start": 1055.88,
      "duration": 4.48,
      "text": "部局がもしですねそういった考えを持っ"
    },
    {
      "start": 1058.24,
      "duration": 4.799,
      "text": "てるということであればこれ議会運営を"
    },
    {
      "start": 1060.36,
      "duration": 5.8,
      "text": "警視してるということになりますので議会"
    },
    {
      "start": 1063.039,
      "duration": 5.481,
      "text": "運営としてはあの基本はですねこれ議案"
    },
    {
      "start": 1066.16,
      "duration": 4.44,
      "text": "はえ委員会負託をしていくということで"
    },
    {
      "start": 1068.52,
      "duration": 4.48,
      "text": "身長審議をしていくというような形を取っ"
    },
    {
      "start": 1070.6,
      "duration": 3.88,
      "text": "ておりますそちらについてもしですね即決"
    },
    {
      "start": 1073.0,
      "duration": 4.76,
      "text": "をどうしてもしたいということであるんで"
    },
    {
      "start": 1074.48,
      "duration": 5.76,
      "text": "あれば一定のですねきちんとしたあの理解"
    },
    {
      "start": 1077.76,
      "duration": 5.32,
      "text": "の理解が必要だという風に考えております"
    },
    {
      "start": 1080.24,
      "duration": 4.88,
      "text": "今そういっったあのえ手順を踏んでないで"
    },
    {
      "start": 1083.08,
      "duration": 4.2,
      "text": "はないかということを指摘ておりますので"
    },
    {
      "start": 1085.12,
      "duration": 4.96,
      "text": "そちらについてはきちんとですねあの"
    },
    {
      "start": 1087.28,
      "duration": 5.2,
      "text": "振り返ってあのそういったことにが今後"
    },
    {
      "start": 1090.08,
      "duration": 3.92,
      "text": "行われないような形にしていただきたいと"
    },
    {
      "start": 1092.48,
      "duration": 6.84,
      "text": "いうことを申し上げておきたいと思って"
    },
    {
      "start": 1094.0,
      "duration": 9.6,
      "text": "おりますご意見ではい他ございますかよ"
    },
    {
      "start": 1099.32,
      "duration": 6.32,
      "text": "はいではお諮りいたしはいはいはい"
    },
    {
      "start": 1103.6,
      "duration": 6.04,
      "text": "安はい"
    },
    {
      "start": 1105.64,
      "duration": 6.84,
      "text": "えっと今日のこの議案3と1号の速結に"
    },
    {
      "start": 1109.64,
      "duration": 6.159,
      "text": "ついてなんですけれども育公立創育権の"
    },
    {
      "start": 1112.48,
      "duration": 9.199,
      "text": "あり方検討委員会設置条例はあの今裁判の"
    },
    {
      "start": 1115.799,
      "duration": 10.321,
      "text": "判決があってから出てきたということで"
    },
    {
      "start": 1121.679,
      "duration": 8.401,
      "text": "あの以前にもま色々説明は受けております"
    },
    {
      "start": 1126.12,
      "duration": 6.0,
      "text": "けれどもあの今の状況化においてこの検討"
    },
    {
      "start": 1130.08,
      "duration": 6.12,
      "text": "委員会がどうなっていくのかっていうこと"
    },
    {
      "start": 1132.12,
      "duration": 8.24,
      "text": "はちょっとあの即決で図るにはとても理論"
    },
    {
      "start": 1136.2,
      "duration": 7.959,
      "text": "があの尽くしたとは言えないような"
    },
    {
      "start": 1140.36,
      "duration": 8.559,
      "text": "受け取り方でおりますえっとその今"
    },
    {
      "start": 1144.159,
      "duration": 9.4,
      "text": "あの片山委員がおっしゃいましたけれども"
    },
    {
      "start": 1148.919,
      "duration": 6.921,
      "text": "あの委員会付託といったことはないという"
    },
    {
      "start": 1153.559,
      "duration": 7.081,
      "text": "ことなんですけどもそのえっと今日は"
    },
    {
      "start": 1155.84,
      "duration": 8.839,
      "text": "えっと予もえ公文も開かれますけれども"
    },
    {
      "start": 1160.64,
      "duration": 7.08,
      "text": "そこでの説明等もしていただけないという"
    },
    {
      "start": 1164.679,
      "duration": 4.921,
      "text": "ことでよろしいんでしょう"
    },
    {
      "start": 1167.72,
      "duration": 5.48,
      "text": "か"
    },
    {
      "start": 1169.6,
      "duration": 6.12,
      "text": "総部長はいあのこの議案の審査については"
    },
    {
      "start": 1173.2,
      "duration": 5.56,
      "text": "あの即決でお願いしてございますので最終"
    },
    {
      "start": 1175.72,
      "duration": 6.64,
      "text": "日のその審査の中でお願いできればと思っ"
    },
    {
      "start": 1178.76,
      "duration": 5.96,
      "text": "てございますはい安田えっともう意見です"
    },
    {
      "start": 1182.36,
      "duration": 6.76,
      "text": "けれどもちょっと丁寧ではないのではない"
    },
    {
      "start": 1184.72,
      "duration": 7.4,
      "text": "かなという風に思いますですはい"
    },
    {
      "start": 1189.12,
      "duration": 6.799,
      "text": "水谷はいあのま進め方についてなかなか"
    },
    {
      "start": 1192.12,
      "duration": 5.799,
      "text": "日程的に厳しい中でまあの進め方が丁寧で"
    },
    {
      "start": 1195.919,
      "duration": 5.601,
      "text": "はないというなご意見が出るのはあのそう"
    },
    {
      "start": 1197.919,
      "duration": 7.161,
      "text": "いうご意見出ると私もそうあのそのことは"
    },
    {
      "start": 1201.52,
      "duration": 6.56,
      "text": "理解いたしますただあの判決が出た後ま短"
    },
    {
      "start": 1205.08,
      "duration": 4.88,
      "text": "期間の間に控訴しないということを決めて"
    },
    {
      "start": 1208.08,
      "duration": 5.0,
      "text": "まどのような受け入れをしていくのかま"
    },
    {
      "start": 1209.96,
      "duration": 5.92,
      "text": "検討した結果まギリギリの日程でまなんと"
    },
    {
      "start": 1213.08,
      "duration": 5.32,
      "text": "かこの3月12姿勢を示して欲しいという"
    },
    {
      "start": 1215.88,
      "duration": 5.6,
      "text": "ようなご意見も出されていた中えなんとか"
    },
    {
      "start": 1218.4,
      "duration": 6.0,
      "text": "間に合わせてま今回提案があったという風"
    },
    {
      "start": 1221.48,
      "duration": 6.16,
      "text": "に私は受け止めておりますはい以上ですご"
    },
    {
      "start": 1224.4,
      "duration": 5.72,
      "text": "意見よろしいですかはいそのございます"
    },
    {
      "start": 1227.64,
      "duration": 5.56,
      "text": "か"
    },
    {
      "start": 1230.12,
      "duration": 6.559,
      "text": "ではお諮りいたします本件について議長の"
    },
    {
      "start": 1233.2,
      "duration": 6.8,
      "text": "指紋通り決定することにご異議ありません"
    },
    {
      "start": 1236.679,
      "duration": 5.921,
      "text": "かご異議なしと認めます従って本件は議長"
    },
    {
      "start": 1240.0,
      "duration": 4.64,
      "text": "の指通り決定いたしました協議事故かに"
    },
    {
      "start": 1242.6,
      "duration": 5.64,
      "text": "その他でございますが何かご発言はござい"
    },
    {
      "start": 1244.64,
      "duration": 6.159,
      "text": "ますかはい以上で議会運営に関する議長の"
    },
    {
      "start": 1248.24,
      "duration": 4.919,
      "text": "諮問事項についてをわります休憩いたして"
    },
    {
      "start": 1250.799,
      "duration": 4.24,
      "text": "います前半はここまででございますお疲れ"
    },
    {
      "start": 1253.159,
      "duration": 6.161,
      "text": "様でし"
    },
    {
      "start": 1255.039,
      "duration": 9.681,
      "text": "たはいはいあの最後にあるので"
    },
    {
      "start": 1259.32,
      "duration": 5.4,
      "text": "はい最後に1番最後あの"
    }
  ]
}