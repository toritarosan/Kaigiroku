      "duration": 5.88,
      "text": "日切26日ですよね26日です26まで"
    },
    {
      "start": 700.88,
      "duration": 8.639,
      "text": "ですはい"
    },
    {
      "start": 703.32,
      "duration": 9.519,
      "text": "はい中中ですはいでればまでお願いしたい"
    },
    {
      "start": 709.519,
      "duration": 6.481,
      "text": "と思います一応あの27日がですねあのご"
    },
    {
      "start": 712.839,
      "duration": 6.961,
      "text": "用の日なので一応その日も含めてちょっと"
    },
    {
      "start": 716.0,
      "duration": 7.16,
      "text": "事務局の担当はこれ全部の委員会実は全部"
    },
    {
      "start": 719.8,
      "duration": 6.719,
      "text": "一緒にしてえで27にちょっともうある"
    },
    {
      "start": 723.16,
      "duration": 5.84,
      "text": "程度動いてでれ前までになんとかしたいと"
    },
    {
      "start": 726.519,
      "duration": 5.641,
      "text": "思ってますのですいませんご協力よろしく"
    },
    {
      "start": 729.0,
      "duration": 5.44,
      "text": "お願いいたしますはい厚生分会は走れが2"
    },
    {
      "start": 732.16,
      "duration": 4.76,
      "text": "本ですから2つそれぞれ出してくださいと"
    },
    {
      "start": 734.44,
      "duration": 2.48,
      "text": "いうことになり"
    },
    {
      "start": 738.12,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 742.199,
      "duration": 9.241,
      "text": "確えと派であの1つに確それしたことあの"
    },
    {
      "start": 747.72,
      "duration": 5.799,
      "text": "ありますんであの会派の方は2人いる場合"
    },
    {
      "start": 751.44,
      "duration": 7.36,
      "text": "にはそのどちらかが代表で書いて"
    },
    {
      "start": 753.519,
      "duration": 8.361,
      "text": "るっていう形を取ってはおりますねなので"
    },
    {
      "start": 758.8,
      "duration": 7.52,
      "text": "子供の権利さんお2人いるんでそのまお"
    },
    {
      "start": 761.88,
      "duration": 8.399,
      "text": "2人でいうのでお出しいただくこともでき"
    },
    {
      "start": 766.32,
      "duration": 3.959,
      "text": "ます別々でき"
    },
    {
      "start": 771.8,
      "duration": 5.8,
      "text": "ますはいあのお2人出てるとこはあの2人"
    },
    {
      "start": 775.399,
      "duration": 4.56,
      "text": "で同じ会派であれば1つっていうことも"
    },
    {
      "start": 777.6,
      "duration": 7.039,
      "text": "出していただいてることもあり"
    },
    {
      "start": 779.959,
      "duration": 7.361,
      "text": "も丈はいどちらでもいいですうちの一応"
    },
    {
      "start": 784.639,
      "duration": 5.481,
      "text": "2人出させていただいておりますけどさん"
    },
    {
      "start": 787.32,
      "duration": 5.92,
      "text": "にお願いする形と"
    },
    {
      "start": 790.12,
      "duration": 3.12,
      "text": "長の"
    },
    {
      "start": 793.8,
      "duration": 6.64,
      "text": "で応一応委員長もですねあの出してはあの"
    },
    {
      "start": 798.56,
      "duration": 4.8,
      "text": "召喚事務調査については委員長も出して"
    },
    {
      "start": 800.44,
      "duration": 6.44,
      "text": "いただくんですけどあれそうそう"
    },
    {
      "start": 803.36,
      "duration": 7.68,
      "text": "そうの広告のことじゃなくて委出して"
    },
    {
      "start": 806.88,
      "duration": 4.16,
      "text": "なかったんじゃないですか出して"
    },
    {
      "start": 812.24,
      "duration": 6.76,
      "text": "ででもあのお2人お2人いればそれはあの"
    },
    {
      "start": 816.16,
      "duration": 5.799,
      "text": "同じ会派ですから例えばいしだけっていう"
    },
    {
      "start": 819.0,
      "duration": 5.959,
      "text": "のはそれはあのオッケーですけどあもう"
    },
    {
      "start": 821.959,
      "duration": 5.401,
      "text": "もうもう終わってますからもうもう終わっ"
    },
    {
      "start": 824.959,
      "duration": 2.401,
      "text": "終わってる"
    },
    {
      "start": 827.56,
      "duration": 6.6,
      "text": "からもうもうもうこれ議会内の技なんで"
    },
    {
      "start": 830.759,
      "duration": 7.241,
      "text": "はいもう終わってますはいはいえっとそれ"
    },
    {
      "start": 834.16,
      "duration": 7.4,
      "text": "ではあのみにあたっての意見要望のについ"
    },
    {
      "start": 838.0,
      "duration": 6.519,
      "text": "ては今しいですかね今話あとその他です"
    },
    {
      "start": 841.56,
      "duration": 5.6,
      "text": "けど何かございますその他何かありますか"
    },
    {
      "start": 844.519,
      "duration": 5.481,
      "text": "ないですねあとはもう今日あれですねあの"
    },
    {
      "start": 847.16,
      "duration": 5.679,
      "text": "尋常一件継続になってますけどこれ継続と"
    },
    {
      "start": 850.0,
      "duration": 6.0,
      "text": "は言っても次の定例会のところで議題に"
    },
    {
      "start": 852.839,
      "duration": 5.36,
      "text": "上げて当然これ審査いたしますのでもう"
    },
    {
      "start": 856.0,
      "duration": 6.92,
      "text": "閉会中に飛ぶとかじゃなくて次の定例会で"
    },
    {
      "start": 858.199,
      "duration": 7.961,
      "text": "当然これはあの審査を行ういますのではい"
    },
    {
      "start": 862.92,
      "duration": 6.56,
      "text": "はいねその結局"
    },
    {
      "start": 866.16,
      "duration": 7.0,
      "text": "その1月までは何もないわけじゃないです"
    },
    {
      "start": 869.48,
      "duration": 4.799,
      "text": "うんその間局はちゃんと考えてくれるのか"
    },
    {
      "start": 873.16,
      "duration": 6.08,
      "text": "どうかて"
    },
    {
      "start": 874.279,
      "duration": 10.881,
      "text": "いう調査するから一応考え陳情についてね"
    },
    {
      "start": 879.24,
      "duration": 8.8,
      "text": "うんでるうんだからなんかどっかでまあ会"
    },
    {
      "start": 885.16,
      "duration": 6.88,
      "text": "協議会じゃないけど協議会の協議会みたい"
    },
    {
      "start": 888.04,
      "duration": 6.76,
      "text": "な感じでどう考えてんのっていうやった方"
    },
    {
      "start": 892.04,
      "duration": 7.2,
      "text": "がいいのかもうやらない"
    },
    {
      "start": 894.8,
      "duration": 7.44,
      "text": "で択が消しちゃうのかもしあれですよねね"
    },
    {
      "start": 899.24,
      "duration": 4.959,
      "text": "やり方としては今回あの継続で資料要求"
    },
    {
      "start": 902.24,
      "duration": 4.399,
      "text": "出してるじゃないですかそうすると多分"
    },
    {
      "start": 904.199,
      "duration": 6.121,
      "text": "その資料の調整は"
    },
    {
      "start": 906.639,
      "duration": 6.76,
      "text": "必ずまあまあ年内のギリギリか年明けに"
    },
    {
      "start": 910.32,
      "duration": 7.28,
      "text": "来ると思うんですけどその時にあのご要求"
    },
    {
      "start": 913.399,
      "duration": 7.401,
      "text": "されてる方にあの前回こんな話あったけど"
    },
    {
      "start": 917.6,
      "duration": 7.039,
      "text": "ていうことはですねお話はちょっとできる"
    },
    {
      "start": 920.8,
      "duration": 6.44,
      "text": "かなと思っていてでそこの中でもし委員に"
    },
    {
      "start": 924.639,
      "duration": 5.361,
      "text": "あの情報共有必要っていうことであれば"
    },
    {
      "start": 927.24,
      "duration": 5.36,
      "text": "あのちょっと制服とも相談しながらていお"
    },
    {
      "start": 930.0,
      "duration": 4.88,
      "text": "話は多分白要求の調整があればそこで"
    },
    {
      "start": 932.6,
      "duration": 5.12,
      "text": "できるとは思いますんでそういうちょっと"
    },
    {
      "start": 934.88,
      "duration": 4.84,
      "text": "機会もあのなかなかあのここのメンバーで"
    },
    {
      "start": 937.72,
      "duration": 5.28,
      "text": "集まってっていうのはなかなか難しいと"
    },
    {
      "start": 939.72,
      "duration": 6.039,
      "text": "思いますのでその辺ちょっとうまく政府と"
    },
    {
      "start": 943.0,
      "duration": 5.44,
      "text": "もあの連絡取ってやっていただけると多分"
    },
    {
      "start": 945.759,
      "duration": 10.241,
      "text": "もう時期的にはですねかなりもうきつきつ"
    },
    {
      "start": 948.44,
      "duration": 10.199,
      "text": "なのではいましはい立はないですか立"
    },
    {
      "start": 956.0,
      "duration": 5.079,
      "text": "はいくなっちゃったけどまだあると思い"
    },
    {
      "start": 958.639,
      "duration": 4.12,
      "text": "ますとしてはま年度内はあるのかもしれ"
    },
    {
      "start": 961.079,
      "duration": 3.161,
      "text": "ないですけどこの委員会のとこまで"
    },
    {
      "start": 962.759,
      "duration": 6.281,
      "text": "ちょっとあるかどうかってのは私もすい"
    },
    {
      "start": 964.24,
      "duration": 9.079,
      "text": "ませんまだないですけどましその大会提会"
    },
    {
      "start": 969.04,
      "duration": 6.799,
      "text": "は調査閉めてるから質疑じゃないはい質疑"
    },
    {
      "start": 973.319,
      "duration": 7.2,
      "text": "は所管事務調査についてはないですなので"
    },
    {
      "start": 975.839,
      "duration": 6.721,
      "text": "今回はこのあの新の審査だけですね新1本"
    },
    {
      "start": 980.519,
      "duration": 5.961,
      "text": "そうそうですそうですうんで継続でやった"
    },
    {
      "start": 982.56,
      "duration": 8.12,
      "text": "ので当然それはありますこれこれもう一緒"
    },
    {
      "start": 986.48,
      "duration": 7.4,
      "text": "だったんでちょっとあの覧たしか"
    },
    {
      "start": 990.68,
      "duration": 5.839,
      "text": "あそうですかあの一応もうあの一定で"
    },
    {
      "start": 993.88,
      "duration": 4.04,
      "text": "できるのはこの陳情発でやっちゃったんで"
    },
    {
      "start": 996.519,
      "duration": 3.081,
      "text": "あ"
    },
    {
      "start": 997.92,
      "duration": 4.2,
      "text": "はは"
    },
    {
      "start": 999.6,
      "duration": 6.44,
      "text": "は言わっ"
    },
    {
      "start": 1002.12,
      "duration": 6.079,
      "text": "たあ大丈夫ちゃんともう常であの一括で"
    },
    {
      "start": 1006.04,
      "duration": 5.52,
      "text": "審査しましたけどその中ではじゃ別れてる"
    },
    {
      "start": 1008.199,
      "duration": 7.12,
      "text": "のが分かってるんうんあこちこちらとして"
    },
    {
      "start": 1011.56,
      "duration": 3.759,
      "text": "はだから"
    },
    {
      "start": 1019.079,
      "duration": 6.921,
      "text": "にあっそっそっあそうですね確かに確かに"
    },
    {
      "start": 1022.44,
      "duration": 7.28,
      "text": "それはわかんない確かにそこは3つね一括"
    },
    {
      "start": 1026.0,
      "duration": 5.919,
      "text": "でやっちゃったんでかななるほどはいそこ"
    },
    {
      "start": 1029.72,
      "duration": 4.359,
      "text": "は確かにそそういうところはちょっとあっ"
    },
    {
      "start": 1031.919,
      "duration": 6.201,
      "text": "たかもしれないですね3つが一括でしたん"
    },
    {
      "start": 1034.079,
      "duration": 6.12,
      "text": "でねはいはいあとよろしいですかはいそれ"
    },
    {
      "start": 1038.12,
      "duration": 4.16,
      "text": "ではお疲れ様でしたはいどうもお疲れ様"
    },
    {
      "start": 1040.199,
      "duration": 2.081,
      "text": "でし"
    },
    {
      "start": 1047.84,
      "duration": 4.04,
      "text": "たあ"
    }
  ]
}