    {
      "start": 572.839,
      "duration": 5.56,
      "text": "委員会の中で答えるとかそういったことは"
    },
    {
      "start": 574.6,
      "duration": 6.52,
      "text": "可能かと思われますが、所管外のまま局が"
    },
    {
      "start": 578.399,
      "duration": 5.761,
      "text": "出て答弁という形にはなかなかなりのかな"
    },
    {
      "start": 581.12,
      "duration": 7.36,
      "text": "と考えることでございます"
    },
    {
      "start": 584.16,
      "duration": 8.239,
      "text": "というのでごいはいで1つだけ紹介しとく"
    },
    {
      "start": 588.48,
      "duration": 7.0,
      "text": "とああの、指定管理者の選定委員会っての"
    },
    {
      "start": 592.399,
      "duration": 6.361,
      "text": "は開かれていて、えっと、令和6年7月"
    },
    {
      "start": 595.48,
      "duration": 7.52,
      "text": "12日のですね、選定委員会でこの要する"
    },
    {
      "start": 598.76,
      "duration": 7.56,
      "text": "にあの指定管理のあの案件があの審査され"
    },
    {
      "start": 603.0,
      "duration": 8.24,
      "text": "てるんですね。で、それを見ると障害学習"
    },
    {
      "start": 606.32,
      "duration": 8.8,
      "text": "家から選定委員会に対してあの募集要綱と"
    },
    {
      "start": 611.24,
      "duration": 8.32,
      "text": "あの指定管理者業務使用書先定基準用など"
    },
    {
      "start": 615.12,
      "duration": 6.959,
      "text": "を出されてあのえっと選定基準などについ"
    },
    {
      "start": 619.56,
      "duration": 5.56,
      "text": "てです。あ、審査基準についてですね、"
    },
    {
      "start": 622.079,
      "duration": 5.801,
      "text": "あの要するに選定委員会にあの教育委員会"
    },
    {
      "start": 625.12,
      "duration": 6.24,
      "text": "が指問するって形になってます。で、それ"
    },
    {
      "start": 627.88,
      "duration": 6.44,
      "text": "で実際の質疑は選定委員の方から色々質疑"
    },
    {
      "start": 631.36,
      "duration": 5.279,
      "text": "が受けて、で、例えばあのプールの事故に"
    },
    {
      "start": 634.32,
      "duration": 4.959,
      "text": "ついてもあのプールなんかやってるけど"
    },
    {
      "start": 636.639,
      "duration": 5.921,
      "text": "大丈夫かっていうのが先定委員会から質問"
    },
    {
      "start": 639.279,
      "duration": 6.12,
      "text": "があって、それに対して答えてるのが障害"
    },
    {
      "start": 642.56,
      "duration": 5.0,
      "text": "学習課長になってるんですね。だから選定"
    },
    {
      "start": 645.399,
      "duration": 6.521,
      "text": "にあたっての要するにいろんな質問に対し"
    },
    {
      "start": 647.56,
      "duration": 7.92,
      "text": "てその質問したあの障害学習家が障害学習"
    },
    {
      "start": 651.92,
      "duration": 5.88,
      "text": "部が答えるって形になってますのであの"
    },
    {
      "start": 655.48,
      "duration": 4.84,
      "text": "この要するに陳常審査するってことになる"
    },
    {
      "start": 657.8,
      "duration": 6.64,
      "text": "とまずちょっと公文でやってもらってです"
    },
    {
      "start": 660.32,
      "duration": 7.319,
      "text": "ねというのことが障害学習部で十分答え"
    },
    {
      "start": 664.44,
      "duration": 6.16,
      "text": "られることもあると思いますのでで最終的"
    },
    {
      "start": 667.639,
      "duration": 5.44,
      "text": "にその指定管理どうするかってことになっ"
    },
    {
      "start": 670.6,
      "duration": 3.44,
      "text": "てくるとこれはまたちょっとどうなるのか"
    },
    {
      "start": 673.079,
      "duration": 3.961,
      "text": "よくわかりません"
    },
    {
      "start": 674.04,
      "duration": 3.0,
      "text": "けど、あの、審査の内容としてはちょっとこの選定委員会の状況を見てると、あの、厚生文教委員会でいいんではないかなっていう風に個人的には思って、ま、"
    },
    {
      "start": 684.72,
      "duration": 3.16,
      "text": "4"
    },
    {
      "start": 684.88,
      "duration": 3.0,
      "text": "社教でもそういう風な意したっていうな状況です。"
    },
    {
      "start": 688.839,
      "duration": 2.281,
      "text": "はい。"
    },
    {
      "start": 689.519,
      "duration": 1.921,
      "text": "はい。水員さん。"
    },
    {
      "start": 691.12,
      "duration": 3.32,
      "text": "はい。"
    },
    {
      "start": 691.44,
      "duration": 3.0,
      "text": "えっと、ここであまり長くあの議論をすることはあの生産的ではないと思ってるんですけれども、ま、例えばそれが"
    },
    {
      "start": 697.56,
      "duration": 3.6,
      "text": "2"
    },
    {
      "start": 698.16,
      "duration": 3.0,
      "text": "先私があの所属する厚生文教会になった時に私もその技似"
    },
    {
      "start": 702.279,
      "duration": 4.56,
      "text": "610月9"
    },
    {
      "start": 703.839,
      "duration": 3.0,
      "text": "日のあの先行の時とかのあのも見たんですけどうん。"
    },
    {
      "start": 707.92,
      "duration": 3.0,
      "text": "えっと、あ、私が委ドしてこれを審査するとしたらこの重大事項っていうことに対する定義がどうなってるか、他の自治体のことも調査して欲しいとかいう風に思った時にその調査"
    },
    {
      "start": 720.639,
      "duration": 3.0,
      "text": "をするのは私はあの総務企画委員会の所管家のかなと思ったんですが、ま、厚生文教委員会でもそういう資料を要求して、"
    },
    {
      "start": 729.399,
      "duration": 3.0,
      "text": "えっと、障害学習家がそれをまとめてくださるっていうようなことになるのかちょっとでもイメージができなかったので、ま、懸念はありますが、"
    },
    {
      "start": 736.6,
      "duration": 3.76,
      "text": "ちょっとここであ"
    },
    {
      "start": 737.36,
      "duration": 3.0,
      "text": "あの、これ以上の時間をかけてもと思いますので、一致しないのであれば、あの、質問の通りに決めていただくというのが、あの筋かと思います。あ、"
    },
    {
      "start": 744.68,
      "duration": 5.159,
      "text": "はい。"
    },
    {
      "start": 746.839,
      "duration": 3.0,
      "text": "他に何かありますか?皆さんから厚生文教委員会でという質問の通りでよろしいでしょうか?はい。"
    },
    {
      "start": 758.199,
      "duration": 3.0,
      "text": "ええ、お諮りいたします。本件についてお手元に配布されております予定。"
    },
    {
      "start": 763.72,
      "duration": 3.64,
      "text": "え、表括1"
    },
    {
      "start": 764.48,
      "duration": 5.88,
      "text": "案の通り決定することにご異議ありませんか?"
    },
    {
      "start": 767.36,
      "duration": 3.0,
      "text": "え、ご異議なしと認め、正願賃上の草先委員会についてはお手元の予定表の通り、え、決定いたしました事項"
    },
    {
      "start": 775.56,
      "duration": 3.2,
      "text": "3"
    },
    {
      "start": 775.76,
      "duration": 3.0,
      "text": "その他でございますが、え、何かご発言ございますか?"
    },
    {
      "start": 780.32,
      "duration": 3.0,
      "text": "え、次に行政策にかかる所管事務調査の継続審査議決について行ます。"
    },
    {
      "start": 786.639,
      "duration": 7.401,
      "text": "議会運営委員会の行政視察は、え、偽算"
    },
    {
      "start": 790.88,
      "duration": 6.079,
      "text": "委員の活用について、議会による試験者"
    },
    {
      "start": 794.04,
      "duration": 7.12,
      "text": "教育の取り組みについて、議会による市民"
    },
    {
      "start": 796.959,
      "duration": 7.641,
      "text": "意見聴取の取り組みについて及び政策立案"
    },
    {
      "start": 801.16,
      "duration": 7.2,
      "text": "機能の強化に向けた仕組みについて視察"
    },
    {
      "start": 804.6,
      "duration": 6.32,
      "text": "項目として、え、実施することとし本当"
    },
    {
      "start": 808.36,
      "duration": 5.88,
      "text": "総委員会の所管事務調査事件とするととも"
    },
    {
      "start": 810.92,
      "duration": 5.76,
      "text": "に閉会中の継続調査とすることにご異議"
    },
    {
      "start": 814.24,
      "duration": 4.48,
      "text": "ありませんか?ええ、ご異議なしと認め"
    },
    {
      "start": 816.68,
      "duration": 4.839,
      "text": "ます。従ってただいま申し上げました通り"
    },
    {
      "start": 818.72,
      "duration": 6.679,
      "text": "決定いたしました。なお閉会中の委員派遣"
    },
    {
      "start": 821.519,
      "duration": 7.241,
      "text": "は議長に対して委員派遣承認要求を行う"
    },
    {
      "start": 825.399,
      "duration": 3.361,
      "text": "こととし派遣委員日場所及び費等"
    },
    {
      "start": 829.6,
      "duration": 5.039,
      "text": "の手続きについては委員長にご一任願い"
    },
    {
      "start": 832.92,
      "duration": 4.2,
      "text": "たいと思います。これにご異議ありません"
    },
    {
      "start": 834.639,
      "duration": 5.0,
      "text": "か?ご異議なしと認めます。しって"
    },
    {
      "start": 837.12,
      "duration": 5.2,
      "text": "ただいま申し上げました通り決定いたし"
    },
    {
      "start": 839.639,
      "duration": 5.601,
      "text": "ました。以上で当委員会に付託されており"
    },
    {
      "start": 842.32,
      "duration": 5.4,
      "text": "ます案件の審査は全て終了いたしました。"
    },
    {
      "start": 845.24,
      "duration": 5.76,
      "text": "これで議会運営委員会の会議を閉じ参加"
    },
    {
      "start": 847.72,
      "duration": 6.799,
      "text": "いたします。お疲れ様でした。で、次に"
    },
    {
      "start": 851.0,
      "duration": 8.6,
      "text": "協議事項令和8年第1回定例会の日程に"
    },
    {
      "start": 854.519,
      "duration": 8.961,
      "text": "ついては来年2月16日でしたね。それで"
    },
    {
      "start": 859.6,
      "duration": 8.76,
      "text": "皆さん大丈夫でしょうか?じゃあ2月16"
    },
    {
      "start": 863.48,
      "duration": 7.32,
      "text": "日が初日ということであの確定他"
    },
    {
      "start": 868.36,
      "duration": 5.44,
      "text": "何かありますか?あります。"
    },
    {
      "start": 870.8,
      "duration": 3.0,
      "text": "事務局から何かよろしいでしょうか?はい、じゃあ以上で議会運営委員会終わります。お疲れ様でした。"
    },
    {
      "start": 878.16,
      "duration": 6.0,
      "text": "お疲れ様でした。"
    },
    {
      "start": 881.16,
      "duration": 3.0,
      "text": "ま、明日開発どもやりますが、あの、こういう状況なんで、閉中の委員会も、あ、それですね、閉会中の委員会で、えっと、この抜き差しをこうあまりやりたくないと思うんですけど、"
    },
    {
      "start": 895.32,
      "duration": 3.759,
      "text": "うん。"
    },
    {
      "start": 896.079,
      "duration": 3.0,
      "text": "この教室型で委員会を開いていただくという形になるかもしれませんと"
    },
    {
      "start": 904.079,
      "duration": 4.416,
      "text": "教室型"
    },
    {
      "start": 905.759,
      "duration": 4.756,
      "text": "教室が特でね、"
    },
    {
      "start": 908.495,
      "duration": 2.02,
      "text": "[笑い]"
    },
    {
      "start": 910.639,
      "duration": 5.12,
      "text": "また視察、"
    },
    {
      "start": 912.0,
      "duration": 3.759,
      "text": "また視察来し"
    }
  ]
}