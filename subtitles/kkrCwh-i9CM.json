{
  "entries": [
    {
      "start": 34.559,
      "duration": 4.721,
      "text": "はいお疲れ様でございますえ50分定国前"
    },
    {
      "start": 37.36,
      "duration": 3.84,
      "text": "でございますけどそでございますので議会"
    },
    {
      "start": 39.28,
      "duration": 4.959,
      "text": "運営委員会の協議会を始めさせていただき"
    },
    {
      "start": 41.2,
      "duration": 7.039,
      "text": "ますえただいまございました議案第44号"
    },
    {
      "start": 44.239,
      "duration": 8.32,
      "text": "45号議案第34号についてえ討論のご"
    },
    {
      "start": 48.239,
      "duration": 6.041,
      "text": "予定はございますでしょうかはい皆さん"
    },
    {
      "start": 52.559,
      "duration": 3.84,
      "text": "なしということではい討論はなしという"
    },
    {
      "start": 54.28,
      "duration": 2.119,
      "text": "こと"
    },
    {
      "start": 56.84,
      "duration": 7.679,
      "text": "であ東路東路のところ"
    },
    {
      "start": 61.559,
      "duration": 6.88,
      "text": "オまで来てあはいでは"
    },
    {
      "start": 64.519,
      "duration": 5.64,
      "text": "あのはいえ本日あの富春委員が厳のためご"
    },
    {
      "start": 68.439,
      "duration": 4.881,
      "text": "欠席でございますのでオブザーバーの"
    },
    {
      "start": 70.159,
      "duration": 4.921,
      "text": "いらしの発言を許可いたしますはい井すい"
    },
    {
      "start": 73.32,
      "duration": 5.08,
      "text": "ません発言の機会をいただいてありがとう"
    },
    {
      "start": 75.08,
      "duration": 7.56,
      "text": "ございます議員案第34号に反対の立場"
    },
    {
      "start": 78.4,
      "duration": 10.12,
      "text": "から井嵐が討論させていただきます"
    },
    {
      "start": 82.64,
      "duration": 9.36,
      "text": "はいはいはいその他討論ございますかはい"
    },
    {
      "start": 88.52,
      "duration": 5.0,
      "text": "それでは討論1件と34号の反対討論一件"
    },
    {
      "start": 92.0,
      "duration": 3.36,
      "text": "ということで確認させていただきました"
    },
    {
      "start": 93.52,
      "duration": 5.0,
      "text": "採決再度は従前通りでよろしかった"
    },
    {
      "start": 95.36,
      "duration": 7.399,
      "text": "でしょうかはいその他何かご発言ござい"
    },
    {
      "start": 98.52,
      "duration": 6.76,
      "text": "ますかはいではオブザーバーの嵐はいすみ"
    },
    {
      "start": 102.759,
      "duration": 6.32,
      "text": "ませんえっと発言の機会をいただいて"
    },
    {
      "start": 105.28,
      "duration": 8.6,
      "text": "ありがとうございますえっと昨日あの陳情"
    },
    {
      "start": 109.079,
      "duration": 8.481,
      "text": "星がのあ陳情の委員会2がございましてえ"
    },
    {
      "start": 113.88,
      "duration": 6.159,
      "text": "本来そこで発言をすれば良かったのですが"
    },
    {
      "start": 117.56,
      "duration": 5.599,
      "text": "ちょっと後から気がついてちょっとあの"
    },
    {
      "start": 120.039,
      "duration": 5.521,
      "text": "こと発言させていただきたいなと思ってえ"
    },
    {
      "start": 123.159,
      "duration": 6.8,
      "text": "お時間をちょっと取っていただきました"
    },
    {
      "start": 125.56,
      "duration": 7.399,
      "text": "えっと6陳情第29号についてのあの件な"
    },
    {
      "start": 129.959,
      "duration": 7.401,
      "text": "んですがあのまちょっと気になってる"
    },
    {
      "start": 132.959,
      "duration": 7.601,
      "text": "ところであのこの間えっと色々とあの検討"
    },
    {
      "start": 137.36,
      "duration": 6.32,
      "text": "期間も長くとってあのここに至ってま総務"
    },
    {
      "start": 140.56,
      "duration": 5.92,
      "text": "学委員会に付託されま陳述もあるという"
    },
    {
      "start": 143.68,
      "duration": 6.96,
      "text": "ことがま昨日分かったわけですけれども"
    },
    {
      "start": 146.48,
      "duration": 8.8,
      "text": "えっとこれについてですねあの"
    },
    {
      "start": 150.64,
      "duration": 7.92,
      "text": "まあの私たちとしてはあのま反対の立場"
    },
    {
      "start": 155.28,
      "duration": 5.319,
      "text": "から一応意見を言ってま望むしかないかな"
    },
    {
      "start": 158.56,
      "duration": 5.12,
      "text": "と思ってあの受け止めておるとこでござい"
    },
    {
      "start": 160.599,
      "duration": 6.0,
      "text": "ましてまここま昨日まででこう手続きが"
    },
    {
      "start": 163.68,
      "duration": 5.0,
      "text": "進んでますので次の本会議で委会負託を"
    },
    {
      "start": 166.599,
      "duration": 4.801,
      "text": "そのままされていく風に流れていくだろう"
    },
    {
      "start": 168.68,
      "duration": 6.44,
      "text": "なということはあの思っておりますが"
    },
    {
      "start": 171.4,
      "duration": 6.64,
      "text": "えっとそういうあの内容を考えますと"
    },
    {
      "start": 175.12,
      "duration": 6.6,
      "text": "よくよく調べてみますとあの地方事事法の"
    },
    {
      "start": 178.04,
      "duration": 8.32,
      "text": "第109条の4項ににあの常任委員会で"
    },
    {
      "start": 181.72,
      "duration": 7.76,
      "text": "あの議論するのにその当該え団体地方自治"
    },
    {
      "start": 186.36,
      "duration": 6.76,
      "text": "体のあの事務以外のもの"
    },
    {
      "start": 189.48,
      "duration": 7.399,
      "text": "を議論してはならないというかそこで常任"
    },
    {
      "start": 193.12,
      "duration": 6.08,
      "text": "委員会で議論するのはその当該地方事体の"
    },
    {
      "start": 196.879,
      "duration": 6.041,
      "text": "事務に関することという言い方の表現が"
    },
    {
      "start": 199.2,
      "duration": 6.399,
      "text": "ありまして明確にその自治法に歌ってい"
    },
    {
      "start": 202.92,
      "duration": 6.44,
      "text": "るっていうことがちょっとあの分かったの"
    },
    {
      "start": 205.599,
      "duration": 7.36,
      "text": "でえその件についてはあの総務画委員会の"
    },
    {
      "start": 209.36,
      "duration": 8.36,
      "text": "中でま表明するしかないかなという風に"
    },
    {
      "start": 212.959,
      "duration": 7.321,
      "text": "思っておりましてえそのことだけえあじめ"
    },
    {
      "start": 217.72,
      "duration": 5.239,
      "text": "えご理解いただければと思ってえちょっと"
    },
    {
      "start": 220.28,
      "duration": 6.36,
      "text": "発言をさせていただきまし"
    },
    {
      "start": 222.959,
      "duration": 7.121,
      "text": "たはいその他の部分のご発言でございます"
    },
    {
      "start": 226.64,
      "duration": 3.44,
      "text": "他にございます"
    },
    {
      "start": 230.12,
      "duration": 10.16,
      "text": "かんはい加長はいあえっとま今井さんから"
    },
    {
      "start": 237.84,
      "duration": 5.239,
      "text": "ですね発言があったわけですけどこれその"
    },
    {
      "start": 240.28,
      "duration": 4.92,
      "text": "企画委員会の中での議論になのかと思うん"
    },
    {
      "start": 243.079,
      "duration": 4.44,
      "text": "ですがまこれまでもですねあのいろんな形"
    },
    {
      "start": 245.2,
      "duration": 5.119,
      "text": "であの国に検証出してほしいとかそういっ"
    },
    {
      "start": 247.519,
      "duration": 7.321,
      "text": "た形のあの陳情はあの山のように出てきて"
    },
    {
      "start": 250.319,
      "duration": 7.681,
      "text": "いてま当該あのだからここの小金姿勢に"
    },
    {
      "start": 254.84,
      "duration": 6.239,
      "text": "あのの事務に関しないことについてもま"
    },
    {
      "start": 258.0,
      "duration": 4.72,
      "text": "様々な陳情を受けて議論してきたなと思っ"
    },
    {
      "start": 261.079,
      "duration": 3.281,
      "text": "ておりますので一応それだけ申し上げと"
    },
    {
      "start": 262.72,
      "duration": 7.44,
      "text": "おきたいと思っており"
    },
    {
      "start": 264.36,
      "duration": 8.119,
      "text": "ますはいかかにございますかはい小林ま山"
    },
    {
      "start": 270.16,
      "duration": 4.759,
      "text": "のよに出てきたんだけどまそれがあのいい"
    },
    {
      "start": 272.479,
      "duration": 6.401,
      "text": "のか悪いのかっていうことはあの賛否ある"
    },
    {
      "start": 274.919,
      "duration": 6.161,
      "text": "と思いますのであのまま山のに出てきたの"
    },
    {
      "start": 278.88,
      "duration": 4.96,
      "text": "で今回も委員会付託を利としてきたんだ"
    },
    {
      "start": 281.08,
      "duration": 6.2,
      "text": "けどもま今後ですねあの見直すような機会"
    },
    {
      "start": 283.84,
      "duration": 8.04,
      "text": "があればダにしていただければと思います"
    },
    {
      "start": 287.28,
      "duration": 6.72,
      "text": "はいんか長あのま他の自治体でもですね"
    },
    {
      "start": 291.88,
      "duration": 3.8,
      "text": "そういったあの陳情については出ていると"
    },
    {
      "start": 294.0,
      "duration": 4.52,
      "text": "いうこともあって議論もしてるということ"
    },
    {
      "start": 295.68,
      "duration": 5.56,
      "text": "もありますのであの小金だけの問題でそう"
    },
    {
      "start": 298.52,
      "duration": 5.64,
      "text": "やってやるのかともありますしま小金主"
    },
    {
      "start": 301.24,
      "duration": 5.36,
      "text": "議会としてはですねこれまではあのまそう"
    },
    {
      "start": 304.16,
      "duration": 4.56,
      "text": "いった一定ま市民からの陳情を受けてきた"
    },
    {
      "start": 306.6,
      "duration": 5.64,
      "text": "というルールがありますのでそちらをです"
    },
    {
      "start": 308.72,
      "duration": 5.0,
      "text": "ねま経験にあの簡単あの変えていくような"
    },
    {
      "start": 312.24,
      "duration": 3.76,
      "text": "ものではないという風に考えてるという"
    },
    {
      "start": 313.72,
      "duration": 5.96,
      "text": "ことは申し上げてきたいと思いますはい"
    },
    {
      "start": 316.0,
      "duration": 6.44,
      "text": "小林だから参考送付にしてるね議会なども"
    },
    {
      "start": 319.68,
      "duration": 5.2,
      "text": "たくさんありますのであの経験にという"
    },
    {
      "start": 322.44,
      "duration": 5.8,
      "text": "ことではなくてましっかりとあの話し合い"
    },
    {
      "start": 324.88,
      "duration": 5.64,
      "text": "をしてま限られた時間の審議の中でま必要"
    },
    {
      "start": 328.24,
      "duration": 4.2,
      "text": "なことをしっかりとじっくりねあの議論"
    },
    {
      "start": 330.52,
      "duration": 4.08,
      "text": "できるようにしていくということも議会"
    },
    {
      "start": 332.44,
      "duration": 5.0,
      "text": "改革だと思いますのでまそのように"
    },
    {
      "start": 334.6,
      "duration": 3.68,
      "text": "申し上げておきたいと思いますはい一度"
    },
    {
      "start": 337.44,
      "duration": 4.72,
      "text": "じゃ"
    },
    {
      "start": 338.28,
      "duration": 7.639,
      "text": "水あのま地方自治法惹かれたと思うんです"
    },
    {
      "start": 342.16,
      "duration": 6.56,
      "text": "けどあの要するにあの自治体の事務以外の"
    },
    {
      "start": 345.919,
      "duration": 5.12,
      "text": "ものについての扱いについてっていうこと"
    },
    {
      "start": 348.72,
      "duration": 6.08,
      "text": "だったと思うんですがさっきあの片山さん"
    },
    {
      "start": 351.039,
      "duration": 8.88,
      "text": "も言われた通りまノコの問題であるとか"
    },
    {
      "start": 354.8,
      "duration": 9.839,
      "text": "あの確かあの他君に関する意見証であった"
    },
    {
      "start": 359.919,
      "duration": 7.68,
      "text": "かな確かあの核実験の問題とか北朝鮮の"
    },
    {
      "start": 364.639,
      "duration": 6.041,
      "text": "問題とかねありましたよねそういうのある"
    },
    {
      "start": 367.599,
      "duration": 5.44,
      "text": "のであの一概にねなんか小金師の事務に"
    },
    {
      "start": 370.68,
      "duration": 4.76,
      "text": "限ってっていうことではあのなかったと"
    },
    {
      "start": 373.039,
      "duration": 5.801,
      "text": "思うんですねであの一応そのハンドボック"
    },
    {
      "start": 375.44,
      "duration": 5.56,
      "text": "の中であのま参考送付にするものていう"
    },
    {
      "start": 378.84,
      "duration": 4.4,
      "text": "ことは取り決めてあるのでそこをまた"
    },
    {
      "start": 381.0,
      "duration": 4.24,
      "text": "見直しておきたいってことであればそれは"
    },
    {
      "start": 383.24,
      "duration": 4.72,
      "text": "それでねあの議論していくっていうことに"
    },
    {
      "start": 385.24,
      "duration": 5.359,
      "text": "なると思いますけどただ私はね広く"
    },
    {
      "start": 387.96,
      "duration": 5.76,
      "text": "やっぱり市民の意見として"
    },
    {
      "start": 390.599,
      "duration": 7.521,
      "text": "はあのプライバシーを犯すようなあの問題"
    },
    {
      "start": 393.72,
      "duration": 7.12,
      "text": "でなければ受け付けてあは委員会でね色々"
    },
    {
      "start": 398.12,
      "duration": 5.04,
      "text": "あの取り扱いについては知恵を出して扱っ"
    },
    {
      "start": 400.84,
      "duration": 5.0,
      "text": "てきてるわけだからそういうものとして"
    },
    {
      "start": 403.16,
      "duration": 5.12,
      "text": "取り扱っていくという風にあのしていく"
    },
    {
      "start": 405.84,
      "duration": 4.84,
      "text": "必要があるかなという風には考えており"
    },
    {
      "start": 408.28,
      "duration": 5.919,
      "text": "ますので"
    },
    {
      "start": 410.68,
      "duration": 9.28,
      "text": "あのああの一応その市民じゃなくてもあの"
    },
    {
      "start": 414.199,
      "duration": 8.56,
      "text": "他市のあの要するにあの市民も含めてあの"
    },
    {
      "start": 419.96,
      "duration": 5.959,
      "text": "は提出されておりますのであの一般的な"
    },
    {
      "start": 422.759,
      "duration": 5.56,
      "text": "市民という形であの小金市の市民だけでは"
    },
    {
      "start": 425.919,
      "duration": 4.641,
      "text": "なくということで市民という言葉使わせて"
    },
    {
      "start": 428.319,
      "duration": 5.241,
      "text": "もらいましたのであのそういうこととして"
    },
    {
      "start": 430.56,
      "duration": 6.359,
      "text": "今現状ね扱ってるのであのそういうルール"
    },
    {
      "start": 433.56,
      "duration": 5.84,
      "text": "に従って今回は付託されたというものだと"
    },
    {
      "start": 436.919,
      "duration": 6.481,
      "text": "考えておりますのであのそのように"
    },
    {
      "start": 439.4,
      "duration": 4.0,
      "text": "取り扱っていくということだと思い"
    },
    {
      "start": 443.879,
      "duration": 8.32,
      "text": "ますよろしいですかはい他にございます"
    },
    {
      "start": 447.84,
      "duration": 6.479,
      "text": "かいますね大丈夫ですかはいそれではま"
    },
    {
      "start": 452.199,
      "duration": 5.641,
      "text": "様々ご解禁をいただきましたけどもまこの"
    },
    {
      "start": 454.319,
      "duration": 5.121,
      "text": "件についてはあの昨日決まった通りに運ば"
    },
    {
      "start": 457.84,
      "duration": 3.52,
      "text": "せていただくことになると思いますので"
    },
    {
      "start": 459.44,
      "duration": 6.92,
      "text": "よろしくお願いいたしますそれでは以上で"
    },
    {
      "start": 461.36,
      "duration": 5.0,
      "text": "議会運会協議会とに参回といたします"
    }
  ]
}