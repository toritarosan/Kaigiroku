{
  "entries": [
    {
      "start": 31.16,
      "duration": 4.239,
      "text": "はいそれでは皆様お揃いでございますので"
    },
    {
      "start": 33.44,
      "duration": 3.72,
      "text": "帝国前でございますが議会委員会協議会"
    },
    {
      "start": 35.399,
      "duration": 4.441,
      "text": "始めさせていただきますお手元の協議事故"
    },
    {
      "start": 37.16,
      "duration": 5.64,
      "text": "をご覧くださいえ本日の信行予定について"
    },
    {
      "start": 39.84,
      "duration": 5.48,
      "text": "え議長の諮問事項1件でございます議会に"
    },
    {
      "start": 42.8,
      "duration": 5.16,
      "text": "関する議長の諮問事項について括1正眼"
    },
    {
      "start": 45.32,
      "duration": 5.32,
      "text": "陳情の追加部の付託委員会について2議員"
    },
    {
      "start": 47.96,
      "duration": 5.759,
      "text": "の派遣についてえこ3議会運営委員会継続"
    },
    {
      "start": 50.64,
      "duration": 5.68,
      "text": "審査議決についてえでございますえこ4"
    },
    {
      "start": 53.719,
      "duration": 6.241,
      "text": "その他で何かご発言があればお願いいたし"
    },
    {
      "start": 56.32,
      "duration": 5.96,
      "text": "ますであの進については以になりますがろ"
    },
    {
      "start": 59.96,
      "duration": 5.32,
      "text": "いいですかはいはいそれではあの協議会の"
    },
    {
      "start": 62.28,
      "duration": 5.159,
      "text": "方でですねえっと議員提出案件の討論採決"
    },
    {
      "start": 65.28,
      "duration": 5.839,
      "text": "があれば伺っていきたいと思いますえ自由"
    },
    {
      "start": 67.439,
      "duration": 5.921,
      "text": "民主と信頼の小金さん討論ございません"
    },
    {
      "start": 71.119,
      "duration": 5.081,
      "text": "はいありがとうございますえ未来の古賀も"
    },
    {
      "start": 73.36,
      "duration": 6.36,
      "text": "討論ございませんはい子供の権利を守る会"
    },
    {
      "start": 76.2,
      "duration": 8.08,
      "text": "さんはいありませんはい日本共産党さん産"
    },
    {
      "start": 79.72,
      "duration": 9.96,
      "text": "党はあの48号えっと反対登路水上です"
    },
    {
      "start": 84.28,
      "duration": 8.96,
      "text": "48号反対多様な人材の地方議会への三角"
    },
    {
      "start": 89.68,
      "duration": 6.92,
      "text": "はいはいコメトさんございませんはい小金"
    },
    {
      "start": 93.24,
      "duration": 5.44,
      "text": "面白く世界さんありませんはいではえ生活"
    },
    {
      "start": 96.6,
      "duration": 5.28,
      "text": "者ネットワークさん他単独会お願いします"
    },
    {
      "start": 98.68,
      "duration": 7.68,
      "text": "はい生活者ネットワーク議員代あ48"
    },
    {
      "start": 101.88,
      "duration": 9.12,
      "text": "号反対と反対はい"
    },
    {
      "start": 106.36,
      "duration": 9.56,
      "text": "同じく48号はい反対討論緑繋がる"
    },
    {
      "start": 111.0,
      "duration": 9.32,
      "text": "小がねはい酒井さんはい以上です以上で他"
    },
    {
      "start": 115.92,
      "duration": 7.76,
      "text": "はなしはいということはえ議案第488号"
    },
    {
      "start": 120.32,
      "duration": 6.0,
      "text": "でえ反対討論水上さん安田さん酒井さんの"
    },
    {
      "start": 123.68,
      "duration": 4.919,
      "text": "3名と以上3件ということでよろしかった"
    },
    {
      "start": 126.32,
      "duration": 4.52,
      "text": "ですかはいでは採決についた従前通りで"
    },
    {
      "start": 128.599,
      "duration": 5.241,
      "text": "よろしかったですかはいそれでは員会入っ"
    },
    {
      "start": 130.84,
      "duration": 3.0,
      "text": "てまりますよろしくお願いし"
    },
    {
      "start": 134.0,
      "duration": 4.92,
      "text": "ますただいまから議会運営委員会の会議を"
    },
    {
      "start": 136.76,
      "duration": 4.4,
      "text": "開きます直に議事に入ります当委員会に"
    },
    {
      "start": 138.92,
      "duration": 4.959,
      "text": "付託されております案件は議長の諮問事項"
    },
    {
      "start": 141.16,
      "duration": 4.719,
      "text": "1件であります議長からお手元に議会運営"
    },
    {
      "start": 143.879,
      "duration": 4.041,
      "text": "委員会協議事項が提示されておりますので"
    },
    {
      "start": 145.879,
      "duration": 4.321,
      "text": "その順序に従って順次協議をしてまいり"
    },
    {
      "start": 147.92,
      "duration": 5.16,
      "text": "たいと思います議会運営に関する議長の"
    },
    {
      "start": 150.2,
      "duration": 6.039,
      "text": "諮問事項についてを議題といたします始め"
    },
    {
      "start": 153.08,
      "duration": 6.12,
      "text": "に協議事項1正眼陳情の追加部の2先委員"
    },
    {
      "start": 156.239,
      "duration": 5.0,
      "text": "会についてを行います議長の下問案が示さ"
    },
    {
      "start": 159.2,
      "duration": 7.24,
      "text": "れておりますので副議長から説明をお願い"
    },
    {
      "start": 161.239,
      "duration": 8.0,
      "text": "いたしますはいえ12月17日の午後5時"
    },
    {
      "start": 166.44,
      "duration": 6.0,
      "text": "までに受付けました正眼陳情はありません"
    },
    {
      "start": 169.239,
      "duration": 5.841,
      "text": "でしたのでご報告をいたしますはい"
    },
    {
      "start": 172.44,
      "duration": 4.879,
      "text": "ただいま副議長の説明の通り追加分の正眼"
    },
    {
      "start": 175.08,
      "duration": 5.56,
      "text": "陳情はないということでご確認いただけ"
    },
    {
      "start": 177.319,
      "duration": 5.28,
      "text": "ますでしょうかはい追加の陳情はないと"
    },
    {
      "start": 180.64,
      "duration": 4.28,
      "text": "いうことでご確認いただきました次に教育"
    },
    {
      "start": 182.599,
      "duration": 4.441,
      "text": "事項括弧に議員の派遣についてを行います"
    },
    {
      "start": 184.92,
      "duration": 5.12,
      "text": "議長の諮問案が示されておりますので副議"
    },
    {
      "start": 187.04,
      "duration": 5.199,
      "text": "長から説明をお願いいたしますはいえ事務"
    },
    {
      "start": 190.04,
      "duration": 5.88,
      "text": "局から説明いたします"
    },
    {
      "start": 192.239,
      "duration": 6.401,
      "text": "局長はいえ本日までに決定しております"
    },
    {
      "start": 195.92,
      "duration": 5.599,
      "text": "議員派遣につきましてはお手元の資料の"
    },
    {
      "start": 198.64,
      "duration": 6.56,
      "text": "通りとなっております本件につきましては"
    },
    {
      "start": 201.519,
      "duration": 6.761,
      "text": "説明質疑委員会負託を省略して即決する"
    },
    {
      "start": 205.2,
      "duration": 6.0,
      "text": "また初犯の事情により変更が生じた場合や"
    },
    {
      "start": 208.28,
      "duration": 7.36,
      "text": "閉会中に議員派遣が生じた場合などについ"
    },
    {
      "start": 211.2,
      "duration": 7.08,
      "text": "てその日次場所目的及び派遣議員名等は"
    },
    {
      "start": 215.64,
      "duration": 6.4,
      "text": "議長にご一任願いたいというのが議長の"
    },
    {
      "start": 218.28,
      "duration": 5.72,
      "text": "下問案でございます副議長及び事務局の"
    },
    {
      "start": 222.04,
      "duration": 5.24,
      "text": "説明は終わりましたご意見ご質疑とは"
    },
    {
      "start": 224.0,
      "duration": 5.4,
      "text": "ございますかはいでは員あはいすいません"
    },
    {
      "start": 227.28,
      "duration": 5.12,
      "text": "あの銀の派遣について拝見いたしました"
    },
    {
      "start": 229.4,
      "duration": 4.8,
      "text": "けどもこれ出式って入ってなか今まで入っ"
    },
    {
      "start": 232.4,
      "duration": 7.919,
      "text": "てたんじゃなかったかなと思ったりしたん"
    },
    {
      "start": 234.2,
      "duration": 6.119,
      "text": "ですけどいかがだったでしょうか出式"
    },
    {
      "start": 244.76,
      "duration": 8.08,
      "text": "はい次長はいえっと一応ですねえっと従来"
    },
    {
      "start": 249.36,
      "duration": 6.879,
      "text": "載せてるえ銀派遣についてこちら載せてる"
    },
    {
      "start": 252.84,
      "duration": 7.44,
      "text": "形になりましてえっとちょっと確認は"
    },
    {
      "start": 256.239,
      "duration": 6.4,
      "text": "いたしますがあの従来載せてるあの現在"
    },
    {
      "start": 260.28,
      "duration": 5.72,
      "text": "分かってる銀派遣について載せてるような"
    },
    {
      "start": 262.639,
      "duration": 6.361,
      "text": "状況でございますでもしあのベッドですね"
    },
    {
      "start": 266.0,
      "duration": 7.199,
      "text": "あの銀派遣が必要な場合はあのそれを一見"
    },
    {
      "start": 269.0,
      "duration": 6.6,
      "text": "ア技人であの案であの派遣はかけたいと"
    },
    {
      "start": 273.199,
      "duration": 6.241,
      "text": "思います以上でございますはいよろしい"
    },
    {
      "start": 275.6,
      "duration": 9.879,
      "text": "ですかはいじゃあ安田委員すいませ1月の"
    },
    {
      "start": 279.44,
      "duration": 9.08,
      "text": "28日水教のえ第1委員会に出席派遣と"
    },
    {
      "start": 285.479,
      "duration": 8.481,
      "text": "いうことなんですけれどもこの日はえっと"
    },
    {
      "start": 288.52,
      "duration": 8.32,
      "text": "第1定例会の初日になりますえっとこの"
    },
    {
      "start": 293.96,
      "duration": 7.92,
      "text": "この場合はどのようにするのでしょう"
    },
    {
      "start": 296.84,
      "duration": 6.96,
      "text": "かはいませについてはあの行く可能性が"
    },
    {
      "start": 301.88,
      "duration": 5.12,
      "text": "あるものをあのかけさせていただきますの"
    },
    {
      "start": 303.8,
      "duration": 5.72,
      "text": "で出血の関係はまたベッちょっと調整をさ"
    },
    {
      "start": 307.0,
      "duration": 6.12,
      "text": "せていただきたいと思います以上ですはい"
    },
    {
      "start": 309.52,
      "duration": 3.6,
      "text": "よろしいですかはい他にございます"
    },
    {
      "start": 317.08,
      "duration": 8.559,
      "text": "かです"
    },
    {
      "start": 320.759,
      "duration": 7.081,
      "text": "うん大丈夫ですかはいではおりいたします"
    },
    {
      "start": 325.639,
      "duration": 5.241,
      "text": "本については議長の指の通り決定すること"
    },
    {
      "start": 327.84,
      "duration": 6.079,
      "text": "にご異議ありませんか認めます従って本件"
    },
    {
      "start": 330.88,
      "duration": 6.28,
      "text": "は議長の諮問の通り決定といたしましたえ"
    },
    {
      "start": 333.919,
      "duration": 5.681,
      "text": "次に協議事故括3議会運営委員会継続審査"
    },
    {
      "start": 337.16,
      "duration": 5.879,
      "text": "議決について行いますお諮りいたします"
    },
    {
      "start": 339.6,
      "duration": 6.68,
      "text": "次期定例会括弧臨時会を含むの会期及び"
    },
    {
      "start": 343.039,
      "duration": 6.44,
      "text": "会議被等議会運営に関する調査議会の会議"
    },
    {
      "start": 346.28,
      "duration": 6.359,
      "text": "規則委員会条例等に関する調査議会運営に"
    },
    {
      "start": 349.479,
      "duration": 5.201,
      "text": "関する議長の諮問事項について閉会中文な"
    },
    {
      "start": 352.639,
      "duration": 4.441,
      "text": "を継続して調査することにご異議ありませ"
    },
    {
      "start": 354.68,
      "duration": 4.44,
      "text": "んかご異議なしと認めます従ってただいま"
    },
    {
      "start": 357.08,
      "duration": 5.48,
      "text": "申し上げました通り閉会中もを継続して"
    },
    {
      "start": 359.12,
      "duration": 6.04,
      "text": "調査すると決定いしました事項4その他で"
    },
    {
      "start": 362.56,
      "duration": 7.0,
      "text": "ございますが何かご発言をございます"
    },
    {
      "start": 365.16,
      "duration": 7.439,
      "text": "かはいはい片山福長すいませんあれ今会"
    },
    {
      "start": 369.56,
      "duration": 4.72,
      "text": "だったまではいはいすいませんあごめん"
    },
    {
      "start": 372.599,
      "duration": 3.6,
      "text": "なさいあのちょっと戻ってしまってあれな"
    },
    {
      "start": 374.28,
      "duration": 4.68,
      "text": "んですがごめんなさいこ閉中じゃなくて"
    },
    {
      "start": 376.199,
      "duration": 5.921,
      "text": "あれですよねあの開会中の議員の背景も"
    },
    {
      "start": 378.96,
      "duration": 6.04,
      "text": "入ってますよねえすいませんえいやあの玉"
    },
    {
      "start": 382.12,
      "duration": 6.799,
      "text": "きがないなと思ったもんですからあも多分"
    },
    {
      "start": 385.0,
      "duration": 6.0,
      "text": "あの予算委員会中のはずだったんであの"
    },
    {
      "start": 388.919,
      "duration": 4.961,
      "text": "なかったなとっんでちょっととりあえず"
    },
    {
      "start": 391.0,
      "duration": 6.24,
      "text": "確認だけですはい次長すいませんあの"
    },
    {
      "start": 393.88,
      "duration": 6.24,
      "text": "先ほどあすいませんでしたあのえあの派遣"
    },
    {
      "start": 397.24,
      "duration": 6.64,
      "text": "他の派遣がもしある場合はちょっとあの"
    },
    {
      "start": 400.12,
      "duration": 6.44,
      "text": "気安気安にてちょっと派遣のえ手続きを"
    },
    {
      "start": 403.88,
      "duration": 6.599,
      "text": "行いたいと思います以上ですはいという"
    },
    {
      "start": 406.56,
      "duration": 6.72,
      "text": "ことでございますはい他ございますか"
    },
    {
      "start": 410.479,
      "duration": 5.521,
      "text": "その田ございますかはいよろしいですか"
    },
    {
      "start": 413.28,
      "duration": 4.44,
      "text": "はいはいそれでは以上で当委員会に託され"
    },
    {
      "start": 416.0,
      "duration": 4.36,
      "text": "ております案件の審査は全て終了いたし"
    },
    {
      "start": 417.72,
      "duration": 7.44,
      "text": "ましたこれで議会員会の会議をり参いし"
    },
    {
      "start": 420.36,
      "duration": 4.8,
      "text": "ますはいお疲れ様でした"
    }
  ]
}