{
  "entries": [
    {
      "start": 29.24,
      "duration": 7.159,
      "text": "よはいお疲れ様でございます疲れ様ですえ"
    },
    {
      "start": 33.64,
      "duration": 5.64,
      "text": "予備日の議運がこんな時間に始まるなんで"
    },
    {
      "start": 36.399,
      "duration": 5.041,
      "text": "という感じでお揃いでございますので議会"
    },
    {
      "start": 39.28,
      "duration": 5.4,
      "text": "運営会協議会を始めさせていただきます2"
    },
    {
      "start": 41.44,
      "duration": 5.08,
      "text": "の競技事故の2の方でございますねで本日"
    },
    {
      "start": 44.68,
      "duration": 5.28,
      "text": "の進行状況の確認についてということと"
    },
    {
      "start": 46.52,
      "duration": 6.76,
      "text": "議会整備についてこれ事務局からはい事務"
    },
    {
      "start": 49.96,
      "duration": 6.68,
      "text": "局局長はいえそれではですねえ本日のえ"
    },
    {
      "start": 53.28,
      "duration": 6.0,
      "text": "冒頭の議科委員会の際にですねえ確認をさ"
    },
    {
      "start": 56.64,
      "duration": 6.879,
      "text": "せていただきましたま本日の進行予定に"
    },
    {
      "start": 59.28,
      "duration": 8.08,
      "text": "ついてえ順で言いますと1番から5番まで"
    },
    {
      "start": 63.519,
      "duration": 7.481,
      "text": "の今会派代表者会議までえ終了をしており"
    },
    {
      "start": 67.36,
      "duration": 7.0,
      "text": "ますえ従いましてえ特に保留事項等は"
    },
    {
      "start": 71.0,
      "duration": 7.4,
      "text": "ございませんのでえ明日につきましてはえ"
    },
    {
      "start": 74.36,
      "duration": 7.439,
      "text": "本会議のま準備のための議会整備という形"
    },
    {
      "start": 78.4,
      "duration": 6.12,
      "text": "でえ明日はさせていただきたいと思います"
    },
    {
      "start": 81.799,
      "duration": 6.121,
      "text": "以上でございますはいこの件について何か"
    },
    {
      "start": 84.52,
      "duration": 5.04,
      "text": "ご質疑ございますかはいでは総部はこちら"
    },
    {
      "start": 87.92,
      "duration": 2.519,
      "text": "までということではいお疲れ様でござい"
    },
    {
      "start": 89.56,
      "duration": 3.04,
      "text": "ます"
    },
    {
      "start": 90.439,
      "duration": 6.161,
      "text": "はいそれではかこさんの行政殺報告書の"
    },
    {
      "start": 92.6,
      "duration": 6.24,
      "text": "修正についてはいえ佐すいませんえっと"
    },
    {
      "start": 96.6,
      "duration": 6.64,
      "text": "まず詫びというところなんですけども私の"
    },
    {
      "start": 98.84,
      "duration": 7.84,
      "text": "ちょっと認識不足でありましてと委員委員"
    },
    {
      "start": 103.24,
      "duration": 7.04,
      "text": "の意見のところあと議長のやつそのまま"
    },
    {
      "start": 106.68,
      "duration": 5.799,
      "text": "入れてしまいまして議長いらは不要であっ"
    },
    {
      "start": 110.28,
      "duration": 4.4,
      "text": "たというところになり伝しなくてもいいの"
    },
    {
      "start": 112.479,
      "duration": 4.481,
      "text": "にしちゃったもんです変申し訳ありません"
    },
    {
      "start": 114.68,
      "duration": 6.56,
      "text": "素晴らしい大変申し訳ありますあの私も"
    },
    {
      "start": 116.96,
      "duration": 7.6,
      "text": "ちょっと知らなくて書てる既にもう配布し"
    },
    {
      "start": 121.24,
      "duration": 5.519,
      "text": "てしまってる部分に関してはと委員の最後"
    },
    {
      "start": 124.56,
      "duration": 4.64,
      "text": "のところえっと消して見ていただければと"
    },
    {
      "start": 126.759,
      "duration": 4.48,
      "text": "思いますもし必要であればえっと印刷して"
    },
    {
      "start": 129.2,
      "duration": 4.72,
      "text": "お渡しをしますので行っていただければと"
    },
    {
      "start": 131.239,
      "duration": 7.28,
      "text": "思いますで明後日の本会議に出すものに"
    },
    {
      "start": 133.92,
      "duration": 6.039,
      "text": "関しましては削ったものをえ提出配布させ"
    },
    {
      "start": 138.519,
      "duration": 4.681,
      "text": "ていただきたいと思いますのですいません"
    },
    {
      "start": 139.959,
      "duration": 7.401,
      "text": "申し訳ありません以上ですはい何かご質疑"
    },
    {
      "start": 143.2,
      "duration": 8.36,
      "text": "ご意見ございますかはいそれでは4銀集に"
    },
    {
      "start": 147.36,
      "duration": 6.959,
      "text": "ついてはい長はいえので研修内容の確認が"
    },
    {
      "start": 151.56,
      "duration": 6.319,
      "text": "宿題となっておりましたご報告いたします"
    },
    {
      "start": 154.319,
      "duration": 5.961,
      "text": "えっと今回の議員研修会はえ冒頭であの"
    },
    {
      "start": 157.879,
      "duration": 6.241,
      "text": "ファシリテーションとは何かという説明の"
    },
    {
      "start": 160.28,
      "duration": 6.599,
      "text": "後にえ講義演習講義演習というよなのを"
    },
    {
      "start": 164.12,
      "duration": 5.839,
      "text": "繰り返す研修内容であるとのことですで"
    },
    {
      "start": 166.879,
      "duration": 5.241,
      "text": "そのためえ研修の参加者である議員の皆"
    },
    {
      "start": 169.959,
      "duration": 5.161,
      "text": "さんが研修効果を高めるということを"
    },
    {
      "start": 172.12,
      "duration": 6.039,
      "text": "考えるとま膨張している方がいる場合は"
    },
    {
      "start": 175.12,
      "duration": 5.28,
      "text": "発言したいことがえできなくなってしまう"
    },
    {
      "start": 178.159,
      "duration": 4.72,
      "text": "というような懸念がありましあるんじゃ"
    },
    {
      "start": 180.4,
      "duration": 5.64,
      "text": "ないかとでファシリテーションを理解する"
    },
    {
      "start": 182.879,
      "duration": 5.961,
      "text": "ためにはできるだけ本音が話ができる環境"
    },
    {
      "start": 186.04,
      "duration": 4.96,
      "text": "が望ましいとのことでございますまた是非"
    },
    {
      "start": 188.84,
      "duration": 5.24,
      "text": "演習の中でファシリテーターを実践する"
    },
    {
      "start": 191.0,
      "duration": 5.56,
      "text": "感覚を掴んでいただきたいということでえ"
    },
    {
      "start": 194.08,
      "duration": 4.96,
      "text": "うまく進められない要素膨張者の方から見"
    },
    {
      "start": 196.56,
      "duration": 5.48,
      "text": "られるとま思いきって心取り組めないこと"
    },
    {
      "start": 199.04,
      "duration": 5.52,
      "text": "も考えられるんではないかとのことですえ"
    },
    {
      "start": 202.04,
      "duration": 5.36,
      "text": "以上のことからもえ今回は膨張者の方が"
    },
    {
      "start": 204.56,
      "duration": 5.759,
      "text": "いらっしゃらない方がより研修の効果は"
    },
    {
      "start": 207.4,
      "duration": 5.68,
      "text": "高まるのではないかとえいう風にわれると"
    },
    {
      "start": 210.319,
      "duration": 4.761,
      "text": "のことでしたえなおあの議員研修会につき"
    },
    {
      "start": 213.08,
      "duration": 5.92,
      "text": "ましてはえっとハンドブックの101"
    },
    {
      "start": 215.08,
      "duration": 7.68,
      "text": "ページにえ研修内容によりえ議員のみの"
    },
    {
      "start": 219.0,
      "duration": 6.799,
      "text": "研修とえ市民も行できる公開研修に分けて"
    },
    {
      "start": 222.76,
      "duration": 5.479,
      "text": "実施するものとしという申し合わせがある"
    },
    {
      "start": 225.799,
      "duration": 5.401,
      "text": "ことを念のためえご報告させていただき"
    },
    {
      "start": 228.239,
      "duration": 6.92,
      "text": "ますえ報告は以上でございますはいこれに"
    },
    {
      "start": 231.2,
      "duration": 6.119,
      "text": "対してご意見ご質ございますかはい片長"
    },
    {
      "start": 235.159,
      "duration": 6.681,
      "text": "はいあの調査いただきましてありがとう"
    },
    {
      "start": 237.319,
      "duration": 7.081,
      "text": "ございますえっとまかりあのえ先日のです"
    },
    {
      "start": 241.84,
      "duration": 5.599,
      "text": "ねところであのま公開非公開の話があった"
    },
    {
      "start": 244.4,
      "duration": 4.96,
      "text": "のであのそういったことでま講師の方の"
    },
    {
      "start": 247.439,
      "duration": 5.281,
      "text": "移行に沿った形で進めていただければと"
    },
    {
      "start": 249.36,
      "duration": 6.12,
      "text": "思っております以上ですはいで今回の議員"
    },
    {
      "start": 252.72,
      "duration": 4.479,
      "text": "研修会については非公会ということで研修"
    },
    {
      "start": 255.48,
      "duration": 3.64,
      "text": "趣旨からして非行会ということでえ"
    },
    {
      "start": 257.199,
      "duration": 5.041,
      "text": "よろしかったでしょうかはいはいという"
    },
    {
      "start": 259.12,
      "duration": 6.92,
      "text": "ことでございますはいではかこ5その他で"
    },
    {
      "start": 262.24,
      "duration": 7.959,
      "text": "ございます何かございますかはい山副長"
    },
    {
      "start": 266.04,
      "duration": 6.08,
      "text": "はいえっとですねあのえっと議会の面に"
    },
    {
      "start": 270.199,
      "duration": 3.72,
      "text": "ついてなんですけれどもあの記事の方を"
    },
    {
      "start": 272.12,
      "duration": 3.68,
      "text": "ですねお送りしたところあのご意見"
    },
    {
      "start": 273.919,
      "duration": 4.401,
      "text": "いただきましてありがとうございますで"
    },
    {
      "start": 275.8,
      "duration": 4.92,
      "text": "あの先ほどえっとまたお送りしているん"
    },
    {
      "start": 278.32,
      "duration": 5.2,
      "text": "ですけどもあの安田さんが手直しして"
    },
    {
      "start": 280.72,
      "duration": 6.24,
      "text": "くださったものに小林さんのですねあの"
    },
    {
      "start": 283.52,
      "duration": 7.239,
      "text": "意見を加えましてであの人数も15名と"
    },
    {
      "start": 286.96,
      "duration": 6.92,
      "text": "いうことで私もカトた15名ででしたけど"
    },
    {
      "start": 290.759,
      "duration": 5.681,
      "text": "えっとそちらをえ修正したものをお送りし"
    },
    {
      "start": 293.88,
      "duration": 7.24,
      "text": "ておりますのでこちらでよろしかったか"
    },
    {
      "start": 296.44,
      "duration": 4.68,
      "text": "どうか確認いただければと思います"
    },
    {
      "start": 307.199,
      "duration": 5.521,
      "text": "いいですあの"
    },
    {
      "start": 308.72,
      "duration": 7.6,
      "text": "あしはいはい長はいませえっともし何か"
    },
    {
      "start": 312.72,
      "duration": 7.56,
      "text": "見れないってこと今あの紙いただきました"
    },
    {
      "start": 316.32,
      "duration": 6.04,
      "text": "んで後でこれ回しますけれどもこちら回し"
    },
    {
      "start": 320.28,
      "duration": 6.919,
      "text": "てみていただいた方がよろしいですか"
    },
    {
      "start": 322.36,
      "duration": 9.72,
      "text": "ね大丈夫送ってますよろしいですか"
    },
    {
      "start": 327.199,
      "duration": 7.481,
      "text": "はいじゃこ安はいすいませんちょっと提案"
    },
    {
      "start": 332.08,
      "duration": 5.76,
      "text": "後から考えたんですけども最後のところ"
    },
    {
      "start": 334.68,
      "duration": 6.16,
      "text": "双方にとって大きな刺激となりっていう"
    },
    {
      "start": 337.84,
      "duration": 6.28,
      "text": "ことであまお互いに刺激となったっていう"
    },
    {
      "start": 340.84,
      "duration": 5.84,
      "text": "ことはあるんですけどもあのそういった"
    },
    {
      "start": 344.12,
      "duration": 6.12,
      "text": "生徒会さんからのこう1個意見をいだい"
    },
    {
      "start": 346.68,
      "duration": 3.56,
      "text": "たっていうことで大丈夫でしょうか"
    },
    {
      "start": 351.72,
      "duration": 3.599,
      "text": "うん私たちが"
    },
    {
      "start": 355.479,
      "duration": 6.641,
      "text": "刺激はいあのはいはい片山長はいえとま"
    },
    {
      "start": 359.8,
      "duration": 5.0,
      "text": "終わった後にま懇談をしてる中で本当に"
    },
    {
      "start": 362.12,
      "duration": 4.639,
      "text": "ロロとあのえっとま感想良かったという"
    },
    {
      "start": 364.8,
      "duration": 4.519,
      "text": "感想いただいておりますのでちょっと今"
    },
    {
      "start": 366.759,
      "duration": 4.88,
      "text": "具体的なその事後のアンケートあれは特に"
    },
    {
      "start": 369.319,
      "duration": 5.121,
      "text": "あのないんですけれどもまちの場で"
    },
    {
      "start": 371.639,
      "duration": 5.881,
      "text": "いただいたご意見を元にあのあの書いてる"
    },
    {
      "start": 374.44,
      "duration": 4.8,
      "text": "というような形になりますじゃこちらで"
    },
    {
      "start": 377.52,
      "duration": 4.16,
      "text": "よろしければこれあの今日の後時までに"
    },
    {
      "start": 379.24,
      "duration": 4.2,
      "text": "提出ということなのであの提出させて"
    },
    {
      "start": 381.68,
      "duration": 4.12,
      "text": "いただきたいと思いますのでよろしくお"
    },
    {
      "start": 383.44,
      "duration": 4.84,
      "text": "願いしますはい作成ありがとうございまし"
    },
    {
      "start": 385.8,
      "duration": 6.36,
      "text": "たお疲れ様でしたはいその他ございますか"
    },
    {
      "start": 388.28,
      "duration": 8.639,
      "text": "よはいそれで"
    },
    {
      "start": 392.16,
      "duration": 9.159,
      "text": "はみてはいそれでは議会運営委員会協議会"
    },
    {
      "start": 396.919,
      "duration": 4.4,
      "text": "をじ参回をいたします"
    }
  ]
}