    {
      "start": 486.84,
      "duration": 2.359,
      "text": "出てん"
    },
    {
      "start": 489.4,
      "duration": 6.4,
      "text": "のあ電気台はどこで確認してるあ今回っ"
    },
    {
      "start": 494.4,
      "duration": 3.28,
      "text": "てる"
    },
    {
      "start": 495.8,
      "duration": 4.88,
      "text": "ところあ"
    },
    {
      "start": 497.68,
      "duration": 5.6,
      "text": "そうじゃあ今日打ち合わせこの後持つ時に"
    },
    {
      "start": 500.68,
      "duration": 4.44,
      "text": "は一応その途中段階かも出てるものか含め"
    },
    {
      "start": 503.28,
      "duration": 5.359,
      "text": "てちょっと1回持ち寄ってもらう必要が"
    },
    {
      "start": 505.12,
      "duration": 5.68,
      "text": "ありますねえよろしくお願いしますその際"
    },
    {
      "start": 508.639,
      "duration": 7.2,
      "text": "にお持ちいということでよろしくお願いし"
    },
    {
      "start": 510.8,
      "duration": 8.0,
      "text": "ますはいえっとそれでは次にでまずじゃ括"
    },
    {
      "start": 515.839,
      "duration": 5.12,
      "text": "1終わりますえ次に括弧に次回の開催に"
    },
    {
      "start": 518.8,
      "duration": 5.84,
      "text": "ついてでございますけれども次回の開催日"
    },
    {
      "start": 520.959,
      "duration": 6.361,
      "text": "はいつにいたしましょうか閉会"
    },
    {
      "start": 524.64,
      "duration": 7.44,
      "text": "中閉会中"
    },
    {
      "start": 527.32,
      "duration": 4.76,
      "text": "に1回ぐらい入れます"
    },
    {
      "start": 533.0,
      "duration": 5.8,
      "text": "かなんか進捗してるんだったらですけどね"
    },
    {
      "start": 541.2,
      "duration": 6.84,
      "text": "特段ないかな開かなきゃいけない広報協議"
    },
    {
      "start": 546.32,
      "duration": 4.079,
      "text": "会そのものを開かなきゃいけないような"
    },
    {
      "start": 548.04,
      "duration": 6.88,
      "text": "ところまで行き継ぎてそうですか各部会"
    },
    {
      "start": 550.399,
      "duration": 8.321,
      "text": "から何か上がってくるならはいはいさんえ"
    },
    {
      "start": 554.92,
      "duration": 7.68,
      "text": "広報部会はですねえガイドブックえの"
    },
    {
      "start": 558.72,
      "duration": 8.64,
      "text": "えっと編集ええなんだ改て確認してるん"
    },
    {
      "start": 562.6,
      "duration": 8.88,
      "text": "ですけど3定の9月の定例会の公共議会で"
    },
    {
      "start": 567.36,
      "duration": 7.32,
      "text": "には部会としてのをここに示したいと"
    },
    {
      "start": 571.48,
      "duration": 5.56,
      "text": "スケジュールでやってるのでま閉中はえ"
    },
    {
      "start": 574.68,
      "duration": 4.8,
      "text": "特にえ出すものはないなはいはい"
    },
    {
      "start": 577.04,
      "duration": 5.0,
      "text": "スケジュールで作業しますはいじゃあ広報"
    },
    {
      "start": 579.48,
      "duration": 5.359,
      "text": "部会そういうことですがあの四面改革部会"
    },
    {
      "start": 582.04,
      "duration": 6.0,
      "text": "今どうですか小部さんあの先ほど申し上げ"
    },
    {
      "start": 584.839,
      "duration": 5.921,
      "text": "たようにその予算競技のとこに上げたいん"
    },
    {
      "start": 588.04,
      "duration": 7.039,
      "text": "ですでそれが定例会"
    },
    {
      "start": 590.76,
      "duration": 7.36,
      "text": "の初めの方から始まるんだとするとその前"
    },
    {
      "start": 595.079,
      "duration": 5.921,
      "text": "に部会の内容1回ここで確認をいただき"
    },
    {
      "start": 598.12,
      "duration": 8.719,
      "text": "たいところはあります"
    },
    {
      "start": 601.0,
      "duration": 8.079,
      "text": "がまそんな長時間いらないのであの前半の"
    },
    {
      "start": 606.839,
      "duration": 4.24,
      "text": "本会議とこでちょっと入れてもらっても"
    },
    {
      "start": 609.079,
      "duration": 3.241,
      "text": "いいかなと思いますけどはいああの三定の"
    },
    {
      "start": 611.079,
      "duration": 5.76,
      "text": "ね"
    },
    {
      "start": 612.32,
      "duration": 7.639,
      "text": "はい三定の前半の本会議ぐらい"
    },
    {
      "start": 616.839,
      "duration": 5.761,
      "text": "か予算要望との兼ね合いで言うとどうなり"
    },
    {
      "start": 619.959,
      "duration": 5.961,
      "text": "ますか次長はい次長はいえっと前半の"
    },
    {
      "start": 622.6,
      "duration": 7.2,
      "text": "えっと4日目3日目の会派でえっと頭出し"
    },
    {
      "start": 625.92,
      "duration": 7.76,
      "text": "をさせていただいてで予備日あの三定の"
    },
    {
      "start": 629.8,
      "duration": 6.44,
      "text": "予備日最終日あたりにあのこれで行きます"
    },
    {
      "start": 633.68,
      "duration": 5.719,
      "text": "ということでうんはいはいということで"
    },
    {
      "start": 636.24,
      "duration": 7.64,
      "text": "ございますはい9月中になのではいと"
    },
    {
      "start": 639.399,
      "duration": 4.481,
      "text": "やっぱりじゃ前半の本会3日目"
    },
    {
      "start": 649.32,
      "duration": 7.959,
      "text": "えっとはいはいどうぞあすいませんえっと"
    },
    {
      "start": 653.399,
      "duration": 7.641,
      "text": "りえ第3回会の初日の会派代表者会議の"
    },
    {
      "start": 657.279,
      "duration": 8.441,
      "text": "ところで皆様にえ"
    },
    {
      "start": 661.04,
      "duration": 7.88,
      "text": "スそれでえ質問の4日目ですねえと終了後"
    },
    {
      "start": 665.72,
      "duration": 5.32,
      "text": "にそこの派代表者会議の中でえっと出揃う"
    },
    {
      "start": 668.92,
      "duration": 4.68,
      "text": "形になりましてでそこで決定して"
    },
    {
      "start": 671.04,
      "duration": 4.919,
      "text": "いただければそれで終わりなんですけども"
    },
    {
      "start": 673.6,
      "duration": 4.679,
      "text": "そこでまとまんないものとかま再度確認が"
    },
    {
      "start": 675.959,
      "duration": 4.521,
      "text": "あるものについてはまえっと予備日の会派"
    },
    {
      "start": 678.279,
      "duration": 3.8,
      "text": "代表者会議で確認を行うとそういった"
    },
    {
      "start": 680.48,
      "duration": 5.56,
      "text": "スケジュールを想定しておりますわりまし"
    },
    {
      "start": 682.079,
      "duration": 7.521,
      "text": "たとなるとえっとやっぱり前半の本会議の"
    },
    {
      "start": 686.04,
      "duration": 5.84,
      "text": "中でどこかにえっとしかも一般質問の最後"
    },
    {
      "start": 689.6,
      "duration": 5.96,
      "text": "の日の会派射会議でそういうことですから"
    },
    {
      "start": 691.88,
      "duration": 7.199,
      "text": "その前だよねえっとなると例えばその9月"
    },
    {
      "start": 695.56,
      "duration": 5.68,
      "text": "2日が初日でしたよね9月2日の決算上帝"
    },
    {
      "start": 699.079,
      "duration": 4.76,
      "text": "の本会議があってその後にまず会派代表者"
    },
    {
      "start": 701.24,
      "duration": 4.68,
      "text": "会議開くんでしょその会派代表者会議"
    },
    {
      "start": 703.839,
      "duration": 5.12,
      "text": "終わった後にでもじゃ"
    },
    {
      "start": 705.92,
      "duration": 6.159,
      "text": "やるしあるいは一般質問とかのどっかで"
    },
    {
      "start": 708.959,
      "duration": 3.12,
      "text": "入れるか終わった後"
    },
    {
      "start": 713.88,
      "duration": 6.56,
      "text": "にの前に1回ちょっとうん一般質問のその"
    },
    {
      "start": 717.639,
      "duration": 6.481,
      "text": "最後の日の会派"
    },
    {
      "start": 720.44,
      "duration": 5.92,
      "text": "よりは前がいいよね今の話だとねじゃあ"
    },
    {
      "start": 724.12,
      "duration": 4.719,
      "text": "どうしようか一般質問の最後の日っていう"
    },
    {
      "start": 726.36,
      "duration": 7.32,
      "text": "のはね10日なんですね9月"
    },
    {
      "start": 728.839,
      "duration": 6.36,
      "text": "の初日2日にじゃあえっと9月2日のです"
    },
    {
      "start": 733.68,
      "duration": 5.08,
      "text": "ね"
    },
    {
      "start": 735.199,
      "duration": 6.521,
      "text": "えっとまずあの決算上程の本会議がま開か"
    },
    {
      "start": 738.76,
      "duration": 6.079,
      "text": "れてでその後会派代表者会議が開かれます"
    },
    {
      "start": 741.72,
      "duration": 5.559,
      "text": "がその終了後ということで広報協議会を"
    },
    {
      "start": 744.839,
      "duration": 6.12,
      "text": "入れておきますので皆さん手帳の方にです"
    },
    {
      "start": 747.279,
      "duration": 6.321,
      "text": "ねその旨記載をお願いしてでこのこのあの"
    },
    {
      "start": 750.959,
      "duration": 6.24,
      "text": "広報協議会の主なテーマは今えっと市門"
    },
    {
      "start": 753.6,
      "duration": 6.44,
      "text": "改革部会の方がこの閉会中に一定議論をし"
    },
    {
      "start": 757.199,
      "duration": 5.921,
      "text": "て予算要望に関して整理をされたらばえ"
    },
    {
      "start": 760.04,
      "duration": 6.84,
      "text": "それをこの広報協議会9月2日の日にあの"
    },
    {
      "start": 763.12,
      "duration": 6.12,
      "text": "提案をいただくとえいうことになるかなと"
    },
    {
      "start": 766.88,
      "duration": 5.68,
      "text": "いう風に思うのでその段取りでよろしくお"
    },
    {
      "start": 769.24,
      "duration": 6.08,
      "text": "願いしたいということでありますそれで"
    },
    {
      "start": 772.56,
      "duration": 4.399,
      "text": "あの9月2日の日にいきなりボンと出ると"
    },
    {
      "start": 775.32,
      "duration": 4.0,
      "text": "あのその日は持ち帰りみたいになっちゃう"
    },
    {
      "start": 776.959,
      "duration": 4.761,
      "text": "可能性があるのでまできればその9月2日"
    },
    {
      "start": 779.32,
      "duration": 4.759,
      "text": "にきちんと決めるんだったらあのあの市名"
    },
    {
      "start": 781.72,
      "duration": 4.32,
      "text": "改革部会の方でなるべく早めに各会派に"
    },
    {
      "start": 784.079,
      "duration": 4.161,
      "text": "アナウンスしていただいて少しその"
    },
    {
      "start": 786.04,
      "duration": 4.68,
      "text": "それぞれの会派内での意見交換促進しとい"
    },
    {
      "start": 788.24,
      "duration": 5.039,
      "text": "ていただいた方が2日は少し話が早いかな"
    },
    {
      "start": 790.72,
      "duration": 4.28,
      "text": "と思うんでよろしくお願いしたいと思い"
    },
    {
      "start": 793.279,
      "duration": 4.721,
      "text": "ます"
    },
    {
      "start": 795.0,
      "duration": 5.399,
      "text": "えっとそれではえっとかこには終わります"
    },
    {
      "start": 798.0,
      "duration": 5.0,
      "text": "次にかこさんのその田でございますが"
    },
    {
      "start": 800.399,
      "duration": 6.521,
      "text": "その田岸田君からですよねはい岸田さん"
    },
    {
      "start": 803.0,
      "duration": 6.32,
      "text": "はい議運委員会でございますえっと兼ねて"
    },
    {
      "start": 806.92,
      "duration": 6.64,
      "text": "からですね市民の皆さんから頂いたご意見"
    },
    {
      "start": 809.32,
      "duration": 7.199,
      "text": "をどうするのかということで好調機能つい"
    },
    {
      "start": 813.56,
      "duration": 4.6,
      "text": "てま課題が前期から申し送りがございまし"
    },
    {
      "start": 816.519,
      "duration": 6.201,
      "text": "てま今の"
    },
    {
      "start": 818.16,
      "duration": 8.52,
      "text": "あ議会基本条例検証協議会においてもです"
    },
    {
      "start": 822.72,
      "duration": 7.4,
      "text": "ねこれを協議した結果あのま前回は出席し"
    },
    {
      "start": 826.68,
      "duration": 7.0,
      "text": "ていただいてますがま候補校長協議会に"
    },
    {
      "start": 830.12,
      "duration": 6.8,
      "text": "拡充をすべきだというお話がございまして"
    },
    {
      "start": 833.68,
      "duration": 6.159,
      "text": "先般の議会運営委員会でえ候補校長協議会"
    },
    {
      "start": 836.92,
      "duration": 5.24,
      "text": "とすることは確認をさせていただきました"
    },
    {
      "start": 839.839,
      "duration": 4.601,
      "text": "で現状はですねあの名前だけ変えるという"
    },
    {
      "start": 842.16,
      "duration": 5.0,
      "text": "わけにはいかないのでま所書など含めて"
    },
    {
      "start": 844.44,
      "duration": 6.24,
      "text": "最終的にはあの会議規則の改正など議決も"
    },
    {
      "start": 847.16,
      "duration": 6.679,
      "text": "必要になってまりますのでま第1回定例会"
    },
    {
      "start": 850.68,
      "duration": 5.64,
      "text": "を目指してですね今議会委員会の方で所書"
    },
    {
      "start": 853.839,
      "duration": 6.8,
      "text": "等協議をしてるところでございますという"
    },
    {
      "start": 856.32,
      "duration": 6.319,
      "text": "ことでえ新しい人気から方校長協議会とす"
    },
    {
      "start": 860.639,
      "duration": 4.64,
      "text": "べく今動いているという現状報告でござい"
    },
    {
      "start": 862.639,
      "duration": 5.56,
      "text": "ますですえっと議会運委員会の方からご"
    },
    {
      "start": 865.279,
      "duration": 6.041,
      "text": "報告をいただきましたあの広報今我々広報"
    },
    {
      "start": 868.199,
      "duration": 5.961,
      "text": "協議会ですがこれを広報校長協議会という"
    },
    {
      "start": 871.32,
      "duration": 6.28,
      "text": "ことで拡充するということで所書の整理"
    },
    {
      "start": 874.16,
      "duration": 6.0,
      "text": "会議規則の改正なども射程でえ第1回定例"
    },
    {
      "start": 877.6,
      "duration": 5.76,
      "text": "会でのま提案を目指して作業中というご"
    },
    {
      "start": 880.16,
      "duration": 4.88,
      "text": "報告があったので一応広報協議会としては"
    },
    {
      "start": 883.36,
      "duration": 3.44,
      "text": "受け止めておくということでよろしいかな"
    },
    {
      "start": 885.04,
      "duration": 4.32,
      "text": "と思いますが皆さんから何かございますか"
    },
    {
      "start": 886.8,
      "duration": 5.52,
      "text": "はい斎藤さんあのそれに異論あるわけじゃ"
    },
    {
      "start": 889.36,
      "duration": 7.76,
      "text": "ないんですがあの間に合いは第3回第4回"
    },
    {
      "start": 892.32,
      "duration": 6.28,
      "text": "でえっと決めてしまって施行日を決めゃ"
    },
    {
      "start": 897.12,
      "duration": 2.719,
      "text": "いいんじゃないかなと思うんですがいかが"
    },
    {
      "start": 898.6,
      "duration": 4.479,
      "text": "でしょう"
    },
    {
      "start": 899.839,
      "duration": 5.041,
      "text": "岸田さんはいあのおっしゃる通りだと思い"
    },
    {
      "start": 903.079,
      "duration": 4.161,
      "text": "ますがちょっとその前に整理するべきこと"
    },
    {
      "start": 904.88,
      "duration": 3.959,
      "text": "がありましてですねなるべく早く行いたい"
    },
    {
      "start": 907.24,
      "duration": 3.959,
      "text": "と思っておりますのではいよろしくお願い"
    },
    {
      "start": 908.839,
      "duration": 4.44,
      "text": "しますあの第1回定例会のあたりはかなり"
    },
    {
      "start": 911.199,
      "duration": 4.841,
      "text": "あの皆さん忙しいんじゃないかなという風"
    },
    {
      "start": 913.279,
      "duration": 5.92,
      "text": "に想像いたしますのでえなるべく早め早め"
    },
    {
      "start": 916.04,
      "duration": 5.599,
      "text": "にえ物事が処理されるようにですねえまお"
    },
    {
      "start": 919.199,
      "duration": 4.721,
      "text": "願いはしておきたいとえいう風に思います"
    },
    {
      "start": 921.639,
      "duration": 5.56,
      "text": "谷はございますでしょう"
    },
    {
      "start": 923.92,
      "duration": 5.359,
      "text": "かよろしいですかはいそれではですね以上"
    },
    {
      "start": 927.199,
      "duration": 4.76,
      "text": "持ちますあ待って事務局から何かあるか"
    },
    {
      "start": 929.279,
      "duration": 5.321,
      "text": "特段ね大丈夫ですねはいえそれでは以上を"
    },
    {
      "start": 931.959,
      "duration": 7.0,
      "text": "持ちまして広報協議会の会議を参加いたし"
    },
    {
      "start": 934.6,
      "duration": 4.359,
      "text": "ますお疲れ様でございます"
    }
  ]
}