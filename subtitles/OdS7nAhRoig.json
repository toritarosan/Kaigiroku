    {
      "start": 439.759,
      "duration": 6.0,
      "text": "ただ今日の進み具合だと早く終わっちゃう"
    },
    {
      "start": 442.599,
      "duration": 6.201,
      "text": "可能性あるんだけどま終わり次第こう早く"
    },
    {
      "start": 445.759,
      "duration": 8.081,
      "text": "詰めていただいてそまとまり次第やっぱ"
    },
    {
      "start": 448.8,
      "duration": 8.92,
      "text": "集まる方がいいかな短時間でもはい現行は"
    },
    {
      "start": 453.84,
      "duration": 7.639,
      "text": "担当されてる方はそれぞれできてるって解"
    },
    {
      "start": 457.72,
      "duration": 4.72,
      "text": "でいいですよね換ってます喧嘩割ってます"
    },
    {
      "start": 461.479,
      "duration": 3.241,
      "text": "よね"
    },
    {
      "start": 462.44,
      "duration": 6.08,
      "text": "早期はどう"
    },
    {
      "start": 464.72,
      "duration": 7.68,
      "text": "だろうあ終わってね早期終ってるあと"
    },
    {
      "start": 468.52,
      "duration": 6.88,
      "text": "公文はできてるできてる公文できてるあと"
    },
    {
      "start": 472.4,
      "duration": 3.0,
      "text": "義"
    },
    {
      "start": 479.68,
      "duration": 7.16,
      "text": "方はあ殺の方は出たでまずそこまであと例"
    },
    {
      "start": 482.919,
      "duration": 6.28,
      "text": "の電気代のやつがあそうですよね電気代も"
