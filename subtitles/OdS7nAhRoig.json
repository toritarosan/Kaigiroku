      "text": "では"
    },
    {
      "start": 54.239,
      "duration": 6.201,
      "text": "ブザえこんにちはえただいまから広報協議"
    },
    {
      "start": 58.6,
      "duration": 5.519,
      "text": "会の会議を開きます"
    },
    {
      "start": 60.44,
      "duration": 8.08,
      "text": "えに議題に入りますえまず1え各部会の"
    },
    {
      "start": 64.119,
      "duration": 7.401,
      "text": "報告についてを行いますえめに1え面改革"
    },
    {
      "start": 68.52,
      "duration": 6.8,
      "text": "部会の報告を求め"
    },
    {
      "start": 71.52,
      "duration": 7.44,
      "text": "ますはい小さん特にございませんこれ"
    },
    {
      "start": 75.32,
      "duration": 6.159,
      "text": "終わった後にえ少しえここまでの進捗を"
    },
    {
      "start": 78.96,
      "duration": 5.96,
      "text": "確認をして次"
    },
    {
      "start": 81.479,
      "duration": 6.121,
      "text": "の目標設定をするのですねはいこの後やり"
    },
    {
      "start": 84.92,
      "duration": 7.8,
      "text": "ますのでございませんはいはいということ"
    },
    {
      "start": 87.6,
      "duration": 8.0,
      "text": "ではいあのがなあったのであの報告がない"
    },
    {
      "start": 92.72,
      "duration": 5.92,
      "text": "ということになりますねえ次にですねこ2"
    },
    {
      "start": 95.6,
      "duration": 7.36,
      "text": "広報部会の報告を求めます太"
    },
    {
      "start": 98.64,
      "duration": 6.4,
      "text": "さんはいえ広報部会ですえっと資料がある"
    },
    {
      "start": 102.96,
      "duration": 4.519,
      "text": "のでご覧いただきたいと思います13日に"
    },
    {
      "start": 105.04,
      "duration": 4.52,
      "text": "行いましたえちょっと全部説明してると"
    },
    {
      "start": 107.479,
      "duration": 5.6,
      "text": "時間かかっちゃうんで省略して大雑把に"
    },
    {
      "start": 109.56,
      "duration": 5.44,
      "text": "言いますとえ技事項としてはかこ1議会会"
    },
    {
      "start": 113.079,
      "duration": 4.841,
      "text": "僕のレイアウト呼び内容についてこれは"
    },
    {
      "start": 115.0,
      "duration": 6.68,
      "text": "前回からの引き続きですで弧2が法活動に"
    },
    {
      "start": 117.92,
      "duration": 6.44,
      "text": "ついてですで1についてはええご覧の通り"
    },
    {
      "start": 121.68,
      "duration": 5.6,
      "text": "なんですけどえっとこの日やったのは"
    },
    {
      "start": 124.36,
      "duration": 5.2,
      "text": "えっと現行の議会ガイドブックの1番最後"
    },
    {
      "start": 127.28,
      "duration": 5.64,
      "text": "のQ&Aをもうちょっと分かりやすく"
    },
    {
      "start": 129.56,
      "duration": 6.84,
      "text": "しようということでえっと部会の中で検討"
    },
    {
      "start": 132.92,
      "duration": 5.88,
      "text": "しましたまだ引き続き検討中でを続けて"
    },
    {
      "start": 136.4,
      "duration": 7.0,
      "text": "いきたいと思っております"
    },
    {
      "start": 138.8,
      "duration": 6.68,
      "text": "え3ページ目の括2の広報活動について"
    },
    {
      "start": 143.4,
      "duration": 4.24,
      "text": "ありますこれは主義会ホームページ年の"
    },
    {
      "start": 145.48,
      "duration": 5.44,
      "text": "キップページについてこの中で作成された"
    },
    {
      "start": 147.64,
      "duration": 6.76,
      "text": "ことも利現上に即し修正が必要であという"
    },
    {
      "start": 150.92,
      "duration": 5.319,
      "text": "えことですで川野さんから政策者の原さん"
    },
    {
      "start": 154.4,
      "duration": 4.24,
      "text": "に修正案の作成をお願いしてそれを元に"
    },
    {
      "start": 156.239,
      "duration": 4.92,
      "text": "次回以降の部会で協議することになったと"
    },
    {
      "start": 158.64,
      "duration": 6.4,
      "text": "いうことなんですけれども"
    },
    {
      "start": 161.159,
      "duration": 6.281,
      "text": "えっとまえっとなん川野さんに修正が必要"
    },
    {
      "start": 165.04,
      "duration": 4.88,
      "text": "じゃないかというえ意見があってカーノ"
    },
    {
      "start": 167.44,
      "duration": 5.28,
      "text": "さんが部会で言ってもらって部会の中で"
    },
    {
      "start": 169.92,
      "duration": 5.28,
      "text": "修正する必要があると確認されましたで"
    },
    {
      "start": 172.72,
      "duration": 5.599,
      "text": "結局誰にお願いするかというのがえ作った"
    },
    {
      "start": 175.2,
      "duration": 5.48,
      "text": "福原さんにまず第一義的に野さんからお"
    },
    {
      "start": 178.319,
      "duration": 6.441,
      "text": "願いしていこうというとここまでが確認さ"
    },
    {
      "start": 180.68,
      "duration": 8.6,
      "text": "れたということでありますで"
    },
    {
      "start": 184.76,
      "duration": 8.199,
      "text": "えっと以上ですねはい了解ですえただ今の"
    },
    {
      "start": 189.28,
      "duration": 6.56,
      "text": "えっと広報部会の報告に関して何かご意見"
    },
    {
      "start": 192.959,
      "duration": 2.881,
      "text": "ご質問ございます"
    },
    {
      "start": 197.4,
      "duration": 8.24,
      "text": "かないですかはいえそれではえっと括弧1"
    },
    {
      "start": 202.4,
      "duration": 6.119,
      "text": "括弧2とも終わりましてえ次にですねえ"
    },
    {
      "start": 205.64,
      "duration": 6.519,
      "text": "大きな2で議会改革の調査事項についてを"
    },
    {
      "start": 208.519,
      "duration": 7.121,
      "text": "行いますえ直にこ1多くの市民に読んで"
    },
    {
      "start": 212.159,
      "duration": 8.881,
      "text": "もらえる市議会頼よりへの見直しまたはえ"
    },
    {
      "start": 215.64,
      "duration": 8.4,
      "text": "年1回別発行についてを行います"
    },
    {
      "start": 221.04,
      "duration": 8.08,
      "text": "えっと何か皆様からあります"
    },
    {
      "start": 224.04,
      "duration": 8.32,
      "text": "か特にはないですかはい水谷さんはいあの"
    },
    {
      "start": 229.12,
      "duration": 6.039,
      "text": "提案会派の小顔でございますとこの間あの"
    },
    {
      "start": 232.36,
      "duration": 5.719,
      "text": "市名改革部会のあの開催がなかったという"
    },
    {
      "start": 235.159,
      "duration": 5.521,
      "text": "ことなのでま次にあのしていただく時に"
    },
    {
      "start": 238.079,
      "duration": 4.121,
      "text": "また引き続きあの充実ご協議をいただけれ"
    },
    {
      "start": 240.68,
      "duration": 4.52,
      "text": "ばと思いますのでよろしくお願いいたし"
    },
    {
      "start": 242.2,
      "duration": 6.319,
      "text": "ますはいあの本件につきましてはえっと"
    },
    {
      "start": 245.2,
      "duration": 5.92,
      "text": "この12月ですね年末ですね12月に広報"
    },
    {
      "start": 248.519,
      "duration": 6.08,
      "text": "協議会としての協議結果をまとめて議会"
    },
    {
      "start": 251.12,
      "duration": 5.799,
      "text": "運営委員会に報告をしますのでえその点も"
    },
    {
      "start": 254.599,
      "duration": 4.6,
      "text": "含めてですね今後協議の方も加速していか"
    },
    {
      "start": 256.919,
      "duration": 5.201,
      "text": "なければいけないとあつまり12月であの"
    },
    {
      "start": 259.199,
      "duration": 6.401,
      "text": "協議の結果を出すということになりますの"
    },
    {
      "start": 262.12,
      "duration": 5.88,
      "text": "でえその点に関してよろしくお願いしたい"
    },
    {
      "start": 265.6,
      "duration": 6.76,
      "text": "とお含み置きをいただきたいということで"
    },
    {
      "start": 268.0,
      "duration": 6.96,
      "text": "ございますで四面え改革部会の方でもそれ"
    },
    {
      "start": 272.36,
      "duration": 5.72,
      "text": "を前提に少しご議論をいただきたいという"
    },
    {
      "start": 274.96,
      "duration": 6.88,
      "text": "ことですねはいどうぞ小さんえっと市名"
    },
    {
      "start": 278.08,
      "duration": 9.24,
      "text": "改革部会の方は今までご報告してる通りえ"
    },
    {
      "start": 281.84,
      "duration": 9.72,
      "text": "来年の春の開戦号のA4版の協議をして"
    },
    {
      "start": 287.32,
      "duration": 8.4,
      "text": "おりますでそのゴールはえ9月定例会の"
    },
    {
      "start": 291.56,
      "duration": 6.16,
      "text": "開発協議での来年の予算要望ここを1つ"
    },
    {
      "start": 295.72,
      "duration": 6.12,
      "text": "ターゲットにしていて"
    },
    {
      "start": 297.72,
      "duration": 7.919,
      "text": "えそれ以外の議論していませんでま今"
    },
    {
      "start": 301.84,
      "duration": 6.96,
      "text": "ちょっと三谷委員の発言の趣旨とまれて"
    },
    {
      "start": 305.639,
      "duration": 6.761,
      "text": "いるんであればですねあの別の場での協議"
    },
    {
      "start": 308.8,
      "duration": 5.52,
      "text": "をするかあのまそういったご認識でいて"
    },
    {
      "start": 312.4,
      "duration": 4.799,
      "text": "いただければそれで結構"
    },
    {
      "start": 314.32,
      "duration": 5.68,
      "text": "です今小林さんからありましたが三太さん"
    },
    {
      "start": 317.199,
      "duration": 4.44,
      "text": "なんかありますはい三太さんはいあの特に"
    },
    {
      "start": 320.0,
      "duration": 4.84,
      "text": "ずれてるとかそういうことではございませ"
    },
    {
      "start": 321.639,
      "duration": 6.481,
      "text": "んではいあの年1回別発行っていうような"
    },
    {
      "start": 324.84,
      "duration": 6.16,
      "text": "こととかまA4番への変更などもあの提案"
    },
    {
      "start": 328.12,
      "duration": 6.199,
      "text": "としてはご提案申し上げてますけれどもま"
    },
    {
      "start": 331.0,
      "duration": 5.44,
      "text": "その臨時号でそういう趣旨であのやって"
    },
    {
      "start": 334.319,
      "duration": 3.921,
      "text": "いただくという方向で検討いただいてると"
    },
    {
      "start": 336.44,
      "duration": 4.12,
      "text": "聞いておりますので引き続きよろしくお"
    },
    {
      "start": 338.24,
      "duration": 4.16,
      "text": "願いいたしますはいということであ両者の"
    },
    {
      "start": 340.56,
      "duration": 5.12,
      "text": "認識は一致しているということで大丈夫"
    },
    {
      "start": 342.4,
      "duration": 6.6,
      "text": "確認ができました谷はございますか"
    },
    {
      "start": 345.68,
      "duration": 9.359,
      "text": "よろしくございますかはいえ次にですね"
    },
    {
      "start": 349.0,
      "duration": 8.759,
      "text": "えっとかこえ次に3その他を行いますがえ"
    },
    {
      "start": 355.039,
      "duration": 6.481,
      "text": "初めにかこ議会法編集部会について行い"
    },
    {
      "start": 357.759,
      "duration": 8.88,
      "text": "ますがえっと何かございますでしょう"
    },
    {
      "start": 361.52,
      "duration": 9.04,
      "text": "か今日今日議会法編集部会開きますので"
    },
    {
      "start": 366.639,
      "duration": 6.081,
      "text": "ねええ私の方で開きますのであの皆様あの"
    },
    {
      "start": 370.56,
      "duration": 4.039,
      "text": "メンバーの方帰らないように1つよろしく"
