      "text": "お願いいたします"
    },
    {
      "start": 374.599,
      "duration": 4.241,
      "text": "あのということでございますね"
    },
    {
      "start": 379.8,
      "duration": 7.04,
      "text": "あなんか予備日に少し集まらなきゃいけな"
