    },
    {
      "start": 427.199,
      "duration": 5.041,
      "text": "まで定するってルールでやってるのでま"
    },
    {
      "start": 429.479,
      "duration": 7.921,
      "text": "本日確認した方がいいと思いますただあの"
    },
    {
      "start": 432.24,
