    },
    {
      "start": 1516.399,
      "duration": 5.28,
      "text": "討論を終了することにご異議ありませんか"
    },
    {
      "start": 1518.96,
      "duration": 5.839,
      "text": "ご異議なしと認め討論を終了します直に"
    },
    {
      "start": 1521.679,
      "duration": 7.12,
      "text": "採決しますお分かりします本件について原"
    },
    {
      "start": 1524.799,
