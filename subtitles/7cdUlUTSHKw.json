    },
    {
      "start": 1720.12,
      "duration": 5.439,
      "text": "ませんかご異議な人と認めただいま"
    },
    {
      "start": 1722.64,
      "duration": 6.56,
      "text": "申し上げた通り行うことと決定しました"
