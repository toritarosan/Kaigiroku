      "start": 1062.28,
      "duration": 5.96,
      "text": "他"
    },
    {
      "start": 1065.24,
      "duration": 3.0,
      "text": "を"
    },
    {
      "start": 1068.64,
      "duration": 8.48,
      "text": "もこれは公約違反以前に一度破壊された"
    },
    {
      "start": 1073.0,
      "duration": 10.039,
      "text": "自然環境は回復できないという点で古と"
    },
    {
      "start": 1077.12,
      "duration": 5.919,
      "text": "市民にし益をもたらすものです"
    },
    {
      "start": 1110.039,
      "duration": 12.161,
      "text": "さの変に対してもどよでこのような専門的"
    },
    {
      "start": 1118.48,
      "duration": 7.96,
      "text": "地形へのリスペクトを書く態度は新長者新"
    },
    {
      "start": 1122.2,
      "duration": 9.839,
      "text": "福祉会館の見直し案や肺炎訴訟の確定判決"
    },
    {
      "start": 1126.44,
      "duration": 5.599,
      "text": "への弁護士や研究者の見解に対しても同様"
    },
    {
      "start": 1133.96,
      "duration": 4.0,
      "text": "です偉"
    },
    {
      "start": 1148.76,
      "duration": 5.72,
      "text": "のないと思うと"
    },
    {
      "start": 1155.88,
      "duration": 6.36,
      "text": "とても議員時代の白井さんだったらかかる"
    },
    {
      "start": 1159.2,
      "duration": 8.04,
      "text": "姿勢運営を厳しく正し是正させたのでは"
    },
    {
      "start": 1162.24,
      "duration": 5.0,
      "text": "ないかと思うととても残念です"
    },
    {
      "start": 1173.48,
      "duration": 2.64,
      "text": "て"
    },
    {
      "start": 1176.159,
      "duration": 13.041,
      "text": "るよなですれたではない"
    },
    {
      "start": 1185.48,
      "duration": 6.0,
      "text": "でいつからエビデンスを警視しフェイクに"
    },
    {
      "start": 1189.2,
      "duration": 5.959,
      "text": "乗っ取って姿勢を語るようになってしまわ"
    },
    {
      "start": 1191.48,
      "duration": 3.679,
      "text": "れたのでしょうか"
    },
    {
      "start": 1199.96,
      "duration": 5.48,
      "text": "も"
    },
    {
      "start": 1201.799,
      "duration": 9.441,
      "text": "フをる"
    },
    {
      "start": 1205.44,
      "duration": 9.64,
      "text": "立場にないと考えます市長はもはや"
    },
    {
      "start": 1211.24,
      "duration": 6.76,
      "text": "マニフェストを語る立場にないと考え"
    },
    {
      "start": 1215.08,
      "duration": 6.92,
      "text": "ます"
    },
    {
      "start": 1218.0,
      "duration": 4.0,
      "text": "全の"
    },
    {
      "start": 1229.6,
      "duration": 3.76,
      "text": "され"
    },
    {
      "start": 1231.24,
      "duration": 3.76,
      "text": "た"
    },
    {
      "start": 1233.36,
      "duration": 7.319,
      "text": "の"
    },
    {
      "start": 1235.0,
      "duration": 9.08,
      "text": "のは西岡全市長のふのレガシーから小金石"
    },
    {
      "start": 1240.679,
      "duration": 4.601,
      "text": "を立て直すことが期待された市長の公約の"
    },
    {
      "start": 1244.08,
      "duration": 4.2,
      "text": "多く"
    },
    {
      "start": 1245.28,
      "duration": 3.0,
      "text": "は"
    },
    {
      "start": 1248.679,
      "duration": 3.0,
      "text": "を"
    },
    {
      "start": 1253.48,
      "duration": 8.96,
      "text": "立てけてしまいました"
    },
    {
      "start": 1259.12,
      "duration": 5.439,
      "text": "裁を失い詐欺フェストになりはててしまい"
    },
    {
      "start": 1262.44,
      "duration": 2.119,
      "text": "まし"
    },
    {
      "start": 1273.19,
      "duration": 3.079,
      "text": "[音楽]"
    },
    {
      "start": 1277.44,
      "duration": 12.52,
      "text": "たるものと考えますか私は当然市長は不解"
    },
    {
      "start": 1286.159,
      "duration": 8.0,
      "text": "に値するものと考えますが"
    },
    {
      "start": 1289.96,
      "duration": 4.199,
      "text": "現て"
    },
    {
      "start": 1295.08,
      "duration": 14.839,
      "text": "もっとをてりた思っていにすることがきの"
    },
    {
      "start": 1312.679,
      "duration": 4.761,
      "text": "めなと"
    },
    {
      "start": 1322.08,
      "duration": 7.4,
      "text": "2元代表性のも議会は熟を経てより多数を"
    },
    {
      "start": 1326.279,
      "duration": 6.0,
      "text": "持って意思表示することが決議の政治的"
    },
    {
      "start": 1329.48,
      "duration": 5.92,
      "text": "意義を高めることになると考えるに至り"
    },
    {
      "start": 1332.279,
      "duration": 3.121,
      "text": "ました"
    },
    {
      "start": 1349.0,
      "duration": 3.0,
      "text": "H"
    },
    {
      "start": 1380.36,
      "duration": 7.4,
      "text": "よって白徹市長は市長としての支出に"
    },
    {
      "start": 1384.0,
      "duration": 7.48,
      "text": "著しくかけその職にふさわしくなく辞職に"
    },
    {
      "start": 1387.76,
      "duration": 6.96,
      "text": "値するべきものと断罪し本決議案に賛成"
    },
    {
      "start": 1391.48,
      "duration": 5.439,
      "text": "するとともに議員各位に賛同を呼びかける"
    },
    {
      "start": 1394.72,
      "duration": 2.199,
      "text": "もの"
    },
    {
      "start": 1401.12,
      "duration": 6.559,
      "text": "ですねご清聴ありがとうございます以上"
    },
    {
      "start": 1404.679,
      "duration": 3.0,
      "text": "です"
    },
    {
      "start": 1439.64,
      "duration": 6.88,
      "text": "以上で討論を終了します本件は起立採決を"
    },
    {
      "start": 1443.44,
      "duration": 7.479,
      "text": "しますお諮りします本件は現案の通り可決"
    },
    {
      "start": 1446.52,
      "duration": 4.399,
      "text": "することに賛成の皆さんの起立を求め"
    },
    {
      "start": 1460.24,
      "duration": 10.12,
      "text": "ますですねはい立数立多数本件は原案可決"
    },
    {
      "start": 1466.039,
      "duration": 4.321,
      "text": "と決定しましたちょっと待っ"
    },
    {
      "start": 1478.88,
      "duration": 6.64,
      "text": "議案第8号小金市議会基本条例の一部を"
    },
    {
      "start": 1482.32,
      "duration": 5.719,
      "text": "改正する条例これから討論を行います本件"
    },
    {
      "start": 1485.52,
      "duration": 5.399,
      "text": "に対する討論を終了することにご異議あり"
    },
    {
      "start": 1488.039,
      "duration": 4.841,
      "text": "ませんかご異議なしとを認め討論を終了し"
    },
    {
      "start": 1490.919,
      "duration": 5.48,
      "text": "ます直に採決し"
    },
    {
      "start": 1492.88,
      "duration": 6.96,
      "text": "ますお別れします本件について原案の通り"
    },
    {
      "start": 1496.399,
      "duration": 6.121,
      "text": "可決することにご異議ありませんか"
    },
    {
      "start": 1499.84,
      "duration": 7.12,
      "text": "ご異議なしと認め本件は原案の通り可決"
    },
    {
      "start": 1502.52,
      "duration": 8.84,
      "text": "することと決定しました議案第9号小金"
    },
    {
      "start": 1506.96,
