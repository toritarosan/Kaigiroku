    {
      "start": 1634.48,
      "duration": 6.679,
      "text": "ます立起立少数本件は否決と決定いたし"
    },
    {
      "start": 1639.679,
      "duration": 4.441,
      "text": "まし"
    },
    {
      "start": 1641.159,
      "duration": 6.321,
      "text": "たお分りしますお手元にご配布してあり"
    },
    {
      "start": 1644.12,
