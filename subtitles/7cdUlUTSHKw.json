    },
    {
      "start": 1531.52,
      "duration": 6.96,
      "text": "することと決定しまし"
    },
    {
      "start": 1533.96,
      "duration": 7.76,
      "text": "た議案第10号小金市議会の個人情報の"
    },
    {
      "start": 1538.48,
