    },
    {
      "start": 1545.84,
      "duration": 6.48,
      "text": "討論を終了することにご異議ありませんか"
    },
    {
      "start": 1549.36,
      "duration": 5.559,
      "text": "ご異議なしと認め討論を終了します直に"
    },
    {
      "start": 1552.32,
      "duration": 2.599,
      "text": "採決し"
    },
    {
      "start": 1555.76,
      "duration": 7.24,
      "text": "ますお分かりします本につい原案の通り決"
    },
    {
      "start": 1560.6,
      "duration": 5.88,
      "text": "することにご異議ありません"
    },
    {
      "start": 1563.0,
      "duration": 4.24,
      "text": "かご異議がありますので本件は立採決を"
    },
    {
      "start": 1566.48,
      "duration": 4.72,
      "text": "いたし"
    },
    {
      "start": 1567.24,
      "duration": 8.559,
      "text": "ますお分かりします本件は原案の通り可決"
    },
    {
      "start": 1571.2,
      "duration": 4.599,
      "text": "することに賛成の皆さんの起立を求め"
    },
    {
      "start": 1585.36,
      "duration": 7.84,
      "text": "ます数キス数"
    },
    {
      "start": 1588.919,
      "duration": 8.841,
      "text": "本件は現案可決と決定いたしました議員案"
    },
    {
      "start": 1593.2,
