{
  "entries": [
    {
      "start": 16.0,
      "duration": 5.24,
      "text": "そ時間前ですがお揃いでございますので"
    },
    {
      "start": 18.119,
      "duration": 6.881,
      "text": "議会運営会協議会を開催させていただき"
    },
    {
      "start": 21.24,
      "duration": 10.159,
      "text": "ますはいえ討論ある会派はいらっしゃい"
    },
    {
      "start": 25.0,
      "duration": 11.52,
      "text": "ますかはい片山長ああれ今はいはいえっと"
    },
    {
      "start": 31.399,
      "duration": 9.601,
      "text": "えっと豪珍城第49号にえ賛成討論片山"
    },
    {
      "start": 36.52,
      "duration": 5.879,
      "text": "です賛成討論片山1件ですねはい岡はいえ"
    },
    {
      "start": 41.0,
      "duration": 6.36,
      "text": "水上委員"
    },
    {
      "start": 42.399,
      "duration": 6.761,
      "text": "えっと同じくあのえゴチ城第49号賛成"
    },
    {
      "start": 47.36,
      "duration": 6.359,
      "text": "討論森戸です"
    },
    {
      "start": 49.16,
      "duration": 6.6,
      "text": "おはいその他討論あるかはございますか"
    },
    {
      "start": 53.719,
      "duration": 4.201,
      "text": "はいじゃは討論は以上2件ということでご"
    },
    {
      "start": 55.76,
      "duration": 3.52,
      "text": "確認いただいてよろしいですかはいえ最"
    },
    {
      "start": 57.92,
      "duration": 4.84,
      "text": "ついは従前通りということでよろしい"
    },
    {
      "start": 59.28,
      "duration": 5.76,
      "text": "でしょうかはいこ何かございますはいそれ"
    },
    {
      "start": 62.76,
      "duration": 4.759,
      "text": "では以上でえ議会委員会協議会じさん"
    },
    {
      "start": 65.04,
      "duration": 2.479,
      "text": "がたし"
    },
    {
      "start": 73.759,
      "duration": 3.0,
      "text": "ます"
    }
