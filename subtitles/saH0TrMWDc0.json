    },
    {
      "start": 1202.24,
      "duration": 7.48,
      "text": "のかということを確認したいと思います"
    },
    {
      "start": 1204.799,
      "duration": 7.041,
      "text": "あの以前のええ住宅の事業者さんとは私も"
    },
    {
      "start": 1209.72,
      "duration": 5.48,
      "text": "館長さんとお話したことがあるんですけど"
    },
    {
      "start": 1211.84,
      "duration": 5.56,
      "text": "もとてもあの理解をしていただいていたと"
