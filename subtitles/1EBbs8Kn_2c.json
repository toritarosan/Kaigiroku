{
  "entries": [
    {
      "start": 12.88,
      "duration": 4.44,
      "text": "じゃあ再開します。"
    },
    {
      "start": 14.679,
      "duration": 5.801,
      "text": "えっと、それでこれからの進め方なんです"
    },
    {
      "start": 17.32,
      "duration": 6.16,
      "text": "けど、あの、今日ですの全てちょっと決め"
    },
    {
      "start": 20.48,
      "duration": 7.0,
      "text": "るっていうのなかなか難しいと思うので、"
    },
    {
      "start": 23.48,
      "duration": 7.559,
      "text": "時間的な関係もあって、あの、緑つ繋がる"
    },
    {
      "start": 27.48,
      "duration": 5.68,
      "text": "小金遺産の案をベースにあの、検討するっ"
    },
    {
      "start": 31.039,
      "duration": 6.441,
      "text": "ていうことをちょっとご確認いただければ"
    },
    {
      "start": 33.16,
      "duration": 7.559,
      "text": "、あの、皆さんからこの後この案について"
    },
    {
      "start": 37.48,
      "duration": 5.559,
      "text": "、この案にこの具体的に書かれてることに"
    },
    {
      "start": 40.719,
      "duration": 6.121,
      "text": "ついてこだわらずにもうちょっとこうした"
    },
    {
      "start": 43.039,
      "duration": 7.36,
      "text": "方がいいっていう意見をもらった後に政府"
    },
    {
      "start": 46.84,
      "duration": 6.719,
      "text": "委員長と酒井提案会派の酒井さんと、え、"
    },
    {
      "start": 50.399,
      "duration": 7.48,
      "text": "3人でまたちょっとあの、えっと、この案"
    },
    {
      "start": 53.559,
      "duration": 7.761,
      "text": "をもにあの具体的なちょっと進興案を作っ"
    },
    {
      "start": 57.879,
      "duration": 6.0,
      "text": "てで、ま、皆さんにちょっとご提示して、"
    },
    {
      "start": 61.32,
      "duration": 4.96,
      "text": "えっと、確定していくとなるべくだから"
    },
    {
      "start": 63.879,
      "duration": 4.681,
      "text": "議会運営委員会ちょっと協議会なんかを"
    },
    {
      "start": 66.28,
      "duration": 4.879,
      "text": "開いていくことになりますけど、そういう"
    },
    {
      "start": 68.56,
      "duration": 5.08,
      "text": "風な形で進めていったらどうかっていう"
    },
    {
      "start": 71.159,
      "duration": 5.481,
      "text": "ことと、今日はその事前アンケート"
    },
    {
      "start": 73.64,
      "duration": 3.0,
      "text": "についてディスカッションテーマをその生徒さんに募集するかどうか、そこはちょっと一応ご確認いただくっていう形で、あの、進めていきたいと思ってるんですが、皆さんいかがでしょうか?"
    },
    {
      "start": 82.31,
      "duration": 3.209,
      "text": "[音楽]"
    },
    {
      "start": 90.799,
      "duration": 3.881,
      "text": "はい、片山さん。"
    },
    {
      "start": 91.759,
      "duration": 5.0,
      "text": "はい。はい。えっとですね、あの、ま、"
    },
    {
      "start": 94.68,
      "duration": 4.36,
      "text": "先ほどあの副議長の方からもですね、"
    },
    {
      "start": 96.759,
      "duration": 5.36,
      "text": "ちょっとあのご意見ありましたけれども、"
    },
    {
      "start": 99.04,
      "duration": 5.079,
      "text": "このちょディベートについてをやっぱどう"
    },
    {
      "start": 102.119,
      "duration": 4.32,
      "text": "いう風にするかってはちょっとよく検討が"
    },
    {
      "start": 104.119,
      "duration": 6.761,
      "text": "いるかなと思っておりまして、ま、もし"
    },
    {
      "start": 106.439,
      "duration": 7.441,
      "text": "あの坂井さんの提案のあの、えと、ま、"
    },
    {
      "start": 110.88,
      "duration": 5.12,
      "text": "大体の形で進めていくとしてもですね、"
    },
    {
      "start": 113.88,
      "duration": 4.96,
      "text": "ちょっとその、ま、盛り込み、盛り込み"
    },
    {
      "start": 116.0,
      "duration": 5.6,
      "text": "すぎというか、その、え、テーマ、テーマ"
    },
    {
      "start": 118.84,
      "duration": 3.559,
      "text": "というかですね、このス、あの、時間の"
    },
    {
      "start": 121.6,
      "duration": 3.799,
      "text": "配分でやる"
    },
    {
      "start": 122.399,
      "duration": 3.0,
      "text": "ということではなくて、ちょっともう少し検討した方がいいんじゃないかなというのは、え、考えるところです。"
    },
    {
      "start": 129.16,
      "duration": 4.28,
      "text": "で、あの、"
    },
    {
      "start": 130.44,
      "duration": 3.0,
      "text": "えっと、それでそのただ事前アーケートのとこ、あの、ま、のところではですね、やっぱりこのディスカッションのテーマについては私はあの、聞いた方がいいんじゃないかということを先ほども申し上げましたけど、ま、そちらの方は意見としては申し上げておきたいと思います。"
    },
    {
      "start": 147.519,
      "duration": 3.401,
      "text": "はい。"
    },
    {
      "start": 147.92,
      "duration": 3.0,
      "text": "他にありますか?ま、投票っていう意見もあったので、ま、投票など賛否をこう問うみたいなそんなことも含めてどうできるかは検討するっていうことになると思いますが"
    },
    {
      "start": 173.319,
      "duration": 3.121,
      "text": "はい。水谷さん、"
    },
    {
      "start": 175.319,
      "duration": 4.121,
      "text": "あ、立つんだっけ?はい。"
    },
    {
      "start": 176.44,
      "duration": 3.0,
      "text": "えっと、酒井さんの、あの、ご提案いただいてる中では"
    },
    {
      "start": 180.56,
      "duration": 2.44,
      "text": "4回投票をする"
    },
    {
      "start": 182.239,
      "duration": 3.761,
      "text": "うん、4"
    },
    {
      "start": 183.0,
      "duration": 3.0,
      "text": "つのテーマっていうのがやっぱりちょっと時間的に厳しいかなと思ったので、ま、その辺りあの、制服と酒井さんとでもう"
    },
    {
      "start": 189.319,
      "duration": 3.121,
      "text": "1"
    },
    {
      "start": 189.44,
      "duration": 3.2,
      "text": "回あの考えてくださるということなので、ま、あの、"
    },
    {
      "start": 192.44,
      "duration": 3.2,
      "text": "2"
    },
    {
      "start": 192.64,
      "duration": 3.0,
      "text": "回ぐらいに絞るとかいうのでももじっくり話す時間がもう少しあった方がいいような気がしたので、"
    },
    {
      "start": 200.12,
      "duration": 3.0,
      "text": "あの、意見として申し上げます。"
    },
    {
      "start": 207.239,
      "duration": 3.0,
      "text": "はい。他は何かありますか?"
    },
    {
      "start": 212.64,
      "duration": 3.84,
      "text": "はい。片山さん"
    },
    {
      "start": 213.48,
      "duration": 3.0,
      "text": "すいません。えっと、先ほど委員長がおっしゃったのはこのまず一応その"
    },
    {
      "start": 217.28,
      "duration": 3.72,
      "text": "3人ご3"
    },
    {
      "start": 218.0,
      "duration": 3.0,
      "text": "人というか委員長と副委員長と坂井さんの方で少しまたこうこれをあの問んだものをまた叩き代というか新たに提案してくださるということでよろしいんですよね。"
    },
    {
      "start": 228.799,
      "duration": 4.681,
      "text": "そういう風にしたいと思うんです。"
    },
    {
      "start": 230.48,
      "duration": 3.0,
      "text": "皆さんの意見踏まえて提案会派の酒井さんも必ずしもこの中身に具体的にこだわらないっていうような話だと思うので、あの全体で何かやって、"
    },
    {
      "start": 241.72,
      "duration": 5.509,
      "text": "あの各教室に分れてあのまディベートをした後にまた全体集まってというような流れの中でどう組み立てるかっていう話になると思うんですね。"
    },
    {
      "start": 244.15,
      "duration": 3.079,
      "text": "[音楽]"
    },
    {
      "start": 254.64,
      "duration": 5.2,
      "text": "えっと、皆さんから意見いただいた、あの"
    },
    {
      "start": 257.199,
      "duration": 4.641,
      "text": "、4回投票4つのテーマは厳しいんじゃ"
    },
    {
      "start": 259.84,
      "duration": 4.76,
      "text": "ないかってこととか、ディベートはもう"
    },
    {
      "start": 261.84,
      "duration": 4.84,
      "text": "少しシンプルにした方がいいとか、ま、"
    },
    {
      "start": 264.6,
      "duration": 4.72,
      "text": "投票はした方がいいっていうこう意見も"
    },
    {
      "start": 266.68,
      "duration": 5.239,
      "text": "あったので、そういう意見を最大限"
    },
    {
      "start": 269.32,
      "duration": 5.159,
      "text": "ちょっとどんな風に盛り込めるか分かり"
    },
    {
      "start": 271.919,
      "duration": 4.801,
      "text": "ませんけど、ちょっとそういう意見踏まえ"
    },
    {
      "start": 274.479,
      "duration": 5.121,
      "text": "て検討したいっていう風に思ってますので"
    },
    {
      "start": 276.72,
      "duration": 5.56,
      "text": "、で、なるべく早くちょっと皆さんに提示"
    },
    {
      "start": 279.6,
      "duration": 5.4,
      "text": "してテーマとかについてはまたちょっと"
    },
    {
      "start": 282.28,
      "duration": 5.08,
      "text": "意見をもらって決めていくって形になって"
    },
    {
      "start": 285.0,
      "duration": 4.36,
      "text": "くると思うんですね。あと生徒さんにも"
    },
    {
      "start": 287.36,
      "duration": 5.0,
      "text": "一応聞いた方がいいっていう意見もあるの"
    },
    {
      "start": 289.36,
      "duration": 6.52,
      "text": "で、そうするとすれば生徒さんの意見も"
    },
    {
      "start": 292.36,
      "duration": 5.6,
      "text": "踏まえて考える必要があるので、"
    },
    {
      "start": 295.88,
      "duration": 4.08,
      "text": "そういう形にしていきたいと考えており"
    },
    {
      "start": 297.96,
      "duration": 5.0,
      "text": "ますが、あの皆さん"
    },
    {
      "start": 299.96,
      "duration": 3.0,
      "text": "から他何かありますか?"
    },
    {
      "start": 303.68,
      "duration": 2.56,
      "text": "はい"
    },
    {
      "start": 304.32,
      "duration": 4.92,
      "text": "はい。はい。"
    },
    {
      "start": 306.24,
      "duration": 3.0,
      "text": "えっと、生徒さんのあの意見を聞くというのは、あの、参加していただく意識を高めるためにもとてもいいと思うんですけれども、中学"
    },
    {
      "start": 314.08,
      "duration": 3.119,
      "text": "2"
    },
    {
      "start": 314.199,
      "duration": 3.0,
      "text": "年生ということを考えるとフリーハンドで聞いてしまうとちょっと難しいかなと思って、例えばこちらであの"
    },
    {
      "start": 320.52,
      "duration": 3.16,
      "text": "3"
    },
    {
      "start": 320.68,
      "duration": 3.0,
      "text": "つぐらいを提示してどれが話し合いたいですかみたいに聞くならは可能かなと思います。"
    },
    {
      "start": 325.96,
      "duration": 3.6,
      "text": "うん。うん。"
    },
    {
      "start": 326.56,
      "duration": 3.0,
      "text": "はい。"
    },
    {
      "start": 331.4,
      "duration": 3.0,
      "text": "テーマの案をちょっと考えた方がいいと。"
    },
    {
      "start": 335.4,
      "duration": 3.48,
      "text": "くなら"
    },
    {
      "start": 335.88,
      "duration": 3.0,
      "text": "あ、効くならね、言うような。"
    },
    {
      "start": 358.16,
      "duration": 1.12,
      "text": "はい。"
    },
    {
      "start": 358.919,
      "duration": 3.361,
      "text": "はい。"
    },
    {
      "start": 359.28,
      "duration": 3.0,
      "text": "めさん、ちょっと教えてスケジュールを教えていただきたいんですけども、もし中付の生徒さんから聞くとするといつまでに聞い、いつまでにそのアンケートを出して、いつまでに聞いてとかっていうのがなかなか時間的に厳しいのかなと思うので、ま、シンプルでっが何人かから出ましたので、ま、こちらで設定していいんじゃないかなとは思っております。"
    },
    {
      "start": 389.08,
      "duration": 3.0,
      "text": "あ、特に聞く必要はないんじゃないかっていうあること。"
    },
    {
      "start": 392.759,
      "duration": 3.72,
      "text": "あ、さん。"
    },
    {
      "start": 393.479,
      "duration": 3.0,
      "text": "はい。あの、聞く必要がないということではなくてですね、聞きたいのは山まなんですけども、時間的に厳しいんじゃないかなって思って。"
    },
    {
      "start": 398.65,
      "duration": 3.15,
      "text": "[音楽]"
    },
    {
      "start": 402.16,
      "duration": 3.0,
      "text": "で、聞くんであれば本水谷さんがおっしゃったように"
    },
    {
      "start": 406.08,
      "duration": 3.0,
      "text": "選択の中から選んでもらってもう多いものっていう風にしないと聞いたところからま、選ぶっていうとまた大変だなと思いますので、"
    },
    {
      "start": 414.4,
      "duration": 3.0,
      "text": "え、シンプルにしていきたいと思ってます。"
    },
    {
      "start": 419.12,
      "duration": 3.0,
      "text": "はい。"
    },
    {
      "start": 423.16,
      "duration": 3.96,
      "text": "あ、天野さん、"
    },
    {
      "start": 424.919,
      "duration": 5.201,
      "text": "ちょっと質問なんですけど、10月の20"
    },
    {
      "start": 427.12,
      "duration": 3.0,
      "text": "日に向けて今後どういうスケジュール感でこれを進めていくのかについて、あの、一旦多分ベースも決まったと思うので、もしあのちょっと方針みたいなのがあればお聞かせていただきたいなと思います。"
    },
    {
      "start": 438.8,
      "duration": 5.28,
      "text": "はい。"
    },
    {
      "start": 440.919,
      "duration": 5.68,
      "text": "えっと、スケジュール感はその"
    },
    {
      "start": 444.08,
      "duration": 6.2,
      "text": "学校サイドとまだあんまり具体的に詰めて"
    },
    {
      "start": 446.599,
      "duration": 7.201,
      "text": "はいないんですけど、学校サイドの方は"
    },
    {
      "start": 450.28,
      "duration": 6.28,
      "text": "あの内容については前日までにあの決まっ"
    },
    {
      "start": 453.8,
      "duration": 4.959,
      "text": "てれば別に構いませんっていうようなお話"
    },
    {
      "start": 456.56,
      "duration": 5.68,
      "text": "だったと思うんですね。ただこちらの準備"
    },
    {
      "start": 458.759,
      "duration": 6.0,
      "text": "があるので、特にあの今話題になってる"
    },
    {
      "start": 462.24,
      "duration": 6.04,
      "text": "そのえっと"
    },
    {
      "start": 464.759,
      "duration": 7.4,
      "text": "事前アンケートについてはこれはあの学校"
    },
    {
      "start": 468.28,
      "duration": 7.16,
      "text": "が始まって早いうちにあのアンケートを"
    },
    {
      "start": 472.159,
      "duration": 6.121,
      "text": "取った方がまいいだろうとまいうことに"
    },
    {
      "start": 475.44,
      "duration": 4.8,
      "text": "なってますのでこれはちょっと優先的に"
    },
    {
      "start": 478.28,
      "duration": 6.44,
      "text": "決めた方がいいかなっていう風に思うん"
    },
    {
      "start": 480.24,
      "duration": 7.359,
      "text": "ですね。で、あの、議会の準備がどういう"
    },
    {
      "start": 484.72,
      "duration": 5.599,
      "text": "風にできるのかっていうところが1つの、"
    },
    {
      "start": 487.599,
      "duration": 6.401,
      "text": "ま、スケジュールとすれば必要なところな"
    },
    {
      "start": 490.319,
      "duration": 6.921,
      "text": "ので、できればだから第1回、あ、あ、第"
    },
    {
      "start": 494.0,
      "duration": 6.36,
      "text": "3回定例会の議運でもう1回きちんと議論"
    },
    {
      "start": 497.24,
      "duration": 6.2,
      "text": "をして、あの、"
    },
    {
      "start": 500.36,
      "duration": 7.679,
      "text": "ま、根会中ぐらいに"
    },
    {
      "start": 503.44,
      "duration": 7.28,
      "text": "確定できれば最低限、あの、1番遅い日程"
    },
    {
      "start": 508.039,
      "duration": 5.681,
      "text": "でも、あの、いいのかなって"
    },
    {
      "start": 510.72,
      "duration": 3.0,
      "text": "いう風には感じてるんですけど、あ、個人的にはね。"
    },
    {
      "start": 517.0,
      "duration": 5.839,
      "text": "はい。太田さん。"
    },
    {
      "start": 519.839,
      "duration": 3.0,
      "text": "えっと、テーマについてなんですけれども、えっと、やはりその中学生がそのディベートで扱えるテーマっていうのはうん、"
    },
    {
      "start": 530.08,
      "duration": 5.4,
      "text": "あの、慎重に選んだ方がいいかなと"
    },
    {
      "start": 532.68,
      "duration": 6.12,
      "text": "いう風に思います。あの、関心があって"
    },
    {
      "start": 535.48,
      "duration": 6.16,
      "text": "その知識もあるような内容がいいかと思う"
    },
    {
      "start": 538.8,
      "duration": 6.32,
      "text": "ので、え、事前のアンケートを取るという"
    },
    {
      "start": 541.64,
      "duration": 7.16,
      "text": "ことであれば、えっと、中学生、今、あ、"
    },
    {
      "start": 545.12,
      "duration": 6.24,
      "text": "中学生が、あ、興味のある項目と言います"
    },
    {
      "start": 548.8,
      "duration": 7.44,
      "text": "か、そういうものを、あの、事前に収集し"
    },
    {
      "start": 551.36,
      "duration": 9.08,
      "text": "た上でその中から、え、方があのスムーズ"
    },
    {
      "start": 556.24,
      "duration": 7.4,
      "text": "に行くのではないかなと思います。うん。"
    },
    {
      "start": 560.44,
      "duration": 3.2,
      "text": "はい。"
    },
    {
      "start": 566.8,
      "duration": 5.84,
      "text": "事前アンケートについてね、どういう風に"
    },
    {
      "start": 569.72,
      "duration": 5.0,
      "text": "ちょっとやるのか、ま、ちょっと先生にも"
    },
    {
      "start": 572.64,
      "duration": 3.96,
      "text": "聞いてみる必要あるかなと思うんですね。"
    },
    {
      "start": 574.72,
