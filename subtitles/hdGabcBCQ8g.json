    },
    {
      "start": 1119.679,
      "duration": 7.0,
      "text": "ますはいそれはあれだよね議会改革の方で"
    },
    {
      "start": 1124.28,
      "duration": 7.0,
      "text": "義軍の方でやる話だったよね確かねませ"
    },
    {
      "start": 1126.679,
      "duration": 6.12,
      "text": "はい長長ですえっとそうですね2点考え方"
    },
    {
      "start": 1131.28,
      "duration": 4.2,
      "text": "があるかなと思うんですけどもえっとまず"
    },
    {
      "start": 1132.799,
      "duration": 4.521,
      "text": "1点目がえっとこの転職協議会単独で"
    },
    {
      "start": 1135.48,
      "duration": 4.0,
      "text": "考えるかどうかということについてで"
    },
    {
      "start": 1137.32,
      "duration": 4.08,
      "text": "ございますえっと前回ははえっと特に"
    },
    {
      "start": 1139.48,
      "duration": 4.96,
      "text": "えっとホームページの方に掲載するという"
    },
    {
      "start": 1141.4,
      "duration": 5.6,
      "text": "お話がありませんでしたのでえっとま掲載"
    },
    {
      "start": 1144.44,
      "duration": 4.8,
      "text": "してないんですけどもえっと今回あの掲載"
    },
    {
      "start": 1147.0,
      "duration": 4.44,
      "text": "するとなればですねえっと前回のも合わせ"
    },
    {
      "start": 1149.24,
      "duration": 4.84,
      "text": "て掲載するかというご協議が必要になるか"
    },
    {
      "start": 1151.44,
      "duration": 4.92,
      "text": "と思いますでえっと2点目がえっとこちら"
    },
    {
      "start": 1154.08,
      "duration": 4.24,
      "text": "のえっと検証協議会についてはえっと議運"
    },
    {
      "start": 1156.36,
      "duration": 4.76,
      "text": "の方でま依頼を受けてっていうんですかね"
    },
    {
      "start": 1158.32,
      "duration": 5.0,
      "text": "あのえっと議運で本来協議すべきものを"
    },
    {
      "start": 1161.12,
      "duration": 5.039,
      "text": "えっとこの会議体設置してご協議いたい"
    },
    {
      "start": 1163.32,
      "duration": 5.88,
      "text": "てるわけでしてえ中身としてはえっと議会"
    },
    {
      "start": 1166.159,
      "duration": 5.64,
      "text": "改革の中に含まれるものでございますその"
    },
    {
      "start": 1169.2,
      "duration": 5.92,
      "text": "ためえっと議運の方の最終的な報告ですね"
    },
    {
      "start": 1171.799,
      "duration": 6.441,
      "text": "えっと議会改革のえ所問題の調査のそちら"
    },
    {
      "start": 1175.12,
      "duration": 5.72,
      "text": "の報告があるんですけどもそちらの中に"
    },
    {
      "start": 1178.24,
      "duration": 5.679,
      "text": "このえっと検証協議会のこの報告も含まれ"
    },
    {
      "start": 1180.84,
      "duration": 5.28,
      "text": "てまいりますなのでえっと本体の方は"
    },
    {
      "start": 1183.919,
      "duration": 4.76,
      "text": "えっとそちらのえっと今申し上げたえっと"
    },
    {
      "start": 1186.12,
      "duration": 4.48,
      "text": "議会革の報告書の方が本体になるのかなと"
    },
    {
      "start": 1188.679,
      "duration": 4.081,
      "text": "いう風に思うんですけどもえっとそちらも"
    },
    {
      "start": 1190.6,
      "duration": 5.079,
      "text": "ホームページは特に掲載しておりませんで"
    },
    {
      "start": 1192.76,
      "duration": 4.68,
      "text": "また他のえっと常任委員会のえ所管事務"
    },
    {
      "start": 1195.679,
      "duration": 4.321,
      "text": "調査そちらも掲載しておりませんしあと"
    },
    {
      "start": 1197.44,
      "duration": 5.28,
      "text": "特別委員会もそうですねなのでえっとそこ"
    },
    {
      "start": 1200.0,
      "duration": 4.799,
      "text": "の辺りの整理をどうするかというえところ"
    },
    {
      "start": 1202.72,
      "duration": 6.319,
      "text": "も考えていかなければいけないかなと思い"
    },
    {
      "start": 1204.799,
      "duration": 6.441,
      "text": "ます以上ですはいはい水谷はいあの乗って"
    },
    {
      "start": 1209.039,
      "duration": 6.161,
      "text": "いない理由については分かりましたで"
    },
    {
      "start": 1211.24,
      "duration": 7.439,
      "text": "えっとただですねあの市民の方が基本条例"
    },
    {
      "start": 1215.2,
      "duration": 7.12,
      "text": "で検索をされるとこう策定の過程のですね"
    },
    {
      "start": 1218.679,
      "duration": 6.681,
      "text": "あの基本条例をができるまでの報告書は出"
    },
    {
      "start": 1222.32,
      "duration": 5.44,
      "text": "ているのにできてからのこの検証とか運用"
    },
    {
      "start": 1225.36,
      "duration": 6.16,
      "text": "についてあのたどりつけないというのは"
    },
    {
      "start": 1227.76,
      "duration": 6.919,
      "text": "あの市民の立場からするとあの不便だし"
    },
    {
      "start": 1231.52,
      "duration": 5.36,
      "text": "私たちもこの議会の基本条例に基づいて"
    },
    {
      "start": 1234.679,
      "duration": 4.041,
      "text": "活動しているということを積極的に候補し"
    },
    {
      "start": 1236.88,
      "duration": 4.039,
      "text": "ていくべきだと思うのでじゃまたあの議運"
    },
    {
      "start": 1238.72,
      "duration": 5.0,
      "text": "の方で必要であれば発言させていただき"
    },
    {
      "start": 1240.919,
      "duration": 5.561,
      "text": "たいと思いますはいありがとうございます"
    },
    {
      "start": 1243.72,
      "duration": 5.64,
      "text": "じゃあのこの報告書案がまとまりましたら"
    },
    {
      "start": 1246.48,
      "duration": 5.4,
      "text": "これを義軍の方にお返しをするというのが"
    },
    {
      "start": 1249.36,
      "duration": 5.08,
      "text": "一応の流れになっておりますのであのその"
    },
    {
      "start": 1251.88,
      "duration": 4.72,
      "text": "後のことについては議運の方でご協議"
    },
    {
      "start": 1254.44,
      "duration": 4.92,
      "text": "いただければという風に思っております"
    },
    {
      "start": 1256.6,
      "duration": 6.52,
      "text": "その他この報告書についてえご意見ご質"
    },
    {
      "start": 1259.36,
      "duration": 9.48,
      "text": "すぎとございますか"
    },
    {
      "start": 1263.12,
      "duration": 7.96,
      "text": "よま特段内容でしたら先ほどまあの小林"
    },
    {
      "start": 1268.84,
      "duration": 4.76,
      "text": "委員から頂だいたようにまもう少しですね"
    },
    {
      "start": 1271.08,
      "duration": 5.12,
      "text": "その議会改革と取り組みのところをですね"
    },
    {
      "start": 1273.6,
      "duration": 4.64,
      "text": "あの精査をさせていただいて先ほど水上"
    },
    {
      "start": 1276.2,
      "duration": 5.079,
      "text": "委員からあったご意見や小林委員からあっ"
    },
    {
      "start": 1278.24,
      "duration": 6.96,
      "text": "たご意見等も含めてですね精査をしてで"
    },
    {
      "start": 1281.279,
      "duration": 6.161,
      "text": "先ほどご指摘いただいた校長会のところも"
    },
    {
      "start": 1285.2,
      "duration": 4.32,
      "text": "含めてえっと1度もう1度修正をさせて"
    },
    {
      "start": 1287.44,
      "duration": 3.119,
      "text": "いただいたものを皆様にお示しをさせて"
    },
    {
      "start": 1289.52,
      "duration": 4.08,
      "text": "いただきたい"
    },
    {
      "start": 1290.559,
      "duration": 6.401,
      "text": "という風に思いますが"
    },
    {
      "start": 1293.6,
      "duration": 5.84,
      "text": "えっとそれはこの場ではなくてもよろしい"
    },
    {
      "start": 1296.96,
      "duration": 4.719,
      "text": "ですか制服に一任をしていただいて修正を"
    },
    {
      "start": 1299.44,
      "duration": 4.32,
      "text": "したための皆さんにお示しをするのかもう"
    },
    {
      "start": 1301.679,
      "duration": 4.841,
      "text": "一度こういう場を開いて確認を取った方が"
    },
    {
      "start": 1303.76,
      "duration": 4.12,
      "text": "よろしいかといううところなんですけれど"
    },
    {
      "start": 1306.52,
      "duration": 6.039,
      "text": "も"
    },
    {
      "start": 1307.88,
      "duration": 7.72,
      "text": "はいはいはいよろしいですかはいなので"
    },
    {
      "start": 1312.559,
      "duration": 5.041,
      "text": "えっとま今日いたたご意見について修正し"
    },
    {
      "start": 1315.6,
      "duration": 6.0,
      "text": "たものはメールで皆さんにお示しますが"
    },
    {
      "start": 1317.6,
      "duration": 6.8,
      "text": "あの検証協議会とすると今日でえ終了と"
    },
    {
      "start": 1321.6,
      "duration": 6.0,
      "text": "いうことでよろしいですかねはいという"
    },
    {
      "start": 1324.4,
      "duration": 5.04,
      "text": "ことで大丈夫ですかはいではえっと検証"
    },
    {
      "start": 1327.6,
      "duration": 3.76,
      "text": "協議会は今日で終了とさせていただいて"
    },
    {
      "start": 1329.44,
      "duration": 3.8,
      "text": "今日いただいたご意見を修正したものを皆"
    },
    {
      "start": 1331.36,
      "duration": 4.76,
      "text": "様にお示しをしてご了解をいただいたら"
    },
    {
      "start": 1333.24,
      "duration": 4.799,
      "text": "それを議会委員会の方にお返しをすると"
    },
    {
      "start": 1336.12,
      "duration": 5.24,
      "text": "いうような流れでよろしいでしょうかご"
    },
    {
      "start": 1338.039,
      "duration": 6.481,
      "text": "確認いただいて議長よろしいでしょうか"
    },
    {
      "start": 1341.36,
      "duration": 5.799,
      "text": "はいはいありがとうございますではあの"
    },
    {
      "start": 1344.52,
      "duration": 4.08,
      "text": "大変長期間にわたりまして皆さんご協議を"
    },
    {
      "start": 1347.159,
      "duration": 3.201,
      "text": "いただきましてお力いただきました"
    },
    {
      "start": 1348.6,
      "duration": 4.959,
      "text": "ありがとうございましたでは以上を持って"
    },
    {
      "start": 1350.36,
      "duration": 8.559,
      "text": "議会基本条例の検証協議会を閉じ3回と"
    },
    {
      "start": 1353.559,
      "duration": 5.36,
      "text": "いたしますお疲れ様でございましたました"
    }
  ]
}