{
  "entries": [
    {
      "start": 20.84,
      "duration": 3.0,
      "text": "ご"
    },
    {
      "start": 36.84,
      "duration": 3.0,
      "text": "あ"
    },
    {
      "start": 76.439,
      "duration": 5.241,
      "text": "おはようございますはいえ帝国でござい"
    },
    {
      "start": 79.479,
      "duration": 4.0,
      "text": "ますので議会運会の協議会を始めさせて"
    },
    {
      "start": 81.68,
      "duration": 4.24,
      "text": "いただきますお手元の協議事項をご覧"
    },
    {
      "start": 83.479,
      "duration": 6.441,
      "text": "くださいえ本日の進行について議長の問"
    },
    {
      "start": 85.92,
      "duration": 7.0,
      "text": "事項1件調査1件の経2件でございますえ"
    },
    {
      "start": 89.92,
      "duration": 6.72,
      "text": "ソフ案件の取り扱いについて議案第52"
    },
    {
      "start": 92.92,
      "duration": 5.36,
      "text": "号ののソフト取り扱いについてご協議"
    },
    {
      "start": 96.64,
      "duration": 4.2,
      "text": "いただきますその他で何かあればご発言を"
    },
    {
      "start": 98.28,
      "duration": 5.08,
      "text": "お願いいたしますえ3番の議会会に関する"
    },
    {
      "start": 100.84,
      "duration": 6.48,
      "text": "初問題の調査と協議会事項のその2は1番"
    },
    {
      "start": 103.36,
      "duration": 6.84,
      "text": "最後の議会委員会でえ協議させていただき"
    },
    {
      "start": 107.32,
      "duration": 6.2,
      "text": "ますが議会BCPについてえ避難訓練に"
    },
    {
      "start": 110.2,
      "duration": 7.44,
      "text": "ついてえ福座長の方からお話がございます"
    },
    {
      "start": 113.52,
      "duration": 7.879,
      "text": "えその他でえ何かあればお願いをいたし"
    },
    {
      "start": 117.64,
      "duration": 7.399,
      "text": "ますはいあとその他の部分でタブレット"
    },
    {
      "start": 121.399,
      "duration": 7.2,
      "text": "PTの方で事務局の方からちょっと報告が"
    },
    {
      "start": 125.039,
      "duration": 5.36,
      "text": "あるということでございますはいえでと"
    },
    {
      "start": 128.599,
      "duration": 4.321,
      "text": "いうことになりますがあ進行よろしい"
    },
    {
      "start": 130.399,
      "duration": 5.2,
      "text": "でしょうか以上ではいではあの協議議会"
    },
    {
      "start": 132.92,
      "duration": 5.12,
      "text": "事項のその位置について事務局からお願い"
    },
    {
      "start": 135.599,
      "duration": 5.64,
      "text": "いたします局長はいえそれではですね"
    },
    {
      "start": 138.04,
      "duration": 6.12,
      "text": "えっとお手元の進行予定表の案ご覧"
    },
    {
      "start": 141.239,
      "duration": 5.72,
      "text": "いただきたいと思いますえ1番の議会運営"
    },
    {
      "start": 144.16,
      "duration": 5.96,
      "text": "委員会ではあ今委員長からお話ありました"
    },
    {
      "start": 146.959,
      "duration": 6.56,
      "text": "1と2についてこれからご説明をしてでえ"
    },
    {
      "start": 150.12,
      "duration": 6.96,
      "text": "3番の市長層府案件の取り扱いこれ議案第"
    },
    {
      "start": 153.519,
      "duration": 7.241,
      "text": "52号の取り扱いを行いますで議会運営"
    },
    {
      "start": 157.08,
      "duration": 7.0,
      "text": "委員会終了後に2番の厚生文教委員会"
    },
    {
      "start": 160.76,
      "duration": 5.92,
      "text": "こちらは保留案件として所管事務調査の"
    },
    {
      "start": 164.08,
      "duration": 6.04,
      "text": "質疑がえ保留となっているものがござい"
    },
    {
      "start": 166.68,
      "duration": 6.279,
      "text": "ますのでこちらの質疑の方して処理をして"
    },
    {
      "start": 170.12,
      "duration": 6.6,
      "text": "いただきますでそれが終わりましたら次え"
    },
    {
      "start": 172.959,
      "duration": 8.36,
      "text": "順の3番建設環境委員会こちらは6陳情第"
    },
    {
      "start": 176.72,
      "duration": 6.799,
      "text": "41号のえこちらは採決ののみがえ保留と"
    },
    {
      "start": 181.319,
      "duration": 5.521,
      "text": "なっておりますのでえ採決をしていただく"
    },
    {
      "start": 183.519,
      "duration": 6.72,
      "text": "ことになりますでなお建設環境委員会に"
    },
    {
      "start": 186.84,
      "duration": 6.16,
      "text": "つきましてはえこちらの陳情の採決後に"
    },
    {
      "start": 190.239,
      "duration": 6.481,
      "text": "ですね一応協議会をちょっと開く予定で"
    },
    {
      "start": 193.0,
      "duration": 8.4,
      "text": "おりますで次にえ4番の総務企画委員会"
    },
    {
      "start": 196.72,
      "duration": 8.96,
      "text": "ですがえとかこ1の6陳情第29号こちら"
    },
    {
      "start": 201.4,
      "duration": 7.68,
      "text": "の採決を残すのみえ保留となっております"
    },
    {
      "start": 205.68,
      "duration": 8.68,
      "text": "でこちらがえ終わりましたらあえっと5番"
    },
    {
      "start": 209.08,
      "duration": 9.519,
      "text": "の広報協議会6番の議会法編集部会で7番"
    },
    {
      "start": 214.36,
      "duration": 8.04,
      "text": "の会派代表者会議と順次進めてまりまして"
    },
    {
      "start": 218.599,
      "duration": 7.681,
      "text": "え会派代表者会議終了後にですね8番の"
    },
    {
      "start": 222.4,
      "duration": 7.119,
      "text": "議会運営委員会としてえ1番の議会改革に"
    },
    {
      "start": 226.28,
      "duration": 7.12,
      "text": "関する諸問題の調査これあの冒頭に委員長"
    },
    {
      "start": 229.519,
      "duration": 8.321,
      "text": "からえご説明ございましたBCPの関係の"
    },
    {
      "start": 233.4,
      "duration": 8.679,
      "text": "報告がございますであと2番と3番え本日"
    },
    {
      "start": 237.84,
      "duration": 6.599,
      "text": "の進行状況と議会整理日についてという"
    },
    {
      "start": 242.079,
      "duration": 5.921,
      "text": "ことでこの2つのご確認を取っていただい"
    },
    {
      "start": 244.439,
      "duration": 6.241,
      "text": "た後まその他としてえタブレットの関係の"
    },
    {
      "start": 248.0,
      "duration": 5.319,
      "text": "スケジュールについてちょっと事務局の方"
    },
    {
      "start": 250.68,
      "duration": 5.64,
      "text": "からご報告をさせていただく予定でござい"
    },
    {
      "start": 253.319,
      "duration": 7.241,
      "text": "ますえ本日の進行は以上になり"
    },
    {
      "start": 256.32,
      "duration": 6.92,
      "text": "ますはいえただ今のご報告え何かご意見ご"
    },
    {
      "start": 260.56,
      "duration": 5.919,
      "text": "とございますかはいそれでは委員会の方に"
    },
    {
      "start": 263.24,
      "duration": 3.239,
      "text": "入ってまいりますお願いし"
    },
    {
      "start": 266.759,
      "duration": 5.361,
      "text": "ますただ今から議会委員会の会議を開きち"
    },
    {
      "start": 270.24,
      "duration": 4.04,
      "text": "に議事に入ります当委員会に付託されて"
    },
    {
      "start": 272.12,
      "duration": 4.48,
      "text": "おります案件は議長の諮問事項1件調査1"
    },
    {
      "start": 274.28,
      "duration": 4.639,
      "text": "件の計2件であります議長からお手元に"
    },
    {
      "start": 276.6,
      "duration": 4.599,
      "text": "議会運営委員会協議事項が提示されており"
    },
    {
      "start": 278.919,
      "duration": 4.56,
      "text": "ますのでその順序に従って順次協議をして"
    },
    {
      "start": 281.199,
      "duration": 4.121,
      "text": "まいりたいと思います議会運営に関する"
    },
    {
      "start": 283.479,
      "duration": 4.921,
      "text": "議長の諮問事項についてを議題といたし"
    },
    {
      "start": 285.32,
      "duration": 5.2,
      "text": "ますはめに協議事項1市長送付案件の"
    },
    {
      "start": 288.4,
      "duration": 4.359,
      "text": "取り扱いについて行います部局から発言が"
    },
    {
      "start": 290.52,
      "duration": 6.0,
      "text": "あればお願いします村部"
    },
    {
      "start": 292.759,
      "duration": 7.72,
      "text": "長はいえ後日送付案件についてご報告"
    },
    {
      "start": 296.52,
      "duration": 7.959,
      "text": "いたしますえ後日付案件として9月19日"
    },
    {
      "start": 300.479,
      "duration": 6.641,
      "text": "木曜日けえ議案第52号小金市会計年度"
    },
    {
      "start": 304.479,
      "duration": 5.401,
      "text": "任用職員の報酬等に関する条例の一部を"
    },
    {
      "start": 307.12,
      "duration": 5.919,
      "text": "改正する条例を送付させていただきました"
    },
    {
      "start": 309.88,
      "duration": 6.0,
      "text": "ので取り扱い方よろしくお願いいたします"
    },
    {
      "start": 313.039,
      "duration": 6.0,
      "text": "えなお本件につきましては本会議での即決"
    },
    {
      "start": 315.88,
      "duration": 4.8,
      "text": "をお願いいたしますはい取り扱いについて"
    },
    {
      "start": 319.039,
      "duration": 3.921,
      "text": "議長の下問案が提示されておりますので"
    },
    {
      "start": 320.68,
      "duration": 3.56,
      "text": "説明をお願いいたしますえ事務局から説明"
    },
    {
      "start": 322.96,
      "duration": 5.72,
      "text": "しますはい"
    },
    {
      "start": 324.24,
      "duration": 8.799,
      "text": "局長はいえ議案第52号につきましては9"
    },
    {
      "start": 328.68,
      "duration": 7.12,
      "text": "月26日の本会議に定し説明質疑後委員会"
    },
    {
      "start": 333.039,
      "duration": 5.6,
      "text": "付託を省略し即決することとしたいという"
    },
    {
      "start": 335.8,
      "duration": 4.92,
      "text": "のが議長の諮問案でございますはい議長"
    },
    {
      "start": 338.639,
      "duration": 5.12,
      "text": "及び事務局の説明は終わりましたご意見ご"
    },
    {
      "start": 340.72,
      "duration": 5.16,
      "text": "質疑とございますかはいお諮りいたします"
    },
    {
      "start": 343.759,
      "duration": 4.121,
      "text": "本件については議長の諮問の通り決定する"
    },
    {
      "start": 345.88,
      "duration": 4.24,
      "text": "ことにご異議ありませんかはいご異議なし"
    },
    {
      "start": 347.88,
      "duration": 4.84,
      "text": "と認めます従って本件は議長の諮問の通り"
    },
    {
      "start": 350.12,
      "duration": 5.28,
      "text": "決定いたしました協議事故か2その他で"
    },
    {
      "start": 352.72,
      "duration": 4.759,
      "text": "ございますが何かご発言はございますか"
    },
    {
      "start": 355.4,
      "duration": 4.84,
      "text": "はいそれでは以上で議会運営に関する議長"
    },
    {
      "start": 357.479,
      "duration": 5.761,
      "text": "の諮問事項について終わります休憩します"
    },
    {
      "start": 360.24,
      "duration": 3.0,
      "text": "はい"
    }
  ]
}