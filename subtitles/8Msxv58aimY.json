{
  "entries": [
    {
      "start": 140.0,
      "duration": 6.04,
      "text": "えこんにちはこんにちはえただいまからえ"
    },
    {
      "start": 143.12,
      "duration": 6.08,
      "text": "広報協議会の会議をえ開きますえたちに"
    },
    {
      "start": 146.04,
      "duration": 7.559,
      "text": "議題に入りますえ1え各部会の報告につい"
    },
    {
      "start": 149.2,
      "duration": 5.72,
      "text": "てを行いめにえ1面改革部会の報告を求め"
    },
    {
      "start": 153.599,
      "duration": 4.92,
      "text": "ます小別"
    },
    {
      "start": 154.92,
      "duration": 7.2,
      "text": "さん特にございませんはい開いてないです"
    },
    {
      "start": 158.519,
      "duration": 5.72,
      "text": "ねはいえっとでは市改革部会は開催がない"
    },
    {
      "start": 162.12,
      "duration": 6.32,
      "text": "ので以上で終わります次にえ広報部会の"
    },
    {
      "start": 164.239,
      "duration": 7.241,
      "text": "報告を求めます田さんあ広報部会もあの"
    },
    {
      "start": 168.44,
      "duration": 6.2,
      "text": "開催しておりませんはいえっと広報部会の"
    },
    {
      "start": 171.48,
      "duration": 6.039,
      "text": "方もえ開催がないということでえ各部の"
    },
    {
      "start": 174.64,
      "duration": 6.239,
      "text": "報告に関しましてはえということになり"
    },
    {
      "start": 177.519,
      "duration": 7.601,
      "text": "ますよねはいどうぞ"
    },
    {
      "start": 180.879,
      "duration": 6.561,
      "text": "さんあすいませんえっと広報部会太さん"
    },
    {
      "start": 185.12,
      "duration": 5.32,
      "text": "ありがとうございましたえっと確かに開催"
    },
    {
      "start": 187.44,
      "duration": 5.879,
      "text": "はしてないんですけれども多分前回の時に"
    },
    {
      "start": 190.44,
      "duration": 5.64,
      "text": "9月20日に開催していてと議会"
    },
    {
      "start": 193.319,
      "duration": 5.64,
      "text": "ガイドブックのレイアウト及び内容につい"
    },
    {
      "start": 196.08,
      "duration": 5.879,
      "text": "て前回のこの広報協議会で確認をしたん"
    },
    {
      "start": 198.959,
      "duration": 5.321,
      "text": "ですねでなんかえっとま広報部会に入って"
    },
    {
      "start": 201.959,
      "duration": 5.36,
      "text": "いらっしゃらない人もいらっしゃるので"
    },
    {
      "start": 204.28,
      "duration": 5.12,
      "text": "何かある時には10月7日までに対部会長"
    },
    {
      "start": 207.319,
      "duration": 4.2,
      "text": "にメールを送っていただくていう風に"
    },
    {
      "start": 209.4,
      "duration": 5.399,
      "text": "終わっいたのでその後のなんかちょっと"
    },
    {
      "start": 211.519,
      "duration": 5.841,
      "text": "進捗あったのか私確認させていただいたか"
    },
    {
      "start": 214.799,
      "duration": 5.041,
      "text": "どうかもちょっと記憶が曖昧なのでそれに"
    },
    {
      "start": 217.36,
      "duration": 6.4,
      "text": "ついてちょっとご報告をいただければと"
    },
    {
      "start": 219.84,
      "duration": 7.039,
      "text": "思いますはいさんあえっとすいません自分"
    },
    {
      "start": 223.76,
      "duration": 7.28,
      "text": "から言うべき内容でしたえっと連絡は特に"
    },
    {
      "start": 226.879,
      "duration": 5.36,
      "text": "なかったですえなのでだからちょっと実は"
    },
    {
      "start": 231.04,
      "duration": 5.16,
      "text": "自分の中"
    },
    {
      "start": 232.239,
      "duration": 6.441,
      "text": "でその広部会と広報協議会のこの"
    },
    {
      "start": 236.2,
      "duration": 4.56,
      "text": "ハンドブックの改定をこの人気終わるにっ"
    },
    {
      "start": 238.68,
      "duration": 3.96,
      "text": "てどういう終り方をすればいいのかが"
    },
    {
      "start": 240.76,
      "duration": 3.8,
      "text": "ちょっと自分で分かってなくてちょっと"
    },
    {
      "start": 242.64,
      "duration": 5.08,
      "text": "発言を躊躇してしまったっていうところが"
    },
    {
      "start": 244.56,
      "duration": 5.8,
      "text": "あったんですけどまどっかの段階で確認し"
    },
    {
      "start": 247.72,
      "duration": 2.64,
      "text": "たいと思っており"
    },
    {
      "start": 250.64,
      "duration": 7.8,
      "text": "ます大丈夫ですか酒井さん大丈夫ですか"
    },
    {
      "start": 254.76,
      "duration": 8.12,
      "text": "いう酒井さんどうぞはいということで"
    },
    {
      "start": 258.44,
      "duration": 7.4,
      "text": "えっと多分今人気の広報部会ではえっと"
    },
    {
      "start": 262.88,
      "duration": 6.599,
      "text": "広報部会で確認したものを広報協議会でも"
    },
    {
      "start": 265.84,
      "duration": 8.84,
      "text": "確認していただいてそれを元にえっと時期"
    },
    {
      "start": 269.479,
      "duration": 7.761,
      "text": "こ法協議会に託す申し送りをするという"
    },
    {
      "start": 274.68,
      "duration": 5.6,
      "text": "ことだったと認識しているのでで特にご"
    },
    {
      "start": 277.24,
      "duration": 6.36,
      "text": "意見がなかったので前回共有したものを"
    },
    {
      "start": 280.28,
      "duration": 6.12,
      "text": "そのまま時期の広報協議会に送るという"
    },
    {
      "start": 283.6,
      "duration": 7.599,
      "text": "まとめになるかと思いまし"
    },
    {
      "start": 286.4,
      "duration": 7.72,
      "text": "たあはいあはいさんあえっと私もその認識"
    },
    {
      "start": 291.199,
      "duration": 5.601,
      "text": "でいてその申し送りの仕方っていうのが"
    },
    {
      "start": 294.12,
      "duration": 4.519,
      "text": "なんか形式的なものがあったのかなかった"
    },
    {
      "start": 296.8,
      "duration": 4.92,
      "text": "のかをちょっと"
    },
    {
      "start": 298.639,
      "duration": 4.601,
      "text": "まあ事務局とまこの場じゃないとこで確認"
    },
    {
      "start": 301.72,
      "duration": 4.12,
      "text": "しようかなと思ってたんですけどま"
    },
    {
      "start": 303.24,
      "duration": 5.32,
      "text": "せっかく話が出たのでなんかそういうの"
    },
    {
      "start": 305.84,
      "duration": 5.04,
      "text": "作る作るんでしたっけ事務局から何ここで"
    },
    {
      "start": 308.56,
      "duration": 4.52,
      "text": "あの確認したという記録が残ればそれで"
    },
    {
      "start": 310.88,
      "duration": 5.12,
      "text": "終わりなのか"
    },
    {
      "start": 313.08,
      "duration": 6.32,
      "text": "なんかどうぞすいませんえっと特にですね"
    },
    {
      "start": 316.0,
      "duration": 5.72,
      "text": "様式はございませんそれでえっと時期に"
    },
    {
      "start": 319.4,
      "duration": 6.0,
      "text": "申し来るかどうかっていうのはえっとその"
    },
    {
      "start": 321.72,
      "duration": 6.759,
      "text": "時のえっと広報協議会のえっと方々によっ"
    },
    {
      "start": 325.4,
      "duration": 4.799,
      "text": "てえっと決定されていたかなと思いますで"
    },
    {
      "start": 328.479,
      "duration": 5.361,
      "text": "えなので"
    },
    {
      "start": 330.199,
      "duration": 6.081,
      "text": "えまとめられる時はえっと何かえま一にさ"
    },
    {
      "start": 333.84,
      "duration": 4.96,
      "text": "れたものとかをえっと申し送ってたなと"
    },
    {
      "start": 336.28,
      "duration": 5.88,
      "text": "いう風に記憶してございます以上ですはい"
    },
    {
      "start": 338.8,
      "duration": 8.16,
      "text": "たさんそしたらちょっと"
    },
    {
      "start": 342.16,
      "duration": 8.96,
      "text": "あ広報部会として確認したいのがここで"
    },
    {
      "start": 346.96,
      "duration": 7.48,
      "text": "あの前回話し合ったというなん議論をした"
    },
    {
      "start": 351.12,
      "duration": 5.519,
      "text": "ということを持って申し送りにするのか"
    },
    {
      "start": 354.44,
      "duration": 6.039,
      "text": "それともなんかペーパーを作った方がいい"
    },
    {
      "start": 356.639,
      "duration": 6.361,
      "text": "のかちょっと私だと判断できないのであの"
    },
    {
      "start": 360.479,
      "duration": 4.28,
      "text": "実際にあのペーパー作ってないので必要"
    },
    {
      "start": 363.0,
      "duration": 6.4,
      "text": "ならば作る必要あるのかなと思ってるん"
    },
    {
      "start": 364.759,
      "duration": 6.361,
      "text": "ですけどその点どういう形式が1番ここで"
    },
    {
      "start": 369.4,
      "duration": 3.84,
      "text": "ここでどっちにするかを確認すればいいっ"
    },
    {
      "start": 371.12,
      "duration": 5.44,
      "text": "て話ですかどういう形式にするのが一番"
    },
    {
      "start": 373.24,
      "duration": 8.519,
      "text": "事務的にはいいかは判断"
    },
    {
      "start": 376.56,
      "duration": 7.88,
      "text": "つくはい小さん原則あの部会なのであの"
    },
    {
      "start": 381.759,
      "duration": 5.72,
      "text": "申しくるのは教員会ですよねおっしゃる"
    },
    {
      "start": 384.44,
      "duration": 7.159,
      "text": "その集中されてる通り教員会として何を"
    },
    {
      "start": 387.479,
      "duration": 6.16,
      "text": "送るのかという整理の方をするとま"
    },
    {
      "start": 391.599,
      "duration": 5.641,
      "text": "おのずとやることが出てくるのかなと思う"
    },
    {
      "start": 393.639,
      "duration": 6.361,
      "text": "ますあはいたさんあえっとその通りだと"
    },
    {
      "start": 397.24,
      "duration": 6.72,
      "text": "思うんですけど送る内容はもう前回で確認"
    },
    {
      "start": 400.0,
      "duration": 6.44,
      "text": "して意見がなかったのであの議論はしたと"
    },
    {
      "start": 403.96,
      "duration": 5.679,
      "text": "でそれをなんか紙にした方がいいのかどう"
    },
    {
      "start": 406.44,
      "duration": 4.759,
      "text": "か議論したということを持って送ったこと"
    },
    {
      "start": 409.639,
      "duration": 4.68,
      "text": "になるの"
    },
    {
      "start": 411.199,
      "duration": 6.241,
      "text": "か申しを送るということになるとなんか"
    },
    {
      "start": 414.319,
      "duration": 5.921,
      "text": "きちんと文章になってる方が適切ですよね"
    },
    {
      "start": 417.44,
      "duration": 4.52,
      "text": "だと思いますあの公会で"
    },
    {
      "start": 420.24,
      "duration": 5.48,
      "text": "そうですよね広報協議会"
    },
    {
      "start": 421.96,
      "duration": 5.32,
      "text": "でうん申上は文章文章をきちんと作って"
    },
    {
      "start": 425.72,
      "duration": 4.4,
      "text": "いただいたものをここで確認するという"
    },
    {
      "start": 427.28,
      "duration": 6.28,
      "text": "作業がいるのではないでしょうかねまだ"
    },
    {
      "start": 430.12,
      "duration": 5.919,
      "text": "その文書はできていないよねその文書化し"
    },
    {
      "start": 433.56,
      "duration": 4.52,
      "text": "てもらうところからかなまずそうするとで"
    },
    {
      "start": 436.039,
      "duration": 4.801,
      "text": "文書化していただいた上で例えば次回の"
    },
    {
      "start": 438.08,
      "duration": 5.32,
      "text": "協議会に出していただいてそこでえここで"
    },
    {
      "start": 440.84,
      "duration": 5.639,
      "text": "決定すれば候補協議会として申しを送る"
    },
    {
      "start": 443.4,
      "duration": 4.6,
      "text": "ことになりますよねじゃあ広報部会で文章"
    },
    {
      "start": 446.479,
      "duration": 4.681,
      "text": "を作っていただくという流れでよろしい"
    },
    {
      "start": 448.0,
      "duration": 6.12,
      "text": "ですかあ分かりましまと言ってもその"
    },
    {
      "start": 451.16,
      "duration": 7.159,
      "text": "レイアウトあそれ自体はもうあのあるので"
    },
    {
      "start": 454.12,
      "duration": 6.84,
      "text": "まそれがこのこのこのようにえお願いし"
    },
    {
      "start": 458.319,
      "duration": 5.801,
      "text": "たいみたいなうんことが申し送りないよう"
    },
    {
      "start": 460.96,
      "duration": 5.919,
      "text": "になるのでうんま単純になんか表題だけ"
    },
    {
      "start": 464.12,
      "duration": 5.919,
      "text": "つつけるみたいなことになるイメジです"
    },
    {
      "start": 466.879,
      "duration": 6.201,
      "text": "けど表題と説明ぐらいいるかあの過去の"
    },
    {
      "start": 470.039,
      "duration": 5.12,
      "text": "また後であそうですねすいませじゃあその"
    },
    {
      "start": 473.08,
      "duration": 4.28,
      "text": "しませあの様式は別にフリーなんですが"
    },
    {
      "start": 475.159,
      "duration": 4.641,
      "text": "あのどういう内容を記載するべきかに関し"
    },
    {
      "start": 477.36,
      "duration": 4.92,
      "text": "てはちょっと事務局の考え方もあるので"
    },
    {
      "start": 479.8,
      "duration": 5.28,
      "text": "あの候補部会のあのさとあの詰めて"
    },
    {
      "start": 482.28,
      "duration": 5.599,
      "text": "いただいて適切な形で例えば次回の協議会"
    },
    {
      "start": 485.08,
      "duration": 5.28,
      "text": "に向けて部会も開いていただいて確認した"
    },
    {
      "start": 487.879,
      "duration": 5.361,
      "text": "上でえ広報協議会にげていただくとこう"
    },
    {
      "start": 490.36,
      "duration": 5.6,
      "text": "いう流れでよろしいでしょうかよろしい"
    },
    {
      "start": 493.24,
      "duration": 5.079,
      "text": "ですね酒井さんそれでいいですよねはい"
    },
    {
      "start": 495.96,
      "duration": 6.239,
      "text": "じゃあそういう形にさせていただきますえ"
    },
    {
      "start": 498.319,
      "duration": 7.16,
      "text": "それからですねえっと座長からえっと前回"
    },
    {
      "start": 502.199,
      "duration": 7.801,
      "text": "え広報協議会から議会運営委員会に協議を"
    },
    {
      "start": 505.479,
      "duration": 7.521,
      "text": "依頼しましたえ1えホームページに膨張"
    },
    {
      "start": 510.0,
      "duration": 5.839,
      "text": "関連を掲載することについて及び2え"
    },
    {
      "start": 513.0,
      "duration": 6.68,
      "text": "ホームページの正眼陳情一覧の表記につい"
    },
    {
      "start": 515.839,
      "duration": 6.0,
      "text": "ての2件についてえ11月21日に議会"
    },
    {
      "start": 519.68,
      "duration": 5.8,
      "text": "運営委員会で協議を行っていただきました"
    },
    {
      "start": 521.839,
      "duration": 6.761,
      "text": "結果膨張関連はえホームページに膨張の"
    },
    {
      "start": 525.48,
      "duration": 6.12,
      "text": "案内を掲載することまた正眼陳情について"
    },
    {
      "start": 528.6,
      "duration": 5.64,
      "text": "はホームページに現在表記されている2に"
    },
    {
      "start": 531.6,
      "duration": 5.32,
      "text": "加え陳情番号を加えることになりましたの"
    },
    {
      "start": 534.24,
      "duration": 5.32,
      "text": "でこの場でえご報告をえいたしますという"
    },
    {
      "start": 536.92,
      "duration": 4.64,
      "text": "ことであのえ議員の方にお認めいただいて"
    },
    {
      "start": 539.56,
      "duration": 4.08,
      "text": "いるということでご報告をさせていただき"
    },
    {
      "start": 541.56,
      "duration": 6.48,
      "text": "ますがこの件ではよろしいですよね確認"
    },
    {
      "start": 543.64,
      "duration": 7.6,
      "text": "だけではいえそれではえ以上でえ1を"
    },
    {
      "start": 548.04,
      "duration": 6.32,
      "text": "終わりますえ次に2議会改革の調査事項に"
    },
    {
      "start": 551.24,
      "duration": 5.56,
      "text": "ついてを行いますえ直ちにかこ1多くの"
    },
    {
      "start": 554.36,
      "duration": 5.84,
      "text": "市民に読んでもらえる市議会頼よりへの"
    },
    {
      "start": 556.8,
      "duration": 6.08,
      "text": "見直しまたは年1回別冊発行についてをえ"
    },
    {
      "start": 560.2,
      "duration": 5.44,
      "text": "行います本件につきましては制服座長で"
    },
    {
      "start": 562.88,
      "duration": 5.24,
      "text": "まとめた案を本日確認して議会運営委員会"
    },
    {
      "start": 565.64,
      "duration": 4.92,
      "text": "に報告することになっておりましたえ報告"
    },
    {
      "start": 568.12,
      "duration": 4.68,
      "text": "案については事前に局から各委員に送付し"
    },
    {
      "start": 570.56,
      "duration": 4.92,
      "text": "ておりますが特段ご意見お寄せいただいて"
    },
    {
      "start": 572.8,
      "duration": 5.159,
      "text": "おりませんがえ皆様のお手元に送った内容"
    },
    {
      "start": 575.48,
      "duration": 5.2,
      "text": "であの特段の意見がなかったのでこの内容"
    },
    {
      "start": 577.959,
      "duration": 4.841,
      "text": "で確定をして議会運営委員会にあの広報協"
    },
    {
      "start": 580.68,
      "duration": 4.64,
      "text": "議会から報告するという形を取らせて"
    },
    {
      "start": 582.8,
      "duration": 5.4,
      "text": "いただいてよろしいでしょうか何かあれば"
    },
    {
      "start": 585.32,
      "duration": 2.88,
      "text": "ご発言お願いし"
    },
    {
      "start": 591.839,
      "duration": 4.481,
      "text": "ますよろしいですかじゃああのえあの送っ"
    },
    {
      "start": 594.48,
      "duration": 4.12,
      "text": "ていただいた内容のまま特にご意見なかっ"
    },
    {
      "start": 596.32,
      "duration": 5.04,
      "text": "たので確定させていただいてあのそのまま"
    },
    {
      "start": 598.6,
      "duration": 5.16,
      "text": "の内容でえ議会運営委会にあの送付をさせ"
    },
    {
      "start": 601.36,
      "duration": 4.56,
      "text": "ていただくということでご確認をえ"
    },
    {
      "start": 603.76,
      "duration": 5.24,
      "text": "いただきました事務局じゃあそれではい"
    },
    {
      "start": 605.92,
      "duration": 5.08,
      "text": "よろしくお願いしますえ次にあえっとこの"
    },
    {
      "start": 609.0,
      "duration": 5.12,
      "text": "括弧1に関して他にないですよねよろしい"
    },
    {
      "start": 611.0,
      "duration": 5.92,
      "text": "ですよねはいえっと次にですねえっと3え"
    },
    {
      "start": 614.12,
      "duration": 5.8,
      "text": "その他についてを行いますえ初めにですね"
    },
    {
      "start": 616.92,
      "duration": 5.72,
      "text": "えっと括1議会法編集部会についてを行い"
    },
    {
      "start": 619.92,
      "duration": 4.599,
      "text": "ますが議会法編集部会について何か皆様"
    },
    {
      "start": 622.64,
      "duration": 5.4,
      "text": "からございますでしょう"
    },
    {
      "start": 624.519,
      "duration": 6.281,
      "text": "か特段ございませんよねはいじゃあ括1"
    },
    {
      "start": 628.04,
      "duration": 5.84,
      "text": "終わります次に2次回の開催についてなん"
    },
    {
      "start": 630.8,
      "duration": 5.159,
      "text": "ですがということでえっと特段あのあまり"
    },
    {
      "start": 633.88,
      "duration": 5.12,
      "text": "予定してなかったんですが今後補部会の方"
    },
    {
      "start": 635.959,
      "duration": 4.921,
      "text": "で一定のあの書類を作っていただいて次回"
    },
    {
      "start": 639.0,
      "duration": 4.839,
      "text": "の協議会に出していただくということに"
    },
    {
      "start": 640.88,
      "duration": 5.079,
      "text": "なりますとえっとその候補部会をいつ頃"
    },
    {
      "start": 643.839,
      "duration": 4.961,
      "text": "開いていただくかにもより蹴りですがその"
    },
    {
      "start": 645.959,
      "duration": 6.721,
      "text": "後のタイミングでえ開くことになるのかな"
    },
    {
      "start": 648.8,
      "duration": 6.44,
      "text": "とで例えばそのこの閉会中に広報部会開い"
    },
    {
      "start": 652.68,
      "duration": 4.599,
      "text": "ていただいあこのあの開会中の定例会中で"
    },
    {
      "start": 655.24,
      "duration": 5.12,
      "text": "もいいですがえっとどっかで開いて"
    },
    {
      "start": 657.279,
      "duration": 5.161,
      "text": "いただいてえただの呼びまでたらちょっと"
    },
    {
      "start": 660.36,
      "duration": 5.0,
      "text": "難しいですよ"
    },
    {
      "start": 662.44,
      "duration": 6.68,
      "text": "ねもしそれが可能なら予備日に断時間でも"
    },
    {
      "start": 665.36,
      "duration": 5.52,
      "text": "入れちゃいますがもはいできますかできる"
    },
    {
      "start": 669.12,
      "duration": 5.839,
      "text": "んなら予備日にもう1回開いてもいいです"
    },
    {
      "start": 670.88,
      "duration": 6.36,
      "text": "けどできるます似て候補部集まれますか"
    },
    {
      "start": 674.959,
      "duration": 4.401,
      "text": "みんなできると思いますできる大丈夫です"
    },
    {
      "start": 677.24,
      "duration": 5.36,
      "text": "ねはいじゃああの"
    },
    {
      "start": 679.36,
      "duration": 6.64,
      "text": "えっとタさんから力強くできるんだという"
    },
    {
      "start": 682.6,
      "duration": 6.76,
      "text": "お話があのございましたのでえじゃああの"
    },
    {
      "start": 686.0,
      "duration": 4.68,
      "text": "広報部会をえ"
    },
    {
      "start": 689.36,
      "duration": 3.88,
      "text": "はま持ちまれでもいいと思うんですけどね"
    },
    {
      "start": 690.68,
      "duration": 5.68,
      "text": "広報部会開催していただいてえっとそれで"
    },
    {
      "start": 693.24,
      "duration": 5.08,
      "text": "は広報協議会の方に次回の協議会であの"
    },
    {
      "start": 696.36,
      "duration": 5.039,
      "text": "出していただくということでその広報協議"
    },
    {
      "start": 698.32,
      "duration": 5.48,
      "text": "会の日程はということで予備日のえっと中"
    },
    {
      "start": 701.399,
      "duration": 4.961,
      "text": "で広報協議会をまた開かせていただいて"
    },
    {
      "start": 703.8,
      "duration": 4.56,
      "text": "その件についてえ議論をさせていただくと"
    },
    {
      "start": 706.36,
      "duration": 3.599,
      "text": "え確認をさせていただくということにし"
    },
    {
      "start": 708.36,
      "duration": 4.36,
      "text": "たいと思いますのでじゃあ事務局すいませ"
    },
    {
      "start": 709.959,
      "duration": 5.041,
      "text": "んがあの予備日の日程の中に広報協議会え"
    },
    {
      "start": 712.72,
      "duration": 5.64,
      "text": "どこか適切なところに入れておいて"
    },
    {
      "start": 715.0,
      "duration": 6.16,
      "text": "くださいえっとそれでは次回の開催につい"
    },
    {
      "start": 718.36,
      "duration": 5.0,
      "text": "ては以上でえ今度は予備日開催するという"
    },
    {
      "start": 721.16,
      "duration": 5.56,
      "text": "こととさせていただきます次にかこさんの"
    },
    {
      "start": 723.36,
      "duration": 6.159,
      "text": "その他についてをえ行いますえっとまず"
    },
    {
      "start": 726.72,
      "duration": 5.679,
      "text": "あの座長からでございますけれどもえ開戦"
    },
    {
      "start": 729.519,
      "duration": 6.801,
      "text": "時ですね市議会議員選挙が終わった時の"
    },
    {
      "start": 732.399,
      "duration": 7.161,
      "text": "個人写真についてえはもうその撮影をあの"
    },
    {
      "start": 736.32,
      "duration": 5.56,
      "text": "廃止するという話があのこの間出ていまし"
    },
    {
      "start": 739.56,
      "duration": 5.519,
      "text": "たよねあの結局皆さん自分の用意した写真"
    },
    {
      "start": 741.88,
      "duration": 5.399,
      "text": "を使ってえあのあのあの時撮った写真って"
    },
    {
      "start": 745.079,
      "duration": 4.681,
      "text": "あのあまり使われていないという実態が"
    },
    {
      "start": 747.279,
      "duration": 6.441,
      "text": "ございますのでもう廃止したいという話が"
    },
    {
      "start": 749.76,
      "duration": 6.16,
      "text": "ありましたがえっとそのその点で最終確認"
    },
    {
      "start": 753.72,
      "duration": 4.2,
      "text": "であの個人写真の撮影は行わないという"
    },
    {
      "start": 755.92,
      "duration": 5.2,
      "text": "確認をさせていただいてよろしいでしょう"
    },
    {
      "start": 757.92,
      "duration": 5.719,
      "text": "かよろしいですよねはいではそのも確認を"
    },
    {
      "start": 761.12,
      "duration": 5.0,
      "text": "させていただいた上で写真の件はですね"
    },
    {
      "start": 763.639,
      "duration": 5.921,
      "text": "あの申し合わせ事項に実は記載がござい"
    },
    {
      "start": 766.12,
      "duration": 6.32,
      "text": "ますので本件については議会運営委員会に"
    },
    {
      "start": 769.56,
      "duration": 5.12,
      "text": "え個人写真の撮影を廃止する方向で協議の"
    },
    {
      "start": 772.44,
      "duration": 4.32,
      "text": "依頼を議運にしたいと思いますけれども"
    },
    {
      "start": 774.68,
      "duration": 4.68,
      "text": "それでよろしいですよねはいでそれでは"
    },
    {
      "start": 776.76,
      "duration": 4.639,
      "text": "事務局の方からあの議会運営委員会に今"
    },
    {
      "start": 779.36,
      "duration": 4.76,
      "text": "岸田委員長もいらっしゃいますけれども"
    },
    {
      "start": 781.399,
      "duration": 4.921,
      "text": "あのその旨広報協議会で全体で合意取れた"
    },
    {
      "start": 784.12,
      "duration": 5.719,
      "text": "ということでああの投げかけていただけれ"
    },
    {
      "start": 786.32,
      "duration": 5.56,
      "text": "ばということでよろしくお願いいたします"
    },
    {
      "start": 789.839,
      "duration": 5.44,
      "text": "その他に関して皆さんから何かございます"
    },
    {
      "start": 791.88,
      "duration": 6.399,
      "text": "でしょうか特段ございませんかなしですね"
    },
    {
      "start": 795.279,
      "duration": 7.481,
      "text": "はいえそれでは以上で広報協議会の会議を"
    },
    {
      "start": 798.279,
      "duration": 4.481,
      "text": "終了いたします大変お疲れ様でございまし"
    },
    {
      "start": 808.12,
      "duration": 4.0,
      "text": "たJA"
    }
  ]
}