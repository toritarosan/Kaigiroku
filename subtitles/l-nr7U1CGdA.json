{
  "entries": [
    {
      "start": 0.0,
      "duration": 4.24,
      "text": "あの消防書の方の方から人を派遣して"
    },
    {
      "start": 2.44,
      "duration": 4.8,
      "text": "くださるというだったんですけれども"
    },
    {
      "start": 4.24,
      "duration": 6.04,
      "text": "ちょっと都合によりあの若干予定少なく"
    },
    {
      "start": 7.24,
      "duration": 5.279,
      "text": "なるかなというところただあの指導の方は"
    },
    {
      "start": 10.28,
      "duration": 5.479,
      "text": "付けさせていただくことについてこれから"
    },
    {
      "start": 12.519,
      "duration": 7.52,
      "text": "あのえ打ち合せをしながら自己委かとあの"
    },
    {
      "start": 15.759,
      "duration": 6.76,
      "text": "消防書えもちろん議会事務局の方えに間に"
    },
    {
      "start": 20.039,
      "duration": 5.121,
      "text": "入っていただきながら打ち合せして進めて"
    },
    {
      "start": 22.519,
      "duration": 5.201,
      "text": "いってて報告させていただこうという"
    },
    {
      "start": 25.16,
      "duration": 4.48,
      "text": "ところでございます私から以上ですはい"
    },
    {
      "start": 27.72,
      "duration": 4.999,
      "text": "ありがとうございますただいまの報告に"
    },
    {
      "start": 29.64,
      "duration": 5.079,
      "text": "ついて何かご意見ご質とございますかはい"
    },
    {
      "start": 32.719,
      "duration": 4.0,
      "text": "それではま残念審者は難しいということ"
    },
    {
      "start": 34.719,
      "duration": 4.721,
      "text": "ですが代用についてまた引き続き実行委員"
    },
    {
      "start": 36.719,
      "duration": 5.721,
      "text": "会の方で問でいただいてご提いたと他"
    },
    {
      "start": 39.44,
      "duration": 6.92,
      "text": "ございますかはいそれでは議会員会協議"
    },
    {
      "start": 42.44,
      "duration": 3.92,
      "text": "会同に参加いたしますお"
    }
  ]
}