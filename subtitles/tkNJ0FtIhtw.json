{
  "entries": [
    {
      "start": 82.64,
      "duration": 4.32,
      "text": "はいお疲れ様でございますえお揃いで"
    },
    {
      "start": 84.72,
      "duration": 6.039,
      "text": "ございますので会委員会の協議会始めさせ"
    },
    {
      "start": 86.96,
      "duration": 5.96,
      "text": "ていただきますまずえ銀第1号につい討論"
    },
    {
      "start": 90.759,
      "duration": 9.601,
      "text": "の確認をいしますが討論あるところござい"
    },
    {
      "start": 92.92,
      "duration": 11.68,
      "text": "ますかはい安田委えっと反対討論待の仲間"
    },
    {
      "start": 100.36,
      "duration": 11.48,
      "text": "た反対で待の仲間たち"
    },
    {
      "start": 104.6,
      "duration": 7.24,
      "text": "はいはい水神え賛成等の森戸ですお"
    },
    {
      "start": 114.2,
      "duration": 5.599,
      "text": "はいはい他にございますか"
    },
    {
      "start": 123.119,
      "duration": 6.12,
      "text": "はい"
    },
    {
      "start": 125.0,
      "duration": 8.2,
      "text": "あできないわけじゃないはいではえ討論が"
    },
    {
      "start": 129.239,
      "duration": 7.041,
      "text": "賛成で森戸議員と反対で清水議員という"
    },
    {
      "start": 133.2,
      "duration": 5.72,
      "text": "ことですね以上2件となりますえ決は前"
    },
    {
      "start": 136.28,
      "duration": 5.48,
      "text": "通りでよろしかったでしょうかはいえでは"
    },
    {
      "start": 138.92,
      "duration": 7.8,
      "text": "え討論再ついては通り確認は終わりました"
    },
    {
      "start": 141.76,
      "duration": 8.559,
      "text": "その他で何かございますかはい副長はい"
    },
    {
      "start": 146.72,
      "duration": 3.599,
      "text": "えっとですね"
    },
    {
      "start": 150.519,
      "duration": 7.601,
      "text": "のあの答弁の中でま視聴報告をするという"
    },
    {
      "start": 154.44,
      "duration": 5.879,
      "text": "ことを聞いてるんですけもその後の日定に"
    },
    {
      "start": 158.12,
      "duration": 6.6,
      "text": "ついてはどうなってるのかというのを確認"
    },
    {
      "start": 160.319,
      "duration": 7.56,
      "text": "したいと思いますはい総務部長はいえ市長"
    },
    {
      "start": 164.72,
      "duration": 5.68,
      "text": "国議案の送付につきましては遅くとも14"
    },
    {
      "start": 167.879,
      "duration": 5.121,
      "text": "日までに送付させていただく予定でござい"
    },
    {
      "start": 170.4,
      "duration": 5.32,
      "text": "ましてえ事前にご相談させていただきまし"
    },
    {
      "start": 173.0,
      "duration": 6.08,
      "text": "た17日には間に合うよう努力させて"
    },
    {
      "start": 175.72,
      "duration": 4.76,
      "text": "いただきますよろしくお願いしますはい風"
    },
    {
      "start": 179.08,
      "duration": 4.96,
      "text": "員長"
    },
    {
      "start": 180.48,
      "duration": 7.44,
      "text": "今主張報告の議案ということなのでま主張"
    },
    {
      "start": 184.04,
      "duration": 6.08,
      "text": "報告という発言なんですけどもということ"
    },
    {
      "start": 187.92,
      "duration": 6.039,
      "text": "はこれはあの本会議ということになるん"
    },
    {
      "start": 190.12,
      "duration": 8.52,
      "text": "ですかねどのような形でのあの扱いになる"
    },
    {
      "start": 193.959,
      "duration": 7.441,
      "text": "んでしょうかはい局長はいえっと今ですね"
    },
    {
      "start": 198.64,
      "duration": 5.84,
      "text": "ま総務部長の方から視聴報告ということの"
    },
    {
      "start": 201.4,
      "duration": 6.36,
      "text": "ご発言あの発言がありましたけもえ本審議"
    },
    {
      "start": 204.48,
      "duration": 7.319,
      "text": "会においてはですね視聴報告はあの本会議"
    },
    {
      "start": 207.76,
      "duration": 8.0,
      "text": "でえ行われておりますま従いましてま具体"
    },
    {
      "start": 211.799,
      "duration": 6.961,
      "text": "の日程等につきましてはえま議案送付後に"
    },
    {
      "start": 215.76,
      "duration": 5.72,
      "text": "ですね取り扱いも含めてま議会の方でま"
    },
    {
      "start": 218.76,
      "duration": 5.96,
      "text": "決定されるものという風にま理解をして"
    },
    {
      "start": 221.48,
      "duration": 5.52,
      "text": "おりますま現時点におけるですねご説明と"
    },
    {
      "start": 224.72,
      "duration": 5.4,
      "text": "いたしましてはですねま議案の送付がまだ"
    },
    {
      "start": 227.0,
      "duration": 5.079,
      "text": "されておりませんのでまこのような内容で"
    },
    {
      "start": 230.12,
      "duration": 4.52,
      "text": "ですねあのご理解をいただければと思い"
    },
    {
      "start": 232.079,
      "duration": 7.121,
      "text": "ますよろしくお願いいたしますはい片山副"
    },
    {
      "start": 234.64,
      "duration": 7.319,
      "text": "委長はいあのま今あのですねあの答弁で"
    },
    {
      "start": 239.2,
      "duration": 5.679,
      "text": "状況分かりましたけれどもこの案件につい"
    },
    {
      "start": 241.959,
      "duration": 5.441,
      "text": "ては非常にこう多くの市民の方もあの関心"
    },
    {
      "start": 244.879,
      "duration": 6.401,
      "text": "を持っておあのいらっしゃいましてで議会"
    },
    {
      "start": 247.4,
      "duration": 6.72,
      "text": "としても本来はこれあのこの定例会の初日"
    },
    {
      "start": 251.28,
      "duration": 5.639,
      "text": "にでもですねまずは報告をすべきだという"
    },
    {
      "start": 254.12,
      "duration": 5.679,
      "text": "ことを決議としてもあげてるわけですま"
    },
    {
      "start": 256.919,
      "duration": 5.761,
      "text": "そういったあの冒頭にあのやっていないと"
    },
    {
      "start": 259.799,
      "duration": 5.281,
      "text": "いうことであのこうやって日がですね"
    },
    {
      "start": 262.68,
      "duration": 4.28,
      "text": "どんどんこう伸びていくというような形で"
    },
    {
      "start": 265.08,
      "duration": 5.08,
      "text": "一体いつになるのかも分からないような"
    },
    {
      "start": 266.96,
      "duration": 6.0,
      "text": "状況が今続いておりましたそしてまた性格"
    },
    {
      "start": 270.16,
      "duration": 5.12,
      "text": "あの正式なこう日程についてもお知らせは"
    },
    {
      "start": 272.96,
      "duration": 5.0,
      "text": "できてないというような状況については私"
    },
    {
      "start": 275.28,
      "duration": 5.12,
      "text": "は大変大きな問題だと思っておりますあの"
    },
    {
      "start": 277.96,
      "duration": 4.76,
      "text": "非常に遺憾ですこのようなことはですね"
    },
    {
      "start": 280.4,
      "duration": 4.68,
      "text": "今後ないようにしていただきたい本当に"
    },
    {
      "start": 282.72,
      "duration": 6.36,
      "text": "ですねあのこのことについて振り回され"
    },
    {
      "start": 285.08,
      "duration": 6.839,
      "text": "てるというこんなあのもうあの議会に行て"
    },
    {
      "start": 289.08,
      "duration": 4.88,
      "text": "ですよそれでですねこんな形で振り回せる"
    },
    {
      "start": 291.919,
      "duration": 4.761,
      "text": "なんてことはあってはならないということ"
    },
    {
      "start": 293.96,
      "duration": 5.76,
      "text": "を申し上げておきたいと思っております"
    },
    {
      "start": 296.68,
      "duration": 6.0,
      "text": "はい他にございますかはい水上委員ま今の"
    },
    {
      "start": 299.72,
      "duration": 6.039,
      "text": "の件なんですけど議案送付後後に要するに"
    },
    {
      "start": 302.68,
      "duration": 7.04,
      "text": "議会日程を確定するっていうことになると"
    },
    {
      "start": 305.759,
      "duration": 7.641,
      "text": "一応議案送付は14日に送付したいって話"
    },
    {
      "start": 309.72,
      "duration": 7.12,
      "text": "だったのでそうすると14日に確定するま"
    },
    {
      "start": 313.4,
      "duration": 5.079,
      "text": "議員会委員会である程度そのあの議会日程"
    },
    {
      "start": 316.84,
      "duration": 4.84,
      "text": "については確認しなくちゃいけないと思う"
    },
    {
      "start": 318.479,
      "duration": 5.72,
      "text": "んですけどまそこで要するに市民的にも"
    },
    {
      "start": 321.68,
      "duration": 4.88,
      "text": "あのこの日に市場報告が行われますみたい"
    },
    {
      "start": 324.199,
      "duration": 4.201,
      "text": "な形になると思うんですがそれは14日"
    },
    {
      "start": 326.56,
      "duration": 4.52,
      "text": "っていうことになるんですかその辺"
    },
    {
      "start": 328.4,
      "duration": 4.84,
      "text": "ちょっと確認しておきたい長はいえっと今"
    },
    {
      "start": 331.08,
      "duration": 5.399,
      "text": "水委員からおっしゃっていただいたように"
    },
    {
      "start": 333.24,
      "duration": 6.56,
      "text": "14日に今の時点では議員を開く予定は"
    },
    {
      "start": 336.479,
      "duration": 6.681,
      "text": "ございませんでそれを14日にえその"
    },
    {
      "start": 339.8,
      "duration": 6.36,
      "text": "取り扱いを図るための議運を開けばですね"
    },
    {
      "start": 343.16,
      "duration": 5.92,
      "text": "その日にまあのホームページ上にもですね"
    },
    {
      "start": 346.16,
      "duration": 6.479,
      "text": "その辺は乗ることはできますけれどもま"
    },
    {
      "start": 349.08,
      "duration": 7.92,
      "text": "現状ではですねあのま議案が14日に仮に"
    },
    {
      "start": 352.639,
      "duration": 8.921,
      "text": "送付されたとしますとえ多分もし17日に"
    },
    {
      "start": 357.0,
      "duration": 7.56,
      "text": "その取り扱いも含めた形での議運を開くと"
    },
    {
      "start": 361.56,
      "duration": 6.639,
      "text": "いうことになると実際にホームページ上で"
    },
    {
      "start": 364.56,
      "duration": 6.44,
      "text": "日程が進と確定というのはあの17日に"
    },
    {
      "start": 368.199,
      "duration": 6.44,
      "text": "なるという形になりますのでそこの時点で"
    },
    {
      "start": 371.0,
      "duration": 6.4,
      "text": "えま議会事務局としてはですねあの日程的"
    },
    {
      "start": 374.639,
      "duration": 6.041,
      "text": "なもののまあのホームページの掲載は"
    },
    {
      "start": 377.4,
      "duration": 6.16,
      "text": "できるとただ議案の送付自体これま今まで"
    },
    {
      "start": 380.68,
      "duration": 6.2,
      "text": "のやり方ですけれども議案が例えば14日"
    },
    {
      "start": 383.56,
      "duration": 6.6,
      "text": "に送付されれば追加送付案件については"
    },
    {
      "start": 386.88,
      "duration": 5.96,
      "text": "送付され次第ですねあの議会事務局の"
    },
    {
      "start": 390.16,
      "duration": 5.0,
      "text": "ホームページに載せておりますのでそれに"
    },
    {
      "start": 392.84,
      "duration": 5.0,
      "text": "ついては載せられますけれどもじゃその"
    },
    {
      "start": 395.16,
      "duration": 4.96,
      "text": "日程が具体にどこに本会議なりなんな"
    },
    {
      "start": 397.84,
      "duration": 5.0,
      "text": "りっていうことになると今のような手続き"
    },
    {
      "start": 400.12,
      "duration": 5.96,
      "text": "を経ないとですねあの実際には取り扱い"
    },
    {
      "start": 402.84,
      "duration": 6.079,
      "text": "図ってない状態でせするわけにはあのいか"
    },
    {
      "start": 406.08,
      "duration": 5.04,
      "text": "ないのでそのような形で今までもあの事務"
    },
    {
      "start": 408.919,
      "duration": 5.321,
      "text": "局の方としては事務をさせていただいてる"
    },
    {
      "start": 411.12,
      "duration": 6.639,
      "text": "という現状でございます以上ですはい水上"
    },
    {
      "start": 414.24,
      "duration": 6.519,
      "text": "委員状況分かりましたけど非常に重要なね"
    },
    {
      "start": 417.759,
      "duration": 6.321,
      "text": "案件なのでこれがそういう形でちょっと"
    },
    {
      "start": 420.759,
      "duration": 6.0,
      "text": "議会日程があの定まって市民に公表され"
    },
    {
      "start": 424.08,
      "duration": 5.239,
      "text": "るっていうのはやっぱりちょっとね議会と"
    },
    {
      "start": 426.759,
      "duration": 5.401,
      "text": "してもやっぱり問題あの議会に問題がある"
    },
    {
      "start": 429.319,
      "duration": 5.841,
      "text": "わけでもなく市長の進め方としては"
    },
    {
      "start": 432.16,
      "duration": 5.92,
      "text": "ちょっとやっぱりねあの過残すなっていう"
    },
    {
      "start": 435.16,
      "duration": 5.2,
      "text": "風な気持ちはありますのであのちょっと"
    },
    {
      "start": 438.08,
      "duration": 4.16,
      "text": "今後ねこういうことがないように是非対応"
    },
    {
      "start": 440.36,
      "duration": 3.32,
      "text": "してもらいたいということは言っておき"
    },
    {
      "start": 442.24,
      "duration": 5.88,
      "text": "たいと思い"
    },
    {
      "start": 443.68,
      "duration": 7.84,
      "text": "ますはい山副長えっとま今あの局長の方"
    },
    {
      "start": 448.12,
      "duration": 6.6,
      "text": "からそういった形で式な形でのねあの市議"
    },
    {
      "start": 451.52,
      "duration": 5.48,
      "text": "会としてのお知らせについては17日当日"
    },
    {
      "start": 454.72,
      "duration": 6.08,
      "text": "になるというような形だということがあっ"
    },
    {
      "start": 457.0,
      "duration": 6.199,
      "text": "たわけですがま今この協議会のあの中での"
    },
    {
      "start": 460.8,
      "duration": 4.92,
      "text": "発言としてはまこれYouTubeでも"
    },
    {
      "start": 463.199,
      "duration": 5.28,
      "text": "流れてるわけですねですのでもう一定の"
    },
    {
      "start": 465.72,
      "duration": 6.039,
      "text": "ですねこういった形でもうあの大の場での"
    },
    {
      "start": 468.479,
      "duration": 6.321,
      "text": "え発言となっておりますのでこれはですね"
    },
    {
      "start": 471.759,
      "duration": 6.12,
      "text": "あのまこちらとしてはしっかりと市民の方"
    },
    {
      "start": 474.8,
      "duration": 6.28,
      "text": "に知らせていきたいという風に考えており"
    },
    {
      "start": 477.879,
      "duration": 7.201,
      "text": "ますはい他にございますか"
    },
    {
      "start": 481.08,
      "duration": 8.48,
      "text": "よしはいそれでは以上でえ議会運会協議会"
    },
    {
      "start": 485.08,
      "duration": 4.48,
      "text": "と参加いたしますお疲れ様でした"
    }
  ]
}