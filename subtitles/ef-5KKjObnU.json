      "start": 664.839,
      "duration": 4.401,
      "text": "で、あの、司法などの候補も間に合、えっ"
    },
    {
      "start": 667.48,
      "duration": 4.479,
      "text": "と、議会法も間に合わないということなの"
    },
    {
      "start": 669.24,
      "duration": 4.48,
      "text": "で、じゃ、ちょっと8月は見送ってで、"
    },
    {
      "start": 671.959,
      "duration": 4.521,
      "text": "えっと、準備をした上で10月ということ"
    },
    {
      "start": 673.72,
      "duration": 7.28,
      "text": "で、今後日として考えられるのが、えっと"
    },
    {
      "start": 676.48,
      "duration": 8.44,
      "text": "、10月6日火曜日の午前中、"
    },
    {
      "start": 681.0,
      "duration": 6.8,
      "text": "それと、えっと、先ほど中大付属が21位"
    },
    {
      "start": 684.92,
      "duration": 7.039,
      "text": "に決まったんですよね。なので、ま、"
    },
    {
      "start": 687.8,
      "duration": 8.0,
      "text": "可能性としてはですが22の木曜日"
    },
    {
      "start": 691.959,
      "duration": 6.841,
      "text": "も可能にはなります。"
    },
    {
      "start": 695.8,
      "duration": 3.0,
      "text": "あ、ごめんなさい。安田さん。あ、ごめんなさい。じゃあだめです。はい、失礼しました。"
    },
    {
      "start": 700.12,
      "duration": 3.36,
      "text": "あとは26、27。"
    },
    {
      "start": 704.2,
      "duration": 4.84,
      "text": "26か。"
    },
    {
      "start": 706.04,
      "duration": 3.0,
      "text": "はい。なので、あの、今から調整をしていきますが、あの、この日はどうしても難しいとかそういうことであれば、あの、早めに言っていただいた方が調整が"
    },
    {
      "start": 715.8,
      "duration": 2.0,
      "text": "26"
    },
    {
      "start": 716.32,
      "duration": 1.84,
      "text": "だと"
    },
    {
      "start": 717.8,
      "duration": 2.76,
      "text": "過去。"
    },
    {
      "start": 718.16,
      "duration": 3.88,
      "text": "午後26と、27"
    },
    {
      "start": 720.56,
      "duration": 2.12,
      "text": "だと午前午前はい。"
    },
    {
      "start": 722.04,
      "duration": 3.799,
      "text": "はい。"
    },
    {
      "start": 722.68,
      "duration": 5.279,
      "text": "になります。じゃあこの3つのそれぞれご"
    },
    {
      "start": 725.839,
      "duration": 4.68,
      "text": "検討いただくという形で"
    },
    {
      "start": 727.959,
      "duration": 4.401,
      "text": "でそれでちょっとあの皆さんと調整して"
    },
    {
      "start": 730.519,
      "duration": 4.88,
      "text": "いただくということでよろしくお願いし"
    },
    {
      "start": 732.36,
      "duration": 5.24,
      "text": "ます。えっとその他何かありますか?皆"
    },
    {
      "start": 735.399,
      "duration": 5.041,
      "text": "さんから"
    },
    {
      "start": 737.6,
      "duration": 8.96,
      "text": "よろしいでしょうか?じゃあ議会委員"
    },
    {
      "start": 740.44,
      "duration": 6.12,
      "text": "会協議会終わります。お疲れ様でした。"
    }
  ]
}