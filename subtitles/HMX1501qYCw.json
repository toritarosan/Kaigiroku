{
  "entries": [
    {
      "start": 94.2,
      "duration": 7.959,
      "text": "はいでは帝国でございますので議会委員会"
    },
    {
      "start": 97.0,
      "duration": 6.0,
      "text": "協議会始めさせていただきますえ委報告の"
    },
    {
      "start": 102.159,
      "duration": 5.081,
      "text": "討論"
    },
    {
      "start": 103.0,
      "duration": 6.88,
      "text": "採決につきましてあとま000第3号の"
    },
    {
      "start": 107.24,
      "duration": 5.4,
      "text": "討論採決について一括でお伺いをして"
    },
    {
      "start": 109.88,
      "duration": 8.48,
      "text": "まいります討論予定されてる"
    },
    {
      "start": 112.64,
      "duration": 11.839,
      "text": "方はいじゃあ片山近長はいあつだっけいや"
    },
    {
      "start": 118.36,
      "duration": 12.48,
      "text": "協議会だからはいはいえどだっけはいえ第"
    },
    {
      "start": 124.479,
      "duration": 10.4,
      "text": "1号にえ賛成討論片山です6神城17号で"
    },
    {
      "start": 130.84,
      "duration": 8.32,
      "text": "賛成片山さん1件でよろしいですか他"
    },
    {
      "start": 134.879,
      "duration": 9.561,
      "text": "ございますかはい水上えっと共産党陳情第"
    },
    {
      "start": 139.16,
      "duration": 8.2,
      "text": "17号え賛成討論森戸ですはい以上1件で"
    },
    {
      "start": 144.44,
      "duration": 6.2,
      "text": "よろしいですかはい他にございます"
    },
    {
      "start": 147.36,
      "duration": 7.0,
      "text": "かよろしいですか"
    },
    {
      "start": 150.64,
      "duration": 8.239,
      "text": "え選書を含めてなしでよろしいですかはい"
    },
    {
      "start": 154.36,
      "duration": 9.48,
      "text": "ではえ討論については6陳情第17号でえ"
    },
    {
      "start": 158.879,
      "duration": 7.241,
      "text": "賛成討論で片山さんと森戸さんということ"
    },
    {
      "start": 163.84,
      "duration": 7.0,
      "text": "でえ以上2件でご確認いただいてよろしい"
    },
    {
      "start": 166.12,
      "duration": 6.52,
      "text": "ですかはいではその他あ何かございます"
    },
    {
      "start": 170.84,
      "duration": 4.28,
      "text": "か"
    },
    {
      "start": 172.64,
      "duration": 7.44,
      "text": "なし"
    },
    {
      "start": 175.12,
      "duration": 8.08,
      "text": "キはいえっと明日ですけれどもえっと"
    },
    {
      "start": 180.08,
      "duration": 5.64,
      "text": "議会の審査避難訓練を10時から行います"
    },
    {
      "start": 183.2,
      "duration": 4.599,
      "text": "のでえご出席いただけますようよろしくお"
    },
    {
      "start": 185.72,
      "duration": 6.0,
      "text": "願いいたします以上でございます"
    },
    {
      "start": 187.799,
      "duration": 3.921,
      "text": "とりあえず今大丈夫です"
    },
    {
      "start": 192.879,
      "duration": 6.161,
      "text": "ねはいえっとそれと今日あの本日の会派"
    },
    {
      "start": 196.28,
      "duration": 6.08,
      "text": "代表限にえっと座長として出席させて"
    },
    {
      "start": 199.04,
      "duration": 5.6,
      "text": "いただきましてあのまたあの改めてまた"
    },
    {
      "start": 202.36,
      "duration": 5.76,
      "text": "流れについてなど説明させていただければ"
    },
    {
      "start": 204.64,
      "duration": 6.72,
      "text": "と思っております以上ですはい前回あの"
    },
    {
      "start": 208.12,
      "duration": 5.24,
      "text": "議会会議の皆さについては概要はお知らせ"
    },
    {
      "start": 211.36,
      "duration": 3.68,
      "text": "したと思いますけれどもまそれ以外の会派"
    },
    {
      "start": 213.36,
      "duration": 4.68,
      "text": "の皆さんもいらっしゃいますのでえ会派"
    },
    {
      "start": 215.04,
      "duration": 5.04,
      "text": "代表者会議においてえ詳細を座長の方から"
    },
    {
      "start": 218.04,
      "duration": 5.44,
      "text": "ご報告いただく"
    },
    {
      "start": 220.08,
      "duration": 5.519,
      "text": "と委員あ自己委員長です自己委員長から"
    },
    {
      "start": 223.48,
      "duration": 5.56,
      "text": "はいはいあのご報告いただくということで"
    },
    {
      "start": 225.599,
      "duration": 7.601,
      "text": "ございます他何かございますかはい議長え"
    },
    {
      "start": 229.04,
      "duration": 7.8,
      "text": "市長から話がありまして本日え東京都市長"
    },
    {
      "start": 233.2,
      "duration": 7.119,
      "text": "村懇談会に出席するためえ午後4時には"
    },
    {
      "start": 236.84,
      "duration": 7.239,
      "text": "小金への役所を出たいということでおが"
    },
    {
      "start": 240.319,
      "duration": 5.601,
      "text": "ありましたのでえおえお話ししておきます"
    },
    {
      "start": 244.079,
      "duration": 4.681,
      "text": "はい"
    },
    {
      "start": 245.92,
      "duration": 5.84,
      "text": "はいということでございますこの件につい"
    },
    {
      "start": 248.76,
      "duration": 4.8,
      "text": "て何かご意見ご質疑とございます"
    },
    {
      "start": 251.76,
      "duration": 3.319,
      "text": "かはい"
    },
    {
      "start": 253.56,
      "duration": 4.88,
      "text": "水上"
    },
    {
      "start": 255.079,
      "duration": 5.801,
      "text": "あの今機長から報告があって状況よく"
    },
    {
      "start": 258.44,
      "duration": 4.759,
      "text": "分かったんですけどあの今日あ"
    },
    {
      "start": 260.88,
      "duration": 5.039,
      "text": "るってことは前から決まってたはずなので"
    },
    {
      "start": 263.199,
      "duration": 5.44,
      "text": "もうちょっと早くなんか議会とね情報共有"
    },
    {
      "start": 265.919,
      "duration": 5.681,
      "text": "していただければ別になんかあの行くこと"
    },
    {
      "start": 268.639,
      "duration": 5.721,
      "text": "についてね僕らあのダだいうつもりは全く"
    },
    {
      "start": 271.6,
      "duration": 6.36,
      "text": "ないのでその辺はちょっとあの市長にも"
    },
    {
      "start": 274.36,
      "duration": 5.44,
      "text": "よくあの今後のあの対応としてあの言っ"
    },
    {
      "start": 277.96,
      "duration": 3.56,
      "text": "といていただきたいなっていうことはあの"
    },
    {
      "start": 279.8,
      "duration": 4.36,
      "text": "申し上げておきたいと思いますので"
    },
    {
      "start": 281.52,
      "duration": 4.519,
      "text": "よろしくお願いしますはいではそのように"
    },
    {
      "start": 284.16,
      "duration": 6.36,
      "text": "総務部長の方からお伝えいただければと"
    },
    {
      "start": 286.039,
      "duration": 6.641,
      "text": "いうふに思っておいます一応あの朝の4社"
    },
    {
      "start": 290.52,
      "duration": 7.64,
      "text": "の方ではまそういったことでございますん"
    },
    {
      "start": 292.68,
      "duration": 9.28,
      "text": "で16時にはえっとま新状況によります"
    },
    {
      "start": 298.16,
      "duration": 6.319,
      "text": "けれどもま一応そこでじるということで"
    },
    {
      "start": 301.96,
      "duration": 4.72,
      "text": "確認はしておりますがそのような運びで"
    },
    {
      "start": 304.479,
      "duration": 4.361,
      "text": "よろしいですか16時今日は目のという"
    },
    {
      "start": 306.68,
      "duration": 4.519,
      "text": "ことでわんなかったら明日もちろんあの"
    },
    {
      "start": 308.84,
      "duration": 4.84,
      "text": "16時で残ったものはもう当然明日という"
    },
    {
      "start": 311.199,
      "duration": 4.641,
      "text": "話になりますけれども13はいはい明日"
    },
    {
      "start": 313.68,
      "duration": 4.92,
      "text": "13時からということになります午前中は"
    },
    {
      "start": 315.84,
      "duration": 6.6,
      "text": "あの先ほどあの吹きえ自己委員長からあり"
    },
    {
      "start": 318.6,
      "duration": 5.319,
      "text": "ました通り避難訓がございますのではいこ"
    },
    {
      "start": 322.44,
      "duration": 4.759,
      "text": "についてはそれでご確認いただいて"
    },
    {
      "start": 323.919,
      "duration": 4.28,
      "text": "よろしいですかはいではその他何かござい"
    },
    {
      "start": 327.199,
      "duration": 5.161,
      "text": "ます"
    },
    {
      "start": 328.199,
      "duration": 8.961,
      "text": "かはいそれでは以上でえ議会法委員会の"
    },
    {
      "start": 332.36,
      "duration": 4.8,
      "text": "議会運営委員会の協議会を終了いたします"
    }
  ]
}