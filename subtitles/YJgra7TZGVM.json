{
  "entries": [
    {
      "start": 66.6,
      "duration": 9.12,
      "text": "安田さん安田"
    },
    {
      "start": 69.64,
      "duration": 6.08,
      "text": "さん会協議会ですよ安田さん"
    },
    {
      "start": 134.0,
      "duration": 8.08,
      "text": "年はいは部長はい皆さんお疲れ様でござい"
    },
    {
      "start": 138.08,
      "duration": 6.159,
      "text": "ますはい会を再開いたしますえ先ほどの件"
    },
    {
      "start": 142.08,
      "duration": 4.439,
      "text": "について事務局の方から提案が出ており"
    },
    {
      "start": 144.239,
      "duration": 6.921,
      "text": "ますの説明をしますはいすいません先ほど"
    },
    {
      "start": 146.519,
      "duration": 7.921,
      "text": "の話でちょっと安分を作ってみましたえと"
    },
    {
      "start": 151.16,
      "duration": 7.48,
      "text": "えっとホームページの方の画面のところは"
    },
    {
      "start": 154.44,
      "duration": 7.2,
      "text": "えっと報告という始まりを上期視聴報告は"
    },
    {
      "start": 158.64,
      "duration": 7.64,
      "text": "という形でえちょっと正しましたそれから"
    },
    {
      "start": 161.64,
      "duration": 7.08,
      "text": "裏面にえポチっと押しますとこれが1番"
    },
    {
      "start": 166.28,
      "duration": 5.0,
      "text": "最初に出てくるという案分を作ってみまし"
    },
    {
      "start": 168.72,
      "duration": 4.84,
      "text": "たのでちょっとご確認いただきと思います"
    },
    {
      "start": 171.28,
      "duration": 6.36,
      "text": "以ですはい"
    },
    {
      "start": 173.56,
      "duration": 6.64,
      "text": "えこれについて何かご意見ご質ざいますか"
    },
    {
      "start": 177.64,
      "duration": 6.08,
      "text": "あの案を出していいたのでとも分かり"
    },
    {
      "start": 180.2,
      "duration": 6.24,
      "text": "やすくなったと思いますえか分の方であの"
    },
    {
      "start": 183.72,
      "duration": 7.159,
      "text": "より分かりやすくなればと思って提案し"
    },
    {
      "start": 186.44,
      "duration": 9.24,
      "text": "ますがえ最初の1行目の点までのところを"
    },
    {
      "start": 190.879,
      "duration": 11.08,
      "text": "自ペジ以降の視報告につきましては令和7"
    },
    {
      "start": 195.68,
      "duration": 7.839,
      "text": "年2月117日に上程さ"
    },
    {
      "start": 201.959,
      "duration": 6.0,
      "text": "れ"
    },
    {
      "start": 203.519,
      "duration": 7.321,
      "text": "点かまされましたが点いうまそんな感の方"
    },
    {
      "start": 207.959,
      "duration": 6.0,
      "text": "がりやすいんじゃないでしょうか"
    },
    {
      "start": 210.84,
      "duration": 6.2,
      "text": "はい冒頭に自ペジ以降の主張報告ましては"
    },
    {
      "start": 213.959,
      "duration": 7.761,
      "text": "令和7年2月17日に定さ"
    },
    {
      "start": 217.04,
      "duration": 4.68,
      "text": "れました"
    },
    {
      "start": 223.72,
      "duration": 9.84,
      "text": "うん"
    },
    {
      "start": 226.64,
      "duration": 6.92,
      "text": "はいが提出さ国の撤回が提出され"
    },
    {
      "start": 245.04,
      "duration": 5.0,
      "text": "視聴報告の撤回っていう言い方が提出さ"
    },
    {
      "start": 247.64,
      "duration": 2.4,
      "text": "れって"
    },
    {
      "start": 253.64,
      "duration": 8.36,
      "text": "ところはいえっと調整というか色々ご検討"
    },
    {
      "start": 259.88,
      "duration": 5.759,
      "text": "いただいて提しいたいてありがとうござい"
    },
    {
      "start": 262.0,
      "duration": 7.72,
      "text": "ますあの私これがすごくシンプルでいいか"
    },
    {
      "start": 265.639,
      "duration": 5.961,
      "text": "とまあれけたりこれつけたりる確かに"
    },
    {
      "start": 269.72,
      "duration": 5.759,
      "text": "詳しく説明することも大事なこと思うん"
    },
    {
      "start": 271.6,
      "duration": 6.68,
      "text": "けども今拝見したとかこれでなんかこう"
    },
    {
      "start": 275.479,
      "duration": 5.72,
      "text": "いいのかなとに入ってくるところがあるか"
    },
    {
      "start": 278.28,
      "duration": 5.04,
      "text": "と思うのでこれで言っていただいていいん"
    },
    {
      "start": 281.199,
      "duration": 4.241,
      "text": "じゃないかと私は思いますという意見を"
    },
    {
      "start": 283.32,
      "duration": 4.159,
      "text": "申し上げて終わり"
    },
    {
      "start": 285.44,
      "duration": 5.28,
      "text": "ます"
    },
    {
      "start": 287.479,
      "duration": 6.201,
      "text": "はいはいあのまたちょっと違う方向の意見"
    },
    {
      "start": 290.72,
      "duration": 6.28,
      "text": "になってしまいますがえですね撤回された"
    },
    {
      "start": 293.68,
      "duration": 6.88,
      "text": "理由を簡単で良いの"
    },
    {
      "start": 297.0,
      "duration": 5.52,
      "text": "での用が不適切だった"
    },
    {
      "start": 300.56,
      "duration": 5.84,
      "text": "いうのを追加する"
    },
    {
      "start": 302.52,
      "duration": 6.88,
      "text": "ことができればと思い"
    },
    {
      "start": 306.4,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 309.56,
      "duration": 7.44,
      "text": "はいえっと入れるとすれ入れるとすれば7"
    },
    {
      "start": 313.4,
      "duration": 7.12,
      "text": "何が2の前だと思うんです"
    },
    {
      "start": 317.0,
      "duration": 5.08,
      "text": "けどなんか今色ますね小林さんのご意見が"
    },
    {
      "start": 320.52,
      "duration": 5.44,
      "text": "ありそのままでいいんじゃないかというふ"
    },
    {
      "start": 322.08,
      "duration": 8.64,
      "text": "さんのご意見があり理由までの"
    },
    {
      "start": 325.96,
      "duration": 7.799,
      "text": "小林あまそのままだとねこれね事実として"
    },
    {
      "start": 330.72,
      "duration": 6.8,
      "text": "少し伝わりにくいんですあの付け加えると"
    },
    {
      "start": 333.759,
      "duration": 6.601,
      "text": "いうよりもこかきっぷりは少し色々誤解"
    },
    {
      "start": 337.52,
      "duration": 7.959,
      "text": "生む内容になってるので変えてみての私"
    },
    {
      "start": 340.36,
      "duration": 8.24,
      "text": "提案で水さんのやつはま今回はそれもいい"
    },
    {
      "start": 345.479,
      "duration": 5.641,
      "text": "もしんないんだけどそのそのまた収まら"
    },
    {
      "start": 348.6,
      "duration": 4.8,
      "text": "なくなるっていうかねもっと押したいいん"
    },
    {
      "start": 351.12,
      "duration": 5.0,
      "text": "じゃないか明日がいていうそこに立ちてっ"
    },
    {
      "start": 353.4,
      "duration": 6.84,
      "text": "ちゃうのでそこはなしの方がいないかなと"
    },
    {
      "start": 356.12,
      "duration": 7.6,
      "text": "思いますはいはいあの小林ご意見いただい"
    },
    {
      "start": 360.24,
      "duration": 7.079,
      "text": "たところなんですあの提出されたその専門"
    },
    {
      "start": 363.72,
      "duration": 6.919,
      "text": "家のあ提出され方じゃないあの専門方から"
    },
    {
      "start": 367.319,
      "duration": 6.0,
      "text": "本来であれば全部削除して欲しいていう"
    },
    {
      "start": 370.639,
      "duration": 5.56,
      "text": "ようなお希望あったと聞てますでもそれが"
    },
    {
      "start": 373.319,
      "duration": 4.88,
      "text": "やはりあの1度提出した議案を全てなくし"
    },
    {
      "start": 376.199,
      "duration": 5.081,
      "text": "てしまうことはできないということなので"
    },
    {
      "start": 378.199,
      "duration": 7.161,
      "text": "あのあくまでもこちらこちらというか市長"
    },
    {
      "start": 381.28,
      "duration": 7.479,
      "text": "のあの不適切だったっていう理由があった"
    },
    {
      "start": 385.36,
      "duration": 5.6,
      "text": "方がなんか他の理由でされとかまそういう"
    },
    {
      "start": 388.759,
      "duration": 6.28,
      "text": "こともあるかもしれないんですけどそちら"
    },
    {
      "start": 390.96,
      "duration": 6.32,
      "text": "の絵の配慮の意味で短い一分でも引用が不"
    },
    {
      "start": 395.039,
      "duration": 7.16,
      "text": "適切だったというのが入った方が良いと"
    },
    {
      "start": 397.28,
      "duration": 4.919,
      "text": "思いましたはい点いかがでしょう"
    },
    {
      "start": 408.919,
      "duration": 25.11,
      "text": "かいかがですか"
    },
    {
      "start": 411.67,
      "duration": 22.359,
      "text": "[音楽]"
    },
    {
      "start": 435.96,
      "duration": 8.16,
      "text": "はい片山近長はいうんとちょっとやっぱり"
    },
    {
      "start": 440.24,
      "duration": 6.799,
      "text": "微妙かなと思いますねそのそれだけにこう"
    },
    {
      "start": 444.12,
      "duration": 4.759,
      "text": "なんか限定するのかどうかもあるので"
    },
    {
      "start": 447.039,
      "duration": 5.081,
      "text": "やっぱりこのぐらいのシンプルまあの"
    },
    {
      "start": 448.879,
      "duration": 7.32,
      "text": "なんていうかななあの割と少ない文明にし"
    },
    {
      "start": 452.12,
      "duration": 7.519,
      "text": "ておいてでまこれまたせあのねえっと者の"
    },
    {
      "start": 456.199,
      "duration": 6.28,
      "text": "方との調整もあると思うのでそこでのこう"
    },
    {
      "start": 459.639,
      "duration": 4.881,
      "text": "まやり取りによってま少しもしかしたら"
    },
    {
      "start": 462.479,
      "duration": 5.601,
      "text": "また検討しなきゃいけないということ"
    },
    {
      "start": 464.52,
      "duration": 3.56,
      "text": "ぐらいかなという風に考え"
    },
    {
      "start": 469.4,
      "duration": 8.44,
      "text": "ますはい他にいかですかはい員はいえっと"
    },
    {
      "start": 473.479,
      "duration": 9.12,
      "text": "3の1の表現は不適切だったためという"
    },
    {
      "start": 477.84,
      "duration": 8.0,
      "text": "ちょっとことを償化するというかそれだ"
    },
    {
      "start": 482.599,
      "duration": 5.761,
      "text": "ないような気もするのでその書き取りは"
    },
    {
      "start": 485.84,
      "duration": 5.639,
      "text": "ちょっと違うかなっていう風に思いますま"
    },
    {
      "start": 488.36,
      "duration": 7.6,
      "text": "今片山さんがおっしゃられた意見に賛成"
    },
    {
      "start": 491.479,
      "duration": 7.68,
      "text": "ですはい神僕も内容に踏み込むとちょっと"
    },
    {
      "start": 495.96,
      "duration": 6.919,
      "text": "色々意見が出ると思うのでそこはちょっと"
    },
    {
      "start": 499.159,
      "duration": 6.401,
      "text": "もう撤回されたことをあの分かりやすく"
    },
    {
      "start": 502.879,
      "duration": 6.401,
      "text": "するっていうこが言われたことは1つある"
    },
    {
      "start": 505.56,
      "duration": 6.44,
      "text": "のかなっていうもう少し詳しくそのその点"
    },
    {
      "start": 509.28,
      "duration": 6.84,
      "text": "のところを伸べるって形ですよねそれは"
    },
    {
      "start": 512.0,
      "duration": 4.12,
      "text": "それであり得るんじゃないかなとは思い"
    },
    {
      "start": 516.519,
      "duration": 8.081,
      "text": "ますはいでは理由のはフッチということで"
    },
    {
      "start": 521.36,
      "duration": 7.039,
      "text": "はいつけないということ"
    },
    {
      "start": 524.6,
      "duration": 5.919,
      "text": "です先ほどのここの表現についてはいかが"
    },
    {
      "start": 528.399,
      "duration": 2.12,
      "text": "です"
    },
    {
      "start": 531.32,
      "duration": 6.04,
      "text": "かはい水谷にはいあの先ほどのあの提案は"
    },
    {
      "start": 535.68,
      "duration": 5.64,
      "text": "自ページ以降のっていうのがあった方が私"
    },
    {
      "start": 537.36,
      "duration": 3.96,
      "text": "も分かりやすいと思います"
    },
    {
      "start": 541.6,
      "duration": 6.56,
      "text": "またあのはいあのちょっとじゃはいはい長"
    },
    {
      "start": 545.2,
      "duration": 5.72,
      "text": "お願いしますはいえっと小林議員のえあの"
    },
    {
      "start": 548.16,
      "duration": 8.16,
      "text": "で読み上げますけど最初に次ページ以降の"
    },
    {
      "start": 550.92,
      "duration": 7.599,
      "text": "方につきましては点令和7年2月17日に"
    },
    {
      "start": 556.32,
      "duration": 7.56,
      "text": "上映されました"
    },
    {
      "start": 558.519,
      "duration": 9.601,
      "text": "がであとはそのまま令和7月2で以下この"
    },
    {
      "start": 563.88,
      "duration": 7.48,
      "text": "通りということではいよろしいかねはいと"
    },
    {
      "start": 568.12,
      "duration": 3.24,
      "text": "いう形になります"
    },
    {
      "start": 573.68,
      "duration": 6.64,
      "text": "はい水谷はいあの表現としてちょっと市民"
    },
    {
      "start": 578.519,
      "duration": 5.56,
      "text": "の方に分かりづらいかなと思うのが視聴"
    },
    {
      "start": 580.32,
      "duration": 7.0,
      "text": "報告の撤回が提出されっていうの撤回議案"
    },
    {
      "start": 584.079,
      "duration": 7.081,
      "text": "がとかだったら分かるかなと思うんです"
    },
    {
      "start": 587.32,
      "duration": 7.16,
      "text": "けど撤回が提出されるっていうのがなんか"
    },
    {
      "start": 591.16,
      "duration": 5.96,
      "text": "ちょっと普通の日本語として分かりでか目"
    },
    {
      "start": 594.48,
      "duration": 2.64,
      "text": "がでか"
    },
    {
      "start": 597.279,
      "duration": 7.56,
      "text": "ギアはい議案っっていうのが長国の撤回"
    },
    {
      "start": 602.36,
      "duration": 6.28,
      "text": "議案っていうのじゃなくて撤回ついてと"
    },
    {
      "start": 604.839,
      "duration": 6.24,
      "text": "いうことであの一応頂いてるので会議学校"
    },
    {
      "start": 608.64,
      "duration": 6.199,
      "text": "で主張保護的について会議学校閉じって"
    },
    {
      "start": 611.079,
      "duration": 5.841,
      "text": "いう風にするのはいかがでしょうかねはい"
    },
    {
      "start": 614.839,
      "duration": 5.56,
      "text": "されてことね実際もう出されたもののその"
    },
    {
      "start": 616.92,
      "duration": 8.479,
      "text": "ままのタイトルを入れるとはいはいはい"
    },
    {
      "start": 620.399,
      "duration": 9.081,
      "text": "ですねはい自ペ事項の視聴報告につまして"
    },
    {
      "start": 625.399,
      "duration": 7.601,
      "text": "は7年2月17日に上されましたが令は7"
    },
    {
      "start": 629.48,
      "duration": 6.76,
      "text": "年3月3日かこ視聴報告の撤回について"
    },
    {
      "start": 633.0,
      "duration": 4.839,
      "text": "かこ図が提出され令和7年34日の会議に"
    },
    {
      "start": 636.24,
      "duration": 5.32,
      "text": "おいて承認され撤回となりましたのでお"
    },
    {
      "start": 637.839,
      "duration": 8.401,
      "text": "知らせしますというかってですかあの山長"
    },
    {
      "start": 641.56,
      "duration": 8.32,
      "text": "はいえっとそのあれですよね撤回の提出の"
    },
    {
      "start": 646.24,
      "duration": 9.52,
      "text": "が果提出権の3月3日登録の"
    },
    {
      "start": 649.88,
      "duration": 5.88,
      "text": "分なんですよそうですうん"
    },
    {
      "start": 655.88,
      "duration": 5.36,
      "text": "そこペジの面には1番"
    },
    {
      "start": 662.16,
      "duration": 5.679,
      "text": "うんなんかそこがね分かるようななんて"
    },
    {
      "start": 665.76,
      "duration": 5.519,
      "text": "いうか繋がるあれがあるといいの思いけど"
    },
    {
      "start": 667.839,
      "duration": 6.041,
      "text": "まあんまりねそんなにこううんややこしい"
    },
    {
      "start": 671.279,
      "duration": 2.601,
      "text": "なと思います"
    },
    {
      "start": 684.6,
      "duration": 4.0,
      "text": "がうん"
    },
    {
      "start": 689.399,
      "duration": 4.841,
      "text": "は同じ3月3日っていうとこで一応"
    },
    {
      "start": 697.079,
      "duration": 5.241,
      "text": "は"
    },
    {
      "start": 698.839,
      "duration": 7.961,
      "text": "はいよろしいですか先ほどの文書"
    },
    {
      "start": 702.32,
      "duration": 10.519,
      "text": "ではいにこりますかよろしいですか先ほど"
    },
    {
      "start": 706.8,
      "duration": 6.039,
      "text": "のではいはいでそのよう"
    },
    {
      "start": 714.2,
      "duration": 7.879,
      "text": "にっとこのような形でちょっとあのご協議"
    },
    {
      "start": 717.519,
      "duration": 8.361,
      "text": "いただいたんですが一応まえっと今までは"
    },
    {
      "start": 722.079,
      "duration": 5.841,
      "text": "その中期という形では議案について聞させ"
    },
    {
      "start": 725.88,
      "duration": 5.68,
      "text": "ていただいたんですけど今回ちょっとま"
    },
    {
      "start": 727.92,
      "duration": 5.76,
      "text": "イレギュラーな対応ということでこまた"
    },
    {
      "start": 731.56,
      "duration": 5.639,
      "text": "あの今回についてはこういうような対応"
    },
    {
      "start": 733.68,
      "duration": 5.2,
      "text": "するということで皆さんお含ではい前例と"
    },
    {
      "start": 737.199,
      "duration": 4.801,
      "text": "しないということでお含みおきいただけれ"
    },
    {
      "start": 738.88,
      "duration": 4.639,
      "text": "ばとはいはい事務局としては思いますです"
    },
    {
      "start": 742.0,
      "duration": 3.639,
      "text": "はいま"
    },
    {
      "start": 743.519,
      "duration": 6.521,
      "text": "あ"
    },
    {
      "start": 745.639,
      "duration": 4.401,
      "text": "はいはいま"
    },
    {
      "start": 754.24,
      "duration": 5.52,
      "text": "今後ははい今後はねてるんでこの形でやり"
    },
    {
      "start": 758.88,
      "duration": 2.72,
      "text": "ますはい"
    },
    {
      "start": 759.76,
      "duration": 5.4,
      "text": "はいはい"
    },
    {
      "start": 761.6,
      "duration": 7.76,
      "text": "まの対応はこうこれ限りということで"
    },
    {
      "start": 765.16,
      "duration": 6.6,
      "text": "ございましてはいなけれ従来のやり方に"
    },
    {
      "start": 769.36,
      "duration": 5.12,
      "text": "戻るでそれをもし変えるんであればまた"
    },
    {
      "start": 771.76,
      "duration": 7.759,
      "text": "機械改革でご"
    },
    {
      "start": 774.48,
      "duration": 7.52,
      "text": "いはいはい山長あはいえっとこれはこれで"
    },
    {
      "start": 779.519,
      "duration": 5.521,
      "text": "いいと思うんですけれどもそのまあの学者"
    },
    {
      "start": 782.0,
      "duration": 4.68,
      "text": "の方にねどう知らすかというところについ"
    },
    {
      "start": 785.04,
      "duration": 5.359,
      "text": "てはこれ事務局からということになるん"
    },
    {
      "start": 786.68,
      "duration": 7.159,
      "text": "でしょうかはいそれはなかなか事務局から"
    },
    {
      "start": 790.399,
      "duration": 6.081,
      "text": "難しいというところがあり議長というのも"
    },
    {
      "start": 793.839,
      "duration": 5.68,
      "text": "かなとところもあるのでまちょっと酒井"
    },
    {
      "start": 796.48,
      "duration": 4.64,
      "text": "議員にご協力をいただいてえお伝え"
    },
    {
      "start": 799.519,
      "duration": 4.601,
      "text": "いただくのがいかがかなと思うんです"
    },
    {
      "start": 801.12,
      "duration": 8.719,
      "text": "けれどもいかがです"
    },
    {
      "start": 804.12,
      "duration": 5.719,
      "text": "かあ視聴部局取ってるんですかね"
    },
    {
      "start": 810.639,
      "duration": 4.32,
      "text": "市長部局"
    },
    {
      "start": 812.04,
      "duration": 5.919,
      "text": "からでも議会のことですもん"
    },
    {
      "start": 814.959,
      "duration": 3.0,
      "text": "ね"
    },
    {
      "start": 819.56,
      "duration": 7.44,
      "text": "うんはいみま議会でこう決めたのでって"
    },
    {
      "start": 824.399,
      "duration": 6.44,
      "text": "いうのを視聴部局げるありなのかなと思っ"
    },
    {
      "start": 827.0,
      "duration": 10.48,
      "text": "たんですけど交渉自体"
    },
    {
      "start": 830.839,
      "duration": 10.281,
      "text": "ははいふはいえっと私も部局から職して"
    },
    {
      "start": 837.48,
      "duration": 5.96,
      "text": "いただくのが1番素直なところだと思理由"
    },
    {
      "start": 841.12,
      "duration": 4.519,
      "text": "としては報告書の作成にも関わっ"
    },
    {
      "start": 843.44,
      "duration": 6.199,
      "text": "てらっしゃる部分もあるかとも思いますの"
    },
    {
      "start": 845.639,
      "duration": 6.2,
      "text": "でそでそのまあの作戦にかかった方たちの"
    },
    {
      "start": 849.639,
      "duration": 3.88,
      "text": "方から連絡していただくのが一番いいかと"
    },
    {
      "start": 851.839,
      "duration": 7.44,
      "text": "思い"
    },
    {
      "start": 853.519,
      "duration": 8.44,
      "text": "ますはい水やっぱり議会ので議会のこの"
    },
    {
      "start": 859.279,
      "duration": 5.081,
      "text": "ルールに乗ってこういう形にしたっていう"
    },
    {
      "start": 861.959,
      "duration": 5.081,
      "text": "ことになってのでこれはちょっと視聴部局"
    },
    {
      "start": 864.36,
      "duration": 6.08,
      "text": "から伝えてもらうっていう形にはなり"
    },
    {
      "start": 867.04,
      "duration": 5.599,
      "text": "づらいと思うですねさっきあのそのあの"
    },
    {
      "start": 870.44,
      "duration": 6.079,
      "text": "市民の意見を聞くルールがあるからそれ"
    },
    {
      "start": 872.639,
      "duration": 6.601,
      "text": "でって話したんが今日でも僕らね議会"
    },
    {
      "start": 876.519,
      "duration": 6.961,
      "text": "終わっちゃうのでそのルールやってと"
    },
    {
      "start": 879.24,
      "duration": 9.399,
      "text": "ちょっとそのねあのちょっと馴染まないか"
    },
    {
      "start": 883.48,
      "duration": 8.76,
      "text": "な感じるのであのもうあの酒井さんが直接"
    },
    {
      "start": 888.639,
      "duration": 6.721,
      "text": "あの連絡の窓口になってたりするのでで"
    },
    {
      "start": 892.24,
      "duration": 6.279,
      "text": "酒井さんから情報提供で議会局に来たわけ"
    },
    {
      "start": 895.36,
      "duration": 4.32,
      "text": "ですよそうそうそうであと市長にも最終的"
    },
    {
      "start": 898.519,
      "duration": 3.68,
      "text": "にうん"
    },
    {
      "start": 899.68,
      "duration": 5.92,
      "text": "に事務局から渡ったって形になったのかな"
    },
    {
      "start": 902.199,
      "duration": 5.44,
      "text": "そうだからそういう形になってるのであの"
    },
    {
      "start": 905.6,
      "duration": 5.359,
      "text": "この結果についてはちょっと伝えてもら"
    },
    {
      "start": 907.639,
      "duration": 6.241,
      "text": "うっていうようなことにしたらかなって"
    },
    {
      "start": 910.959,
      "duration": 5.401,
      "text": "いう風に思い本当は議会からなので議長"
    },
    {
      "start": 913.88,
      "duration": 6.44,
      "text": "から伝えてもらうっていうのが筋ろうとは"
    },
    {
      "start": 916.36,
      "duration": 6.08,
      "text": "思うんですがあのその方が何ていうか現実"
    },
    {
      "start": 920.32,
      "duration": 5.439,
      "text": "的かっていうな感じはするありがとう"
    },
    {
      "start": 922.44,
      "duration": 5.759,
      "text": "ございますはい今元々経緯としてあの直接"
    },
    {
      "start": 925.759,
      "duration": 3.831,
      "text": "本人無にお持ちになられたということでは"
    },
    {
      "start": 928.199,
      "duration": 4.501,
      "text": "ないということ"
    },
    {
      "start": 929.59,
      "duration": 3.11,
      "text": "[音楽]"
    },
    {
      "start": 936.279,
      "duration": 9.641,
      "text": "はいじゃなくても調ではいまだからその"
    },
    {
      "start": 941.24,
      "duration": 8.2,
      "text": "ルー元ねあの酒議員経由であの皆さんの方"
    },
    {
      "start": 945.92,
      "duration": 5.96,
      "text": "手元にあの意見があ書類が配られたという"
    },
    {
      "start": 949.44,
      "duration": 5.319,
      "text": "ことでございますのでまそのルートで戻し"
    },
    {
      "start": 951.88,
      "duration": 8.959,
      "text": "ていたということでいかがでございますか"
    },
    {
      "start": 954.759,
      "duration": 8.88,
      "text": "とあただはい副長はいただあのえっとなぜ"
    },
    {
      "start": 960.839,
      "duration": 5.321,
      "text": "こう削除できないかっていうことはや議会"
    },
    {
      "start": 963.639,
      "duration": 6.361,
      "text": "事務局でないと説明ができないところが"
    },
    {
      "start": 966.16,
      "duration": 7.479,
      "text": "あるのでま酒井さんにその連絡先を聞いて"
    },
    {
      "start": 970.0,
      "duration": 8.319,
      "text": "連絡できるかどうかのちょっと調整をして"
    },
    {
      "start": 973.639,
      "duration": 9.64,
      "text": "いただいて議会局からあのやっぱり正式に"
    },
    {
      "start": 978.319,
      "duration": 4.96,
      "text": "あのりかけた方がいいかなと思います"
    },
    {
      "start": 986.6,
      "duration": 6.28,
      "text": "はいはい"
    },
    {
      "start": 989.399,
      "duration": 7.081,
      "text": "地はよろしいですかそういう形でもご相談"
    },
    {
      "start": 992.88,
      "duration": 6.68,
      "text": "してはい休憩して憩しじゃあ協議会を休憩"
    },
    {
      "start": 996.48,
      "duration": 3.08,
      "text": "します"
    },
    {
      "start": 1049.84,
      "duration": 9.64,
      "text": "はいはいはいあそれでそのだからあの連絡"
    },
    {
      "start": 1055.559,
      "duration": 8.36,
      "text": "していただいてあのまた何かもし問題が"
    },
    {
      "start": 1059.48,
      "duration": 7.68,
      "text": "あるとすればまたあのこちらあですかま4"
    },
    {
      "start": 1063.919,
      "duration": 5.481,
      "text": "者なのか何か知らの形で伝えていただいて"
    },
    {
      "start": 1067.16,
      "duration": 4.44,
      "text": "ま協議する必要があるということになるの"
    },
    {
      "start": 1069.4,
      "duration": 4.44,
      "text": "かなという風には思うところなんです"
    },
    {
      "start": 1071.6,
      "duration": 5.319,
      "text": "けれどもまこれでうまくいけばいいです"
    },
    {
      "start": 1073.84,
      "duration": 4.48,
      "text": "けどはいまあのそういうことで結果につい"
    },
    {
      "start": 1076.919,
      "duration": 3.921,
      "text": "てちょっとやっぱりお知らせいただければ"
    },
    {
      "start": 1078.32,
      "duration": 2.52,
      "text": "なと思い"
    },
    {
      "start": 1083.72,
      "duration": 8.839,
      "text": "はい今回の件はま先ほどの文書等について"
    },
    {
      "start": 1088.6,
      "duration": 7.68,
      "text": "ですねあのま議員からあご本人にあのご"
    },
    {
      "start": 1092.559,
      "duration": 6.48,
      "text": "確認をいただいてえそれでれば事務局の方"
    },
    {
      "start": 1096.28,
      "duration": 4.68,
      "text": "からご連絡をしてご説明申し上げるとお"
    },
    {
      "start": 1099.039,
      "duration": 5.241,
      "text": "いうことでえ皆さんしていたよろしいです"
    },
    {
      "start": 1100.96,
      "duration": 6.64,
      "text": "かはいはいじゃあその今は以上でよろしい"
    },
    {
      "start": 1104.28,
      "duration": 3.32,
      "text": "ですかはい"
    },
    {
      "start": 1110.159,
      "duration": 5.841,
      "text": "はい"
    },
    {
      "start": 1111.76,
      "duration": 6.44,
      "text": "はい皆さん44者だけで大丈夫ですか分に"
    },
    {
      "start": 1116.0,
      "duration": 2.2,
      "text": "です"
    },
    {
      "start": 1119.72,
      "duration": 3.76,
      "text": "ねはい問だければ4者でいいということな"
    },
    {
      "start": 1122.679,
      "duration": 4.081,
      "text": "の"
    },
    {
      "start": 1123.48,
      "duration": 6.0,
      "text": "ではいわかりました"
    },
    {
      "start": 1126.76,
      "duration": 5.6,
      "text": "はいはいということでじゃ対応させて"
    },
    {
      "start": 1129.48,
      "duration": 6.199,
      "text": "いただきますはい他にございますかはい"
    },
    {
      "start": 1132.36,
      "duration": 5.96,
      "text": "すいませんすぐ終わりますえっとこれ僕が"
    },
    {
      "start": 1135.679,
      "duration": 4.841,
      "text": "言うことかなと思いながらお伝します皆"
    },
    {
      "start": 1138.32,
      "duration": 4.16,
      "text": "さんあの市議会のホームページの中で傷"
    },
    {
      "start": 1140.52,
      "duration": 6.159,
      "text": "ページがあったのをお忘れになってるしれ"
    },
    {
      "start": 1142.48,
      "duration": 6.079,
      "text": "ませんもえっと傷ページの中でえっと7つ"
    },
    {
      "start": 1146.679,
      "duration": 5.521,
      "text": "のページがあったんですけどその2つ目の"
    },
    {
      "start": 1148.559,
      "duration": 7.641,
      "text": "ところに議場に会議場に行ってみようって"
    },
    {
      "start": 1152.2,
      "duration": 8.0,
      "text": "いうところがあったですねそれあのコロナ"
    },
    {
      "start": 1156.2,
      "duration": 7.359,
      "text": "の影響があったのでしいてとかあと膨張席"
    },
    {
      "start": 1160.2,
      "duration": 5.359,
      "text": "にあのちょっとまびきされてていただいた"
    },
    {
      "start": 1163.559,
      "duration": 4.041,
      "text": "ところです配慮してますっていう風に出て"
    },
    {
      "start": 1165.559,
      "duration": 5.761,
      "text": "たんですけどももうそれ特にやめており"
    },
    {
      "start": 1167.6,
      "duration": 5.64,
      "text": "ますのであの更新ページを更新して現状の"
    },
    {
      "start": 1171.32,
      "duration": 5.479,
      "text": "ところ表すべきじゃないかということで"
    },
    {
      "start": 1173.24,
      "duration": 6.24,
      "text": "それでの方あの差し替えておりますので"
    },
    {
      "start": 1176.799,
      "duration": 6.801,
      "text": "はいということを最近差し替えれましたお"
    },
    {
      "start": 1179.48,
      "duration": 8.079,
      "text": "伝えておきます以上ですはいご対応"
    },
    {
      "start": 1183.6,
      "duration": 6.8,
      "text": "ありがとうございますはい他にございます"
    },
    {
      "start": 1187.559,
      "duration": 6.921,
      "text": "かよろしいですか大丈夫です"
    },
    {
      "start": 1190.4,
      "duration": 5.48,
      "text": "かはい公認最後の委員会でございますけど"
    },
    {
      "start": 1194.48,
      "duration": 6.559,
      "text": "よろしいです"
    },
    {
      "start": 1195.88,
      "duration": 8.52,
      "text": "かはいえれではあ以上でえ議会会からと"
    },
    {
      "start": 1201.039,
      "duration": 7.88,
      "text": "いたしますはい今人誠にお疲れ様でしたお"
    },
    {
      "start": 1204.4,
      "duration": 4.519,
      "text": "世話になりましたありがとうございました"
    }
  ]
}