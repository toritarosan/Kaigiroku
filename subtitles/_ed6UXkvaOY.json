{
  "entries": [
    {
      "start": 10.719,
      "duration": 3.761,
      "text": "はいはい皆さんお疲れ様でございますお"
    },
    {
      "start": 12.92,
      "duration": 3.56,
      "text": "疲れ様ですおそれでございますので"
    },
    {
      "start": 14.48,
      "duration": 4.48,
      "text": "ただいまから議会員会協議会を始めさせて"
    },
    {
      "start": 16.48,
      "duration": 5.24,
      "text": "いただきますお手元の競技事項かこその2"
    },
    {
      "start": 18.96,
      "duration": 5.0,
      "text": "をご覧くださいえ1本日の進行状況の確認"
    },
    {
      "start": 21.72,
      "duration": 4.84,
      "text": "についてと2議会制レビについてまとめて"
    },
    {
      "start": 23.96,
      "duration": 6.239,
      "text": "事務局のお願いします局長はいえそれでは"
    },
    {
      "start": 26.56,
      "duration": 6.92,
      "text": "ですね本日の冒頭の議会運営委員会でえご"
    },
    {
      "start": 30.199,
      "duration": 8.161,
      "text": "確認をいただきましたえ本日のですね進行"
    },
    {
      "start": 33.48,
      "duration": 8.12,
      "text": "予定表のえ案の中におけるえ各ですねえ"
    },
    {
      "start": 38.36,
      "duration": 6.12,
      "text": "委員会等につきましてはえ全てえ終了をし"
    },
    {
      "start": 41.6,
      "duration": 6.639,
      "text": "ております保留案件等はございませんえ"
    },
    {
      "start": 44.48,
      "duration": 5.96,
      "text": "従いまして明日は議会整理日としてえ9会"
    },
    {
      "start": 48.239,
      "duration": 4.64,
      "text": "の日という形でさせていただきたいと思い"
    },
    {
      "start": 50.44,
      "duration": 6.119,
      "text": "ます以上ですはいこの件について何かご"
    },
    {
      "start": 52.879,
      "duration": 6.281,
      "text": "意見ご質疑とございますかはいえそれでは"
    },
    {
      "start": 56.559,
      "duration": 6.16,
      "text": "え1番2番閉じましてその他何かござい"
    },
    {
      "start": 59.16,
      "duration": 6.959,
      "text": "ますでしょうかはい水えっとさっきの視聴"
    },
    {
      "start": 62.719,
      "duration": 6.361,
      "text": "報告の撤回の関係で要するに市議会ホーム"
    },
    {
      "start": 66.119,
      "duration": 5.521,
      "text": "ページに載ってる視聴報告の取り扱いに"
    },
    {
      "start": 69.08,
      "duration": 5.56,
      "text": "ついて何らか是正して欲しいって話もあっ"
    },
    {
      "start": 71.64,
      "duration": 5.76,
      "text": "てこれちょっとどう対応するのかっていう"
    },
    {
      "start": 74.64,
      "duration": 5.6,
      "text": "のはちょっと議会でねあの決めてもらいた"
    },
    {
      "start": 77.4,
      "duration": 6.2,
      "text": "いって話だったのでだからこれについやり"
    },
    {
      "start": 80.24,
      "duration": 6.48,
      "text": "方はほら基本的にいくつかあると思うんで"
    },
    {
      "start": 83.6,
      "duration": 5.519,
      "text": "制服でちょっと案作ってもらってっていう"
    },
    {
      "start": 86.72,
      "duration": 5.16,
      "text": "風にした方がなんかスムーズに進むんじゃ"
    },
    {
      "start": 89.119,
      "duration": 5.481,
      "text": "ないかなと思ってですけど例えばホーム"
    },
    {
      "start": 91.88,
      "duration": 5.599,
      "text": "ページに載ってるものにその訂正記事を"
    },
    {
      "start": 94.6,
      "duration": 6.0,
      "text": "つつけるとかねそのまま全部なくすって"
    },
    {
      "start": 97.479,
      "duration": 7.881,
      "text": "わけにもいかないのかどうかねそんなのも"
    },
    {
      "start": 100.6,
      "duration": 7.119,
      "text": "あるあ制服議長長そうなんかどっかで"
    },
    {
      "start": 105.36,
      "duration": 5.28,
      "text": "ちょっとある程度やり方はあると思う"
    },
    {
      "start": 107.719,
      "duration": 6.921,
      "text": "決まってると思うんであのこういうこと"
    },
    {
      "start": 110.64,
      "duration": 6.0,
      "text": "でって形で案を出してもらってそれで確認"
    },
    {
      "start": 114.64,
      "duration": 4.6,
      "text": "できればいいなとは思うんですけどどう"
    },
    {
      "start": 116.64,
      "duration": 6.96,
      "text": "でしょうかなんか答えられるあります務局"
    },
    {
      "start": 119.24,
      "duration": 7.12,
      "text": "はいはい今まではですねはいえっと特に"
    },
    {
      "start": 123.6,
      "duration": 5.639,
      "text": "そのもの自体をあの下ろしてしまうとか"
    },
    {
      "start": 126.36,
      "duration": 5.879,
      "text": "いう取り扱いはしてないんですけどあの"
    },
    {
      "start": 129.239,
      "duration": 6.841,
      "text": "ホームページにその議案のえタブがあり"
    },
    {
      "start": 132.239,
      "duration": 6.521,
      "text": "ましてその下に中期でまこの件については"
    },
    {
      "start": 136.08,
      "duration": 5.159,
      "text": "この部分が訂正されましたとか差し替えさ"
    },
    {
      "start": 138.76,
      "duration": 4.72,
      "text": "れましたとかそういった中期の記載は"
    },
    {
      "start": 141.239,
      "duration": 6.561,
      "text": "ございますのでそういった対応がま例とし"
    },
    {
      "start": 143.48,
      "duration": 4.32,
      "text": "てちょっと考えられるのかなと思います"
    },
    {
      "start": 148.48,
      "duration": 7.759,
      "text": "はいはいはい水上委員まだからそういう形"
    },
    {
      "start": 152.64,
      "duration": 7.04,
      "text": "で対応するってこで全体が一致できれば"
    },
    {
      "start": 156.239,
      "duration": 6.801,
      "text": "いいのかなと思うのでだから何らかその"
    },
    {
      "start": 159.68,
      "duration": 6.44,
      "text": "文言も含めてなんかあのちょっと考えて"
    },
    {
      "start": 163.04,
      "duration": 9.8,
      "text": "いただいてご提案いただければなと思い"
    },
    {
      "start": 166.12,
      "duration": 9.72,
      "text": "ます会派ってことになるんですかねそれ義"
    },
    {
      "start": 172.84,
      "duration": 3.0,
      "text": "義"
    },
    {
      "start": 177.28,
      "duration": 6.319,
      "text": "はいになりますはいはい"
    },
    {
      "start": 181.28,
      "duration": 5.72,
      "text": "じゃあちえて"
    },
    {
      "start": 183.599,
      "duration": 7.0,
      "text": "もらどうするどうし"
    },
    {
      "start": 187.0,
      "duration": 7.84,
      "text": "ますお願いしますって皆さんていうことで"
    },
    {
      "start": 190.599,
      "duration": 9.841,
      "text": "あればじゃあそれで一応受けといてで"
    },
    {
      "start": 194.84,
      "duration": 5.6,
      "text": "すマイクけあ入ってですねあのあれ"
    },
    {
      "start": 200.92,
      "duration": 9.879,
      "text": "ば了解はい他にございますかはいかそどう"
    },
    {
      "start": 207.48,
      "duration": 5.44,
      "text": "する言っといた方がいいどうすることなっ"
    },
    {
      "start": 210.799,
      "duration": 2.121,
      "text": "た"
    },
    {
      "start": 228.28,
      "duration": 7.76,
      "text": "かえああはいはいはいはいはい全体の合意"
    },
    {
      "start": 232.439,
      "duration": 5.841,
      "text": "がはいいのいやまだだからあ作ってから"
    },
    {
      "start": 236.04,
      "duration": 5.119,
      "text": "作ってからでしょ作ってからでしょって"
    },
    {
      "start": 238.28,
      "duration": 3.84,
      "text": "から作ってくれことじゃそれを受けたいう"
    },
    {
      "start": 241.159,
      "duration": 3.28,
      "text": "ことをま"
    },
    {
      "start": 242.12,
      "duration": 4.52,
      "text": "一応ちょっと考えてみますっていうのを"
    },
    {
      "start": 244.439,
      "duration": 5.241,
      "text": "議長"
    },
    {
      "start": 246.64,
      "duration": 7.28,
      "text": "からはいで先ほど水上委のご提案に対して"
    },
    {
      "start": 249.68,
      "duration": 5.399,
      "text": "じゃ長お願いしますはい座ってあ協はいえ"
    },
    {
      "start": 253.92,
      "duration": 5.12,
      "text": "それじゃあの"
    },
    {
      "start": 255.079,
      "duration": 7.321,
      "text": "制服長でえとあの案を作ってみたいと思い"
    },
    {
      "start": 259.04,
      "duration": 7.24,
      "text": "ますはいはいありがとうございますはい"
    },
    {
      "start": 262.4,
      "duration": 6.2,
      "text": "はい他にございますかはいよろしいですか"
    },
    {
      "start": 266.28,
      "duration": 6.56,
      "text": "はいそれでは以上でえ議会会協議会参加"
    },
    {
      "start": 268.6,
      "duration": 4.24,
      "text": "いたしますお疲れ様でございましあ"
    }
  ]
}