      "start": 1429.0,
      "duration": 6.76,
      "text": "でねまよく四面会革部会で進め話は進め"
    },
    {
      "start": 1432.559,
      "duration": 3.201,
      "text": "といていただければなと思い"
    },
    {
      "start": 1436.0,
      "duration": 5.6,
      "text": "ますはい水谷さんはいあの先ほど座長も"
    },
    {
      "start": 1440.039,
      "duration": 4.801,
      "text": "まとめていただいたようにどうしても同じ"
    },
    {
      "start": 1441.6,
      "duration": 5.72,
      "text": "サイズで市から届く印刷物で片方が"
    },
    {
      "start": 1444.84,
      "duration": 5.079,
      "text": "リニューアルするとこちらが目つっていう"
    },
    {
      "start": 1447.32,
      "duration": 5.88,
      "text": "真のあの市民の方が注目してくださったの"
    },
    {
      "start": 1449.919,
      "duration": 6.64,
      "text": "は良かったなと思っていますであのこれ"
    },
    {
      "start": 1453.2,
      "duration": 6.44,
      "text": "から先ほど斎藤さんのご提案のあったやつ"
    },
    {
      "start": 1456.559,
      "duration": 5.881,
      "text": "は是非あの進めていただきたいなと思って"
    },
    {
      "start": 1459.64,
      "duration": 5.24,
      "text": "あの臨事号だからこそ余計にあのちょっと"
    },
    {
      "start": 1462.44,
      "duration": 5.04,
      "text": "チャレンジもしやすいかなと毎回の分を"
    },
    {
      "start": 1464.88,
      "duration": 5.44,
      "text": "変えるとなると一般質問がこうこれだけの"
    },
    {
      "start": 1467.48,
      "duration": 5.919,
      "text": "分量あるしとかもうすく身がボリがあるの"
    },
    {
      "start": 1470.32,
      "duration": 6.64,
      "text": "で大変ですけど是非あの進めていいてで"
    },
    {
      "start": 1473.399,
      "duration": 5.801,
      "text": "回線後速やかにあの作ってなるべく早く"
    },
    {
      "start": 1476.96,
      "duration": 4.04,
      "text": "市民の皆様のところにお届けできたらいい"
    },
    {
      "start": 1479.2,
      "duration": 4.16,
      "text": "のではないかなと思うので是非よろしくお"
    },
    {
      "start": 1481.0,
      "duration": 5.24,
      "text": "願いしますはいありがとうございますま"
    },
    {
      "start": 1483.36,
      "duration": 4.559,
      "text": "今度この黒飯議会のねこんな感じのえもの"
    },
    {
      "start": 1486.24,
      "duration": 4.52,
      "text": "もちょっと色々やってみようかってことで"
    },
    {
      "start": 1487.919,
      "duration": 4.801,
      "text": "かなり大胆な話になるのかなと思うのでま"
    },
    {
      "start": 1490.76,
      "duration": 4.88,
      "text": "そこら辺の文字の大きさとか縦書き横書き"
    },
    {
      "start": 1492.72,
      "duration": 5.079,
      "text": "の話もまよく市改革部会の方でですねあの"
    },
    {
      "start": 1495.64,
      "duration": 4.399,
      "text": "ちょっと臨時合だということも含めてあの"
    },
    {
      "start": 1497.799,
      "duration": 5.561,
      "text": "思いきりてチャレンジしてみていただき"
    },
    {
      "start": 1500.039,
      "duration": 6.081,
      "text": "たいとま申し上げておこうかなと思い"
    },
    {
      "start": 1503.36,
      "duration": 6.039,
      "text": "ますあとこの件に関しては皆さんよろしく"
    },
    {
      "start": 1506.12,
      "duration": 6.36,
      "text": "ございましょうかよろしいですねはいじゃ"
    },
    {
      "start": 1509.399,
      "duration": 5.481,
      "text": "それではえっとえ括弧1の議会法編集部会"
    },
    {
      "start": 1512.48,
      "duration": 6.88,
      "text": "について終わります次に括弧2次回の開催"
    },
    {
      "start": 1514.88,
      "duration": 8.08,
      "text": "についてはえっと9月のということで24"
    },
    {
      "start": 1519.36,
      "duration": 6.439,
      "text": "日の予備日の候補協議会ということになる"
    },
    {
      "start": 1522.96,
      "duration": 6.24,
      "text": "かなという風に思いますのでよろしくお"
    },
    {
      "start": 1525.799,
      "duration": 5.48,
      "text": "願いいたします次に3のそのですがその他"
    },
    {
      "start": 1529.2,
      "duration": 5.16,
      "text": "について皆様から何かございはいこさん"
    },
    {
      "start": 1531.279,
      "duration": 5.441,
      "text": "どうぞすいません部会の報告で1点報告が"
    },
    {
      "start": 1534.36,
      "duration": 6.199,
      "text": "漏れてたんですけどもえよろしいでしょう"
    },
    {
      "start": 1536.72,
      "duration": 7.439,
      "text": "かあの個人写真を集合写真に変える件なん"
    },
    {
      "start": 1540.559,
      "duration": 6.921,
      "text": "ですがえっと個人写真を取るということが"
    },
    {
      "start": 1544.159,
      "duration": 5.721,
      "text": "あの申し合わせ事項に入っているという"
    },
    {
      "start": 1547.48,
      "duration": 5.84,
      "text": "ことなのであのそういう形で進んでいった"
    },
    {
      "start": 1549.88,
      "duration": 5.48,
      "text": "場合にはですねそこもあの見直しを並行し"
    },
    {
      "start": 1553.32,
      "duration": 5.28,
      "text": "てかけていただくということをご承知をき"
    },
    {
      "start": 1555.36,
      "duration": 7.52,
      "text": "いただければと思いますが何か補足あれば"
    },
    {
      "start": 1558.6,
      "duration": 4.28,
      "text": "あります事務的にはいはい事務"
    },
    {
      "start": 1562.919,
      "duration": 6.561,
      "text": "局はいえっと事務局ですえっと一応ですね"
    },
    {
      "start": 1566.76,
      "duration": 7.08,
      "text": "市議会ハンドブックの令和5年度版105"
    },
    {
      "start": 1569.48,
      "duration": 7.4,
      "text": "ページの14番ですね議員回線に伴う記念"
    },
    {
      "start": 1573.84,
      "duration": 5.559,
      "text": "品類写真撮影についてというところであの"
    },
    {
      "start": 1576.88,
      "duration": 4.799,
      "text": "個人写真の撮影を行うものとするという"
    },
    {
      "start": 1579.399,
      "duration": 4.201,
      "text": "記載がございますのであの取らないという"
    },
    {
      "start": 1581.679,
      "duration": 3.88,
      "text": "ことにするのであればちょっと議会運以会"
    },
    {
      "start": 1583.6,
      "duration": 3.76,
      "text": "その申し合わせを変えていただく必要が"
    },
    {
      "start": 1585.559,
      "duration": 3.961,
      "text": "あの小林議員がおっしゃっていた通りある"
    },
    {
      "start": 1587.36,
      "duration": 5.64,
      "text": "かと思いますのでよろしくお願いいたし"
    },
    {
      "start": 1589.52,
      "duration": 5.72,
      "text": "ます以上ですはいということであの個人"
    },
    {
      "start": 1593.0,
      "duration": 4.44,
      "text": "写真ではなくてそのま集合写真とかいう"
    },
    {
      "start": 1595.24,
      "duration": 5.319,
      "text": "ことになるとそこのあの申し合わせに関し"
    },
    {
      "start": 1597.44,
      "duration": 5.52,
      "text": "てはあのあの見直しを会派代表者会議に"
    },
    {
      "start": 1600.559,
      "duration": 5.641,
      "text": "提起してお願いしておく必要があり"
    },
    {
      "start": 1602.96,
      "duration": 4.64,
      "text": "ましょうね多分ねそれはでもいつの会派で"
    },
    {
      "start": 1606.2,
      "duration": 2.479,
      "text": "やればいいのかな今日じゃなくてもいいよ"
    },
    {
      "start": 1607.6,
      "duration": 5.92,
      "text": "ね別に"
    },
    {
      "start": 1608.679,
      "duration": 6.441,
      "text": "ねでもね大丈夫ですねのじゃその個人写真"
    },
    {
      "start": 1613.52,
      "duration": 3.279,
      "text": "をやめてその集合写真に切り替え"
    },
    {
      "start": 1615.12,
      "duration": 4.4,
      "text": "るっていうのは今日合意取れてるって理解"
    },
    {
      "start": 1616.799,
      "duration": 6.401,
      "text": "でいいんですよねいはいなのでじゃそれに"
    },
    {
      "start": 1619.52,
      "duration": 8.0,
      "text": "大丈夫ですかはいどうぞいやちょっとそれ"
    },
    {
      "start": 1623.2,
      "duration": 8.0,
      "text": "はまだ可能性のはえななんだ"
    },
    {
      "start": 1627.52,
      "duration": 6.08,
      "text": "えとまだちょっと会派に告確認してないの"
    },
    {
      "start": 1631.2,
      "duration": 4.64,
      "text": "でそれはすいませんはいあ分かりました"
    },
    {
      "start": 1633.6,
      "duration": 4.52,
      "text": "じゃあ一応その件はごめんなさいはいじゃ"
    },
    {
      "start": 1635.84,
      "duration": 4.079,
      "text": "その件はあの確認していただい要するに"
    },
    {
      "start": 1638.12,
      "duration": 5.159,
      "text": "あの個人写真をこれまで撮っていたものを"
    },
    {
      "start": 1639.919,
      "duration": 5.081,
      "text": "やめてその分の撮影費などを集合写真とこ"
    },
    {
      "start": 1643.279,
      "duration": 4.321,
      "text": "に振り替えるっていうことなのでちょっと"
    },
    {
      "start": 1645.0,
      "duration": 4.559,
      "text": "まじゃあ持ち帰っていただいてあのご検討"
    },
    {
      "start": 1647.6,
      "duration": 4.48,
      "text": "いただければと思いますということで"
    },
    {
      "start": 1649.559,
      "duration": 4.961,
      "text": "よろしいねでそのえっと共産党さんから"
    },
    {
      "start": 1652.08,
      "duration": 6.079,
      "text": "またその持ち帰った結果聞いてあのえっと"
    },
    {
      "start": 1654.52,
      "duration": 5.24,
      "text": "まあのしかるべくあの必要な措置は取って"
    },
    {
      "start": 1658.159,
      "duration": 4.041,
      "text": "いこうかなと思いますのでよろしくお願い"
    },
    {
      "start": 1659.76,
      "duration": 4.56,
      "text": "いたしますえその他で皆さんから何か"
    },
    {
      "start": 1662.2,
      "duration": 3.88,
      "text": "ございはい酒さんどうぞはいえっと私が"
    },
    {
      "start": 1664.32,
      "duration": 2.76,
      "text": "ちょっと出演していたら申し訳ないんです"
    },
    {
      "start": 1666.08,
      "duration": 5.439,
      "text": "が"
    },
    {
      "start": 1667.08,
      "duration": 6.76,
      "text": "えっと8面を決めるための会議って日程"
    },
    {
      "start": 1671.519,
      "duration": 5.04,
      "text": "って決まってたんでしたっけ毎回そまだ"
    },
    {
      "start": 1673.84,
      "duration": 4.92,
      "text": "決めてなかったねこれからだっけ"
    },
    {
      "start": 1676.559,
      "duration": 5.161,
      "text": "なんかにれ"
    },
    {
      "start": 1678.76,
      "duration": 5.44,
      "text": "を入れておいた方がいいのかな8面につい"
    },
    {
      "start": 1681.72,
      "duration": 5.72,
      "text": "てねどっかで日て今のうちにここで決め"
    },
    {
      "start": 1684.2,
      "duration": 5.92,
      "text": "ちゃおうかみんないるから面会議の日程"
    },
    {
      "start": 1687.44,
      "duration": 2.68,
      "text": "決めちゃいましょうか"
    },
    {
      "start": 1692.159,
      "duration": 4.841,
      "text": "じゃあ決めてなかったと思うね"
    },
    {
      "start": 1700.08,
      "duration": 4.4,
      "text": "確かあれはどっちなだ議会法編集部会って"
    },
    {
      "start": 1703.519,
      "duration": 5.0,
      "text": "んだっ"
    },
    {
      "start": 1704.48,
      "duration": 7.679,
      "text": "けそうだよねじゃ議会法編集部をですね"
    },
    {
      "start": 1708.519,
      "duration": 7.201,
      "text": "どこかに入れたいと思うのですが前半の本"
    },
    {
      "start": 1712.159,
      "duration": 3.561,
      "text": "会議のなるべく早い方がいいんだよ"
    },
    {
      "start": 1715.96,
      "duration": 8.439,
      "text": "ねあん明日で上程終わる可能性あんのあ"
    },
    {
      "start": 1721.2,
      "duration": 8.04,
      "text": "あるあるああるよね十分ねじゃあ4日に来"
    },
    {
      "start": 1724.399,
      "duration": 7.201,
      "text": "てもらうの悪いから日の3日の終了後に短"
    },
    {
      "start": 1729.24,
      "duration": 4.799,
      "text": "時間でできるかなじゃあ3日の終了後に"
    },
    {
      "start": 1731.6,
      "duration": 7.0,
      "text": "やりましょうかじゃすいませんじゃあ明日"
    },
    {
      "start": 1734.039,
      "duration": 7.12,
      "text": "ですね3日えっと終了後にえっと"
    },
    {
      "start": 1738.6,
      "duration": 4.959,
      "text": "面会議やりますのでよろしくお願いいたし"
    },
    {
      "start": 1741.159,
      "duration": 4.64,
      "text": "ますあ議会法編集部会ということでやり"
    },
    {
      "start": 1743.559,
      "duration": 4.801,
      "text": "ますはいあ酒井さんお気づきいただいて"
    },
    {
      "start": 1745.799,
      "duration": 6.961,
      "text": "ありがとうございましたあはございます"
    },
    {
      "start": 1748.36,
      "duration": 7.24,
      "text": "でしょうか大丈夫でしょうかはいでそれで"
    },
    {
      "start": 1752.76,
      "duration": 6.24,
      "text": "はその他終わります事務局からと何か"
    },
    {
      "start": 1755.6,
      "duration": 5.64,
      "text": "ございますか特にないですねはいはいで"
    },
    {
      "start": 1759.0,
      "duration": 5.519,
      "text": "それでは以上で広報協議会の会議を終了"
    },
    {
      "start": 1761.24,
      "duration": 3.279,
      "text": "いたしますお疲れ様でございまし"
    },
    {
      "start": 1767.039,
      "duration": 4.041,
      "text": "たOG"
    }
  ]
}