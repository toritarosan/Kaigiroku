{
  "entries": [
    {
      "start": 106.51,
      "duration": 1.85,
      "text": "[音楽]"
    },
    {
      "start": 106.93,
      "duration": 6.189,
      "text": "[拍手]"
    },
    {
      "start": 108.36,
      "duration": 10.56,
      "text": "そましたね多体性も大丈夫なんですよ"
    },
    {
      "start": 113.119,
      "duration": 5.801,
      "text": "ね中座られましたらますか"
    },
    {
      "start": 122.6,
      "duration": 4.439,
      "text": "はいえっとそれで皆さんおはようござい"
    },
    {
      "start": 124.32,
      "duration": 4.76,
      "text": "ますおはようございますえっと時間1分も"
    },
    {
      "start": 127.039,
      "duration": 4.801,
      "text": "ありますけど皆さんお揃いのようですので"
    },
    {
      "start": 129.08,
      "duration": 5.239,
      "text": "始めさせていただいてよろしいでしょうか"
    },
    {
      "start": 131.84,
      "duration": 4.56,
      "text": "ありがとうございますえそれではまずえ"
    },
    {
      "start": 134.319,
      "duration": 4.361,
      "text": "委員会の進行予定について確認をさせて"
    },
    {
      "start": 136.4,
      "duration": 4.44,
      "text": "いただきます本日の委員会審査予定表の"
    },
    {
      "start": 138.68,
      "duration": 6.12,
      "text": "通り審査行うことについてとありますが"
    },
    {
      "start": 140.84,
      "duration": 6.399,
      "text": "審査案件は所管事務調査の公益政策の課題"
    },
    {
      "start": 144.8,
      "duration": 4.159,
      "text": "についてその一件でございますあすいませ"
    },
    {
      "start": 147.239,
      "duration": 3.161,
      "text": "ん今これ冒頭の協議会に入っております"
    },
    {
      "start": 148.959,
      "duration": 3.481,
      "text": "よろしくお願いいたします"
    },
    {
      "start": 150.4,
      "duration": 4.919,
      "text": "それで委員会の進行予定について確認です"
    },
    {
      "start": 152.44,
      "duration": 5.92,
      "text": "けれども長管事務調査保育政策の課題に"
    },
    {
      "start": 155.319,
      "duration": 5.92,
      "text": "つきましては9月12日前回の厚生文教"
    },
    {
      "start": 158.36,
      "duration": 5.68,
      "text": "委員会で片山委員の1問目の質疑に対する"
    },
    {
      "start": 161.239,
      "duration": 5.681,
      "text": "答弁が保留となっておりますえなお片山"
    },
    {
      "start": 164.04,
      "duration": 5.72,
      "text": "委員以外の主質問は終了しておりますので"
    },
    {
      "start": 166.92,
      "duration": 5.88,
      "text": "本日は片山委員の質疑のみを行うことと"
    },
    {
      "start": 169.76,
      "duration": 5.0,
      "text": "なっておりますがよろしいでしょうかはい"
    },
    {
      "start": 172.8,
      "duration": 5.519,
      "text": "ありがとうございますそれでは委員会に"
    },
    {
      "start": 174.76,
      "duration": 3.559,
      "text": "入ってまいります"
    },
    {
      "start": 181.92,
      "duration": 4.84,
      "text": "おはようございますおはようございます"
    },
    {
      "start": 184.0,
      "duration": 6.239,
      "text": "ただいまから厚生文教委員会の会議を開き"
    },
    {
      "start": 186.76,
      "duration": 6.119,
      "text": "ます直に本日の議事に入ります当委員会に"
    },
    {
      "start": 190.239,
      "duration": 4.0,
      "text": "え付託されております案件は所管事務調査"
    },
    {
      "start": 192.879,
      "duration": 4.401,
      "text": "1件です"
    },
    {
      "start": 194.239,
      "duration": 6.08,
      "text": "以上1件につきましては厚生文教委員会"
    },
    {
      "start": 197.28,
      "duration": 6.319,
      "text": "審査予定表の予定審査予定表の通りを行う"
    },
    {
      "start": 200.319,
      "duration": 5.56,
      "text": "ことといたします直に所管事務調査保育"
    },
    {
      "start": 203.599,
      "duration": 5.681,
      "text": "政策の課題についてを議題といたします"
    },
    {
      "start": 205.879,
      "duration": 4.681,
      "text": "前回片山委員の1問目の出現の答弁が保留"
    },
    {
      "start": 209.28,
      "duration": 5.4,
      "text": "となっており"
    },
    {
      "start": 210.56,
      "duration": 8.319,
      "text": "局の答弁を求めます担当課長です保育政策"
    },
    {
      "start": 214.68,
      "duration": 4.199,
      "text": "え保育政策調整担当"
    },
    {
      "start": 219.04,
      "duration": 5.119,
      "text": "課長"
    },
    {
      "start": 220.72,
      "duration": 5.0,
      "text": "あはいあすいませんえ前回の委員会以降お"
    },
    {
      "start": 224.159,
      "duration": 4.521,
      "text": "時間をいただきまして誠にありがとう"
    },
    {
      "start": 225.72,
      "duration": 5.4,
      "text": "ございますえこの間議事振興に対する答弁"
    },
    {
      "start": 228.68,
      "duration": 5.919,
      "text": "調整をさせていただきましたのでえ答弁を"
    },
    {
      "start": 231.12,
      "duration": 6.72,
      "text": "させていただきますえまず始めにえ法律"
    },
    {
      "start": 234.599,
      "duration": 6.56,
      "text": "意見書についてえ法的根拠を持って反論"
    },
    {
      "start": 237.84,
      "duration": 6.08,
      "text": "するかに対する答弁ですえ今回提出されて"
    },
    {
      "start": 241.159,
      "duration": 6.0,
      "text": "いる法律意見書につきまして貴重なご意見"
    },
    {
      "start": 243.92,
      "duration": 6.12,
      "text": "として受け止めさせていただきますえ続き"
    },
    {
      "start": 247.159,
      "duration": 5.561,
      "text": "ましてえ大の施設の利用について平等利用"
    },
    {
      "start": 250.04,
      "duration": 5.839,
      "text": "権をどう考えているかに対する答弁で"
    },
    {
      "start": 252.72,
      "duration": 5.919,
      "text": "ございますえ地方自治法に基づきえ住民の"
    },
    {
      "start": 255.879,
      "duration": 5.88,
      "text": "権利であるえ平等利用権があると考えてい"
    },
    {
      "start": 258.639,
      "duration": 6.041,
      "text": "ますがえ市といたしましてはえ判決や条例"
    },
    {
      "start": 261.759,
      "duration": 5.801,
      "text": "に基づきえ必要と考えられる対応を取って"
    },
    {
      "start": 264.68,
      "duration": 5.88,
      "text": "いるところでございますえ続きましてえ"
    },
    {
      "start": 267.56,
      "duration": 6.6,
      "text": "人権救済申し当てが出されているがえして"
    },
    {
      "start": 270.56,
      "duration": 6.32,
      "text": "しての見解を求めるに対する答弁ですえ"
    },
    {
      "start": 274.16,
      "duration": 5.96,
      "text": "人権救済申し立てがえ出されたことにつき"
    },
    {
      "start": 276.88,
      "duration": 5.96,
      "text": "まして重くえ受け止めておりますえまた"
    },
    {
      "start": 280.12,
      "duration": 5.44,
      "text": "人権救済の申し立ての進捗状況につきまし"
    },
    {
      "start": 282.84,
      "duration": 6.799,
      "text": "てはえ今後も注視していきたいと考えて"
    },
    {
      "start": 285.56,
      "duration": 7.16,
      "text": "おりますえ続きましてえ人権救済申し立て"
    },
    {
      "start": 289.639,
      "duration": 7.201,
      "text": "や法律意見書を提出されたことでえそれら"
    },
    {
      "start": 292.72,
      "duration": 6.96,
      "text": "を根拠にえ判決の解釈を見直しえ直に今の"
    },
    {
      "start": 296.84,
      "duration": 6.359,
      "text": "え対応を是正すべきではないかに対すると"
    },
    {
      "start": 299.68,
      "duration": 8.0,
      "text": "答弁ですえ現在の条例に基づき来年度の"
    },
    {
      "start": 303.199,
      "duration": 7.681,
      "text": "募集は桜保育園及び栗のみ保育園の0歳時"
    },
    {
      "start": 307.68,
      "duration": 6.28,
      "text": "1歳時及び2歳時の募集は行わないことと"
    },
    {
      "start": 310.88,
      "duration": 6.84,
      "text": "なりますえ募集を開始するためには条例"
    },
    {
      "start": 313.96,
      "duration": 8.239,
      "text": "改正が必要であると考えておりますえ続き"
    },
    {
      "start": 317.72,
      "duration": 7.36,
      "text": "ましてえ人権救済申しが出されえ警告が"
    },
    {
      "start": 322.199,
      "duration": 6.12,
      "text": "出された場合はどうするのかに対する答弁"
    },
    {
      "start": 325.08,
      "duration": 6.88,
      "text": "ですえ警告が出された場合の対応について"
    },
    {
      "start": 328.319,
      "duration": 6.681,
      "text": "ですがえ現時点では告の内容が分からずえ"
    },
    {
      "start": 331.96,
      "duration": 6.32,
      "text": "の話となりますので答弁はえ控えさせて"
    },
    {
      "start": 335.0,
      "duration": 6.479,
      "text": "いただきますえなお警告等の措置がえ出さ"
    },
    {
      "start": 338.28,
      "duration": 5.72,
      "text": "れた場合は他の措置が出された案件を参考"
    },
    {
      "start": 341.479,
      "duration": 5.321,
      "text": "にしながら適切に対応していきたいと考え"
    },
    {
      "start": 344.0,
      "duration": 6.639,
      "text": "ております答弁の方は以上でございます"
    },
    {
      "start": 346.8,
      "duration": 8.239,
      "text": "はい片山さん2問目どうぞはいえっとです"
    },
    {
      "start": 350.639,
      "duration": 7.961,
      "text": "ねあのまこの今え答弁いたいたものに対し"
    },
    {
      "start": 355.039,
      "duration": 5.88,
      "text": "てはですねま一般質問の時からえ同じよう"
    },
    {
      "start": 358.6,
      "duration": 6.719,
      "text": "な質問をして調整をしていたわけなんです"
    },
    {
      "start": 360.919,
      "duration": 7.321,
      "text": "がまあのきちんとしたえ答弁としての私が"
    },
    {
      "start": 365.319,
      "duration": 5.16,
      "text": "ですねあの聞きしている質疑に対しての"
    },
    {
      "start": 368.24,
      "duration": 4.76,
      "text": "それに対応するような答弁がなかったなと"
    },
    {
      "start": 370.479,
      "duration": 5.081,
      "text": "いう風に思っておりましたのであの改めて"
    },
    {
      "start": 373.0,
      "duration": 6.0,
      "text": "厚生文教委会でもお聞きしたところであり"
    },
    {
      "start": 375.56,
      "duration": 7.24,
      "text": "ますでま今あのえお聞きした答弁としてま"
    },
    {
      "start": 379.0,
      "duration": 5.36,
      "text": "部局としての見解はまそこえでですね限界"
    },
    {
      "start": 382.8,
      "duration": 4.08,
      "text": "なのかなという風には考えてるんです"
    },
    {
      "start": 384.36,
      "duration": 5.279,
      "text": "けれどもただですねやっぱりこれはあの"
    },
    {
      "start": 386.88,
      "duration": 4.719,
      "text": "もう政治的判断としてま市長はどう考える"
    },
    {
      "start": 389.639,
      "duration": 5.4,
      "text": "かということになってくるかと私は思って"
    },
    {
      "start": 391.599,
      "duration": 5.72,
      "text": "おりますま市長としてはですねえ今あのお"
    },
    {
      "start": 395.039,
      "duration": 4.801,
      "text": "聞きしたようなことに対してどのような"
    },
    {
      "start": 397.319,
      "duration": 5.081,
      "text": "考えを持ってるのかということについて"
    },
    {
      "start": 399.84,
      "duration": 5.759,
      "text": "そしてまたこの法的根拠についてどのよう"
    },
    {
      "start": 402.4,
      "duration": 5.359,
      "text": "にして示していくのかということをですね"
    },
    {
      "start": 405.599,
      "duration": 5.44,
      "text": "ご説明いただきたいと思っておりますま"
    },
    {
      "start": 407.759,
      "duration": 6.641,
      "text": "法律意見書またあの人権救済申したに対し"
    },
    {
      "start": 411.039,
      "duration": 6.961,
      "text": "てですねこちらについてのま市長のあの"
    },
    {
      "start": 414.4,
      "duration": 5.68,
      "text": "判断としてえ何を根拠にえどのような判断"
    },
    {
      "start": 418.0,
      "duration": 3.879,
      "text": "をしていくのかということをもきちんと"
    },
    {
      "start": 420.08,
      "duration": 4.2,
      "text": "説明していただけないでしょう"
    },
    {
      "start": 421.879,
      "duration": 5.561,
      "text": "かはい"
    },
    {
      "start": 424.28,
      "duration": 4.96,
      "text": "市長まずあの人権救済申し立てが出された"
    },
    {
      "start": 427.44,
      "duration": 4.479,
      "text": "ことについてはあの一般質問のところでも"
    },
    {
      "start": 429.24,
      "duration": 4.959,
      "text": "答弁をいたしましたがあのこれも重くえ"
    },
    {
      "start": 431.919,
      "duration": 4.12,
      "text": "浮き止めざるを得ないという答弁をさせて"
    },
    {
      "start": 434.199,
      "duration": 4.56,
      "text": "いただきましたあのそれは変わりはあり"
    },
    {
      "start": 436.039,
      "duration": 5.201,
      "text": "ませんでえその他諸々えっと加山さんの方"
    },
    {
      "start": 438.759,
      "duration": 4.321,
      "text": "から改めて私に質問いただいた件に関し"
    },
    {
      "start": 441.24,
      "duration": 4.239,
      "text": "ましてはあの課長が答弁した通りでござい"
    },
    {
      "start": 443.08,
      "duration": 2.399,
      "text": "ます以上"
    },
    {
      "start": 447.96,
      "duration": 6.679,
      "text": "ですはいはい片山さんどうぞはいちょっと"
    },
    {
      "start": 451.8,
      "duration": 6.2,
      "text": "あの市長のですね今あの課長が答弁した"
    },
    {
      "start": 454.639,
      "duration": 7.921,
      "text": "通りというようなあの答弁なんですけれど"
    },
    {
      "start": 458.0,
      "duration": 8.72,
      "text": "もやっぱり市長がですねえどういったあの"
    },
    {
      "start": 462.56,
      "duration": 8.12,
      "text": "ま課長としてはえ政治的判断ではなくって"
    },
    {
      "start": 466.72,
      "duration": 6.599,
      "text": "ま部局としてあのえ今回答できる範囲での"
    },
    {
      "start": 470.68,
      "duration": 5.359,
      "text": "ことだということなんですね私はあの市長"
    },
    {
      "start": 473.319,
      "duration": 5.801,
      "text": "は政治的判断としてはどう考えるのかと"
    },
    {
      "start": 476.039,
      "duration": 7.201,
      "text": "いうのを聞いておりますこれあの法律意見"
    },
    {
      "start": 479.12,
      "duration": 7.039,
      "text": "書新しい法律権証が出されそしてま保護者"
    },
    {
      "start": 483.24,
      "duration": 5.2,
      "text": "からこの人権救済の申し立てというですね"
    },
    {
      "start": 486.159,
      "duration": 4.801,
      "text": "このようなあのことが行れたということを"
    },
    {
      "start": 488.44,
      "duration": 5.56,
      "text": "重く受け止めるんであればやっぱりこの"
    },
    {
      "start": 490.96,
      "duration": 5.56,
      "text": "市長としてできることをですね政治的判断"
    },
    {
      "start": 494.0,
      "duration": 5.759,
      "text": "としてやらなきゃいけないと思うわけです"
    },
    {
      "start": 496.52,
      "duration": 6.359,
      "text": "市長としては市長戦の公約では肺炎を撤回"
    },
    {
      "start": 499.759,
      "duration": 5.201,
      "text": "するということが公約でしたであればそれ"
    },
    {
      "start": 502.879,
      "duration": 5.121,
      "text": "をどうやって実現するのかということに"
    },
    {
      "start": 504.96,
      "duration": 5.88,
      "text": "なるかと思いますそちらについてですね"
    },
    {
      "start": 508.0,
      "duration": 4.719,
      "text": "どのような形であの公約を実現していくの"
    },
    {
      "start": 510.84,
      "duration": 5.24,
      "text": "かということにかかってくるかと思います"
    },
    {
      "start": 512.719,
      "duration": 5.76,
      "text": "のであのきちんとしたですねえ市長として"
    },
    {
      "start": 516.08,
      "duration": 4.8,
      "text": "の政治的判断としての答弁をいただきたい"
    },
    {
      "start": 518.479,
      "duration": 4.841,
      "text": "と思いますま課長が答弁した通りという"
    },
    {
      "start": 520.88,
      "duration": 6.24,
      "text": "ことにはならないと私は思っております"
    },
    {
      "start": 523.32,
      "duration": 7.84,
      "text": "課長としては今部局の答弁としましては"
    },
    {
      "start": 527.12,
      "duration": 7.76,
      "text": "ですねこの市長あの市としてはま"
    },
    {
      "start": 531.16,
      "duration": 6.44,
      "text": "えこの判決や条例に基づき必要と考える"
    },
    {
      "start": 534.88,
      "duration": 4.92,
      "text": "対応を行っているというようなことで美"
    },
    {
      "start": 537.6,
      "duration": 5.2,
      "text": "通り要件に対しての答弁をあのしており"
    },
    {
      "start": 539.8,
      "duration": 5.76,
      "text": "ますけれどもそれはだから一体どういう"
    },
    {
      "start": 542.8,
      "duration": 6.159,
      "text": "ことかと思うわけですね判決や条例に"
    },
    {
      "start": 545.56,
      "duration": 7.64,
      "text": "基づい条例に基づくというんであれば判決"
    },
    {
      "start": 548.959,
      "duration": 6.841,
      "text": "では先決処分は違法で肺炎条例は向こうと"
    },
    {
      "start": 553.2,
      "duration": 6.199,
      "text": "いう判断がされているわけですからである"
    },
    {
      "start": 555.8,
      "duration": 7.12,
      "text": "のであれば基づく条例としては元の保育園"
    },
    {
      "start": 559.399,
      "duration": 7.041,
      "text": "条例になると私は考えますしかしそうでは"
    },
    {
      "start": 562.92,
      "duration": 6.52,
      "text": "なく今ですねあの肺炎が続いてるわけです"
    },
    {
      "start": 566.44,
      "duration": 5.639,
      "text": "よね段階的縮小による肺炎が続いてるわけ"
    },
    {
      "start": 569.44,
      "duration": 6.24,
      "text": "ですからちらについて市長としてはこの"
    },
    {
      "start": 572.079,
      "duration": 6.601,
      "text": "平等利用点を保障するためにえどのような"
    },
    {
      "start": 575.68,
      "duration": 5.96,
      "text": "ことをですね公約に従って行っていくのか"
    },
    {
      "start": 578.68,
      "duration": 6.32,
      "text": "という政治的判断をお聞きしたいという風"
    },
    {
      "start": 581.64,
      "duration": 6.56,
      "text": "に何回も申し上げてるわけですですので"
    },
    {
      "start": 585.0,
      "duration": 5.16,
      "text": "市長の考え方を確認したいと思っており"
    },
    {
      "start": 588.2,
      "duration": 5.0,
      "text": "ますはい"
    },
    {
      "start": 590.16,
      "duration": 4.72,
      "text": "市長まずあの公約の話がありましたがあの"
    },
    {
      "start": 593.2,
      "duration": 4.36,
      "text": "これも繰り返し申し上げておりますがあの"
    },
    {
      "start": 594.88,
      "duration": 5.44,
      "text": "私が市長なってあのすぐの12月定例会で"
    },
    {
      "start": 597.56,
      "duration": 5.0,
      "text": "えこのえ肺炎条例を廃す条例を私は提案を"
    },
    {
      "start": 600.32,
      "duration": 4.88,
      "text": "させていただきましたまこれは議会であの"
    },
    {
      "start": 602.56,
      "duration": 5.88,
      "text": "秘訣となったことからえま肺炎が進んでき"
    },
    {
      "start": 605.2,
      "duration": 5.319,
      "text": "た通りでございますでえっと繰り返しあの"
    },
    {
      "start": 608.44,
      "duration": 4.2,
      "text": "市長の答弁を求められておりますがあの"
    },
    {
      "start": 610.519,
      "duration": 4.281,
      "text": "確かに課長が答弁したのはあのま課長が"
    },
    {
      "start": 612.64,
      "duration": 4.08,
      "text": "答弁したんですけどえっとこの答弁に"
    },
    {
      "start": 614.8,
      "duration": 4.4,
      "text": "あたってはですねあの当然打ち合わせを"
    },
    {
      "start": 616.72,
      "duration": 4.84,
      "text": "やって人としての考え方を今あの示してる"
    },
    {
      "start": 619.2,
      "duration": 5.48,
      "text": "わけでございますので私が改めて別の答弁"
    },
    {
      "start": 621.56,
      "duration": 3.12,
      "text": "をすることにはなりません以上"
    },
    {
      "start": 626.0,
      "duration": 7.079,
      "text": "ですって"
    },
    {
      "start": 629.72,
      "duration": 8.0,
      "text": "はいでは以上で本件に対する現時点での"
    },
    {
      "start": 633.079,
      "duration": 4.641,
      "text": "質疑を終了することにご異議ありません"
    },
    {
      "start": 638.12,
      "duration": 5.12,
      "text": "かはいご異議なしと認め本件に対する現"
    },
    {
      "start": 641.2,
      "duration": 4.48,
      "text": "時点の質疑を終了いたしますお諮りいたし"
    },
    {
      "start": 643.24,
      "duration": 5.32,
      "text": "ます本件は引き続き調査する必要があると"
    },
    {
      "start": 645.68,
      "duration": 5.839,
      "text": "認め継続調査といしたいと思いますこれに"
    },
    {
      "start": 648.56,
      "duration": 5.56,
      "text": "ご異議ありませんかご異議なしと認め本件"
    },
    {
      "start": 651.519,
      "duration": 5.361,
      "text": "は継続調査と決定いたしました以上で本日"
    },
    {
      "start": 654.12,
      "duration": 5.159,
      "text": "の日程は全部終了いたしました本日は以上"
    },
    {
      "start": 656.88,
      "duration": 5.68,
      "text": "で厚生文委員会を閉いたしますお疲れ様"
    },
    {
      "start": 659.279,
      "duration": 3.281,
      "text": "でした"
    }
  ]
}