{
  "entries": [
    {
      "start": 103.159,
      "duration": 3.0,
      "text": "あ"
    },
    {
      "start": 183.28,
      "duration": 4.36,
      "text": "はい皆さんお疲れ様でございますえ帝国で"
    },
    {
      "start": 185.56,
      "duration": 3.959,
      "text": "ございますね議会運営委員会協議会を始め"
    },
    {
      "start": 187.64,
      "duration": 4.72,
      "text": "さていただきますお手元の協議事項をご覧"
    },
    {
      "start": 189.519,
      "duration": 5.28,
      "text": "くださいえ新参権議長の諮問事項1件で"
    },
    {
      "start": 192.36,
      "duration": 5.36,
      "text": "ございますえ議会名に関する議長の諮問"
    },
    {
      "start": 194.799,
      "duration": 5.761,
      "text": "事項についてえかこ1え小金市議会議員の"
    },
    {
      "start": 197.72,
      "duration": 5.239,
      "text": "政治理に関する条例第5条の弁名申し書の"
    },
    {
      "start": 200.56,
      "duration": 4.959,
      "text": "取り扱いについてでございますかこ2議員"
    },
    {
      "start": 202.959,
      "duration": 4.92,
      "text": "提出議案の取り扱いについてでございます"
    },
    {
      "start": 205.519,
      "duration": 5.321,
      "text": "さかこ3その他で何かあればお願いを"
    },
    {
      "start": 207.879,
      "duration": 4.72,
      "text": "いたしますでえまずがあ委員長報告後の"
    },
    {
      "start": 210.84,
      "duration": 3.92,
      "text": "討論採決にて伺ってもりますが進行につい"
    },
    {
      "start": 212.599,
      "duration": 5.2,
      "text": "てはこれでよろしいですかはいはいそれで"
    },
    {
      "start": 214.76,
      "duration": 6.199,
      "text": "はえっと委員長報告後の討論採決について"
    },
    {
      "start": 217.799,
      "duration": 7.041,
      "text": "え順次伺ってまいりますが1括でよろしい"
    },
    {
      "start": 220.959,
      "duration": 7.401,
      "text": "ですかはいあの討論採決がある"
    },
    {
      "start": 224.84,
      "duration": 3.52,
      "text": "会派確認して"
    },
    {
      "start": 228.56,
      "duration": 3.0,
      "text": "ない"
    },
    {
      "start": 235.439,
      "duration": 4.761,
      "text": "討論はい休憩します"
    },
    {
      "start": 282.84,
      "duration": 4.799,
      "text": "はい再開いたしますそれではあの順次"
    },
    {
      "start": 285.08,
      "duration": 6.48,
      "text": "やはり伺ってまいりますえ自由民主と信頼"
    },
    {
      "start": 287.639,
      "duration": 6.321,
      "text": "の小金さんどの採決ございますかないはい"
    },
    {
      "start": 291.56,
      "duration": 7.0,
      "text": "未来の小金もございませんそれでは子供の"
    },
    {
      "start": 293.96,
      "duration": 6.44,
      "text": "金利守るかさんはいえっと議案32号にえ"
    },
    {
      "start": 298.56,
      "duration": 5.52,
      "text": "賛成討論"
    },
    {
      "start": 300.4,
      "duration": 7.88,
      "text": "安32賛成片山さんはいありがとうござい"
    },
    {
      "start": 304.08,
      "duration": 9.44,
      "text": "ますじゃ次日本共産党さんはいえっとまず"
    },
    {
      "start": 308.28,
      "duration": 9.919,
      "text": "あの新城え7号え賛成討論森戸ですはい7"
    },
    {
      "start": 313.52,
      "duration": 8.48,
      "text": "号森戸さんはいであとえっと議案第32号"
    },
    {
      "start": 318.199,
      "duration": 10.241,
      "text": "一般会計補正予算賛成討論水上ですはい"
    },
    {
      "start": 322.0,
      "duration": 9.36,
      "text": "水上さはいさんそれでは議案第32号賛"
    },
    {
      "start": 328.44,
      "duration": 7.4,
      "text": "討論渡"
    },
    {
      "start": 331.36,
      "duration": 8.8,
      "text": "はいはい小金面白くする解さはい議案32"
    },
    {
      "start": 335.84,
      "duration": 6.88,
      "text": "号一般会計補正予さんに賛成討論水谷です"
    },
    {
      "start": 340.16,
      "duration": 6.72,
      "text": "はいそれでは単独会派を含めてネットさん"
    },
    {
      "start": 342.72,
      "duration": 7.72,
      "text": "お願いしますはいえ単独会派は討論あり"
    },
    {
      "start": 346.88,
      "duration": 8.8,
      "text": "ません以上ですネットさんもなしはいはい"
    },
    {
      "start": 350.44,
      "duration": 9.16,
      "text": "それではそれでは討論はえ城7号が森さん"
    },
    {
      "start": 355.68,
      "duration": 6.16,
      "text": "と議案32号が片山さん水神さん渡辺さん"
    },
    {
      "start": 359.6,
      "duration": 6.08,
      "text": "谷さんの4件計5件ということで"
    },
    {
      "start": 361.84,
      "duration": 6.199,
      "text": "よろしかったでしょうかはいはいでは入っ"
    },
    {
      "start": 365.68,
      "duration": 2.359,
      "text": "てまいり"
    },
    {
      "start": 368.56,
      "duration": 4.44,
      "text": "ますただいまから議会運営委員会の会議を"
    },
    {
      "start": 371.16,
      "duration": 3.68,
      "text": "開きます直に議事に入ります当委員会に"
    },
    {
      "start": 373.0,
      "duration": 3.68,
      "text": "付託されております案件は議長の諮問事項"
    },
    {
      "start": 374.84,
      "duration": 3.799,
      "text": "一件であります議会運営に関する議長の"
    },
    {
      "start": 376.68,
      "duration": 4.0,
      "text": "諮問事項についてを議題といたします議長"
    },
    {
      "start": 378.639,
      "duration": 3.921,
      "text": "からお手元に議会運営委員会協議事項が"
    },
    {
      "start": 380.68,
      "duration": 3.68,
      "text": "提示されておりますのでその順序に従って"
    },
    {
      "start": 382.56,
      "duration": 4.84,
      "text": "順次協議をしてまいりたいと思います初め"
    },
    {
      "start": 384.36,
      "duration": 5.92,
      "text": "に協議事項1小金市会議員の政治倫理に"
    },
    {
      "start": 387.4,
      "duration": 5.199,
      "text": "関する条例第5条の弁名申しの取り扱いに"
    },
    {
      "start": 390.28,
      "duration": 4.0,
      "text": "ついてを行います下問案が示されており"
    },
    {
      "start": 392.599,
      "duration": 5.16,
      "text": "ますので議長から説明お願いいたします"
    },
    {
      "start": 394.28,
      "duration": 7.24,
      "text": "はい事務局から説明いしますはい局長はい"
    },
    {
      "start": 397.759,
      "duration": 6.921,
      "text": "ですはいえ本件につきましては本日の本"
    },
    {
      "start": 401.52,
      "duration": 6.64,
      "text": "会議に定し議題といたしたいというのが"
    },
    {
      "start": 404.68,
      "duration": 6.56,
      "text": "議長の諮問案でございます本件につきまし"
    },
    {
      "start": 408.16,
      "duration": 3.08,
      "text": "てご発言はございます"
    },
    {
      "start": 411.36,
      "duration": 4.959,
      "text": "かよろしいですかはい本件については議長"
    },
    {
      "start": 414.52,
      "duration": 4.32,
      "text": "の指物通り決定することにご異議ありませ"
    },
    {
      "start": 416.319,
      "duration": 5.641,
      "text": "んかなしご異議なしと認めます従って本は"
    },
    {
      "start": 418.84,
      "duration": 5.639,
      "text": "議長の総理決定いたしました次に協議事項"
    },
    {
      "start": 421.96,
      "duration": 4.519,
      "text": "に議員提出議案の取り扱いについてを協議"
    },
    {
      "start": 424.479,
      "duration": 4.321,
      "text": "いたします議長の指案が示されております"
    },
    {
      "start": 426.479,
      "duration": 5.321,
      "text": "ので議長から説明お願いいたします"
    },
    {
      "start": 428.8,
      "duration": 7.519,
      "text": "はい取扱について事務局から説明いたし"
    },
    {
      "start": 431.8,
      "duration": 8.28,
      "text": "ます局長はいえ議員提出議案はお手元にご"
    },
    {
      "start": 436.319,
      "duration": 7.44,
      "text": "配布してあります通り意見書15件決議2"
    },
    {
      "start": 440.08,
      "duration": 7.64,
      "text": "件が提出されております議案第17号から"
    },
    {
      "start": 443.759,
      "duration": 7.761,
      "text": "議案第33号については本日の本会議に定"
    },
    {
      "start": 447.72,
      "duration": 6.199,
      "text": "し説明質疑委員会2区を省略し即決する"
    },
    {
      "start": 451.52,
      "duration": 5.16,
      "text": "こととしたいというのが議長の諮問案で"
    },
    {
      "start": 453.919,
      "duration": 5.28,
      "text": "ございますはい議長及び事務局の説明は"
    },
    {
      "start": 456.68,
      "duration": 6.48,
      "text": "終わりましたご意見ご質疑等ございますか"
    },
    {
      "start": 459.199,
      "duration": 7.68,
      "text": "はい安田委員はいえっと議員案32号の"
    },
    {
      "start": 463.16,
      "duration": 6.28,
      "text": "決議についてです東小金駅北口外区公園"
    },
    {
      "start": 466.879,
      "duration": 5.121,
      "text": "西側への横断歩道を設置を求める決議で"
    },
    {
      "start": 469.44,
      "duration": 7.0,
      "text": "ありますえっとこの内容についてはですね"
    },
    {
      "start": 472.0,
      "duration": 8.56,
      "text": "あの長年あのああのえっと求めてきたと"
    },
    {
      "start": 476.44,
      "duration": 7.759,
      "text": "いうことがあるということでえ内容につい"
    },
    {
      "start": 480.56,
      "duration": 7.72,
      "text": "てはあの賛成いたしますえしかしながら"
    },
    {
      "start": 484.199,
      "duration": 9.201,
      "text": "このえ個別具体的なというかですねま会派"
    },
    {
      "start": 488.28,
      "duration": 8.44,
      "text": "としての政策提案といったことにあが"
    },
    {
      "start": 493.4,
      "duration": 6.0,
      "text": "ふさわしいような内容かなという風にえ"
    },
    {
      "start": 496.72,
      "duration": 7.56,
      "text": "会派生活者ネットワークとしては考えてい"
    },
    {
      "start": 499.4,
      "duration": 6.88,
      "text": "ますえっとま今後ですねあのこれは決議に"
    },
    {
      "start": 504.28,
      "duration": 4.759,
      "text": "まちょっと馴染まないのではないかという"
    },
    {
      "start": 506.28,
      "duration": 4.52,
      "text": "ような思いを持っておりますまこういった"
    },
    {
      "start": 509.039,
      "duration": 4.041,
      "text": "あの"
    },
    {
      "start": 510.8,
      "duration": 5.239,
      "text": "これまでなかなか動かないからこの決議で"
    },
    {
      "start": 513.08,
      "duration": 4.68,
      "text": "背中をすというそういったま決議なんで"
    },
    {
      "start": 516.039,
      "duration": 4.961,
      "text": "ありますけれどもそういったこともとても"
    },
    {
      "start": 517.76,
      "duration": 6.32,
      "text": "大切なことではありますがえっとこの決議"
    },
    {
      "start": 521.0,
      "duration": 5.519,
      "text": "というものがあの少しあ使いが軽くなって"
    },
    {
      "start": 524.08,
      "duration": 4.72,
      "text": "しまうのではないかという風に懸念を"
    },
    {
      "start": 526.519,
      "duration": 4.88,
      "text": "いたしますえそういったことからえっと"
    },
    {
      "start": 528.8,
      "duration": 6.159,
      "text": "採決態度を決めたいと思います以上です"
    },
    {
      "start": 531.399,
      "duration": 7.041,
      "text": "はいございますかはい小林委員えっと今の"
    },
    {
      "start": 534.959,
      "duration": 6.681,
      "text": "決議出した提案会派として"
    },
    {
      "start": 538.44,
      "duration": 6.399,
      "text": "えっと質問者じゃない安田さんに質問し"
    },
    {
      "start": 541.64,
      "duration": 5.879,
      "text": "たいんですけどもえっとこの決議っって"
    },
    {
      "start": 544.839,
      "duration": 6.961,
      "text": "いうものはそもそもその議会が行う事実の"
    },
    {
      "start": 547.519,
      "duration": 8.32,
      "text": "意思決定行為で意思形成行為で政治的効果"
    },
    {
      "start": 551.8,
      "duration": 6.76,
      "text": "を狙いあるいは議会の意思を対外的に表明"
    },
    {
      "start": 555.839,
      "duration": 5.841,
      "text": "することが必要である等の理由でなされる"
    },
    {
      "start": 558.56,
      "duration": 7.12,
      "text": "議決のことを言うということでえっと決議"
    },
    {
      "start": 561.68,
      "duration": 8.12,
      "text": "のま色々なパターン形式の中に執行機関に"
    },
    {
      "start": 565.68,
      "duration": 6.839,
      "text": "対する要望勧告注意要求などを内容にする"
    },
    {
      "start": 569.8,
      "duration": 7.599,
      "text": "ものというのがま解説本の中にもあるん"
    },
    {
      "start": 572.519,
      "duration": 6.641,
      "text": "ですねで今あの出されたあ決議というのは"
    },
    {
      "start": 577.399,
      "duration": 6.521,
      "text": "もうへ"
    },
    {
      "start": 579.16,
      "duration": 7.96,
      "text": "えっと1618年ですね2018年以来え"
    },
    {
      "start": 583.92,
      "duration": 7.72,
      "text": "議会で繰り返しえ提案をされてきた内容で"
    },
    {
      "start": 587.12,
      "duration": 8.399,
      "text": "ありまたその質疑を経てもですねえ高い派"
    },
    {
      "start": 591.64,
      "duration": 6.72,
      "text": "からのその問題に対するま反対のまご意見"
    },
    {
      "start": 595.519,
      "duration": 6.161,
      "text": "というものはえなくですね利行してる課題"
    },
    {
      "start": 598.36,
      "duration": 7.68,
      "text": "ではないという状況でございましたましか"
    },
    {
      "start": 601.68,
      "duration": 7.2,
      "text": "しながらあ状況が打開しないままあ事実"
    },
    {
      "start": 606.04,
      "duration": 6.44,
      "text": "行為のみが進んできているという現状が"
    },
    {
      "start": 608.88,
      "duration": 7.639,
      "text": "ありましてえそういった中でま今後東小金"
    },
    {
      "start": 612.48,
      "duration": 6.64,
      "text": "北口の外公園などが進んでいく中で今も"
    },
    {
      "start": 616.519,
      "duration": 5.081,
      "text": "なおランオーダーが進まれているところが"
    },
    {
      "start": 619.12,
      "duration": 6.159,
      "text": "あこれ"
    },
    {
      "start": 621.6,
      "duration": 9.16,
      "text": "以上街が完成した時に今の状況が続くと"
    },
    {
      "start": 625.279,
      "duration": 11.56,
      "text": "さらに乱横断が増えていくという中で"
    },
    {
      "start": 630.76,
      "duration": 8.28,
      "text": "え市民の生命を守るためには非常に重要な"
    },
    {
      "start": 636.839,
      "duration": 4.8,
      "text": "内容であるとこのように考えております"
    },
    {
      "start": 639.04,
      "duration": 5.359,
      "text": "そういった意味ではこの決議を出すという"
    },
    {
      "start": 641.639,
      "duration": 7.081,
      "text": "内容には十分に即してるということであり"
    },
    {
      "start": 644.399,
      "duration": 8.361,
      "text": "ますま過去から質問が重ねてくる中でま今"
    },
    {
      "start": 648.72,
      "duration": 7.72,
      "text": "定例会の中ではま一般質問の中でもテーマ"
    },
    {
      "start": 652.76,
      "duration": 7.519,
      "text": "として取り上げられえ当該部局とも"
    },
    {
      "start": 656.44,
      "duration": 6.199,
      "text": "やり取りがなされた内容でもございますえ"
    },
    {
      "start": 660.279,
      "duration": 4.601,
      "text": "常議会を小金心会行っておりませんので"
    },
    {
      "start": 662.639,
      "duration": 5.601,
      "text": "どこかで提案をしなけいけない内容であり"
    },
    {
      "start": 664.88,
      "duration": 5.68,
      "text": "ますまそういった中で今回え提案をさせて"
    },
    {
      "start": 668.24,
      "duration": 6.159,
      "text": "いただくわけでありますがまこういった"
    },
    {
      "start": 670.56,
      "duration": 7.079,
      "text": "ものが決議にそわないというま理由をです"
    },
    {
      "start": 674.399,
      "duration": 5.641,
      "text": "ねえどこにどう書いてあるというところを"
    },
    {
      "start": 677.639,
      "duration": 5.681,
      "text": "明確に示していただいて反論していただき"
    },
    {
      "start": 680.04,
      "duration": 5.84,
      "text": "たいまたここまでの協議の中でま複数回"
    },
    {
      "start": 683.32,
      "duration": 4.4,
      "text": "同じことを繰り返されてるわけですが今回"
    },
    {
      "start": 685.88,
      "duration": 5.68,
      "text": "のような"
    },
    {
      "start": 687.72,
      "duration": 4.6,
      "text": "え政策がもう大きく割れる内容じゃないだ"
    },
    {
      "start": 691.56,
      "duration": 6.16,
      "text": "けど"
    },
    {
      "start": 692.32,
      "duration": 9.319,
      "text": "も議会としての意識を表示するまたえ市"
    },
    {
      "start": 697.72,
      "duration": 6.76,
      "text": "行政当局を後するまこういったものがま"
    },
    {
      "start": 701.639,
      "duration": 5.401,
      "text": "今後乱発されるというようなご意見があっ"
    },
    {
      "start": 704.48,
      "duration": 4.479,
      "text": "たわけですがえ例えばどんなものが乱発さ"
    },
    {
      "start": 707.04,
      "duration": 5.28,
      "text": "れるんですか今のような状況がはまるもの"
    },
    {
      "start": 708.959,
      "duration": 6.601,
      "text": "で私はそういうものが今後あるんであれば"
    },
    {
      "start": 712.32,
      "duration": 6.16,
      "text": "これは是非え議会の意思決定としてま出さ"
    },
    {
      "start": 715.56,
      "duration": 5.36,
      "text": "れていくというようなことが必要ではない"
    },
    {
      "start": 718.48,
      "duration": 4.479,
      "text": "かとま今まで出されている決議や意見書の"
    },
    {
      "start": 720.92,
      "duration": 4.599,
      "text": "中でも議があるものというのはたくさん"
    },
    {
      "start": 722.959,
      "duration": 4.081,
      "text": "あろうかと思いますそういった中でえこの"
    },
    {
      "start": 725.519,
      "duration": 6.44,
      "text": "1点がそこまで"
    },
    {
      "start": 727.04,
      "duration": 6.919,
      "text": "え問題だと言われるんであれば明確なあご"
    },
    {
      "start": 731.959,
      "duration": 5.361,
      "text": "指摘をいただきたいと思い"
    },
    {
      "start": 733.959,
      "duration": 5.601,
      "text": "ますはい安田委員はいえっとですねこの"
    },
    {
      "start": 737.32,
      "duration": 5.24,
      "text": "内容に関してはあの先ほども申し上げた"
    },
    {
      "start": 739.56,
      "duration": 6.88,
      "text": "通りあの対するものでありませんし今の"
    },
    {
      "start": 742.56,
      "duration": 6.16,
      "text": "状況が危険だということでことはあの多く"
    },
    {
      "start": 746.44,
      "duration": 5.28,
      "text": "の意見が出されていたことかと思います"
    },
    {
      "start": 748.72,
      "duration": 5.559,
      "text": "しかしこの定例会の中であの何か質疑が"
    },
    {
      "start": 751.72,
      "duration": 4.6,
      "text": "あったかと言えば特にあの私もあの意見を"
    },
    {
      "start": 754.279,
      "duration": 5.961,
      "text": "申し上げるような場面もありませんでした"
    },
    {
      "start": 756.32,
      "duration": 6.8,
      "text": "しあの議会ではあの渡辺大蔵さんが一般"
    },
    {
      "start": 760.24,
      "duration": 5.88,
      "text": "質問でそういえば取り上げていたなという"
    },
    {
      "start": 763.12,
      "duration": 5.839,
      "text": "ぐらいの認識でありましたのでえ私は個人"
    },
    {
      "start": 766.12,
      "duration": 6.0,
      "text": "的にはこの決議はちょっと少し驚いたと"
    },
    {
      "start": 768.959,
      "duration": 6.801,
      "text": "いうところがありますえっとですねま"
    },
    {
      "start": 772.12,
      "duration": 7.719,
      "text": "えっと重要と考えるえ案件というのは会派"
    },
    {
      "start": 775.76,
      "duration": 7.319,
      "text": "によっても違いますしえっと私もずっとと"
    },
    {
      "start": 779.839,
      "duration": 5.44,
      "text": "あのこれはもっと動かして欲しいといった"
    },
    {
      "start": 783.079,
      "duration": 5.56,
      "text": "ようなことを思っているようなものもあり"
    },
    {
      "start": 785.279,
      "duration": 6.521,
      "text": "ますけれどもじゃあそれをこう決議として"
    },
    {
      "start": 788.639,
      "duration": 6.2,
      "text": "あの議会としてあの示していくのかって"
    },
    {
      "start": 791.8,
      "duration": 6.08,
      "text": "いうことについてはあのちょっとあのそれ"
    },
    {
      "start": 794.839,
      "duration": 7.201,
      "text": "は個別のテーマなのかなっていう風に思っ"
    },
    {
      "start": 797.88,
      "duration": 7.84,
      "text": "ていますでま乱立されるっていうことです"
    },
    {
      "start": 802.04,
      "duration": 7.599,
      "text": "けれどもあのそうですねまあのもちろん"
    },
    {
      "start": 805.72,
      "duration": 5.76,
      "text": "決議として出すってことも重要でえそれが"
    },
    {
      "start": 809.639,
      "duration": 5.88,
      "text": "たくさん出るから良くないということでは"
    },
    {
      "start": 811.48,
      "duration": 8.08,
      "text": "ないとは思うんですけれどもえっとま"
    },
    {
      "start": 815.519,
      "duration": 8.56,
      "text": "例えばまあ皆さんのこの今のであればま"
    },
    {
      "start": 819.56,
      "duration": 7.639,
      "text": "例えばこう北口の武蔵小金駅北口の喫煙所"
    },
    {
      "start": 824.079,
      "duration": 5.2,
      "text": "についてあのもうちょっと抜本的なあの"
    },
    {
      "start": 827.199,
      "duration": 5.361,
      "text": "対策が必要なんじゃないかとかそういった"
    },
    {
      "start": 829.279,
      "duration": 6.841,
      "text": "こともまそれそま例えばですけどもそう"
    },
    {
      "start": 832.56,
      "duration": 5.8,
      "text": "いったことがま議会の中では共通の認識に"
    },
    {
      "start": 836.12,
      "duration": 4.8,
      "text": "はなってるかなと思いますあでもそういう"
    },
    {
      "start": 838.36,
      "duration": 5.279,
      "text": "ことを言い出してもう本当に再現がないん"
    },
    {
      "start": 840.92,
      "duration": 4.24,
      "text": "じゃないかなっていうのが私の問題意識で"
    },
    {
      "start": 843.639,
      "duration": 7.44,
      "text": "あります"
    },
    {
      "start": 845.16,
      "duration": 9.96,
      "text": "はいあはい小林えっと今あの順を追って"
    },
    {
      "start": 851.079,
      "duration": 7.721,
      "text": "ですねもう一度伺います喫煙上東武蔵の"
    },
    {
      "start": 855.12,
      "duration": 5.399,
      "text": "北口の喫煙所についての設置はこれ共通"
    },
    {
      "start": 858.8,
      "duration": 6.719,
      "text": "認識ですか"
    },
    {
      "start": 860.519,
      "duration": 9.201,
      "text": "あのあのそれは全体の総理だとも私は思わ"
    },
    {
      "start": 865.519,
      "duration": 8.88,
      "text": "ないしえっとそもそも"
    },
    {
      "start": 869.72,
      "duration": 7.359,
      "text": "あの行政側も様々なあの当局によっては"
    },
    {
      "start": 874.399,
      "duration": 6.0,
      "text": "違う意見がま出されてきてるものだと思う"
    },
    {
      "start": 877.079,
      "duration": 5.961,
      "text": "のでまそういったものがま出されるという"
    },
    {
      "start": 880.399,
      "duration": 4.921,
      "text": "こと自体もあの否定はしないんですけども"
    },
    {
      "start": 883.04,
      "duration": 5.76,
      "text": "あのそういったことにはま当てはまるのか"
    },
    {
      "start": 885.32,
      "duration": 6.12,
      "text": "どうかなと思いましたで先ほどあの会派の"
    },
    {
      "start": 888.8,
      "duration": 5.64,
      "text": "政策提案だというやり方もしましたけども"
    },
    {
      "start": 891.44,
      "duration": 6.759,
      "text": "ま先ほどは申し上げてるように"
    },
    {
      "start": 894.44,
      "duration": 6.68,
      "text": "えま様々質疑がなされていく中でそれに"
    },
    {
      "start": 898.199,
      "duration": 5.601,
      "text": "対する別の意見というのはま出されてい"
    },
    {
      "start": 901.12,
      "duration": 4.44,
      "text": "なかったし今安田さんもそれは安全な方が"
    },
    {
      "start": 903.8,
      "duration": 5.959,
      "text": "いいねという言われている通りであります"
    },
    {
      "start": 905.56,
      "duration": 6.839,
      "text": "ので単にえ1つの会派があ課題と感じて"
    },
    {
      "start": 909.759,
      "duration": 5.44,
      "text": "出しているものではま当然ないという認識"
    },
    {
      "start": 912.399,
      "duration": 5.961,
      "text": "であろうかと思いますまた"
    },
    {
      "start": 915.199,
      "duration": 5.481,
      "text": "あの一般質問で今回取り上げられた定例会"
    },
    {
      "start": 918.36,
      "duration": 5.36,
      "text": "の中で取り上げられたことがまそういう"
    },
    {
      "start": 920.68,
      "duration": 5.12,
      "text": "質問もあったなって思ういうような記憶が"
    },
    {
      "start": 923.72,
      "duration": 4.76,
      "text": "あるぐらいなことを言われたんですがそれ"
    },
    {
      "start": 925.8,
      "duration": 5.36,
      "text": "は大変に失礼なことで本会議での一般質問"
    },
    {
      "start": 928.48,
      "duration": 4.44,
      "text": "ということでありますのでもう少し丁寧に"
    },
    {
      "start": 931.16,
      "duration": 4.28,
      "text": "おっしゃっていただいたが良かったのでは"
    },
    {
      "start": 932.92,
      "duration": 5.2,
      "text": "ないかなというように思います意見を言う"
    },
    {
      "start": 935.44,
      "duration": 6.0,
      "text": "場がないということ言われたけども当然"
    },
    {
      "start": 938.12,
      "duration": 8.159,
      "text": "この意見書に決議についてはえ討論でき"
    },
    {
      "start": 941.44,
      "duration": 9.12,
      "text": "ますのでえ討論をなされた上でえ丸かバか"
    },
    {
      "start": 946.279,
      "duration": 6.68,
      "text": "明確にえ判断をなされるということがあの"
    },
    {
      "start": 950.56,
      "duration": 4.48,
      "text": "権利としてありますのでお使いいただけれ"
    },
    {
      "start": 952.959,
      "duration": 4.281,
      "text": "ばいいんじゃないかなというようにま思い"
    },
    {
      "start": 955.04,
      "duration": 5.279,
      "text": "ましたのでえ申し上げておきたいと思い"
    },
    {
      "start": 957.24,
      "duration": 5.599,
      "text": "ますま決議解説にある決議のですねルール"
    },
    {
      "start": 960.319,
      "duration": 5.32,
      "text": "にあの即していないということについては"
    },
    {
      "start": 962.839,
      "duration": 4.92,
      "text": "えご説明いただけなかったということだけ"
    },
    {
      "start": 965.639,
      "duration": 2.921,
      "text": "は今分かりましたので発言しておきたいと"
    },
    {
      "start": 967.759,
      "duration": 5.2,
      "text": "思い"
    },
    {
      "start": 968.56,
      "duration": 7.519,
      "text": "ますはい他にございますかはい水上委員ま"
    },
    {
      "start": 972.959,
      "duration": 6.88,
      "text": "今あの発言もあってあの私もあの提案議員"
    },
    {
      "start": 976.079,
      "duration": 5.841,
      "text": "に名前を連ねておりますのであの一言発言"
    },
    {
      "start": 979.839,
      "duration": 5.721,
      "text": "しておきたいと思うんですがま基本的に"
    },
    {
      "start": 981.92,
      "duration": 7.32,
      "text": "あの決議についてはま各配下の実施的な"
    },
    {
      "start": 985.56,
      "duration": 6.88,
      "text": "判断でま提出されるものだと思いますま"
    },
    {
      "start": 989.24,
      "duration": 6.44,
      "text": "内容についてそのえっと例えば誹謗抽象"
    },
    {
      "start": 992.44,
      "duration": 5.8,
      "text": "するものであるとかま社会通年上やっぱり"
    },
    {
      "start": 995.68,
      "duration": 5.719,
      "text": "ちょっと決議としてなじまないっていう風"
    },
    {
      "start": 998.24,
      "duration": 7.32,
      "text": "に判断されるもの以外はですねあの要する"
    },
    {
      "start": 1001.399,
      "duration": 7.281,
      "text": "に各各会派のま自主的な判断のもで提案さ"
    },
    {
      "start": 1005.56,
      "duration": 5.32,
      "text": "れてくるとまいうことについてはあの尊重"
    },
    {
      "start": 1008.68,
      "duration": 6.0,
      "text": "すべきではないかなっていう風に考えてい"
    },
    {
      "start": 1010.88,
      "duration": 6.12,
      "text": "ましてあのそういう提案権まで含めてその"
    },
    {
      "start": 1014.68,
      "duration": 4.76,
      "text": "踏み込んでいくっていう形にはなかなか"
    },
    {
      "start": 1017.0,
      "duration": 4.88,
      "text": "なりづらいと思いますし"
    },
    {
      "start": 1019.44,
      "duration": 4.8,
      "text": "しかも内容についてその基準を定める"
    },
    {
      "start": 1021.88,
      "duration": 5.559,
      "text": "みたいなことはなかなかできないと思うん"
    },
    {
      "start": 1024.24,
      "duration": 5.839,
      "text": "ですねであのそういう点でですね1つは"
    },
    {
      "start": 1027.439,
      "duration": 6.4,
      "text": "やっぱりあの私たちとして考えて"
    },
    {
      "start": 1030.079,
      "duration": 8.201,
      "text": "るっていうことこの東小金駅北口の問題は"
    },
    {
      "start": 1033.839,
      "duration": 7.84,
      "text": "え区画整理が行われてま集計計画が"
    },
    {
      "start": 1038.28,
      "duration": 5.559,
      "text": "街づくり協議会の中で作られてくる中で"
    },
    {
      "start": 1041.679,
      "duration": 5.52,
      "text": "ああいう形になってきてはいると思うん"
    },
    {
      "start": 1043.839,
      "duration": 6.041,
      "text": "ですがその要するに集計計画作る時から"
    },
    {
      "start": 1047.199,
      "duration": 6.641,
      "text": "ですねこの横断歩道どうするんだっていう"
    },
    {
      "start": 1049.88,
      "duration": 6.64,
      "text": "問題は議会からも提案されてきて私もその"
    },
    {
      "start": 1053.84,
      "duration": 5.92,
      "text": "時あのその点に関しては横断ほど作るべき"
    },
    {
      "start": 1056.52,
      "duration": 6.8,
      "text": "だとあのいうことをずっとあの主張してき"
    },
    {
      "start": 1059.76,
      "duration": 6.68,
      "text": "たあの関係があってあのまいろんな議員の"
    },
    {
      "start": 1063.32,
      "duration": 6.8,
      "text": "方からもあの応談報道を作るべきだと今"
    },
    {
      "start": 1066.44,
      "duration": 6.56,
      "text": "事実上そあそこはもう横断歩道はなくても"
    },
    {
      "start": 1070.12,
      "duration": 5.72,
      "text": "人がどんどん通るとまいうような状況に"
    },
    {
      "start": 1073.0,
      "duration": 6.28,
      "text": "なってますのでまそういう形で言うと"
    },
    {
      "start": 1075.84,
      "duration": 8.199,
      "text": "やっぱりあのま決議としてあの提出するっ"
    },
    {
      "start": 1079.28,
      "duration": 8.0,
      "text": "ていうことについてはあのまあの提案者の"
    },
    {
      "start": 1084.039,
      "duration": 6.52,
      "text": "ま意思を尊重するっていう形であの私たち"
    },
    {
      "start": 1087.28,
      "duration": 6.72,
      "text": "も必要なあの手あの内容であるとまいう"
    },
    {
      "start": 1090.559,
      "duration": 6.681,
      "text": "判断をしてま提案議員に名前を一応連ねて"
    },
    {
      "start": 1094.0,
      "duration": 6.48,
      "text": "おりますけれどもだからあのこの決議が"
    },
    {
      "start": 1097.24,
      "duration": 6.679,
      "text": "この中身がどうどどうだとかこうだとかっ"
    },
    {
      "start": 1100.48,
      "duration": 7.079,
      "text": "ていう議論はちょっとやっぱりねあの"
    },
    {
      "start": 1103.919,
      "duration": 6.041,
      "text": "要するにあの議会としてはちょっと馴染ま"
    },
    {
      "start": 1107.559,
      "duration": 4.441,
      "text": "ないのかなっていうようなあの印象は持っ"
    },
    {
      "start": 1109.96,
      "duration": 5.8,
      "text": "てるとまいうことは表明しておきたいと"
    },
    {
      "start": 1112.0,
      "duration": 6.96,
      "text": "思いますはい他にございますかはい"
    },
    {
      "start": 1115.76,
      "duration": 6.0,
      "text": "水谷はい私もあの意見を申し上げさせて"
    },
    {
      "start": 1118.96,
      "duration": 5.36,
      "text": "いただきたいと思いますでこの件のあの"
    },
    {
      "start": 1121.76,
      "duration": 4.56,
      "text": "中身の是非についてのあの議論をしたい"
    },
    {
      "start": 1124.32,
      "duration": 4.16,
      "text": "わけではもちろんありませんしえっと"
    },
    {
      "start": 1126.32,
      "duration": 5.44,
      "text": "2018年からこれまでもあのいろんな"
    },
    {
      "start": 1128.48,
      "duration": 5.679,
      "text": "議員やえ会派からご提案があった案件で"
    },
    {
      "start": 1131.76,
      "duration": 5.279,
      "text": "あるということはあの理解いたしましたで"
    },
    {
      "start": 1134.159,
      "duration": 5.4,
      "text": "ただあの特に反対の意見はなかったという"
    },
    {
      "start": 1137.039,
      "duration": 4.721,
      "text": "ようなあのご発言もあったですけれども"
    },
    {
      "start": 1139.559,
      "duration": 5.0,
      "text": "これに対して何か賛否を求められるような"
    },
    {
      "start": 1141.76,
      "duration": 5.36,
      "text": "場合に私はあの接したことはないので"
    },
    {
      "start": 1144.559,
      "duration": 5.12,
      "text": "えっと反対の意見がなかったということに"
    },
    {
      "start": 1147.12,
      "duration": 4.919,
      "text": "関してはちょっとあの疑問を持っていると"
    },
    {
      "start": 1149.679,
      "duration": 4.601,
      "text": "いうことは申し上げますただあの安全な"
    },
    {
      "start": 1152.039,
      "duration": 4.52,
      "text": "あの交通を確保するべきだということは"
    },
    {
      "start": 1154.28,
      "duration": 4.56,
      "text": "もちろんあの願っておりますのでま内容に"
    },
    {
      "start": 1156.559,
      "duration": 5.281,
      "text": "ついてはあの反対するものではありません"
    },
    {
      "start": 1158.84,
      "duration": 6.199,
      "text": "この件についてはでえっとこれを今回この"
    },
    {
      "start": 1161.84,
      "duration": 6.079,
      "text": "タイミングでその決議という形でですね"
    },
    {
      "start": 1165.039,
      "duration": 5.041,
      "text": "あの提案されたっていうことに対しては私"
    },
    {
      "start": 1167.919,
      "duration": 3.961,
      "text": "も少し違和感がありましたので決議に"
    },
    {
      "start": 1170.08,
      "duration": 4.719,
      "text": "馴染まないのではないかということはあの"
    },
    {
      "start": 1171.88,
      "duration": 4.88,
      "text": "申し上げてきたところですあの表の場では"
    },
    {
      "start": 1174.799,
      "duration": 4.601,
      "text": "なかなかそういう発言をする場合はあり"
    },
    {
      "start": 1176.76,
      "duration": 5.159,
      "text": "ませんでしたけれどもでま決議というのは"
    },
    {
      "start": 1179.4,
      "duration": 6.639,
      "text": "そのもちろん地方自治法に定められており"
    },
    {
      "start": 1181.919,
      "duration": 6.24,
      "text": "ますし内容のあの定義に今回中身があの"
    },
    {
      "start": 1186.039,
      "duration": 4.681,
      "text": "反するものではあのないもちろんそれは"
    },
    {
      "start": 1188.159,
      "duration": 5.201,
      "text": "理解しておりますただこれまで小金市議会"
    },
    {
      "start": 1190.72,
      "duration": 5.16,
      "text": "としてま私が議員になってまだ短い経験で"
    },
    {
      "start": 1193.36,
      "duration": 4.76,
      "text": "はございますがまその中で経験したものの"
    },
    {
      "start": 1195.88,
      "duration": 6.32,
      "text": "中ではちょっと異質のものかなと感じたの"
    },
    {
      "start": 1198.12,
      "duration": 8.6,
      "text": "はあの率直な感想でしたでそれはあの主と"
    },
    {
      "start": 1202.2,
      "duration": 6.719,
      "text": "議会が大きく意見が対立していて議会意を"
    },
    {
      "start": 1206.72,
      "duration": 5.319,
      "text": "団体意思として示す必要があるというよう"
    },
    {
      "start": 1208.919,
      "duration": 5.321,
      "text": "なものだとかあと市に権限があるものに"
    },
    {
      "start": 1212.039,
      "duration": 4.361,
      "text": "ついて議会の意思を大きく示すとかまそう"
    },
    {
      "start": 1214.24,
      "duration": 4.799,
      "text": "いったものであれば決議に馴染むと思った"
    },
    {
      "start": 1216.4,
      "duration": 6.04,
      "text": "んですけれどもま今回は市の担当に確認し"
    },
    {
      "start": 1219.039,
      "duration": 5.481,
      "text": "たところ市としてもあの今設置に向けてえ"
    },
    {
      "start": 1222.44,
      "duration": 7.92,
      "text": "努力をして動いているという風に聞きまし"
    },
    {
      "start": 1224.52,
      "duration": 8.72,
      "text": "たのでまそれしがそのまとま議会の今提案"
    },
    {
      "start": 1230.36,
      "duration": 5.36,
      "text": "してらっしゃるえ方たちと同じ方向に向い"
    },
    {
      "start": 1233.24,
      "duration": 5.04,
      "text": "て努力をしてる最中のものにま決議を出す"
    },
    {
      "start": 1235.72,
      "duration": 4.839,
      "text": "のはちょっと違うのかなと思ったところは"
    },
    {
      "start": 1238.28,
      "duration": 3.84,
      "text": "ございますはいでえっと内容についての"
    },
    {
      "start": 1240.559,
      "duration": 3.521,
      "text": "基準を設けるべきとかそういうことを"
    },
    {
      "start": 1242.12,
      "duration": 4.679,
      "text": "申し上げてるわけではなくもちろんそんな"
    },
    {
      "start": 1244.08,
      "duration": 4.8,
      "text": "基準自体を定めるのはあの難しいと思って"
    },
    {
      "start": 1246.799,
      "duration": 7.481,
      "text": "おりますのでそれも合わせてえ意見として"
    },
    {
      "start": 1248.88,
      "duration": 9.279,
      "text": "申し上げますはい員はいえっと私もこれ"
    },
    {
      "start": 1254.28,
      "duration": 6.04,
      "text": "ですねあの2018年から議会で2018"
    },
    {
      "start": 1258.159,
      "duration": 4.64,
      "text": "年から市民予防教の議員が取りかけてきた"
    },
    {
      "start": 1260.32,
      "duration": 5.239,
      "text": "課題であるとま私もこれ以前建設環境委員"
    },
    {
      "start": 1262.799,
      "duration": 4.88,
      "text": "会に所属していた時にこの該当する区域の"
    },
    {
      "start": 1265.559,
      "duration": 6.561,
      "text": "この横断ほどのことにといて質問などした"
    },
    {
      "start": 1267.679,
      "duration": 8.521,
      "text": "ことがありましたであのま内容とかについ"
    },
    {
      "start": 1272.12,
      "duration": 8.159,
      "text": "まというか端的に申し上げますと1番最初"
    },
    {
      "start": 1276.2,
      "duration": 7.16,
      "text": "に小林さん小林議員がされた発言された"
    },
    {
      "start": 1280.279,
      "duration": 6.52,
      "text": "内容と私とほぼ同じなんですけどもそれで"
    },
    {
      "start": 1283.36,
      "duration": 5.76,
      "text": "あのそれに対するあの安田さんの答えが"
    },
    {
      "start": 1286.799,
      "duration": 4.24,
      "text": "ですねちょっともうちょっと具的しっかり"
    },
    {
      "start": 1289.12,
      "duration": 3.439,
      "text": "したものが欲しかったなというところが"
    },
    {
      "start": 1291.039,
      "duration": 6.161,
      "text": "感想としてございますのでそれだけ"
    },
    {
      "start": 1292.559,
      "duration": 7.761,
      "text": "申し上げとおきますはい小林新"
    },
    {
      "start": 1297.2,
      "duration": 6.44,
      "text": "えっとと今あの水谷さんの発言の中で"
    },
    {
      "start": 1300.32,
      "duration": 6.599,
      "text": "えっと首と方向性が"
    },
    {
      "start": 1303.64,
      "duration": 7.56,
      "text": "え同じ場合には出すものではないという"
    },
    {
      "start": 1306.919,
      "duration": 8.24,
      "text": "ようなご趣旨がありましたまたえ超地法に"
    },
    {
      "start": 1311.2,
      "duration": 5.599,
      "text": "の反したあの決議ではないというお話も"
    },
    {
      "start": 1315.159,
      "duration": 3.88,
      "text": "一方ありました"
    },
    {
      "start": 1316.799,
      "duration": 6.681,
      "text": "えただ"
    },
    {
      "start": 1319.039,
      "duration": 8.401,
      "text": "今この問題はですねその先にさらにえその"
    },
    {
      "start": 1323.48,
      "duration": 7.679,
      "text": "市が働きかけている魚政機関がありまして"
    },
    {
      "start": 1327.44,
      "duration": 5.839,
      "text": "でそこに対してえ長年にわたって市の方も"
    },
    {
      "start": 1331.159,
      "duration": 4.481,
      "text": "対応しているわけだけどもなかなか進ま"
    },
    {
      "start": 1333.279,
      "duration": 5.121,
      "text": "ないというところでま先ほど申し上げた"
    },
    {
      "start": 1335.64,
      "duration": 7.6,
      "text": "ようにこの決議の目的"
    },
    {
      "start": 1338.4,
      "duration": 9.399,
      "text": "を使ってですね議会の意思"
    },
    {
      "start": 1343.24,
      "duration": 8.0,
      "text": "を公表することでえ背中を押そうと市民の"
    },
    {
      "start": 1347.799,
      "duration": 6.76,
      "text": "生命守いこうというやり方でありますま今"
    },
    {
      "start": 1351.24,
      "duration": 6.96,
      "text": "までえやったことがないということであり"
    },
    {
      "start": 1354.559,
      "duration": 7.36,
      "text": "ましたが是非ですねえ事地法を有効に活用"
    },
    {
      "start": 1358.2,
      "duration": 6.92,
      "text": "してですね小市議会の権能をしっかりと"
    },
    {
      "start": 1361.919,
      "duration": 5.681,
      "text": "発揮できてえ市民の利益をしっかり示"
    },
    {
      "start": 1365.12,
      "duration": 4.72,
      "text": "できるような議会運営にしていきたいなと"
    },
    {
      "start": 1367.6,
      "duration": 4.959,
      "text": "いうことを改めて感じたということで"
    },
    {
      "start": 1369.84,
      "duration": 5.92,
      "text": "なかなか私から言う発言ではないんですが"
    },
    {
      "start": 1372.559,
      "duration": 6.0,
      "text": "あの気づかされたということでございます"
    },
    {
      "start": 1375.76,
      "duration": 7.0,
      "text": "よろしくお願いいたします"
    },
    {
      "start": 1378.559,
      "duration": 6.641,
      "text": "ございますかはい片山長はいはいえっと私"
    },
    {
      "start": 1382.76,
      "duration": 4.84,
      "text": "ちょっと会派代表会議出てないんであの"
    },
    {
      "start": 1385.2,
      "duration": 6.079,
      "text": "なんかやたらと盛り上がってたみたいです"
    },
    {
      "start": 1387.6,
      "duration": 6.4,
      "text": "けれどもあのここでだからえっと内容にと"
    },
    {
      "start": 1391.279,
      "duration": 6.321,
      "text": "いうかというかですね決議意見書に対して"
    },
    {
      "start": 1394.0,
      "duration": 5.679,
      "text": "はあの本会議でも質疑できますよねこれ"
    },
    {
      "start": 1397.6,
      "duration": 4.679,
      "text": "あのえっとルールとしてはあると思って"
    },
    {
      "start": 1399.679,
      "duration": 6.321,
      "text": "おりますだから中身に対しての何かしら"
    },
    {
      "start": 1402.279,
      "duration": 7.161,
      "text": "ですね議があるとかあのがあるんであれば"
    },
    {
      "start": 1406.0,
      "duration": 5.799,
      "text": "え質疑という形でえ正していくということ"
    },
    {
      "start": 1409.44,
      "duration": 5.28,
      "text": "はできるかなという風に考えておりますで"
    },
    {
      "start": 1411.799,
      "duration": 5.24,
      "text": "あのまこの場は議会運営会なのであの"
    },
    {
      "start": 1414.72,
      "duration": 4.48,
      "text": "ちょっとその中身の話じゃないと思ってい"
    },
    {
      "start": 1417.039,
      "duration": 5.361,
      "text": "てまこの"
    },
    {
      "start": 1419.2,
      "duration": 4.959,
      "text": "えそて決議として馴染むか馴染まないかと"
    },
    {
      "start": 1422.4,
      "duration": 4.6,
      "text": "いうようなこうご意見はありましたけれど"
    },
    {
      "start": 1424.159,
      "duration": 4.4,
      "text": "もそれもですねまこのそういった規定は"
    },
    {
      "start": 1427.0,
      "duration": 4.08,
      "text": "ないということは先ほどから小林さん"
    },
    {
      "start": 1428.559,
      "duration": 4.681,
      "text": "おっしゃってる通りなのであのもしですね"
    },
    {
      "start": 1431.08,
      "duration": 4.8,
      "text": "何かそういったこう書いたいということで"
    },
    {
      "start": 1433.24,
      "duration": 4.919,
      "text": "あるんであればそれは何か違う形での提案"
    },
    {
      "start": 1435.88,
      "duration": 5.52,
      "text": "にしていくのかあの別の場での議論になっ"
    },
    {
      "start": 1438.159,
      "duration": 6.361,
      "text": "ていくのかなという風なえ感想を持ったと"
    },
    {
      "start": 1441.4,
      "duration": 4.56,
      "text": "いうところです以上ですはい他にござい"
    },
    {
      "start": 1444.52,
      "duration": 5.519,
      "text": "ます"
    },
    {
      "start": 1445.96,
      "duration": 6.079,
      "text": "かはい水谷はいえっと先ほどちょっと言"
    },
    {
      "start": 1450.039,
      "duration": 4.921,
      "text": "言い漏れたものがありますので申し上げ"
    },
    {
      "start": 1452.039,
      "duration": 5.88,
      "text": "たいと思いますえっと今回のあの件はあの"
    },
    {
      "start": 1454.96,
      "duration": 6.079,
      "text": "死の後押しするものだというあのお話が今"
    },
    {
      "start": 1457.919,
      "duration": 5.721,
      "text": "ありましたでえっとそうであればま今回死"
    },
    {
      "start": 1461.039,
      "duration": 4.841,
      "text": "の権限に属するものではないのでその権限"
    },
    {
      "start": 1463.64,
      "duration": 5.24,
      "text": "を持ってるところへの意見書の提出という"
    },
    {
      "start": 1465.88,
      "duration": 5.08,
      "text": "形が最もあの直接的な方法なのがと思い"
    },
    {
      "start": 1468.88,
      "duration": 3.76,
      "text": "ましたのでまそういう形もあったのでは"
    },
    {
      "start": 1470.96,
      "duration": 5.319,
      "text": "ないかと考えているということは申し上げ"
    },
    {
      "start": 1472.64,
      "duration": 4.84,
      "text": "ておりますはい他にございますかよろしい"
    },
    {
      "start": 1476.279,
      "duration": 4.721,
      "text": "です"
    },
    {
      "start": 1477.48,
      "duration": 5.76,
      "text": "かはいではお諮りいたします本件について"
    },
    {
      "start": 1481.0,
      "duration": 3.32,
      "text": "は議長の諮問の通り決定することにご異議"
    },
    {
      "start": 1483.24,
      "duration": 4.159,
      "text": "ありません"
    },
    {
      "start": 1484.32,
      "duration": 5.0,
      "text": "かご異議なしと認めます従って本件は議場"
    },
    {
      "start": 1487.399,
      "duration": 4.4,
      "text": "の質問の通り決定いたしました次に協議"
    },
    {
      "start": 1489.32,
      "duration": 3.76,
      "text": "事項3その他でございますが何かご発言は"
    },
    {
      "start": 1491.799,
      "duration": 4.6,
      "text": "ございます"
    },
    {
      "start": 1493.08,
      "duration": 5.319,
      "text": "かはい以上で当委員会に付託されており"
    },
    {
      "start": 1496.399,
      "duration": 7.16,
      "text": "ます案件の審査は全て終了いしましたこ"
    },
    {
      "start": 1498.399,
      "duration": 5.16,
      "text": "議会委員会の会議を閉じ参加いたします"
    }
  ]
}