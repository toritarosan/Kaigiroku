{
  "entries": [
    {
      "start": 74.88,
      "duration": 7.48,
      "text": "再開しますここで先ほど保留しました日程"
    },
    {
      "start": 78.52,
      "duration": 8.0,
      "text": "第1及び日程第2の保留を解き順次議題と"
    },
    {
      "start": 82.36,
      "duration": 7.24,
      "text": "し討論採決を行います議員案第46号新た"
    },
    {
      "start": 86.52,
      "duration": 6.76,
      "text": "な市民祭りの再構築に向け丁寧な対応を"
    },
    {
      "start": 89.6,
      "duration": 5.96,
      "text": "求め議これから討論を行います本件に"
    },
    {
      "start": 93.28,
      "duration": 5.519,
      "text": "対する討論を終了することにご異議あり"
    },
    {
      "start": 95.56,
      "duration": 5.519,
      "text": "ませんかご異議なしと認め討論を終了し"
    },
    {
      "start": 98.799,
      "duration": 6.36,
      "text": "ますたちに採決し"
    },
    {
      "start": 101.079,
      "duration": 6.921,
      "text": "ますお諮りします本件について原案の通り"
    },
    {
      "start": 105.159,
      "duration": 6.441,
      "text": "可決することにご異議ありません"
    },
    {
      "start": 108.0,
      "duration": 7.079,
      "text": "かご異議がありますので本件は起立採決を"
    },
    {
      "start": 111.6,
      "duration": 6.64,
      "text": "いたしますお諮りします本件は現案の通り"
    },
    {
      "start": 115.079,
      "duration": 6.161,
      "text": "加計することに賛成の皆さんの起立を求め"
    },
    {
      "start": 118.24,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 126.56,
      "duration": 7.759,
      "text": "立"
    },
    {
      "start": 128.599,
      "duration": 5.72,
      "text": "多数本件は原案可決と決定いたしまし"
    },
    {
      "start": 135.239,
      "duration": 8.441,
      "text": "た議案第47号十分な説明責任を果たさ"
    },
    {
      "start": 140.2,
      "duration": 7.679,
      "text": "ない白市長に対し優先整備2路線検証の"
    },
    {
      "start": 143.68,
      "duration": 8.08,
      "text": "総合的判断を令和7年第1回定例会冒頭"
    },
    {
      "start": 147.879,
      "duration": 7.201,
      "text": "までに示すことを求める"
    },
    {
      "start": 151.76,
      "duration": 7.83,
      "text": "本件は討論を行います初めに本件に反対の"
    },
    {
      "start": 155.08,
      "duration": 7.159,
      "text": "ものの発言を許可します6番三谷高子"
    },
    {
      "start": 159.59,
      "duration": 6.77,
      "text": "[音楽]"
    },
    {
      "start": 162.239,
      "duration": 4.121,
      "text": "議員じゃお願いします"
    },
    {
      "start": 168.319,
      "duration": 8.56,
      "text": "はい議員案第47号十分な説明責任を"
    },
    {
      "start": 173.879,
      "duration": 6.961,
      "text": "果たさない市市長に対し優先整備2路線"
    },
    {
      "start": 176.879,
      "duration": 6.801,
      "text": "検証の総合的判断を令和7年第定例会冒頭"
    },
    {
      "start": 180.84,
      "duration": 5.56,
      "text": "までに示すことを求める決議に小金を"
    },
    {
      "start": 183.68,
      "duration": 6.639,
      "text": "面白くする会として反対の立場から討論し"
    },
    {
      "start": 186.4,
      "duration": 8.68,
      "text": "ます本決議案は市市長が提案した検証の"
    },
    {
      "start": 190.319,
      "duration": 7.081,
      "text": "方法に対し熟度が低く事業構築のあり方に"
    },
    {
      "start": 195.08,
      "duration": 5.519,
      "text": "課題があり説明責任を果たしていないと"
    },
    {
      "start": 197.4,
      "duration": 8.24,
      "text": "指摘するものですが私はそうは考えません"
    },
    {
      "start": 200.599,
      "duration": 9.321,
      "text": "以下その理由を述べますまず令和6年第1"
    },
    {
      "start": 205.64,
      "duration": 7.08,
      "text": "回定例会の当初予算の提案時点において"
    },
    {
      "start": 209.92,
      "duration": 6.64,
      "text": "整備に路線の見直しを求める意思を示して"
    },
    {
      "start": 212.72,
      "duration": 8.0,
      "text": "いる市来市長が長を務める本誌としてはえ"
    },
    {
      "start": 216.56,
      "duration": 7.08,
      "text": "とが事業家に着する前に優先整備2路線の"
    },
    {
      "start": 220.72,
      "duration": 5.96,
      "text": "見直しを求める根拠を示す準備が必要と"
    },
    {
      "start": 223.64,
      "duration": 5.959,
      "text": "なりますその理由は本市の都市計画"
    },
    {
      "start": 226.68,
      "duration": 6.24,
      "text": "マスタープランには長期間にわり事業化"
    },
    {
      "start": 229.599,
      "duration": 7.48,
      "text": "する時期が未定の広域感染道路及び感染"
    },
    {
      "start": 232.92,
      "duration": 7.159,
      "text": "道路についてはえ社会経済情勢及び地域の"
    },
    {
      "start": 237.079,
      "duration": 6.36,
      "text": "街づくりの変化などを踏まえ東京と及び"
    },
    {
      "start": 240.079,
      "duration": 6.481,
      "text": "関係士と連携して都市計画道路の検証を"
    },
    {
      "start": 243.439,
      "duration": 6.321,
      "text": "行い必要に応じて見直すべきものは見直し"
    },
    {
      "start": 246.56,
      "duration": 7.16,
      "text": "ていきますと定めているからです党が動き"
    },
    {
      "start": 249.76,
      "duration": 7.08,
      "text": "出してからでは遅いのです当初予算の提案"
    },
    {
      "start": 253.72,
      "duration": 5.84,
      "text": "段階では検証の内容について詳細な内容を"
    },
    {
      "start": 256.84,
      "duration": 5.84,
      "text": "示すことはできませんでしたが具体的に"
    },
    {
      "start": 259.56,
      "duration": 6.4,
      "text": "内容を決めてから議会に提案していたので"
    },
    {
      "start": 262.68,
      "duration": 5.799,
      "text": "は間に合わず予算可決後に具体化せざる得"
    },
    {
      "start": 265.96,
      "duration": 7.12,
      "text": "ないというのはやむ得ない部分があったと"
    },
    {
      "start": 268.479,
      "duration": 7.921,
      "text": "考えます確かに今定例会中の建設環境委員"
    },
    {
      "start": 273.08,
      "duration": 7.36,
      "text": "会においてえ事前に委員に資料を示して"
    },
    {
      "start": 276.4,
      "duration": 6.6,
      "text": "行った説明と委員会当日の答弁に食い違い"
    },
    {
      "start": 280.44,
      "duration": 6.92,
      "text": "があると受け取られかねない場面があり"
    },
    {
      "start": 283.0,
      "duration": 8.08,
      "text": "ましたしかしそれは議会の意見を尊重し"
    },
    {
      "start": 287.36,
      "duration": 6.72,
      "text": "可能な限り反映修正して少しでも良いもの"
    },
    {
      "start": 291.08,
      "duration": 6.679,
      "text": "にしようとする市の真摯な姿勢の結果で"
    },
    {
      "start": 294.08,
      "duration": 7.24,
      "text": "ありそれまでもスケジュールを示した資料"
    },
    {
      "start": 297.759,
      "duration": 6.28,
      "text": "を示しながら答したものであって説明が2"
    },
    {
      "start": 301.32,
      "duration": 5.719,
      "text": "点3点したようなものではないと私は"
    },
    {
      "start": 304.039,
      "duration": 5.88,
      "text": "受け止めています議会の意見を尊重した"
    },
    {
      "start": 307.039,
      "duration": 6.081,
      "text": "からこそ1番初めに想定していた日程より"
    },
    {
      "start": 309.919,
      "duration": 7.321,
      "text": "も検証に着手する時期が遅れてきているの"
    },
    {
      "start": 313.12,
      "duration": 7.04,
      "text": "ではないでしょうかまた都市経学審議会に"
    },
    {
      "start": 317.24,
      "duration": 5.64,
      "text": "おいて専門家からはこのスケジュールでの"
    },
    {
      "start": 320.16,
      "duration": 5.879,
      "text": "検証作業はかなりチャレンジングであると"
    },
    {
      "start": 322.88,
      "duration": 6.96,
      "text": "いう趣旨の指摘もありましたしかしながら"
    },
    {
      "start": 326.039,
      "duration": 7.16,
      "text": "今定例会の最中に東京都は議会答弁にに"
    },
    {
      "start": 329.84,
      "duration": 8.44,
      "text": "おいて次の整備計画策定に向けてこの10"
    },
    {
      "start": 333.199,
      "duration": 8.201,
      "text": "月から学識経験者による委員会やえと区"
    },
    {
      "start": 338.28,
      "duration": 5.72,
      "text": "町村による検討会を設置すると公表して"
    },
    {
      "start": 341.4,
      "duration": 6.919,
      "text": "おり本市が考えているスケジュール通りに"
    },
    {
      "start": 344.0,
      "duration": 6.88,
      "text": "検証作業を行わな行わなければ手遅れに"
    },
    {
      "start": 348.319,
      "duration": 4.201,
      "text": "なってしまいかねないことが明らかになっ"
    },
    {
      "start": 350.88,
      "duration": 5.48,
      "text": "たわけ"
    },
    {
      "start": 352.52,
      "duration": 6.76,
      "text": "です優先整備2路線に関しては整備に賛成"
    },
    {
      "start": 356.36,
      "duration": 6.32,
      "text": "する市民もいれば反対する市民もいます"
    },
    {
      "start": 359.28,
      "duration": 6.919,
      "text": "そして東京都や本市と隣接する自治体との"
    },
    {
      "start": 362.68,
      "duration": 6.76,
      "text": "関係もある大変難しいテーマであり議会の"
    },
    {
      "start": 366.199,
      "duration": 6.961,
      "text": "関心も高い問題であることは否めません"
    },
    {
      "start": 369.44,
      "duration": 7.08,
      "text": "しかしながら具体的な移行調査の項目配布"
    },
    {
      "start": 373.16,
      "duration": 6.0,
      "text": "方法までこと細かに議会に説明し議論し"
    },
    {
      "start": 376.52,
      "duration": 7.0,
      "text": "なければ行政は事務を行えないのでしょう"
    },
    {
      "start": 379.16,
      "duration": 7.52,
      "text": "か令和6年第1回定例会で可決した決議に"
    },
    {
      "start": 383.52,
      "duration": 8.28,
      "text": "古賀を面白くする会は反対しましたがその"
    },
    {
      "start": 386.68,
      "duration": 9.0,
      "text": "2項目目優先整備2路線の検証作業に作業"
    },
    {
      "start": 391.8,
      "duration": 7.48,
      "text": "検証業務にえ着手する前にその目的え全体"
    },
    {
      "start": 395.68,
      "duration": 7.12,
      "text": "像個別具体のプロセスかこ都市計画審議会"
    },
    {
      "start": 399.28,
      "duration": 7.44,
      "text": "の位置付けを含むかこ図を議会に説明する"
    },
    {
      "start": 402.8,
      "duration": 6.399,
      "text": "ことについては議会の移行を尊重しながら"
    },
    {
      "start": 406.72,
      "duration": 6.36,
      "text": "市は可能な限りの説明をしてきたものと"
    },
    {
      "start": 409.199,
      "duration": 7.4,
      "text": "考えておりますもし仮に決議案が求める"
    },
    {
      "start": 413.08,
      "duration": 7.64,
      "text": "ように令和7年第1回定例会の冒頭に市長"
    },
    {
      "start": 416.599,
      "duration": 7.401,
      "text": "が総合的な判断を示すとなれば年内の検証"
    },
    {
      "start": 420.72,
      "duration": 6.919,
      "text": "を終えてから市長が総合的に判判断する"
    },
    {
      "start": 424.0,
      "duration": 7.4,
      "text": "時間は実質的には2週間しかありません"
    },
    {
      "start": 427.639,
      "duration": 7.201,
      "text": "近隣自治体や都にも関係するこれほど重要"
    },
    {
      "start": 431.4,
      "duration": 6.28,
      "text": "な案件についてそんなに短期間で様々な"
    },
    {
      "start": 434.84,
      "duration": 7.479,
      "text": "調整もした上で判断することは果たして"
    },
    {
      "start": 437.68,
      "duration": 7.0,
      "text": "可能でしょうかそれこそ接続な判断だとの"
    },
    {
      "start": 442.319,
      "duration": 6.56,
      "text": "阻りをまかれないことになるのではない"
    },
    {
      "start": 444.68,
      "duration": 7.88,
      "text": "でしょうか現在小金市議会を構成している"
    },
    {
      "start": 448.879,
      "duration": 6.641,
      "text": "1議員ととして自らの人気中にこの重要な"
    },
    {
      "start": 452.56,
      "duration": 5.199,
      "text": "問題についてしから説明を聞き質疑したい"
    },
    {
      "start": 455.52,
      "duration": 5.6,
      "text": "とお考えになる議員のお気持ちは分かり"
    },
    {
      "start": 457.759,
      "duration": 6.241,
      "text": "ますしかし残念ながら都が事業を検証する"
    },
    {
      "start": 461.12,
      "duration": 5.919,
      "text": "スケジュールと私たち小金市議会議員の"
    },
    {
      "start": 464.0,
      "duration": 6.039,
      "text": "人気が終了し議員の構成が変わる"
    },
    {
      "start": 467.039,
      "duration": 6.88,
      "text": "タイミングがあっていないこの現状の中で"
    },
    {
      "start": 470.039,
      "duration": 7.481,
      "text": "原職議員への人気中の説明を優先し短時間"
    },
    {
      "start": 473.919,
      "duration": 6.84,
      "text": "で市長の総合的判断を迫ることは本当に"
    },
    {
      "start": 477.52,
      "duration": 6.16,
      "text": "未来の小金のためになるのででしょうか"
    },
    {
      "start": 480.759,
      "duration": 5.88,
      "text": "市議会議員開戦後に新しい議員構成となっ"
    },
    {
      "start": 483.68,
      "duration": 6.56,
      "text": "た議会に対して説明が行われたとしても市"
    },
    {
      "start": 486.639,
      "duration": 7.321,
      "text": "の明説明責任は果たされるものと私は考え"
    },
    {
      "start": 490.24,
      "duration": 6.959,
      "text": "ます以上より私は関係機関との調整等も"
    },
    {
      "start": 493.96,
      "duration": 6.56,
      "text": "含めて責任者である市来市長が総合的な"
    },
    {
      "start": 497.199,
      "duration": 6.84,
      "text": "判断を行うためには令和7年第1回定例会"
    },
    {
      "start": 500.52,
      "duration": 5.84,
      "text": "冒頭における議会への説明を求めること"
    },
    {
      "start": 504.039,
      "duration": 6.16,
      "text": "及びスケジュールを含めた検証作業の"
    },
    {
      "start": 506.36,
      "duration": 6.64,
      "text": "見直しには賛同できないため本議案には"
    },
    {
      "start": 510.199,
      "duration": 2.801,
      "text": "反対いたし"
    },
    {
      "start": 520.159,
      "duration": 7.441,
      "text": "ます次に本件に賛成のものの発言を許可し"
    },
    {
      "start": 523.919,
      "duration": 3.681,
      "text": "ます20番渡辺大蔵"
    },
    {
      "start": 534.519,
      "duration": 9.361,
      "text": "議員え議案第47号十分な説明責任を市長"
    },
    {
      "start": 540.24,
      "duration": 6.92,
      "text": "に対し優先整備2路線検証の総合的判断を"
    },
    {
      "start": 543.88,
      "duration": 6.24,
      "text": "令和7年え大会定例会冒頭までに示すこと"
    },
    {
      "start": 547.16,
      "duration": 5.04,
      "text": "を求める決議に賛成の立場からえ討論"
    },
    {
      "start": 550.12,
      "duration": 4.6,
      "text": "いたしますあのこの私のあの賛成討論に"
    },
    {
      "start": 552.2,
      "duration": 5.24,
      "text": "先立って反対討論を行われましたがあので"
    },
    {
      "start": 554.72,
      "duration": 5.559,
      "text": "あるならばなぜですねあのそういった慎重"
    },
    {
      "start": 557.44,
      "duration": 4.839,
      "text": "な検討もなく選挙公約ができたのかまた"
    },
    {
      "start": 560.279,
      "duration": 4.24,
      "text": "姿勢方針にありものが書き込まれるのか"
    },
    {
      "start": 562.279,
      "duration": 4.921,
      "text": "全く理解に苦しみますので冒頭申し上げて"
    },
    {
      "start": 564.519,
      "duration": 5.281,
      "text": "おきたいと思いますえさてえ市市長が先の"
    },
    {
      "start": 567.2,
      "duration": 5.68,
      "text": "市長選において都道二路線整備の中見直し"
    },
    {
      "start": 569.8,
      "duration": 5.159,
      "text": "を東京都に求めると公約して初当選されま"
    },
    {
      "start": 572.88,
      "duration": 4.56,
      "text": "もなく2年になろうとしておりますまた"
    },
    {
      "start": 574.959,
      "duration": 5.201,
      "text": "次第市長の姿勢方針には就任以降複数年に"
    },
    {
      "start": 577.44,
      "duration": 5.56,
      "text": "渡り連続して東京都に中止見直しを求める"
    },
    {
      "start": 580.16,
      "duration": 6.239,
      "text": "旨の方針が明記されておりますえしかるに"
    },
    {
      "start": 583.0,
      "duration": 5.519,
      "text": "今日に至るまでその公約方針がえ履行され"
    },
    {
      "start": 586.399,
      "duration": 4.601,
      "text": "ていないのは理解に苦しむところであり"
    },
    {
      "start": 588.519,
      "duration": 5.481,
      "text": "ますえ宣言あるども実践なしということ"
    },
    {
      "start": 591.0,
      "duration": 5.839,
      "text": "ですえ今般市来市長から当該2路線の必要"
    },
    {
      "start": 594.0,
      "duration": 5.8,
      "text": "性を検証し総合的判断をしたいとの考え方"
    },
    {
      "start": 596.839,
      "duration": 5.801,
      "text": "が示されたわけですがえこれが公約履行に"
    },
    {
      "start": 599.8,
      "duration": 5.08,
      "text": "向けた必要不可欠な作業なのか公約不利行"
    },
    {
      "start": 602.64,
      "duration": 4.639,
      "text": "に向けた巧妙な準備行為なのかについては"
    },
    {
      "start": 604.88,
      "duration": 6.12,
      "text": "現時点で不文明であると言わざるを得ませ"
    },
    {
      "start": 607.279,
      "duration": 6.8,
      "text": "んえ市政の重要な選挙である市議会議選挙"
    },
    {
      "start": 611.0,
      "duration": 7.079,
      "text": "前としては最後の定例議会となる令和7年"
    },
    {
      "start": 614.079,
      "duration": 6.921,
      "text": "第1回定例会冒頭までに総合的判断を示し"
    },
    {
      "start": 618.079,
      "duration": 6.521,
      "text": "議会による質疑の機会を保障することは都"
    },
    {
      "start": 621.0,
      "duration": 6.12,
      "text": "道二路線に対してえ賛成化反対化別として"
    },
    {
      "start": 624.6,
      "duration": 5.52,
      "text": "多くの市議会議員が必要だと考えるところ"
    },
    {
      "start": 627.12,
      "duration": 4.88,
      "text": "だと思います判断材料がが示されないまま"
    },
    {
      "start": 630.12,
      "duration": 5.04,
      "text": "選挙になるというどこかで聞いたような"
    },
    {
      "start": 632.0,
      "duration": 6.32,
      "text": "展開にならないようえ市長に対しえ総合的"
    },
    {
      "start": 635.16,
      "duration": 6.56,
      "text": "判断を決議に即して明示するよう強く"
    },
    {
      "start": 638.32,
      "duration": 6.44,
      "text": "求めるものですえなおですね先般担当部局"
    },
    {
      "start": 641.72,
      "duration": 6.48,
      "text": "が私どもの被害室に検証の具体的方法の"
    },
    {
      "start": 644.76,
      "duration": 7.199,
      "text": "説明に来られた際評価項目の重み付けに"
    },
    {
      "start": 648.2,
      "duration": 7.079,
      "text": "ついて市民の意見を反映させる方策として"
    },
    {
      "start": 651.959,
      "duration": 6.921,
      "text": "会場を用意しええキャパに限りがあるため"
    },
    {
      "start": 655.279,
      "duration": 6.041,
      "text": "先着順でえ入場制限して入場できた人の"
    },
    {
      "start": 658.88,
      "duration": 5.959,
      "text": "意見を聞いて重み付けに反映させるとの"
    },
    {
      "start": 661.32,
      "duration": 7.12,
      "text": "趣旨の説明を行いましたえそのような手法"
    },
    {
      "start": 664.839,
      "duration": 7.601,
      "text": "では検証の透明性公平性が確保されるわけ"
    },
    {
      "start": 668.44,
      "duration": 7.12,
      "text": "もなく非常に驚き驚き耳を疑った次第です"
    },
    {
      "start": 672.44,
      "duration": 6.079,
      "text": "私が先着順はまずいのではないかとと言い"
    },
    {
      "start": 675.56,
      "duration": 5.44,
      "text": "ますと担当部局は市民からの意見が色々"
    },
    {
      "start": 678.519,
      "duration": 5.281,
      "text": "あっても重み付けへの影響はそう大きくは"
    },
    {
      "start": 681.0,
      "duration": 5.0,
      "text": "ないとの趣旨の説明をしましたそれでは"
    },
    {
      "start": 683.8,
      "duration": 5.039,
      "text": "単なる市民参加のアバ作りのようなもので"
    },
    {
      "start": 686.0,
      "duration": 5.2,
      "text": "はないでしょうか首をかげるばかりです皆"
    },
    {
      "start": 688.839,
      "duration": 6.161,
      "text": "さんど思われますかいずれにしてもですね"
    },
    {
      "start": 691.2,
      "duration": 6.92,
      "text": "何か全般的に公生性透明性にかける進め方"
    },
    {
      "start": 695.0,
      "duration": 5.839,
      "text": "だと言わざを得ませんそれはそのまま検証"
    },
    {
      "start": 698.12,
      "duration": 5.68,
      "text": "結果の正当性にも影響するものであります"
    },
    {
      "start": 700.839,
      "duration": 5.12,
      "text": "え東京都に対して中止を要望するというえ"
    },
    {
      "start": 703.8,
      "duration": 5.599,
      "text": "中止見直しを要望するという市長の政策"
    },
    {
      "start": 705.959,
      "duration": 7.081,
      "text": "意思に何のゆも揺らぎもないのであれば"
    },
    {
      "start": 709.399,
      "duration": 6.401,
      "text": "かつて私が提案したようにえ中止を要請"
    },
    {
      "start": 713.04,
      "duration": 6.0,
      "text": "するための有識社会議の設置による理論"
    },
    {
      "start": 715.8,
      "duration": 5.56,
      "text": "武装さらには官民共同での運動体の構築"
    },
    {
      "start": 719.04,
      "duration": 5.039,
      "text": "などが有効なのではないかと改めて思う"
    },
    {
      "start": 721.36,
      "duration": 6.479,
      "text": "ところであります以上指摘した上で賛成"
    },
    {
      "start": 724.079,
      "duration": 3.76,
      "text": "討論を終わりますご清聴ありがとうござい"
    },
    {
      "start": 734.279,
      "duration": 8.081,
      "text": "ます以上で討論を終了し"
    },
    {
      "start": 738.16,
      "duration": 7.96,
      "text": "ます本件は起立採決をしますお諮りします"
    },
    {
      "start": 742.36,
      "duration": 8.2,
      "text": "本件は現案の通り駆けすることに賛成の皆"
    },
    {
      "start": 746.12,
      "duration": 4.44,
      "text": "さんの起立を求めます"
    },
    {
      "start": 758.0,
      "duration": 10.199,
      "text": "数起立多数本件は原案可決と決定しまし"
    },
    {
      "start": 764.279,
      "duration": 7.281,
      "text": "たお諮りしますお手元にご配布してあり"
    },
    {
      "start": 768.199,
      "duration": 6.521,
      "text": "ます通り追加日程第1から追加日程第3"
    },
    {
      "start": 771.56,
      "duration": 5.92,
      "text": "までの3件を日程に追加し順次議題とし"
    },
    {
      "start": 774.72,
      "duration": 5.76,
      "text": "ますこれにご異議ありませんかご異議なし"
    },
    {
      "start": 777.48,
      "duration": 6.68,
      "text": "と認め追加日程第1から追加日程第3まで"
    },
    {
      "start": 780.48,
      "duration": 5.039,
      "text": "の3件を日程に追加し順次議題とすること"
    },
    {
      "start": 784.16,
      "duration": 5.679,
      "text": "と決定しまし"
    },
    {
      "start": 785.519,
      "duration": 7.68,
      "text": "た追加日程第1西が陳情の委員会負託を"
    },
    {
      "start": 789.839,
      "duration": 8.56,
      "text": "行います今定例会の10月4日までに受理"
    },
    {
      "start": 793.199,
      "duration": 8.88,
      "text": "した西岸陳情は6陳情第42号から6陳情"
    },
    {
      "start": 798.399,
      "duration": 8.761,
      "text": "第50号までの9件です以上9権はお手元"
    },
    {
      "start": 802.079,
      "duration": 9.281,
      "text": "にご配布しましたえ西が陳情委員会追加"
    },
    {
      "start": 807.16,
      "duration": 7.919,
      "text": "付託予定表の通り所管の常任委員会に付託"
    },
    {
      "start": 811.36,
      "duration": 7.32,
      "text": "しますお別れしますただいま付託しました"
    },
    {
      "start": 815.079,
      "duration": 6.681,
      "text": "千城9権は閉会中の継続審査とすることに"
    },
    {
      "start": 818.68,
      "duration": 6.32,
      "text": "ご異議ありませんかご異議なしと認め"
    },
    {
      "start": 821.76,
      "duration": 5.8,
      "text": "ただいま付託しました陳情9権は閉会中の"
    },
    {
      "start": 825.0,
      "duration": 7.279,
      "text": "継続審査案件と決定しまし"
    },
    {
      "start": 827.56,
      "duration": 8.519,
      "text": "た追加日程第2閉会中継続審査案件を議題"
    },
    {
      "start": 832.279,
      "duration": 7.48,
      "text": "とします各常任委員会委員長議会運営委員"
    },
    {
      "start": 836.079,
      "duration": 7.401,
      "text": "会委員長及び各特別委員会委員長から委員"
    },
    {
      "start": 839.759,
      "duration": 7.601,
      "text": "会において審査調査中の事件につき会議"
    },
    {
      "start": 843.48,
      "duration": 7.96,
      "text": "規則第74条の規定により閉会中継続審査"
    },
    {
      "start": 847.36,
      "duration": 6.919,
      "text": "案件一覧表の通り申し出がありましたお"
    },
    {
      "start": 851.44,
      "duration": 5.6,
      "text": "分りします本件は閉会一もなお審査する"
    },
    {
      "start": 854.279,
      "duration": 7.0,
      "text": "ことにご異議ありませんかご異議なしと"
    },
    {
      "start": 857.04,
      "duration": 8.359,
      "text": "認め閉会中継続審査案件一覧表の通り継続"
    },
    {
      "start": 861.279,
      "duration": 7.161,
      "text": "審査することと決定しました追加日程第3"
    },
    {
      "start": 865.399,
      "duration": 6.961,
      "text": "議員の派遣についてを議題としますお諮り"
    },
    {
      "start": 868.44,
      "duration": 7.92,
      "text": "します地方次地方第100条第13項及び"
    },
    {
      "start": 872.36,
      "duration": 7.24,
      "text": "会議則規則第120条の規定に基づきお"
    },
    {
      "start": 876.36,
      "duration": 7.44,
      "text": "手元に配布しました議員の派遣についての"
    },
    {
      "start": 879.6,
      "duration": 7.52,
      "text": "通り閉会中に議員派遣を行うこととし初犯"
    },
    {
      "start": 883.8,
      "duration": 6.2,
      "text": "の事情により変更が生じた場合は議長にご"
    },
    {
      "start": 887.12,
      "duration": 5.639,
      "text": "一任いただくことにご異議あれませんかご"
    },
    {
      "start": 890.0,
      "duration": 6.6,
      "text": "異議なしと認めただ今申し上げた通り行う"
    },
    {
      "start": 892.759,
      "duration": 7.841,
      "text": "ことと決定しました重ねておはりします"
    },
    {
      "start": 896.6,
      "duration": 8.64,
      "text": "なお閉中に原派遣を行う必が生じた場合"
    },
    {
      "start": 900.6,
      "duration": 7.679,
      "text": "その日時場所目的及び議員えっと派遣議員"
    },
    {
      "start": 905.24,
      "duration": 5.959,
      "text": "名等については議長にご一任いただくこと"
    },
    {
      "start": 908.279,
      "duration": 5.36,
      "text": "にご異議ありませんかご異議なしと認め"
    },
    {
      "start": 911.199,
      "duration": 6.241,
      "text": "ただいま申し上げた通り行うことと決定し"
    },
    {
      "start": 913.639,
      "duration": 7.081,
      "text": "ました以上で今定例会に付託されたあ付議"
    },
    {
      "start": 917.44,
      "duration": 6.319,
      "text": "された案件は全て終了しましたこれを持ち"
    },
    {
      "start": 920.72,
      "duration": 7.64,
      "text": "まして会議を閉じ令和6年度第3回小金"
    },
    {
      "start": 923.759,
      "duration": 4.601,
      "text": "主義会定例会を閉会します"
    },
    {
      "start": 935.519,
      "duration": 3.0,
      "text": "4"
    }
  ]
}