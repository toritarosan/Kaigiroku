      "duration": 8.2,
      "text": "対策の推進に関する賃上書本件につきまし"
    },
    {
      "start": 197.879,
      "duration": 8.681,
      "text": "ては令和5年12月7日の本会議において"
    },
    {
      "start": 201.799,
      "duration": 10.041,
      "text": "当委員会に付託され12月12日令和6年"
    },
    {
      "start": 206.56,
      "duration": 10.12,
      "text": "1月11日の計2回にわり審査を行いまし"
    },
    {
      "start": 211.84,
      "duration": 8.08,
      "text": "たなお12月12日の委員会では陳情者"
    },
    {
      "start": 216.68,
      "duration": 6.88,
      "text": "からの発言の申出がありましたので審査に"
    },
    {
      "start": 219.92,
      "duration": 7.599,
      "text": "先出し委員会協議会を開催し発言して"
    },
    {
      "start": 223.56,
      "duration": 8.12,
      "text": "いただきました1月11日の委員会では"
    },
    {
      "start": 227.519,
      "duration": 8.601,
      "text": "委員から次の意見要望がなされました初め"
    },
    {
      "start": 231.68,
      "duration": 8.119,
      "text": "に本陳情は主催宅が適切であると思うが"
    },
    {
      "start": 236.12,
      "duration": 7.72,
      "text": "採決にあたり意見要望を述べたい本市のの"
    },
    {
      "start": 239.799,
      "duration": 8.8,
      "text": "第2次地球温暖化対策地域推進計画におけ"
    },
    {
      "start": 243.84,
      "duration": 8.759,
      "text": "る計画期間の前半が令和7年度で終わる"
    },
    {
      "start": 248.599,
      "duration": 8.6,
      "text": "ことから一旦立ち止まって今後のあり方等"
    },
    {
      "start": 252.599,
      "duration": 9.521,
      "text": "を検討すべきであるまた部局から令和7"
    },
    {
      "start": 257.199,
      "duration": 9.081,
      "text": "年度にプレ気候市民会議を開き気候変動に"
    },
    {
      "start": 262.12,
      "duration": 7.919,
      "text": "ついて改めて考えることが示されたこれは"
    },
    {
      "start": 266.28,
      "duration": 7.44,
      "text": "陳情項目にあるなるべく早く市民が"
    },
    {
      "start": 270.039,
      "duration": 7.361,
      "text": "1人1人から始める意識改革を行い具体的"
    },
    {
      "start": 273.72,
      "duration": 7.4,
      "text": "な対策に基づいて今すぐ行動することが"
    },
    {
      "start": 277.4,
      "duration": 8.48,
      "text": "できるよう既婚市民会議の早期実施を求め"
    },
    {
      "start": 281.12,
      "duration": 9.2,
      "text": "ますととの趣旨に即したものと考えるこれ"
    },
    {
      "start": 285.88,
      "duration": 10.0,
      "text": "はを踏まえ本陳情の採択に望みたいと"
    },
    {
      "start": 290.32,
      "duration": 9.04,
      "text": "思うまた別の委員から本陳情はさん択じゃ"
    },
    {
      "start": 295.88,
      "duration": 7.72,
      "text": "なくて採決あすいません失礼いたしました"
    },
    {
      "start": 299.36,
      "duration": 8.16,
      "text": "ませはいこれらを採択に変更いたします本"
    },
    {
      "start": 303.6,
      "duration": 6.4,
      "text": "陳上の採択に望みたいあ採決に望みたいと"
    },
    {
      "start": 307.52,
      "duration": 7.519,
      "text": "思失礼しまし"
    },
    {
      "start": 310.0,
      "duration": 8.319,
      "text": "たまた別の委員から本陳情は主旨採択で"
    },
    {
      "start": 315.039,
      "duration": 7.561,
      "text": "まとまれば良かったが一致しなかったため"
    },
    {
      "start": 318.319,
      "duration": 8.081,
      "text": "意見要望を述べておきたい行政が目の前の"
    },
    {
      "start": 322.6,
      "duration": 8.159,
      "text": "気候機器を受け止めて令和7年度にプレ"
    },
    {
      "start": 326.4,
      "duration": 7.2,
      "text": "気候市民会議の開催を本上が提出される前"
    },
    {
      "start": 330.759,
      "duration": 6.681,
      "text": "から検討してきたことについては評価し"
    },
