    },
    {
      "start": 160.2,
      "duration": 7.959,
      "text": "を審査いたしましたのでその審査の概要と"
    },
    {
      "start": 164.2,
      "duration": 8.399,
      "text": "結果につきましてご報告申し上げますなお"
    },
    {
      "start": 168.159,
      "duration": 8.041,
      "text": "所管事務調査循環型社会の形成及び音質"
    },
    {
      "start": 172.599,
      "duration": 9.0,
      "text": "効果ガス削減に関する調査及び所管事務"
