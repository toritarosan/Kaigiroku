{
  "entries": [
    {
      "start": 108.24,
      "duration": 7.64,
      "text": "はいえこんにちはえただ今からえ広報協議"
    },
    {
      "start": 112.759,
      "duration": 6.36,
      "text": "会の会議を開きますえ直ちに議題に入り"
    },
    {
      "start": 115.88,
      "duration": 7.239,
      "text": "ますえ1え各部会の報告についてを行い"
    },
    {
      "start": 119.119,
      "duration": 9.241,
      "text": "ますえ始めにかこ1四面改革部会の報告を"
    },
    {
      "start": 123.119,
      "duration": 8.721,
      "text": "求めます小林さんはいえっとお手元に市名"
    },
    {
      "start": 128.36,
      "duration": 7.959,
      "text": "改革部会の第3回と第4回の会議録"
    },
    {
      "start": 131.84,
      "duration": 9.679,
      "text": "を配布させて配布していただいております"
    },
    {
      "start": 136.319,
      "duration": 8.081,
      "text": "えっと第4回の報告のですねえっと1番下"
    },
    {
      "start": 141.519,
      "duration": 5.201,
      "text": "のところをご確認くださいかこ1今後の"
    },
    {
      "start": 144.4,
      "duration": 6.199,
      "text": "議会代りA4番についての検討という"
    },
    {
      "start": 146.72,
      "duration": 9.04,
      "text": "ところでありますえっと令和7年の"
    },
    {
      "start": 150.599,
      "duration": 9.28,
      "text": "回線号ですねまこれに向けてえっと円4番"
    },
    {
      "start": 155.76,
      "duration": 6.88,
      "text": "の市名改革を今検討を進めてるとこであり"
    },
    {
      "start": 159.879,
      "duration": 7.401,
      "text": "ますえ具体的に今"
    },
    {
      "start": 162.64,
      "duration": 9.08,
      "text": "あと3年前の回線号を音場に落とし込んだ"
    },
    {
      "start": 167.28,
      "duration": 9.36,
      "text": "時にどのようなえ余裕が生まれるかまたえ"
    },
    {
      "start": 171.72,
      "duration": 7.0,
      "text": "先進士などのレイアウトえっとコンテンツ"
    },
    {
      "start": 176.64,
      "duration": 4.879,
      "text": "これがどう入れられるのかというところを"
    },
    {
      "start": 178.72,
      "duration": 6.92,
      "text": "ですねえ検討を進めているとこですえ"
    },
    {
      "start": 181.519,
      "duration": 9.481,
      "text": "引き続きえ協議をしてまいりたいとえそれ"
    },
    {
      "start": 185.64,
      "duration": 8.04,
      "text": "でえっとLINE今年か新年度の秋の予算"
    },
    {
      "start": 191.0,
      "duration": 6.4,
      "text": "要望につなげてまいりたいというのがえ今"
    },
    {
      "start": 193.68,
      "duration": 5.479,
      "text": "我々の目標でありますえ次回についてです"
    },
    {
      "start": 197.4,
      "duration": 6.72,
      "text": "がま予備日に少し"
    },
    {
      "start": 199.159,
      "duration": 7.041,
      "text": "え協議の準備が整えばえ行いたいという"
    },
    {
      "start": 204.12,
      "duration": 4.56,
      "text": "ことになってるのかなというところで"
    },
    {
      "start": 206.2,
      "duration": 5.959,
      "text": "ございます以上ですはいありがとうござい"
    },
    {
      "start": 208.68,
      "duration": 7.44,
      "text": "ますええとただ今のあのご報告にえ質疑"
    },
    {
      "start": 212.159,
      "duration": 7.881,
      "text": "意見ございますかないでしょうかはいえ"
    },
    {
      "start": 216.12,
      "duration": 6.92,
      "text": "それでは次にえっと括にえっと広報部会の"
    },
    {
      "start": 220.04,
      "duration": 7.96,
      "text": "え報告を求めます太"
    },
    {
      "start": 223.04,
      "duration": 9.52,
      "text": "さんあえっと広報部会ですえっと2月5日"
    },
    {
      "start": 228.0,
      "duration": 7.28,
      "text": "にえ全員参加で行いましたで協議事項はえ"
    },
    {
      "start": 232.56,
      "duration": 5.36,
      "text": "記載の通り括1会ガイトブックの恋愛と"
    },
    {
      "start": 235.28,
      "duration": 5.08,
      "text": "及び内容について前回からの続きですで括"
    },
    {
      "start": 237.92,
      "duration": 4.36,
      "text": "に活動についてですでちょっと長いので"
    },
    {
      "start": 240.36,
      "duration": 3.76,
      "text": "省略させていただきたいと思います議会"
    },
    {
      "start": 242.28,
      "duration": 6.0,
      "text": "ガイドブックのレイアウト及び内容につい"
    },
    {
      "start": 244.12,
      "duration": 7.36,
      "text": "てはあの記載の通りであの検討を進めて"
    },
    {
      "start": 248.28,
      "duration": 6.64,
      "text": "おりますえ引き続きを行っていきますで"
    },
    {
      "start": 251.48,
      "duration": 7.68,
      "text": "かこ2のえ候補活動については"
    },
    {
      "start": 254.92,
      "duration": 7.279,
      "text": "えとホームページのえ改定進捗状況につい"
    },
    {
      "start": 259.16,
      "duration": 5.08,
      "text": "てま私が確認したことを座長の私が確認し"
    },
    {
      "start": 262.199,
      "duration": 4.44,
      "text": "たことを報告しましたえ担当化の方で"
    },
    {
      "start": 264.24,
      "duration": 4.959,
      "text": "レイアウトなどがまだ決まっていなくてま"
    },
    {
      "start": 266.639,
      "duration": 5.12,
      "text": "検討中ということでしたでスケジュール等"
    },
    {
      "start": 269.199,
      "duration": 5.361,
      "text": "も含め段階ということであったということ"
    },
    {
      "start": 271.759,
      "duration": 6.801,
      "text": "を共有したというだけでありますで"
    },
    {
      "start": 274.56,
      "duration": 7.68,
      "text": "LINEでの発信についてはま現状Xでの"
    },
    {
      "start": 278.56,
      "duration": 6.4,
      "text": "え議会情報の発信内容は事務局に任せて"
    },
    {
      "start": 282.24,
      "duration": 4.6,
      "text": "いるでLINEでの発信を議会から事務局"
    },
    {
      "start": 284.96,
      "duration": 4.76,
      "text": "をお願いしてもいいのではないかという風"
    },
    {
      "start": 286.84,
      "duration": 5.84,
      "text": "な意見が出ましてXと同じ内容LINEで"
    },
    {
      "start": 289.72,
      "duration": 5.28,
      "text": "も発信することを事務局に依頼えして"
    },
    {
      "start": 292.68,
      "duration": 5.959,
      "text": "みようということをま広報部会の中ではま"
    },
    {
      "start": 295.0,
      "duration": 8.12,
      "text": "全員一致しましたですのでちょっとこの後"
    },
    {
      "start": 298.639,
      "duration": 7.961,
      "text": "そのえ広報協議会の中でLINEでの発信"
    },
    {
      "start": 303.12,
      "duration": 5.96,
      "text": "を現状Xで行ってる範囲内で同じように"
    },
    {
      "start": 306.6,
      "duration": 5.36,
      "text": "やっていただけないかお願いすることに"
    },
    {
      "start": 309.08,
      "duration": 7.0,
      "text": "ついての協議をまこの広報協議会でえでき"
    },
    {
      "start": 311.96,
      "duration": 6.76,
      "text": "たらと思っておりますえ以上ですはいえご"
    },
    {
      "start": 316.08,
      "duration": 5.2,
      "text": "報告ありがとうございますえっと今あの"
    },
    {
      "start": 318.72,
      "duration": 6.64,
      "text": "えっとご報告があった中であのLINEで"
    },
    {
      "start": 321.28,
      "duration": 7.68,
      "text": "の発信についてXとえ同じ内容をLINE"
    },
    {
      "start": 325.36,
      "duration": 5.559,
      "text": "でも発信することについてえ事務局にあの"
    },
    {
      "start": 328.96,
      "duration": 3.88,
      "text": "依頼したいということであの部会の方では"
    },
    {
      "start": 330.919,
      "duration": 6.0,
      "text": "合意が取れてるということなんですが事務"
    },
    {
      "start": 332.84,
      "duration": 8.84,
      "text": "局からは何かこの件でございます"
    },
    {
      "start": 336.919,
      "duration": 7.241,
      "text": "かはい次長えっとすいませんちょっと実務"
    },
    {
      "start": 341.68,
      "duration": 5.519,
      "text": "的にどうか同じようにっていうんであれば"
    },
    {
      "start": 344.16,
      "duration": 5.159,
      "text": "多分対応はできるのかなと思うんですがま"
    },
    {
      "start": 347.199,
      "duration": 4.481,
      "text": "正式にちょっとそういうような依頼があっ"
    },
    {
      "start": 349.319,
      "duration": 4.32,
      "text": "たらちょっと念のためちょっとあの対応"
    },
    {
      "start": 351.68,
      "duration": 3.88,
      "text": "方法はちょっと確認はしたいと思いますが"
    },
    {
      "start": 353.639,
      "duration": 4.961,
      "text": "現点で同じようにっていうなればできるの"
    },
    {
      "start": 355.56,
      "duration": 5.639,
      "text": "かなはいはいえっと今事務局からもご説明"
    },
    {
      "start": 358.6,
      "duration": 6.0,
      "text": "ありましたがんからその件について何か"
    },
    {
      "start": 361.199,
      "duration": 6.72,
      "text": "ございますはいあえっと小林さん1点確認"
    },
    {
      "start": 364.6,
      "duration": 7.4,
      "text": "ですえっと現在あの公式LINEあと小金"
    },
    {
      "start": 367.919,
      "duration": 7.68,
      "text": "の公式ラインの受信設定のところに"
    },
    {
      "start": 372.0,
      "duration": 8.199,
      "text": "あの希望する情報って選べますよね子育て"
    },
    {
      "start": 375.599,
      "duration": 9.88,
      "text": "とかえ暮らしとか健康とかで一応その最後"
    },
    {
      "start": 380.199,
      "duration": 7.601,
      "text": "のとこに市議会ってあるんですねでこれ今"
    },
    {
      "start": 385.479,
      "duration": 5.921,
      "text": "あのここにチェックボックスがあ"
    },
    {
      "start": 387.8,
      "duration": 6.679,
      "text": "るっていうことはえっと今この設定に"
    },
    {
      "start": 391.4,
      "duration": 6.359,
      "text": "基づいて私チェック入ってんですけど議会"
    },
    {
      "start": 394.479,
      "duration": 6.041,
      "text": "が市議会事務局がもう既に発信してる情報"
    },
    {
      "start": 397.759,
      "duration": 7.201,
      "text": "があるということでしょうかそれとも設定"
    },
    {
      "start": 400.52,
      "duration": 6.679,
      "text": "の枠だけ用意されていてそれなりの運用の"
    },
    {
      "start": 404.96,
      "duration": 5.799,
      "text": "指針は"
    },
    {
      "start": 407.199,
      "duration": 5.56,
      "text": "えっと聞かされてるんだけど実際流してる"
    },
    {
      "start": 410.759,
      "duration": 5.321,
      "text": "情報がないという状況なのか教えて"
    },
    {
      "start": 412.759,
      "duration": 7.041,
      "text": "くださいはい事務局はいえっと事務局です"
    },
    {
      "start": 416.08,
      "duration": 7.399,
      "text": "特えっと現あのLINEの方の議会のテで"
    },
    {
      "start": 419.8,
      "duration": 4.959,
      "text": "流してる情報はございません以上ですはい"
    },
    {
      "start": 423.479,
      "duration": 3.84,
      "text": "鈴木"
    },
    {
      "start": 424.759,
      "duration": 4.081,
      "text": "さんあのLINEというのはこの公式"
    },
    {
      "start": 427.319,
      "duration": 3.56,
      "text": "ラインのことかていうことを確認したかっ"
    },
    {
      "start": 428.84,
      "duration": 5.84,
      "text": "たんでそういうことですよねはいはい了解"
    },
    {
      "start": 430.879,
      "duration": 7.681,
      "text": "です何ございますかはい水さんじゃその市"
    },
    {
      "start": 434.68,
      "duration": 7.44,
      "text": "の公式ライの枠を使えば技術的には流す"
    },
    {
      "start": 438.56,
      "duration": 5.759,
      "text": "ことは可能っていうことでいいですか"
    },
    {
      "start": 442.12,
      "duration": 4.799,
      "text": "要するに容器があるけどまだ中身入って"
    },
    {
      "start": 444.319,
      "duration": 6.081,
      "text": "ないだけでねはいそうですね技術的には"
    },
    {
      "start": 446.919,
      "duration": 6.321,
      "text": "はいはいじゃえっと法部会の方から"
    },
    {
      "start": 450.4,
      "duration": 5.6,
      "text": "投げかけがありましたあのま市の公式"
    },
    {
      "start": 453.24,
      "duration": 5.32,
      "text": "ラインにXと同じ内容でとりあえず流して"
    },
    {
      "start": 456.0,
      "duration": 6.08,
      "text": "いくということについてはえっと事務局の"
    },
    {
      "start": 458.56,
      "duration": 7.0,
      "text": "方もできそうだったのでえっとえはい"
    },
    {
      "start": 462.08,
      "duration": 6.399,
      "text": "どうぞ清さんあのいつもこうやる時に必ず"
    },
    {
      "start": 465.56,
      "duration": 6.44,
      "text": "ついてもんのが事務局の負担がどの程度に"
    },
    {
      "start": 468.479,
      "duration": 5.241,
      "text": "なるのかっていうことなのでまやることが"
    },
    {
      "start": 472.0,
      "duration": 4.4,
      "text": "増えるっていうことは間違いないと思うの"
    },
    {
      "start": 473.72,
      "duration": 4.479,
      "text": "でその辺りの確認はしたいなと何でもかん"
    },
    {
      "start": 476.4,
      "duration": 4.04,
      "text": "でもお願いってわけにはいかないと思うの"
    },
    {
      "start": 478.199,
      "duration": 6.921,
      "text": "でそこの確認だけたいと思いますはい"
    },
    {
      "start": 480.44,
      "duration": 6.8,
      "text": "改めて確認があったのでどうでしょうま1"
    },
    {
      "start": 485.12,
      "duration": 6.24,
      "text": "手間は増えるんだけどね当然ね"
    },
    {
      "start": 487.24,
      "duration": 7.28,
      "text": "え今までよりは確かにあの人作業増え"
    },
    {
      "start": 491.36,
      "duration": 8.0,
      "text": "るっていうのはあると思うんですけどそこ"
    },
    {
      "start": 494.52,
      "duration": 8.0,
      "text": "までではないかなと"
    },
    {
      "start": 499.36,
      "duration": 7.279,
      "text": "はいありますか"
    },
    {
      "start": 502.52,
      "duration": 5.76,
      "text": "はいあります今の話を踏まえはい清さんま"
    },
    {
      "start": 506.639,
      "duration": 4.801,
      "text": "もちろんできないことではないっていうの"
    },
    {
      "start": 508.28,
      "duration": 7.439,
      "text": "はもちろんのそれ言わざる得ない感じだと"
    },
    {
      "start": 511.44,
      "duration": 7.24,
      "text": "思うんですけどもあのなんて言う"
    },
    {
      "start": 515.719,
      "duration": 6.281,
      "text": "だろうまちょっとXをやってみての効果と"
    },
    {
      "start": 518.68,
      "duration": 5.64,
      "text": "かも必要だなとは思うんですけどもま"
    },
    {
      "start": 522.0,
      "duration": 4.6,
      "text": "ちょっと何を求めてLINEをするの"
    },
    {
      "start": 524.32,
      "duration": 5.44,
      "text": "かってのが大事だと思うのでその辺りって"
    },
    {
      "start": 526.6,
      "duration": 5.72,
      "text": "候補の方から何か何をそのLINEで流し"
    },
    {
      "start": 529.76,
      "duration": 4.639,
      "text": "て何を求めてんのかをちょっともう1度"
    },
    {
      "start": 532.32,
      "duration": 6.32,
      "text": "教えてもらえたらなと思いその手間を"
    },
    {
      "start": 534.399,
      "duration": 6.641,
      "text": "増やしてまでやる意味をはいタさんああま"
    },
    {
      "start": 538.64,
      "duration": 4.639,
      "text": "私の個人の意見というよりはま広報部会と"
    },
    {
      "start": 541.04,
      "duration": 4.88,
      "text": "してはやっぱ広報活と必要という認識に"
    },
    {
      "start": 543.279,
      "duration": 6.721,
      "text": "至ってま広報協議会全体もそうだと思うん"
    },
    {
      "start": 545.92,
      "duration": 7.0,
      "text": "ですけどなのでま現状Xであの主義会"
    },
    {
      "start": 550.0,
      "duration": 5.76,
      "text": "いついつやってやりますみたいな情報提供"
    },
    {
      "start": 552.92,
      "duration": 6.24,
      "text": "してるのでそれをLINEでも議会情報を"
    },
    {
      "start": 555.76,
      "duration": 6.28,
      "text": "希望する人には提供した方がいいのでは"
    },
    {
      "start": 559.16,
      "duration": 5.52,
      "text": "ないかというのが目的ですねおそらくは"
    },
    {
      "start": 562.04,
      "duration": 5.359,
      "text": "あのLINEとXやってる層ってまず違う"
    },
    {
      "start": 564.68,
      "duration": 4.36,
      "text": "んですよねだからあのえっとXやってる層"
    },
    {
      "start": 567.399,
      "duration": 4.041,
      "text": "以外にもLINEやってる層の方が多分"
    },
    {
      "start": 569.04,
      "duration": 4.44,
      "text": "多いのな若い人たちなのでより後半な"
    },
    {
      "start": 571.44,
      "duration": 4.639,
      "text": "ところに及ぶんじゃないかということと"
    },
    {
      "start": 573.48,
      "duration": 4.56,
      "text": "あと市の方が公式ラインで相当代々的に"
    },
    {
      "start": 576.079,
      "duration": 4.521,
      "text": "あの宣伝してくれてるんでそこに市議会の"
    },
    {
      "start": 578.04,
      "duration": 4.479,
      "text": "もページがありますから逆に言うと今何も"
    },
    {
      "start": 580.6,
      "duration": 4.479,
      "text": "発信しないと市議会だけサボってるように"
    },
    {
      "start": 582.519,
      "duration": 4.481,
      "text": "も受け取られかねないので何か発信してっ"
    },
    {
      "start": 585.079,
      "duration": 4.32,
      "text": "た方が良さげだなという風にさっきの"
    },
    {
      "start": 587.0,
      "duration": 3.839,
      "text": "ちょっと小林さんの確認の話を聞いてて器"
