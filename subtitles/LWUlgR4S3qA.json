    },
    {
      "start": 11.559,
      "duration": 7.041,
      "text": "ですけれどもえこちらの方今行っており"
    },
    {
      "start": 14.04,
      "duration": 7.72,
      "text": "ますがかこ123ということでえ臨時会の"
    },
    {
      "start": 18.6,
      "duration": 5.999,
