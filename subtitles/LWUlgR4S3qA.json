      "text": "ましたら4番請求代表者の意見陳述につい"
    },
    {
      "start": 69.24,
      "duration": 8.12,
      "text": "てとえいうことで予定しておりますえまた"
    },
    {
      "start": 73.0,
      "duration": 6.88,
      "text": "先ほどの本会議始まる冒頭のところで議長"
    },
    {
      "start": 77.36,
      "duration": 6.52,
      "text": "の方からもお話がありましたがえ本日は"
    },
    {
      "start": 79.88,
      "duration": 6.879,
      "text": "ですねえま午後からええっと全員協議会が"
