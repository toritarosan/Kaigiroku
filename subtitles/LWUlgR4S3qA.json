      "text": "予定されておりますがその間にですねえ本"
    },
    {
      "start": 86.759,
      "duration": 6.481,
      "text": "会議終了後に会派代表者会議を予定定して"
    },
    {
      "start": 90.36,
      "duration": 5.32,
      "text": "おりますのでえ合わせてえご報告をさせて"
    },
    {
      "start": 93.24,
      "duration": 5.44,
      "text": "いただきます本日の進行につきましては"
    },
    {
      "start": 95.68,
      "duration": 5.6,
      "text": "以上になりますはい以上進行について何か"
    },
    {
      "start": 98.68,
      "duration": 5.14,
      "text": "ございますかよろしいですかそれでは委員"
    },
    {
      "start": 101.28,
      "duration": 4.119,
      "text": "会に入ってまいりますお願いし"
    },
    {
      "start": 103.82,
      "duration": 4.22,
      "text": "[音楽]"
    },
    {
      "start": 105.399,
      "duration": 4.841,
      "text": "ますただ今から議会運営委員会の会議を"
    },
    {
      "start": 108.04,
      "duration": 4.48,
      "text": "開きますたちに本日の議事に入ります当"
    },
    {
      "start": 110.24,
      "duration": 5.08,
      "text": "委員会に負されております案件は調査一件"
    },
    {
      "start": 112.52,
      "duration": 5.239,
      "text": "であります臨時会の会議及び会議不等議会"
    },
    {
      "start": 115.32,
      "duration": 5.2,
      "text": "運営に関する調査を議題といたします議長"
    },
    {
      "start": 117.759,
      "duration": 4.72,
      "text": "からお手元に議会運営委員会協議が提示さ"
    },
    {
      "start": 120.52,
      "duration": 4.08,
      "text": "れておりますのでその順序に従って順次"
    },
    {
      "start": 122.479,
      "duration": 6.081,
      "text": "協議をしてまいりたいと思います初めに"
    },
    {
      "start": 124.6,
      "duration": 6.88,
      "text": "協議事項1令和6年第1回臨時間臨時会"
    },
    {
      "start": 128.56,
      "duration": 5.36,
      "text": "提出案件を行いますえ協議事項に示されれ"
    },
    {
      "start": 131.48,
      "duration": 4.759,
      "text": "ております通り市長提出案件1件であり"
    },
    {
      "start": 133.92,
      "duration": 3.8,
      "text": "ます部局から発言があればこれを求めます"
    },
    {
      "start": 136.239,
      "duration": 5.921,
      "text": "はい総部"
    },
    {
      "start": 137.72,
      "duration": 9.159,
      "text": "長はいえ令和6年第1回臨時会についてご"
    },
    {
      "start": 142.16,
      "duration": 9.359,
      "text": "説明いたしますえ本臨時会は日を本日7月"
    },
    {
      "start": 146.879,
      "duration": 7.961,
      "text": "18日とし7月11日に自し同日議案を"
    },
    {
      "start": 151.519,
      "duration": 8.681,
      "text": "送付いたしました不議案件につきましては"
    },
    {
      "start": 154.84,
      "duration": 9.08,
      "text": "議案第38号小金石の新長者及び仮称新"
    },
    {
      "start": 160.2,
      "duration": 7.119,
      "text": "福祉会館の建設に関する住民投票条例で"
    },
    {
      "start": 163.92,
      "duration": 6.76,
      "text": "ございますなお本件につきましては令和6"
    },
    {
      "start": 167.319,
      "duration": 7.92,
      "text": "年7月一日付けで提出のあった直接請求に"
    },
    {
      "start": 170.68,
      "duration": 7.88,
      "text": "ついて地方自治法第74条第3項の規定に"
    },
    {
      "start": 175.239,
      "duration": 6.121,
      "text": "基づき市長の意見をつけて区議するもので"
    },
    {
      "start": 178.56,
      "duration": 5.56,
      "text": "ございますよろしくご審議いただきます"
    },
    {
      "start": 181.36,
      "duration": 5.4,
      "text": "ようお願いいたしますえなお本件につき"
    },
    {
      "start": 184.12,
      "duration": 4.64,
      "text": "ましては本会議での即決をお願いいたし"
    },
    {
      "start": 186.76,
      "duration": 5.759,
      "text": "ます以上でござい"
    },
    {
      "start": 188.76,
      "duration": 5.8,
      "text": "ますただ今の総部長の発言の通り市長提出"
    },
    {
      "start": 192.519,
      "duration": 5.8,
      "text": "案件1件についてご確認をいただきたいと"
    },
    {
      "start": 194.56,
      "duration": 7.8,
      "text": "思いますがこれにご異議ありませんかはい"
    },
    {
      "start": 198.319,
      "duration": 7.961,
      "text": "みずあはい水上"
    },
    {
      "start": 202.36,
      "duration": 6.84,
      "text": "委員一応あの住民投票条例に関してはま"
    },
    {
      "start": 206.28,
      "duration": 6.48,
      "text": "即決でお願いしたいとまいうことであり"
    },
    {
      "start": 209.2,
      "duration": 6.36,
      "text": "ました私たちもあの議案等についてはま"
    },
    {
      "start": 212.76,
      "duration": 5.64,
      "text": "基本は委員会負託っていう風なあの考えは"
    },
    {
      "start": 215.56,
      "duration": 6.239,
      "text": "持ってるんですがそれぞれのその案件の"
    },
    {
      "start": 218.4,
      "duration": 6.24,
      "text": "内容やですねあのスケジュールによってま"
    },
    {
      "start": 221.799,
      "duration": 6.241,
      "text": "即決っていうことを認めてきたあの経過が"
    },
    {
      "start": 224.64,
      "duration": 6.679,
      "text": "ありますこの間あの直接請求による住民"
    },
    {
      "start": 228.04,
      "duration": 7.36,
      "text": "投票条例についてはま即決で扱われてき"
    },
    {
      "start": 231.319,
      "duration": 8.76,
      "text": "ましたがあの今回についてはですねあの"
    },
    {
      "start": 235.4,
      "duration": 7.839,
      "text": "住民投票条例をあの要するに議決した後"
    },
    {
      "start": 240.079,
      "duration": 6.401,
      "text": "90日以内に住民投票を行うっていうよう"
    },
    {
      "start": 243.239,
      "duration": 7.321,
      "text": "の条例の中身になってましてそうすると"
    },
    {
      "start": 246.48,
      "duration": 7.319,
      "text": "あのまあ7月31日にま仮にその例えば"
    },
    {
      "start": 250.56,
      "duration": 6.799,
      "text": "可決したとすると11月中にですね住民"
    },
    {
      "start": 253.799,
      "duration": 6.72,
      "text": "投票が終わるとまいう形になってまして"
    },
    {
      "start": 257.359,
      "duration": 5.241,
      "text": "あの市役所長者の建設スケジュールと"
    },
    {
      "start": 260.519,
      "duration": 4.801,
      "text": "考えるとですねもうギリギリタイム"
    },
    {
      "start": 262.6,
      "duration": 5.44,
      "text": "リミットみたいな形にまなってくるのか"
