    },
    {
      "start": 28.32,
      "duration": 8.48,
      "text": "割の決定えさんがえ請求代表者の意見陳述"
    },
    {
      "start": 33.44,
      "duration": 5.959,
      "text": "についてということでこちらの確認を取っ"
