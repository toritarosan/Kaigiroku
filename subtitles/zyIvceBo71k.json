{
  "entries": [
    {
      "start": 25.279,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 72.0,
      "duration": 3.0,
      "text": "ど"
    },
    {
      "start": 133.4,
      "duration": 3.0,
      "text": "な"
    },
    {
      "start": 179.8,
      "duration": 3.0,
      "text": "あ"
    },
    {
      "start": 232.2,
      "duration": 8.0,
      "text": "はいおはようございますおはようござい"
    },
    {
      "start": 234.879,
      "duration": 10.2,
      "text": "ますえこれから会議を開きますが"
    },
    {
      "start": 240.2,
      "duration": 8.92,
      "text": "が出ておりますえ都市整備部長が体調不良"
    },
    {
      "start": 245.079,
      "duration": 7.8,
      "text": "のため欠席ですまた合わせてえ議長もです"
    },
    {
      "start": 249.12,
      "duration": 8.32,
      "text": "ね今日体調不良のため欠席をされるという"
    },
    {
      "start": 252.879,
      "duration": 7.48,
      "text": "ことで副議長の私が変わりましてあの運営"
    },
    {
      "start": 257.44,
      "duration": 6.96,
      "text": "をさせていただきますので皆さんのご協力"
    },
    {
      "start": 260.359,
      "duration": 4.041,
      "text": "よろしくお願いいたします"
    },
    {
      "start": 270.36,
      "duration": 5.64,
      "text": "全部"
    },
    {
      "start": 272.24,
      "duration": 3.76,
      "text": "はいはいはいき"
    },
    {
      "start": 277.72,
      "duration": 5.12,
      "text": "ましょうおはようございますおはよう"
    },
    {
      "start": 280.199,
      "duration": 6.44,
      "text": "ございますただ今から本日の会議を開き"
    },
    {
      "start": 282.84,
      "duration": 7.199,
      "text": "ます議長が欠席のため副議長が変わって"
    },
    {
      "start": 286.639,
      "duration": 7.041,
      "text": "議長の職務を行いますのでご協力のほど"
    },
    {
      "start": 290.039,
      "duration": 6.681,
      "text": "よろしくお願い申し上げます12月17日"
    },
    {
      "start": 293.68,
      "duration": 7.0,
      "text": "に議会運営委員会を開催していますので"
    },
    {
      "start": 296.72,
      "duration": 6.72,
      "text": "議会運営委員長の報告を求めます3番岸田"
    },
    {
      "start": 300.68,
      "duration": 2.76,
      "text": "正義委員"
    },
    {
      "start": 306.72,
      "duration": 5.199,
      "text": "長12月17日に議会運営委員会を開催"
    },
    {
      "start": 310.28,
      "duration": 5.28,
      "text": "いたしましたのでその結果につきましてご"
    },
    {
      "start": 311.919,
      "duration": 7.72,
      "text": "報告いたします陳乗者から令和6年12月"
    },
    {
      "start": 315.56,
      "duration": 6.479,
      "text": "1日付けで6陳情第61号について陳情書"
    },
    {
      "start": 319.639,
      "duration": 4.881,
      "text": "の訂正の申し出が提出されましたのでその"
    },
    {
      "start": 322.039,
      "duration": 4.88,
      "text": "取り扱いについて協議いたしましたその"
    },
    {
      "start": 324.52,
      "duration": 5.92,
      "text": "結果本件については本日の本会議において"
    },
    {
      "start": 326.919,
      "duration": 7.881,
      "text": "所定の手続きを取ることと決定いたします"
    },
    {
      "start": 330.44,
      "duration": 7.24,
      "text": "次に選挙理委員及び同員の選挙について"
    },
    {
      "start": 334.8,
      "duration": 4.88,
      "text": "協議をいしましたその結果本については"
    },
    {
      "start": 337.68,
      "duration": 4.44,
      "text": "いずれも本日の本会議において所定の"
    },
    {
      "start": 339.68,
      "duration": 6.2,
      "text": "手続きを取ることと決定いたしました以上"
    },
    {
      "start": 342.12,
      "duration": 7.6,
      "text": "で議会委員会の報告を終了いたし"
    },
    {
      "start": 345.88,
      "duration": 7.599,
      "text": "ます議会運営委員長の報告に対して質疑は"
    },
    {
      "start": 349.72,
      "duration": 7.24,
      "text": "ありませんか質疑を終了することにご異議"
    },
    {
      "start": 353.479,
      "duration": 6.56,
      "text": "ありませんかご異議なしと認め質疑を終了"
    },
    {
      "start": 356.96,
      "duration": 6.799,
      "text": "いたします議会運営委員長の報告終了"
    },
    {
      "start": 360.039,
      "duration": 6.361,
      "text": "いたしますお諮りいたします議会運営委員"
    },
    {
      "start": 363.759,
      "duration": 6.401,
      "text": "長の報告通り決定することにご異議あり"
    },
    {
      "start": 366.4,
      "duration": 8.28,
      "text": "ませんかご異議なしと認め議会運営委員長"
    },
    {
      "start": 370.16,
      "duration": 8.8,
      "text": "の報告通り決定をいたしました日程第1"
    },
    {
      "start": 374.68,
      "duration": 8.0,
      "text": "議案第55号古賀市放課後児童健全育成"
    },
    {
      "start": 378.96,
      "duration": 8.679,
      "text": "事業の設備及び運営に関する基準を定める"
    },
    {
      "start": 382.68,
      "duration": 8.799,
      "text": "条例の一部を改正する条例から日程第11"
    },
    {
      "start": 387.639,
      "duration": 7.481,
      "text": "議案第59号小金年市役所庁舎変更に"
    },
    {
      "start": 391.479,
      "duration": 8.241,
      "text": "関する条例の一部を改正する条例までの"
    },
    {
      "start": 395.12,
      "duration": 8.479,
      "text": "11件を一括して議題といたします以上"
    },
    {
      "start": 399.72,
      "duration": 8.039,
      "text": "11件について各委員長の報告を求めます"
    },
    {
      "start": 403.599,
      "duration": 7.361,
      "text": "厚生文教委員長の報告を求めます2番富春"
    },
    {
      "start": 407.759,
      "duration": 3.201,
      "text": "泰孝委員長"
    },
    {
      "start": 416.44,
      "duration": 8.479,
      "text": "はいはいどはい私が手さん"
    },
    {
      "start": 421.08,
      "duration": 7.28,
      "text": "はいどうぞはい厚生文教委員会委長報告を"
    },
    {
      "start": 424.919,
      "duration": 7.361,
      "text": "行います厚生文教委員会は令は6年12月"
    },
    {
      "start": 428.36,
      "duration": 6.76,
      "text": "9日に開催し議案2件陳情5件所管事務"
    },
    {
      "start": 432.28,
      "duration": 5.28,
      "text": "調査2件の経9件を申請いたしましたので"
    },
    {
      "start": 435.12,
      "duration": 7.28,
      "text": "その審査の概要と結果につきましてご報告"
    },
    {
      "start": 437.56,
      "duration": 9.319,
      "text": "申し上げますなお6陳情第53号障害時"
    },
    {
      "start": 442.4,
      "duration": 7.84,
      "text": "短期入所施設の新設と季節施設の支援拡大"
    },
    {
      "start": 446.879,
      "duration": 6.04,
      "text": "を求める賃上昇につきましては引きき審査"
    },
    {
      "start": 450.24,
      "duration": 6.44,
      "text": "する必要があると認め継続審査と決定して"
    },
    {
      "start": 452.919,
      "duration": 7.641,
      "text": "おりますまた所管事務調査障害福祉計画"
    },
    {
      "start": 456.68,
      "duration": 8.0,
      "text": "及び介護保険高齢者高齢者保険福祉総合"
    },
    {
      "start": 460.56,
      "duration": 6.479,
      "text": "事業計画について及び所管事務調査保育"
    },
    {
      "start": 464.68,
      "duration": 5.199,
      "text": "政策の課題についての以上2件につきまし"
    },
    {
      "start": 467.039,
      "duration": 6.84,
      "text": "ては引き続き調査する必要があると認め"
    },
    {
      "start": 469.879,
      "duration": 7.6,
      "text": "継続調査と決定しております議案第55号"
    },
    {
      "start": 473.879,
      "duration": 9.16,
      "text": "古賀課後児童健全"
    },
    {
      "start": 477.479,
      "duration": 8.961,
      "text": "育成します第55号古賀放課後児童健全"
    },
    {
      "start": 483.039,
      "duration": 6.12,
      "text": "育成事業の設備及び運営に関する基準を"
    },
    {
      "start": 486.44,
      "duration": 5.84,
      "text": "求めるえ基準を定める条例の一部を改正"
    },
    {
      "start": 489.159,
      "duration": 5.88,
      "text": "する条例本件につきましては令和6年11"
    },
    {
      "start": 492.28,
      "duration": 6.12,
      "text": "月28日の本会議において当委員会に付託"
    },
    {
      "start": 495.039,
      "duration": 7.201,
      "text": "され12月9日に審査を行いました同日の"
    },
    {
      "start": 498.4,
      "duration": 6.639,
      "text": "委員会では質疑を終了し採決の結果原案の"
    },
    {
      "start": 502.24,
      "duration": 8.399,
      "text": "通り可決すべきものと決定いたしました"
    },
    {
      "start": 505.039,
      "duration": 8.521,
      "text": "議案第58号古賀年始総合体館及び小川市"
    },
    {
      "start": 510.639,
      "duration": 5.921,
      "text": "栗山公園健康運動センターの指定管理者の"
    },
    {
      "start": 513.56,
      "duration": 5.959,
      "text": "指定について本件につきましては令和6年"
    },
    {
      "start": 516.56,
      "duration": 6.159,
      "text": "11月28日の本会議において当委員会に"
    },
    {
      "start": 519.519,
      "duration": 6.081,
      "text": "付託され12月9日に審査を行いました"
    },
    {
      "start": 522.719,
      "duration": 6.321,
      "text": "同日の委員会では質疑を終了し採決の結果"
    },
    {
      "start": 525.6,
      "duration": 7.44,
      "text": "可決すべきものと決定いたしました6陳情"
    },
    {
      "start": 529.04,
      "duration": 6.84,
      "text": "第6号学校給食学校給食費の無償化を"
    },
    {
      "start": 533.04,
      "duration": 6.68,
      "text": "求める賃上昇本件につきましては令和6年"
    },
    {
      "start": 535.88,
      "duration": 8.44,
      "text": "3月26日の本会議において党員委員に"
    },
    {
      "start": 539.72,
      "duration": 7.84,
      "text": "付託され4月18日8月2日11月19日"
    },
    {
      "start": 544.32,
      "duration": 6.28,
      "text": "及び12月9日の計4回にあたり審査を"
    },
    {
      "start": 547.56,
      "duration": 6.16,
      "text": "行いました12月9日の委員会では委員"
    },
    {
      "start": 550.6,
      "duration": 5.6,
      "text": "から次の意見要望がなされましたまずこれ"
    },
    {
      "start": 553.72,
      "duration": 7.559,
      "text": "までも述べてきたように小金を面白くする"
    },
    {
      "start": 556.2,
      "duration": 8.36,
      "text": "会は給食の無償化は本来国の責任において"
    },
    {
      "start": 561.279,
      "duration": 6.8,
      "text": "実施すべきものと考えている尋常項目1の"
    },
    {
      "start": 564.56,
      "duration": 6.88,
      "text": "国に対する要望は本年3月25日に小金"
    },
    {
      "start": 568.079,
      "duration": 6.32,
      "text": "市議会として前回1で意見証を可決し国に"
    },
    {
      "start": 571.44,
      "duration": 6.36,
      "text": "提出するなどの働きかけを既に行っている"
    },
    {
      "start": 574.399,
      "duration": 7.88,
      "text": "また尋常科目2と3についてはこれまでの"
    },
    {
      "start": 577.8,
      "duration": 8.68,
      "text": "え市長会などからの働きかけにより東京都"
    },
    {
      "start": 582.279,
      "duration": 6.961,
      "text": "が公立小中学校の給食費の8を補助すると"
    },
    {
      "start": 586.48,
      "duration": 6.12,
      "text": "いう姿勢を打ち出したことを受け次第市長"
    },
    {
      "start": 589.24,
      "duration": 6.2,
      "text": "が本本定例会において補正予算を提案して"
    },
    {
      "start": 592.6,
      "duration": 6.799,
      "text": "おり三岳期から無償化が実現することと"
    },
    {
      "start": 595.44,
      "duration": 6.399,
      "text": "なった一方で項目4の不登校の児童制とは"
    },
    {
      "start": 599.399,
      "duration": 4.841,
      "text": "一部支援の対象となることが想定されるが"
    },
    {
      "start": 601.839,
      "duration": 7.041,
      "text": "学校へ投稿していない児童に対しての支援"
    },
    {
      "start": 604.24,
      "duration": 8.56,
      "text": "は課題が残る項目5の国立学校私立学校わ"
    },
    {
      "start": 608.88,
      "duration": 6.24,
      "text": "私立学校に通う児童生徒については将来的"
    },
    {
      "start": 612.8,
      "duration": 5.479,
      "text": "には支援が実現さげれることが望ましいと"
    },
    {
      "start": 615.12,
      "duration": 5.92,
      "text": "考えているが今般示されている東京都の"
    },
    {
      "start": 618.279,
      "duration": 5.68,
      "text": "スキームでは対象に含まれておらず市が"
    },
    {
      "start": 621.04,
      "duration": 6.0,
      "text": "独自の財源を用いて仕組みを構築し実現"
    },
    {
      "start": 623.959,
      "duration": 5.961,
      "text": "することには課題が大きい尋常審査の中で"
    },
    {
      "start": 627.04,
      "duration": 5.239,
      "text": "明らかになったように多26の中ででも"
    },
    {
      "start": 629.92,
      "duration": 4.84,
      "text": "これらを実現している自治体が存在しない"
    },
    {
      "start": 632.279,
      "duration": 6.68,
      "text": "という点からもその課題が大きいことが"
    },
    {
      "start": 634.76,
      "duration": 6.8,
      "text": "伺える学校給食が子供たちの心と体を育む"
    },
    {
      "start": 638.959,
      "duration": 5.721,
      "text": "ために大切なものであるという尋常の考え"
    },
    {
      "start": 641.56,
      "duration": 6.2,
      "text": "考え方には大いに賛同するものであり"
    },
    {
      "start": 644.68,
      "duration": 5.04,
      "text": "引き続き国や都に対して全ての児童生徒を"
    },
    {
      "start": 647.76,
      "duration": 5.04,
      "text": "対象とするを求めていくことは必要と"
    },
    {
      "start": 649.72,
      "duration": 5.559,
      "text": "考えるが現時点においては市に対してこれ"
    },
    {
      "start": 652.8,
      "duration": 6.68,
      "text": "を心情するを求めることは難しいと考える"
    },
    {
      "start": 655.279,
      "duration": 7.161,
      "text": "ことから本賃常所の採決には反対する12"
    },
    {
      "start": 659.48,
      "duration": 6.76,
      "text": "月9日の委員会では質疑を終了し起立採決"
    },
    {
      "start": 662.44,
      "duration": 7.92,
      "text": "の結果起立少数により普通採択すべきもの"
    },
    {
      "start": 666.24,
      "duration": 6.76,
      "text": "と決定いたしました6陳情第31号主催者"
    },
    {
      "start": 670.36,
      "duration": 6.32,
      "text": "なのに業務の情報を持ち合わせていない"
    },
    {
      "start": 673.0,
      "duration": 6.079,
      "text": "教育委員会の退行を改善すべとする賃常書"
    },
    {
      "start": 676.68,
      "duration": 6.24,
      "text": "本件につきましては令和6年9月10日の"
    },
    {
      "start": 679.079,
      "duration": 7.921,
      "text": "本会議において党員会に付託され9月12"
    },
    {
      "start": 682.92,
      "duration": 7.28,
      "text": "日11月19日及び12月9日の計3会に"
    },
    {
      "start": 687.0,
      "duration": 7.079,
      "text": "あたり審査を行いました12月の委員会で"
    },
    {
      "start": 690.2,
      "duration": 7.52,
      "text": "は質疑を終了し起立採決の結果起立少数に"
    },
    {
      "start": 694.079,
      "duration": 9.081,
      "text": "より不採択すべきものと決定いたしまし"
    },
    {
      "start": 697.72,
      "duration": 8.359,
      "text": "た6賃条第35号ス所事業の時間帯や施設"
    },
    {
      "start": 703.16,
      "duration": 6.119,
      "text": "指定において市民の生存権を守るという"
    },
    {
      "start": 706.079,
      "duration": 5.921,
      "text": "視点で取り組むことを求める陳情賞本件に"
    },
    {
      "start": 709.279,
      "duration": 6.0,
      "text": "つきましては令和6年9月10日の本会議"
    },
    {
      "start": 712.0,
      "duration": 5.399,
      "text": "において党員会に付託され9月12日11"
    },
    {
      "start": 715.279,
      "duration": 5.721,
      "text": "月19日"
    },
    {
      "start": 717.399,
      "duration": 6.641,
      "text": "及び12月9日の計算会にあたる審査を"
    },
    {
      "start": 721.0,
      "duration": 6.32,
      "text": "行いました12月9日の委員会では委員"
    },
    {
      "start": 724.04,
      "duration": 5.919,
      "text": "から次の意見要望がなされました本陳上に"
    },
    {
      "start": 727.32,
      "duration": 5.639,
      "text": "は具体的な8つの項目が挙げられており"
    },
    {
      "start": 729.959,
      "duration": 5.961,
      "text": "その中の本庁者4会の議場や図書館のよう"
    },
    {
      "start": 732.959,
      "duration": 6.56,
      "text": "に指定することで帰って混乱を招く恐れが"
    },
    {
      "start": 735.92,
      "duration": 6.8,
      "text": "あるえ帰って今を招く恐れがあるような"
    },
    {
      "start": 739.519,
      "duration": 6.201,
      "text": "場所は避けるなどえ現場を管理者として"
    },
    {
      "start": 742.72,
      "duration": 5.0,
      "text": "よく調整し来年に向けて進み所を従事する"
    },
    {
      "start": 745.72,
      "duration": 6.04,
      "text": "ことが必要で"
    },
    {
      "start": 747.72,
      "duration": 7.2,
      "text": "あるまた別の委員から本陳上はス所事業の"
    },
    {
      "start": 751.76,
      "duration": 7.079,
      "text": "時間帯や施設指定において市民の生存権を"
    },
    {
      "start": 754.92,
      "duration": 6.719,
      "text": "守る視点え市民の生存権を守る視点で"
    },
    {
      "start": 758.839,
      "duration": 5.521,
      "text": "取り組むことを求める陳情書であるこの間"
    },
    {
      "start": 761.639,
      "duration": 6.76,
      "text": "の気候変動により子宮沸騰化が起こって"
    },
    {
      "start": 764.36,
      "duration": 6.479,
      "text": "いる中高齢者や低所得者世帯などを含めて"
    },
    {
      "start": 768.399,
      "duration": 4.601,
      "text": "電気体が大変かかってクーラーもつけて"
    },
    {
      "start": 770.839,
      "duration": 5.401,
      "text": "ないえクーラーもつけないで1日過ごす"
    },
    {
      "start": 773.0,
      "duration": 5.519,
      "text": "課程もあるそのことによる健康の問題など"
    },
    {
      "start": 776.24,
      "duration": 4.039,
      "text": "も大きな問題としてクローズアップされて"
    },
    {
      "start": 778.519,
      "duration": 4.521,
      "text": "いる"
    },
    {
      "start": 780.279,
      "duration": 5.441,
      "text": "その点から考えるとこの陳情の趣旨で述べ"
    },
    {
      "start": 783.04,
      "duration": 5.56,
      "text": "られている市民の生存権を求めるえ守る"
    },
    {
      "start": 785.72,
      "duration": 6.119,
      "text": "ために住所を拡大してほしいというこの"
    },
    {
      "start": 788.6,
      "duration": 5.56,
      "text": "趣旨は大いに賛同するところであるただ8"
    },
    {
      "start": 791.839,
      "duration": 4.641,
      "text": "項目の中で議会を進みどろにすることに"
    },
    {
      "start": 794.16,
      "duration": 4.88,
      "text": "ついては議会ではやはり難しいだろうと"
    },
    {
      "start": 796.48,
      "duration": 5.479,
      "text": "いう判断になったことなどもあり実態とわ"
    },
    {
      "start": 799.04,
      "duration": 5.479,
      "text": "ないところもある是非実現可能なところ"
    },
    {
      "start": 801.959,
      "duration": 4.841,
      "text": "から私は進めるべきだと思っており陳情"
    },
    {
      "start": 804.519,
      "duration": 5.44,
      "text": "全体の出身に賛同するという立場からこの"
    },
    {
      "start": 806.8,
      "duration": 6.479,
      "text": "陳情に一定の態度を示していきたいまた別"
    },
    {
      "start": 809.959,
      "duration": 6.521,
      "text": "の委員からこの陳情については8項目の"
    },
    {
      "start": 813.279,
      "duration": 7.081,
      "text": "要望が具体的に記述されている閉会時の"
    },
    {
      "start": 816.48,
      "duration": 6.84,
      "text": "事業の解放や新長者に果たして有体部がん"
    },
    {
      "start": 820.36,
      "duration": 6.839,
      "text": "有給部があるか有給部があるのかどうかと"
    },
    {
      "start": 823.32,
      "duration": 6.4,
      "text": "いうこともあるがこの議場の解放や休日の"
    },
    {
      "start": 827.199,
      "duration": 5.32,
      "text": "長者のロビーの解放など実現するには"
    },
    {
      "start": 829.72,
      "duration": 5.08,
      "text": "なかなか難しい項目があるもちろん進み"
    },
    {
      "start": 832.519,
      "duration": 5.24,
      "text": "どろを増やしていくということは近年の"
    },
    {
      "start": 834.8,
      "duration": 5.44,
      "text": "厳しい厚さのことを考えると当然必要と"
    },
    {
      "start": 837.759,
      "duration": 6.361,
      "text": "思うところであるが実現できないなかなか"
    },
    {
      "start": 840.24,
      "duration": 5.599,
      "text": "難しい現状ではなかなか難しい現状では"
    },
    {
      "start": 844.12,
      "duration": 4.76,
      "text": "できない項目があるということを踏まえて"
    },
    {
      "start": 845.839,
      "duration": 6.24,
      "text": "採決態度を表明していきたいと考えるまた"
    },
    {
      "start": 848.88,
      "duration": 6.04,
      "text": "別の委員から市議会公明党としては進みど"
    },
    {
      "start": 852.079,
      "duration": 4.721,
      "text": "自体に反対するものではなくさらなる拡充"
    },
    {
      "start": 854.92,
      "duration": 4.599,
      "text": "を求めるということは同じ思いである"
    },
    {
      "start": 856.8,
      "duration": 5.279,
      "text": "しかしどうしてもこの尋常項目の中には"
    },
    {
      "start": 859.519,
      "duration": 6.0,
      "text": "現実が難しいということもありできれば"
    },
    {
      "start": 862.079,
      "duration": 5.961,
      "text": "主旨採択ではえ支採択でということで提案"
    },
    {
      "start": 865.519,
      "duration": 4.641,
      "text": "させていただいたが一致できなかったので"
    },
    {
      "start": 868.04,
      "duration": 5.44,
      "text": "一点の判断をさせいただきたいと思って"
    },
    {
      "start": 870.16,
      "duration": 6.119,
      "text": "いるまた別の委員から進みどを増やして"
    },
    {
      "start": 873.48,
      "duration": 5.56,
      "text": "欲しいという趣旨には賛同するが新城者が"
    },
    {
      "start": 876.279,
      "duration": 6.92,
      "text": "言うとりあえず実現的そうな場所を指定え"
    },
    {
      "start": 879.04,
      "duration": 7.12,
      "text": "指定しただけということにとまらず市は"
    },
    {
      "start": 883.199,
      "duration": 5.401,
      "text": "市民の命を守るために外年度以降の拡充に"
    },
    {
      "start": 886.16,
      "duration": 5.2,
      "text": "ついても前向きに検討を進めているその"
    },
    {
      "start": 888.6,
      "duration": 5.919,
      "text": "一方で具体的に要望されている8項目の中"
    },
    {
      "start": 891.36,
      "duration": 5.76,
      "text": "には事情や図書館など進みどころとして"
    },
    {
      "start": 894.519,
      "duration": 5.841,
      "text": "指定するには適さない場所が含まれており"
    },
    {
      "start": 897.12,
      "duration": 7.48,
      "text": "尋常項目を全て実現すること難しいこと"
    },
    {
      "start": 900.36,
      "duration": 7.719,
      "text": "から本地上の採択には判定する以上で質疑"
    },
    {
      "start": 904.6,
      "duration": 6.44,
      "text": "を終了し起立採決の結果起立多数により"
    },
    {
      "start": 908.079,
      "duration": 7.12,
      "text": "採択の上地象に送付すべきものと決定"
    },
    {
      "start": 911.04,
      "duration": 7.32,
      "text": "いたしました6陳情第45号市民体育祭"
    },
    {
      "start": 915.199,
      "duration": 5.56,
      "text": "ゴルフ協議における応募者募集の改善を"
    },
    {
      "start": 918.36,
      "duration": 5.919,
      "text": "求める陳情"
    },
    {
      "start": 920.759,
      "duration": 6.52,
      "text": "書本件につきましては令和6年10月8日"
    },
    {
