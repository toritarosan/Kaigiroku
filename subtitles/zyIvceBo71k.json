      "start": 1749.0,
      "duration": 8.32,
      "text": "おいて指名することと決定をいたしました"
    },
    {
      "start": 1752.72,
      "duration": 10.959,
      "text": "小金市選挙管理員補充員には次の順位で"
    },
    {
      "start": 1757.32,
      "duration": 11.599,
      "text": "指名いたします第1順位伊信夫さん第2"
    },
    {
      "start": 1763.679,
      "duration": 10.641,
      "text": "順位宮川俊夫さん第3順位"
    },
    {
      "start": 1768.919,
      "duration": 9.161,
      "text": "藤一郎さん第4順位真"
    },
    {
      "start": 1774.32,
      "duration": 7.04,
      "text": "さんお諮りいたしますただいま副議長に"
    },
    {
      "start": 1778.08,
      "duration": 7.64,
      "text": "おいて指名いたしました順位の通り4人の"
    },
    {
      "start": 1781.36,
      "duration": 7.84,
      "text": "皆さんを小金市選挙管理員保住院の当選人"
    },
    {
      "start": 1785.72,
      "duration": 6.64,
      "text": "と定めることにご異議ありませんかご異議"
    },
    {
      "start": 1789.2,
      "duration": 6.959,
      "text": "なしと認め以上の順位で指名いたしました"
    },
    {
      "start": 1792.36,
      "duration": 7.039,
      "text": "4人の皆さんが小金市選挙管理院補充員に"
    },
    {
      "start": 1796.159,
      "duration": 7.4,
      "text": "当選されましたなおただいま当選されまし"
    },
    {
      "start": 1799.399,
      "duration": 7.601,
      "text": "た皆様皆さんには会議規則第32条第2項"
    },
    {
      "start": 1803.559,
      "duration": 6.72,
      "text": "の規定により議長において5国告知の"
    },
    {
      "start": 1807.0,
      "duration": 6.32,
      "text": "手続きを取らせていただきます会派代表者"
    },
    {
      "start": 1810.279,
      "duration": 5.88,
      "text": "会議を開催するためしばらく休憩いたし"
    },
    {
      "start": 1813.32,
      "duration": 2.839,
      "text": "ますはい"
    },
    {
      "start": 1826.96,
      "duration": 4.0,
      "text": "はいJA"
    }
  ]
