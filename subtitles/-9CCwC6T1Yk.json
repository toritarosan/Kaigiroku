{
  "entries": [
    {
      "start": 76.68,
      "duration": 3.0,
      "text": "あ"
    },
    {
      "start": 164.64,
      "duration": 7.4,
      "text": "はい再開いたします休憩前に引き続き質疑"
    },
    {
      "start": 168.2,
      "duration": 7.6,
      "text": "を行いますえ疑似進行から始めるのはい"
    },
    {
      "start": 172.04,
      "duration": 9.04,
      "text": "森戸さんえっと先ほどですね市長からこの"
    },
    {
      "start": 175.8,
      "duration": 7.92,
      "text": "休憩前入る前にあの発言ががありましたで"
    },
    {
      "start": 181.08,
      "duration": 8.079,
      "text": "ちょっともう1回確認したいのはですね"
    },
    {
      "start": 183.72,
      "duration": 9.36,
      "text": "あのま2月17日の主張報告の件について"
    },
    {
      "start": 189.159,
      "duration": 7.961,
      "text": "ま今日撤回願が出てるんですがこれは行政"
    },
    {
      "start": 193.08,
      "duration": 5.239,
      "text": "決定として撤回願を出しているとで従って"
    },
    {
      "start": 197.12,
      "duration": 4.839,
      "text": "ですね"
    },
    {
      "start": 198.319,
      "duration": 7.601,
      "text": "このここで書かれている総合的判断につい"
    },
    {
      "start": 201.959,
      "duration": 6.801,
      "text": "ては白死であるということで良いかどうか"
    },
    {
      "start": 205.92,
      "duration": 6.12,
      "text": "ですねそれをちょっともう1回確認させて"
    },
    {
      "start": 208.76,
      "duration": 6.88,
      "text": "くださいそれと2つ目にはですね従って"
    },
    {
      "start": 212.04,
      "duration": 6.0,
      "text": "市長が先ほど来ま個人的にどうなんだって"
    },
    {
      "start": 215.64,
      "duration": 7.08,
      "text": "聞かれたから答えたっておっしゃったです"
    },
    {
      "start": 218.04,
      "duration": 8.839,
      "text": "ね3411号戦についてのあの必要性は"
    },
    {
      "start": 222.72,
      "duration": 7.0,
      "text": "否めないという言葉やあの環境に配慮して"
    },
    {
      "start": 226.879,
      "duration": 6.64,
      "text": "あの進めていくということそれから"
    },
    {
      "start": 229.72,
      "duration": 7.48,
      "text": "34111号戦についてはえ一旦中止する"
    },
    {
      "start": 233.519,
      "duration": 8.0,
      "text": "というこれはですね個人的な見解であるの"
    },
    {
      "start": 237.2,
      "duration": 7.28,
      "text": "でということですよね従って私はもし個人"
    },
    {
      "start": 241.519,
      "duration": 6.841,
      "text": "的な見解であるとしたらですねやっぱり"
    },
    {
      "start": 244.48,
      "duration": 5.92,
      "text": "それはあの発言を撤回された方がいいん"
    },
    {
      "start": 248.36,
      "duration": 6.599,
      "text": "じゃないでしょうか"
    },
    {
      "start": 250.4,
      "duration": 8.0,
      "text": "あのやはりですねあの個人的な見解をこの"
    },
    {
      "start": 254.959,
      "duration": 7.761,
      "text": "市議会の場で述べるというのはあのそわ"
    },
    {
      "start": 258.4,
      "duration": 6.76,
      "text": "ないと思うんですねでそういう点では私は"
    },
    {
      "start": 262.72,
      "duration": 6.479,
      "text": "あのきちっとあの混乱を起こさないために"
    },
    {
      "start": 265.16,
      "duration": 7.12,
      "text": "もですねあのそこの発言をあの撤回される"
    },
    {
      "start": 269.199,
      "duration": 5.481,
      "text": "必要がかなと思いますので議長の方でもお"
    },
    {
      "start": 272.28,
      "duration": 5.88,
      "text": "取り計いをお願いしたいと思いますはい"
    },
    {
      "start": 274.68,
      "duration": 6.88,
      "text": "あの議事進行はい小林さん今の森戸さんの"
    },
    {
      "start": 278.16,
      "duration": 7.92,
      "text": "あの銀進行はすごく全頭だと思っており"
    },
    {
      "start": 281.56,
      "duration": 7.96,
      "text": "ましてあの個人的な見解って言ありました"
    },
    {
      "start": 286.08,
      "duration": 6.2,
      "text": "けどこの場でねあの白井さん個人的な話"
    },
    {
      "start": 289.52,
      "duration": 4.64,
      "text": "ってのはないわけですよあの行政決定の"
    },
    {
      "start": 292.28,
      "duration": 4.8,
      "text": "そのプロセスがまだ踏まれていないにして"
    },
    {
      "start": 294.16,
      "duration": 5.2,
      "text": "もこれ市長白井さんとして発言をされてる"
    },
    {
      "start": 297.08,
      "duration": 4.44,
      "text": "わけだからそれを1回ポロっと言ったわけ"
    },
    {
      "start": 299.36,
      "duration": 4.559,
      "text": "じゃなくもうこの間ずっと言われてるわけ"
    },
    {
      "start": 301.52,
      "duration": 5.72,
      "text": "だからそれはまどっちを撤回するかって"
    },
    {
      "start": 303.919,
      "duration": 6.881,
      "text": "いう意味でねうんあのよくよく精査してご"
    },
    {
      "start": 307.24,
      "duration": 7.04,
      "text": "答弁いただきたいはいえ議事を進行したい"
    },
    {
      "start": 310.8,
      "duration": 6.92,
      "text": "というお2人からの発言と受け止めまして"
    },
    {
      "start": 314.28,
      "duration": 5.28,
      "text": "え進めたいと思いますなんか発言あれた"
    },
    {
      "start": 317.72,
      "duration": 4.84,
      "text": "はい"
    },
    {
      "start": 319.56,
      "duration": 5.52,
      "text": "市長議進行いただきましたあのまず森さん"
    },
    {
      "start": 322.56,
      "duration": 6.24,
      "text": "の一点目に関してはですねえっと確かこう"
    },
    {
      "start": 325.08,
      "duration": 6.839,
      "text": "聞かれました2月17日の相報告はえっと"
    },
    {
      "start": 328.8,
      "duration": 4.679,
      "text": "行政決定として撤回願いを出しているので"
    },
    {
      "start": 331.919,
      "duration": 4.0,
      "text": "拍手であるということで良いかということ"
    },
    {
      "start": 333.479,
      "duration": 4.641,
      "text": "でございますがあの行政決定という観点に"
    },
    {
      "start": 335.919,
      "duration": 6.0,
      "text": "おいてあのその通りだと認識をしており"
    },
    {
      "start": 338.12,
      "duration": 5.84,
      "text": "ますでえっと2点目の個人的な見解は撤回"
    },
    {
      "start": 341.919,
      "duration": 5.481,
      "text": "した方がいいのではないか小林さんの方"
    },
    {
      "start": 343.96,
      "duration": 5.48,
      "text": "からはえっとおそらく個人的なっていう"
    },
    {
      "start": 347.4,
      "duration": 4.12,
      "text": "ことをえっと撤回した方がいいんじゃない"
    },
    {
      "start": 349.44,
      "duration": 5.039,
      "text": "かというちょっと両方からのあのご意見を"
    },
    {
      "start": 351.52,
      "duration": 5.88,
      "text": "いだいておりますあのまずあのどう"
    },
    {
      "start": 354.479,
      "duration": 6.16,
      "text": "でしょうこれまでですねえっと議会の場に"
    },
    {
      "start": 357.4,
      "duration": 5.84,
      "text": "おいてえま決まってないあけど市長はどう"
    },
    {
      "start": 360.639,
      "duration": 5.96,
      "text": "考えてるんだとかていう個人的な見解は"
    },
    {
      "start": 363.24,
      "duration": 5.799,
      "text": "多数私は聞かれてきたと思いますえその間"
    },
    {
      "start": 366.599,
      "duration": 7.0,
      "text": "述べられる範囲で私は述べてきたと思って"
    },
    {
      "start": 369.039,
      "duration": 7.761,
      "text": "ますのでえっとま個人的な見解にえでは"
    },
    {
      "start": 373.599,
      "duration": 5.561,
      "text": "ありますがあの述べさせていただいた次第"
    },
    {
      "start": 376.8,
      "duration": 7.44,
      "text": "です"
    },
    {
      "start": 379.16,
      "duration": 9.24,
      "text": "え的はい個人的な見解としてね市長個人と"
    },
    {
      "start": 384.24,
      "duration": 6.519,
      "text": "してちょっとあの要するにですね行政決定"
    },
    {
      "start": 388.4,
      "duration": 7.0,
      "text": "してないけども私は今そう思ってますと"
    },
    {
      "start": 390.759,
      "duration": 8.241,
      "text": "いうことです以上です義次進行渡大蔵さん"
    },
    {
      "start": 395.4,
      "duration": 7.239,
      "text": "えっと一般論としてですよ市議会のあの"
    },
    {
      "start": 399.0,
      "duration": 6.12,
      "text": "質疑の中で市長があの個人的な考え方とか"
    },
    {
      "start": 402.639,
      "duration": 4.12,
      "text": "思いとか述べることはあると思いますし"
    },
    {
      "start": 405.12,
      "duration": 6.24,
      "text": "あっちゃいけないと別に言ってるつもりは"
    },
    {
      "start": 406.759,
      "duration": 7.84,
      "text": "ないんです今回の場合は撤回の議案のあの"
    },
    {
      "start": 411.36,
      "duration": 5.88,
      "text": "説明や答弁の中で出てくるからおかしいん"
    },
    {
      "start": 414.599,
      "duration": 5.16,
      "text": "ですよ撤回って言ってる以上はあのそこの"
    },
    {
      "start": 417.24,
      "duration": 6.12,
      "text": "部分に関しては0になるわけですからこの"
    },
    {
      "start": 419.759,
      "duration": 5.801,
      "text": "結論部分が市長の頭の中の判断としてもう"
    },
    {
      "start": 423.36,
      "duration": 4.76,
      "text": "あってしかもその頭の中にあるだけじゃ"
    },
    {
      "start": 425.56,
      "duration": 4.919,
      "text": "なくて本会議の場で自分の考え方として"
    },
    {
      "start": 428.12,
      "duration": 5.079,
      "text": "述べられるのは撤回議案とは整合しない"
    },
    {
      "start": 430.479,
      "duration": 4.601,
      "text": "からということで森戸さんは言われてるん"
    },
    {
      "start": 433.199,
      "duration": 4.44,
      "text": "だろうという風に思っていてその観点に"
    },
    {
      "start": 435.08,
      "duration": 4.6,
      "text": "おいてあの個人的な見解を述べられこの"
    },
    {
      "start": 437.639,
      "duration": 4.201,
      "text": "撤回議案に関しての質疑をしている中で"
    },
    {
      "start": 439.68,
      "duration": 5.16,
      "text": "個人的見解を述べられたところはえそれ"
    },
    {
      "start": 441.84,
      "duration": 5.96,
      "text": "こそあの撤回訂正されるべきあの削除さ"
    },
    {
      "start": 444.84,
      "duration": 5.0,
      "text": "れるべきだと思うんですつまりあの一般論"
    },
    {
      "start": 447.8,
      "duration": 4.16,
      "text": "的に市長が個人的な思いを述べることは"
    },
    {
      "start": 449.84,
      "duration": 4.52,
      "text": "ありえますが撤回議案との兼ね合いにおい"
    },
    {
      "start": 451.96,
      "duration": 5.079,
      "text": "てはそう整理しないと整理がつかなくなる"
    },
    {
      "start": 454.36,
      "duration": 4.76,
      "text": "ということを述べてあのいるのでそう議長"
    },
    {
      "start": 457.039,
      "duration": 4.761,
      "text": "ねそこはちゃんと整理しないとこの後の"
    },
    {
      "start": 459.12,
      "duration": 4.639,
      "text": "このことが非常に議事が混乱するんですよ"
    },
    {
      "start": 461.8,
      "duration": 4.64,
      "text": "だそこのところをクリアにしてもらった方"
    },
    {
      "start": 463.759,
      "duration": 5.761,
      "text": "があのシンプルになるんですあ撤回なん"
    },
    {
      "start": 466.44,
      "duration": 5.12,
      "text": "ですねということでねところがその撤回だ"
    },
    {
      "start": 469.52,
      "duration": 4.119,
      "text": "と言ってるものの根幹に関わるところが"
    },
    {
      "start": 471.56,
      "duration": 4.079,
      "text": "残存してるから話がややこしくなってるん"
    },
    {
      "start": 473.639,
      "duration": 4.081,
      "text": "でちゃんと整理していただいた方がいいと"
    },
    {
      "start": 475.639,
      "duration": 5.12,
      "text": "思うんですよそこはちょっと議長ねこれ"
    },
    {
      "start": 477.72,
      "duration": 4.68,
      "text": "あの議長の強いの中でもちゃんと整理をし"
    },
    {
      "start": 480.759,
      "duration": 7.241,
      "text": "ていだいて進めていただきたいと思います"
    },
    {
      "start": 482.4,
      "duration": 7.72,
      "text": "はいはいえ小林さん議事進行はいこれあの"
    },
    {
      "start": 488.0,
      "duration": 5.159,
      "text": "議長にパスを出すわけじゃないけどもあの"
    },
    {
      "start": 490.12,
      "duration": 5.4,
      "text": "今日の冒頭の市長の発言をね"
    },
    {
      "start": 493.159,
      "duration": 6.361,
      "text": "えどこだっ"
    },
    {
      "start": 495.52,
      "duration": 6.92,
      "text": "けえっと総合的判断を含む主張報告を一旦"
    },
    {
      "start": 499.52,
      "duration": 6.0,
      "text": "撤回し再整備する必要があると言われた"
    },
    {
      "start": 502.44,
      "duration": 6.319,
      "text": "わけでということはあのまたちょっと大蔵"
    },
    {
      "start": 505.52,
      "duration": 7.36,
      "text": "さんの有進行の逆接になるんだけどそれは"
    },
    {
      "start": 508.759,
      "duration": 5.84,
      "text": "は今は変えないという上でえ再整備をする"
    },
    {
      "start": 512.88,
      "duration": 5.399,
      "text": "ということなのかどうかっていうのは"
    },
    {
      "start": 514.599,
      "duration": 7.12,
      "text": "はっきり言った方がこの後の質疑にあのが"
    },
    {
      "start": 518.279,
      "duration": 9.401,
      "text": "整理できると思うんでそれもうお願いし"
    },
    {
      "start": 521.719,
      "duration": 10.081,
      "text": "ますえ明解な答弁を求められてると私とし"
    },
    {
      "start": 527.68,
      "duration": 4.12,
      "text": "ては判断いたします"
    },
    {
      "start": 540.12,
      "duration": 4.959,
      "text": "はい渡辺大蔵さんあのえっと森戸さん小林"
    },
    {
      "start": 543.64,
      "duration": 3.24,
      "text": "さん私でいろんなこと言ってるから市長"
    },
    {
      "start": 545.079,
      "duration": 6.361,
      "text": "ままなぐちゃぐちゃすると思うんだけど"
    },
    {
      "start": 546.88,
      "duration": 6.56,
      "text": "あのね個人的なことと市長としてあの公人"
    },
    {
      "start": 551.44,
      "duration": 3.519,
      "text": "としての市長としてあの言われてることの"
    },
    {
      "start": 553.44,
      "duration": 3.72,
      "text": "ところを整理していただかなきゃいけない"
    },
    {
      "start": 554.959,
      "duration": 4.401,
      "text": "という風に思ってんですねだからそこの"
    },
    {
      "start": 557.16,
      "duration": 4.88,
      "text": "ところを整理し言いたいで今はこれ撤回の"
    },
    {
      "start": 559.36,
      "duration": 5.24,
      "text": "議案の審議をしてるんですよだその撤回を"
    },
    {
      "start": 562.04,
      "duration": 5.32,
      "text": "撤回を認めてくれと市議会に行っているに"
    },
    {
      "start": 564.6,
      "duration": 5.239,
      "text": "も関わらずその撤回したものの根幹部分に"
    },
    {
      "start": 567.36,
      "duration": 4.599,
      "text": "関して維持されてるってことはありないの"
    },
    {
      "start": 569.839,
      "duration": 4.44,
      "text": "でだからそこはきちんと整理をする必要が"
    },
    {
      "start": 571.959,
      "duration": 4.921,
      "text": "あると思ってですあと別に市長が個人的に"
    },
    {
      "start": 574.279,
      "duration": 4.921,
      "text": "何を頭の中で思ってようがあの思想心情の"
    },
    {
      "start": 576.88,
      "duration": 4.72,
      "text": "自由ですからそれを表に解禁しない限り"
    },
    {
      "start": 579.2,
      "duration": 5.0,
      "text": "にいたは自由ですよだから撤回議案を現に"
    },
    {
      "start": 581.6,
      "duration": 4.28,
      "text": "提出してる提出権者としての立場として"
    },
    {
      "start": 584.2,
      "duration": 3.16,
      "text": "あのそこはきちと整理をされないと"
    },
    {
      "start": 585.88,
      "duration": 4.32,
      "text": "おかしいんじゃないかってことを何度も"
    },
    {
      "start": 587.36,
      "duration": 4.52,
      "text": "申し上げてあのいるわけですだから逆に"
    },
    {
      "start": 590.2,
      "duration": 3.639,
      "text": "言うならば今小林さんが言ったようなこと"
    },
    {
      "start": 591.88,
      "duration": 4.48,
      "text": "だとするならばこれも撤回なんてあのこれ"
    },
    {
      "start": 593.839,
      "duration": 4.721,
      "text": "認められなくなりますよねてだって根幹"
    },
    {
      "start": 596.36,
      "duration": 4.44,
      "text": "部分そのまま残してるって言ってるわけだ"
    },
    {
      "start": 598.56,
      "duration": 5.0,
      "text": "からだったら議案じゃないじゃないそんな"
    },
    {
      "start": 600.8,
      "duration": 4.32,
      "text": "のでしょだ主張報告は撤回かもしんない"
    },
    {
      "start": 603.56,
      "duration": 3.32,
      "text": "けど総合的判断撤回されてないじゃない"
    },
    {
      "start": 605.12,
      "duration": 3.6,
      "text": "ですか結論部分維持してるって言ったらだ"
    },
    {
      "start": 606.88,
      "duration": 3.959,
      "text": "からそんな矛盾が起きるんですよ冒頭の"
    },
    {
      "start": 608.72,
      "duration": 3.6,
      "text": "市長の説明からだそこは整理をしなきゃ"
    },
    {
      "start": 610.839,
      "duration": 3.641,
      "text": "いけないってこと言ってるんであの"
    },
    {
      "start": 612.32,
      "duration": 3.88,
      "text": "ちゃんとそ整理をされた方があのいいと"
    },
    {
      "start": 614.48,
      "duration": 3.56,
      "text": "いう風にあの思うんですよ撤回っていう"
    },
    {
      "start": 616.2,
      "duration": 3.6,
      "text": "以上はもうそこの部分に関しては"
    },
    {
      "start": 618.04,
      "duration": 4.32,
      "text": "エンプティつまり0にならなきゃおかしい"
    },
    {
      "start": 619.8,
      "duration": 8.039,
      "text": "ですちゃんと整理していただきたい市長"
    },
    {
      "start": 622.36,
      "duration": 9.0,
      "text": "広告のまあのえご指摘を受け止めてですね"
    },
    {
      "start": 627.839,
      "duration": 5.041,
      "text": "え聴答弁があればお願お願いし"
    },
    {
      "start": 631.36,
      "duration": 5.039,
      "text": "ます"
    },
    {
      "start": 632.88,
      "duration": 5.92,
      "text": "市長えっと先ほどあのまずあの森田さんの"
    },
    {
      "start": 636.399,
      "duration": 7.081,
      "text": "最初の議事進行のところで申し上げました"
    },
    {
      "start": 638.8,
      "duration": 8.12,
      "text": "ようにえ今回はあの2月17日にあの審議"
    },
    {
      "start": 643.48,
      "duration": 8.159,
      "text": "いただいたえこの視聴報告そのものはえ"
    },
    {
      "start": 646.92,
      "duration": 7.96,
      "text": "行政決定としてあの撤回のあの段取りを"
    },
    {
      "start": 651.639,
      "duration": 7.161,
      "text": "踏まえて今日を迎えておりますので"
    },
    {
      "start": 654.88,
      "duration": 5.519,
      "text": "えま白死になってるというのが今の行政の"
    },
    {
      "start": 658.8,
      "duration": 2.92,
      "text": "現状"
    },
    {
      "start": 660.399,
      "duration": 4.68,
      "text": "で"
    },
    {
      "start": 661.72,
      "duration": 6.0,
      "text": "えっとさっき私が述べたことについて"
    },
    {
      "start": 665.079,
      "duration": 5.681,
      "text": "ちょっとあの混乱を招いておりまして大変"
    },
    {
      "start": 667.72,
      "duration": 6.48,
      "text": "申し訳ございません"
    },
    {
      "start": 670.76,
      "duration": 7.12,
      "text": "えということ"
    },
    {
      "start": 674.2,
      "duration": 6.639,
      "text": "で見解については今後ちょっと答弁を"
    },
    {
      "start": 677.88,
      "duration": 2.959,
      "text": "差し替えさせていただき"
    },
    {
      "start": 683.48,
      "duration": 4.159,
      "text": "ますいませんさん"
    },
    {
      "start": 689.44,
      "duration": 6.04,
      "text": "でですねあの今市長が言われたのは強制"
    },
    {
      "start": 692.079,
      "duration": 6.161,
      "text": "決定としているのだからそれはもう今現状"
    },
    {
      "start": 695.48,
      "duration": 5.88,
      "text": "としては進めるのか進めないのかっていう"
    },
    {
      "start": 698.24,
      "duration": 7.24,
      "text": "ことは白紙状態であるということだと思う"
    },
    {
      "start": 701.36,
      "duration": 8.0,
      "text": "んですねでしかしそのあのこの間の発言の"
    },
    {
      "start": 705.48,
      "duration": 7.56,
      "text": "中では市長ご自身の個人的な見解が述べ"
    },
    {
      "start": 709.36,
      "duration": 7.56,
      "text": "られているとしかし私は行政のトップに"
    },
    {
      "start": 713.04,
      "duration": 6.919,
      "text": "ある人がですねその行政決定した以上の"
    },
    {
      "start": 716.92,
      "duration": 7.4,
      "text": "ことを述べるっていうのはねちょっと"
    },
    {
      "start": 719.959,
      "duration": 8.12,
      "text": "やっぱりそれはあの市長としての"
    },
    {
      "start": 724.32,
      "duration": 6.72,
      "text": "あの資格というかねが問われる問題だと"
    },
    {
      "start": 728.079,
      "duration": 5.841,
      "text": "思うんですよだって決定している以上の"
    },
    {
      "start": 731.04,
      "duration": 8.0,
      "text": "ことを言っちゃだめなんですよそれはどう"
    },
    {
      "start": 733.92,
      "duration": 8.08,
      "text": "考えてもであのその点はですね言いたいの"
    },
    {
      "start": 739.04,
      "duration": 5.44,
      "text": "は山々ねあるのかもしれない我慢我慢し"
    },
    {
      "start": 742.0,
      "duration": 4.48,
      "text": "なきゃいけないんですよそこはやっぱり"
    },
    {
      "start": 744.48,
      "duration": 5.52,
      "text": "あの行政のトップっていうのはそういう"
    },
    {
      "start": 746.48,
      "duration": 5.799,
      "text": "ものなんじゃないんですか行政で決定した"
    },
    {
      "start": 750.0,
      "duration": 5.68,
      "text": "それ以上のことを言ったら部長さんたこれ"
    },
    {
      "start": 752.279,
      "duration": 6.12,
      "text": "から決定したことと違うことがどんどん出"
    },
    {
      "start": 755.68,
      "duration": 5.08,
      "text": "てきたらですね行の手をなさなくなっ"
    },
    {
      "start": 758.399,
      "duration": 6.44,
      "text": "ちゃうわけですよそんなことってありえ"
    },
    {
      "start": 760.76,
      "duration": 7.96,
      "text": "ないはずですよそうだだからあのそこは"
    },
    {
      "start": 764.839,
      "duration": 7.041,
      "text": "やっぱり市長ね市長の個人的な思いはある"
    },
    {
      "start": 768.72,
      "duration": 7.72,
      "text": "かもしれないあると思うしかしそれは今日"
    },
    {
      "start": 771.88,
      "duration": 7.84,
      "text": "はとめないとねあのこれ進行しないですよ"
    },
    {
      "start": 776.44,
      "duration": 5.48,
      "text": "あので先ほど来その個人的なのをったら"
    },
    {
      "start": 779.72,
      "duration": 4.6,
      "text": "どうかとかんなこと言われてるんだけど"
    },
    {
      "start": 781.92,
      "duration": 6.479,
      "text": "そんなことではねあの問題解決しないです"
    },
    {
      "start": 784.32,
      "duration": 6.639,
      "text": "よ前に進まないしってあのクールダウンが"
    },
    {
      "start": 788.399,
      "duration": 5.481,
      "text": "必要であれば休憩取ってクールダウンして"
    },
    {
      "start": 790.959,
      "duration": 5.68,
      "text": "いただいてもう一度自分で整理をされた方"
    },
    {
      "start": 793.88,
      "duration": 5.72,
      "text": "がいいんじゃないかと思うので議長あの"
    },
    {
      "start": 796.639,
      "duration": 4.081,
      "text": "きちっとあのそのことを信言していただき"
    },
    {
      "start": 799.6,
      "duration": 3.32,
      "text": "たいと思い"
    },
    {
      "start": 800.72,
      "duration": 7.52,
      "text": "ます進行するた"
    },
    {
      "start": 802.92,
      "duration": 9.2,
      "text": "のはいはい渡辺さんえっと一応させるため"
    },
    {
      "start": 808.24,
      "duration": 7.159,
      "text": "のまさっき市長のお話を注意深く聞いてい"
    },
    {
      "start": 812.12,
      "duration": 5.079,
      "text": "たら最後のところではあの今後はあそう"
    },
    {
      "start": 815.399,
      "duration": 4.841,
      "text": "いう言い方は差し控えるということでした"
    },
    {
      "start": 817.199,
      "duration": 4.961,
      "text": "よね結最後の結論部分はそなると結局今日"
    },
    {
      "start": 820.24,
      "duration": 5.52,
      "text": "のただもう最初のところからのやり取りの"
    },
    {
      "start": 822.16,
      "duration": 5.44,
      "text": "中で大のもう場で341と3411に関し"
    },
    {
      "start": 825.76,
      "duration": 3.96,
      "text": "ての現状のま個人的認識かなんかわかん"
    },
    {
      "start": 827.6,
      "duration": 3.799,
      "text": "ないけどもそれは話されてるんでだ"
    },
    {
      "start": 829.72,
      "duration": 3.479,
      "text": "ちゃんと整理するんだったらもう今後"
    },
    {
      "start": 831.399,
      "duration": 4.201,
      "text": "差し替えるようなことだったらま遡って"
    },
    {
      "start": 833.199,
      "duration": 4.76,
      "text": "差し換えてもらう必要があるのでそこの"
    },
    {
      "start": 835.6,
      "duration": 4.76,
      "text": "関連部分に関しては基本的には削除され"
    },
    {
      "start": 837.959,
      "duration": 4.56,
      "text": "疑似6場も削除されることを市長から"
    },
    {
      "start": 840.36,
      "duration": 3.88,
      "text": "申し出があればそれを受けて議長の方で"
    },
    {
      "start": 842.519,
      "duration": 4.44,
      "text": "削除されるってことをやればなくなるわけ"
    },
    {
      "start": 844.24,
      "duration": 4.36,
      "text": "ですよねうんだから出ないと今後差し控え"
    },
    {
      "start": 846.959,
      "duration": 4.68,
      "text": "なきゃいけないことがこれまで語られてる"
    },
    {
      "start": 848.6,
      "duration": 4.96,
      "text": "ことが問題なんでしょなのでそこの部分に"
    },
    {
      "start": 851.639,
      "duration": 4.76,
      "text": "関して市長から申し出をしていただいたら"
    },
    {
      "start": 853.56,
      "duration": 5.199,
      "text": "議長で適切に処理をしていただくと議論が"
    },
    {
      "start": 856.399,
      "duration": 4.161,
      "text": "あのまさに議事進行ですよねやりやすく"
    },
    {
      "start": 858.759,
      "duration": 3.08,
      "text": "なるからちゃんとやっていただきたいと"
    },
    {
      "start": 860.56,
      "duration": 3.8,
      "text": "いうこと"
    },
    {
      "start": 861.839,
      "duration": 4.041,
      "text": "ですですよだから市長から申しして"
    },
    {
      "start": 864.36,
      "duration": 5.96,
      "text": "いただいた方がいいんじゃないんですかて"
    },
    {
      "start": 865.88,
      "duration": 4.44,
      "text": "そういうことを申し上げたんですはい"
    },
    {
      "start": 886.24,
      "duration": 5.88,
      "text": "え少しだけ休憩取りたいということですの"
    },
    {
      "start": 888.44,
      "duration": 3.68,
      "text": "で休憩取ります"
    }
  ]
}