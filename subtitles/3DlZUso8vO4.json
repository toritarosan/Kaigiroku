      "text": "自宅者もえともえ協議をしえ自宅者内部で"
    },
    {
      "start": 1966.36,
      "duration": 4.84,
      "text": "え接遇研修等をえ実施する予定としている"
    },
    {
      "start": 1969.44,
      "duration": 4.32,
      "text": "ところでござい"
    },
    {
      "start": 1971.2,
      "duration": 7.16,
      "text": "ますはい高"
    },
    {
      "start": 1973.76,
      "duration": 7.2,
      "text": "委終わりますはいあのただいまあの括弧1"
    },
    {
      "start": 1978.36,
      "duration": 4.84,
      "text": "と括弧2と少しあの入り組んでおりました"
    },
    {
      "start": 1980.96,
      "duration": 3.959,
      "text": "けれどもま財源確保という観点からという"
    },
    {
      "start": 1983.2,
      "duration": 6.56,
      "text": "ことで一緒にお受けさせていただきました"
    },
    {
      "start": 1984.919,
      "duration": 4.841,
      "text": "のでえよろしくお願いしますでは次の方"
    },
    {
      "start": 1992.72,
      "duration": 6.679,
      "text": "どうぞはい太"
    },
    {
      "start": 1994.84,
      "duration": 7.16,
      "text": "委員あの報告のあった窓口関連業務見直し"
    },
    {
      "start": 1999.399,
      "duration": 6.76,
      "text": "っってあってますよねんありましたねに"
    },
    {
      "start": 2002.0,
      "duration": 9.48,
      "text": "ついて一点な経過がありますあの休日会長"
    },
    {
      "start": 2006.159,
      "duration": 8.321,
      "text": "業務の見直しでまえっと毎週やってるのを"
    },
    {
      "start": 2011.48,
      "duration": 5.72,
      "text": "え月2回にすることを検討してるという"
    },
    {
      "start": 2014.48,
      "duration": 4.679,
      "text": "ことについてですあのコンビニ交付が増え"
    },
    {
      "start": 2017.2,
      "duration": 4.719,
      "text": "ているのはますごく良かったと思ってるん"
    },
    {
      "start": 2019.159,
      "duration": 5.441,
      "text": "ですけどまそれが理由でま回数を減らそう"
    },
    {
      "start": 2021.919,
      "duration": 4.561,
      "text": "と検討されてることでありましてま"
    },
    {
      "start": 2024.6,
      "duration": 5.84,
      "text": "ちょっと1個目でまず確認したいのがです"
    },
    {
      "start": 2026.48,
      "duration": 6.559,
      "text": "ねそのコンビニ交付で対応できる証明書"
    },
    {
      "start": 2030.44,
      "duration": 6.8,
      "text": "などの交付主にそれだと思うんですけど"
    },
    {
      "start": 2033.039,
      "duration": 7.441,
      "text": "その業務以外の業務もあの休日窓口でやっ"
    },
    {
      "start": 2037.24,
      "duration": 5.08,
      "text": "ているのではないかということを確認させ"
    },
    {
      "start": 2040.48,
      "duration": 3.039,
      "text": "てくださいちょっとあのホームページで見"
    },
    {
      "start": 2042.32,
      "duration": 6.079,
      "text": "たところま"
    },
    {
      "start": 2043.519,
      "duration": 9.521,
      "text": "様々あの保険年金化では加入の手続きとか"
    },
    {
      "start": 2048.399,
      "duration": 6.52,
      "text": "あと子育支援化でも手当ての申請なども"
    },
    {
      "start": 2053.04,
      "duration": 4.559,
      "text": "やってるのではないかと思うんですけれど"
    },
    {
      "start": 2054.919,
      "duration": 6.16,
      "text": "もまコンビニ交付以外の業務もま休日やっ"
    },
    {
      "start": 2057.599,
      "duration": 6.52,
      "text": "てるのではないかとえいうこととまそれが"
    },
    {
      "start": 2061.079,
      "duration": 5.84,
      "text": "できなくなるそれができる日が減るのでは"
    },
    {
      "start": 2064.119,
      "duration": 5.201,
      "text": "ないかとえ思うんですけれどもその点は"
    },
    {
      "start": 2066.919,
      "duration": 5.801,
      "text": "どうなるのでしょうかい"
    },
    {
      "start": 2069.32,
      "duration": 6.759,
      "text": "ます担政系担当"
    },
    {
      "start": 2072.72,
      "duration": 5.639,
      "text": "課長はいえ休日会長についてご質問"
    },
    {
      "start": 2076.079,
      "duration": 4.6,
      "text": "いただきましたあの今え委員がおっしゃっ"
    },
    {
      "start": 2078.359,
      "duration": 4.881,
      "text": "ていただきました通りえコンビニ交付以外"
    },
    {
      "start": 2080.679,
      "duration": 6.0,
      "text": "での手続きというのは当然ございますでえ"
    },
    {
      "start": 2083.24,
      "duration": 6.359,
      "text": "ま当然そういうのがございますのでえ月4"
    },
    {
      "start": 2086.679,
      "duration": 6.44,
      "text": "回もしくは5回今え毎週末でやってる部分"
    },
    {
      "start": 2089.599,
      "duration": 6.401,
      "text": "をえ月2回程度えやることによって完全に"
    },
    {
      "start": 2093.119,
      "duration": 5.601,
      "text": "なくすのではなくてまそういったえ月2回"
    },
    {
      "start": 2096.0,
      "duration": 7.56,
      "text": "開く中でそういったこともていけるという"
    },
    {
      "start": 2098.72,
      "duration": 4.84,
      "text": "風にえ検討しているとこでございます以上"
    },
    {
      "start": 2104.32,
      "duration": 6.96,
      "text": "ですはいはい田委員はいということであの"
    },
    {
      "start": 2108.92,
      "duration": 5.439,
      "text": "現状を確認できましたということであれば"
    },
    {
      "start": 2111.28,
      "duration": 5.319,
      "text": "ま月2回あれば大丈夫という判断だとは"
    },
    {
      "start": 2114.359,
      "duration": 6.201,
      "text": "思うんですけれどもましかしやっぱり現状"
    },
    {
      "start": 2116.599,
      "duration": 6.321,
      "text": "の毎週からえ減るということはま市民"
    },
    {
      "start": 2120.56,
      "duration": 4.92,
      "text": "サービスの低下にま繋がるということは"
    },
    {
      "start": 2122.92,
      "duration": 6.0,
      "text": "言えると思いますのでま私は現状維持が"
    },
    {
      "start": 2125.48,
      "duration": 5.2,
      "text": "必要ではないかと求めますれもえその点は"
    },
    {
      "start": 2128.92,
      "duration": 6.96,
      "text": "いかがでしょう"
    },
    {
      "start": 2130.68,
      "duration": 7.6,
      "text": "か行政経営担当課長えま今回の見直しに"
    },
    {
      "start": 2135.88,
      "duration": 4.92,
      "text": "つきましてはえコンビニ交付の理由が急激"
    },
    {
      "start": 2138.28,
      "duration": 5.12,
      "text": "にみま反比例するように窓口の来庁者が"
    },
    {
      "start": 2140.8,
      "duration": 5.68,
      "text": "減ってるという事実を分析した上でえ限ら"
    },
    {
      "start": 2143.4,
      "duration": 5.959,
      "text": "れた経営資源をえそのままえ両方に使い"
    },
    {
      "start": 2146.48,
      "duration": 5.08,
      "text": "続けることの方がえ結果的に市民にとって"
    },
    {
      "start": 2149.359,
      "duration": 4.841,
      "text": "はま不利益につながるものではないかと"
    },
    {
      "start": 2151.56,
      "duration": 4.68,
      "text": "考えたところから始まってございますえ"
    },
    {
      "start": 2154.2,
      "duration": 4.119,
      "text": "会長日の見直しによりえ経営資源を"
    },
    {
      "start": 2156.24,
      "duration": 6.48,
      "text": "生み出すことができればえそれを市民"
    },
    {
      "start": 2158.319,
      "duration": 4.401,
      "text": "サービスの質の向上に向けたり他の市民"
    }
  ]
}