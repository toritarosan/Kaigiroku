{
  "entries": [
    {
      "start": 7.759,
      "duration": 4.081,
      "text": "はい皆様お疲れ様でございますお揃いで"
    },
    {
      "start": 9.84,
      "duration": 4.2,
      "text": "ございます議会運営委員会協議会を始め"
    },
    {
      "start": 11.84,
      "duration": 4.56,
      "text": "させていただきますお手元の協議をご覧"
    },
    {
      "start": 14.04,
      "duration": 5.2,
      "text": "くださいえ本日の委員会の進行予定につい"
    },
    {
      "start": 16.4,
      "duration": 6.719,
      "text": "てでございますえ調査一件でございまして"
    },
    {
      "start": 19.24,
      "duration": 7.039,
      "text": "え臨時会の会議及び会議配と議会部に"
    },
    {
      "start": 23.119,
      "duration": 6.441,
      "text": "関する調査でございますえ令和6年第2回"
    },
    {
      "start": 26.279,
      "duration": 6.721,
      "text": "臨時会提出案件視聴相府案件議案第39号"
    },
    {
      "start": 29.56,
      "duration": 5.999,
      "text": "令昨年度公安士一般会計補正予算第3回に"
    },
    {
      "start": 33.0,
      "duration": 6.32,
      "text": "ついてでございますえ会期及び会議配の"
    },
    {
      "start": 35.559,
      "duration": 6.801,
      "text": "決定についてはああ会期8月16日本日の"
    },
    {
      "start": 39.32,
      "duration": 7.079,
      "text": "1日間とすることについてえ別子会議割"
    },
    {
      "start": 42.36,
      "duration": 6.76,
      "text": "表示についてでございますえ3案件2先"
    },
    {
      "start": 46.399,
      "duration": 4.961,
      "text": "委員会の決定について別2先委員会予定表"
    },
    {
      "start": 49.12,
      "duration": 5.16,
      "text": "についてその他ご発言があればと思います"
    },
    {
      "start": 51.36,
      "duration": 5.359,
      "text": "え進行について何かございますでしょうか"
    },
    {
      "start": 54.28,
      "duration": 4.64,
      "text": "はいそれでは協議会事項の1本日の進行に"
    },
    {
      "start": 56.719,
      "duration": 5.961,
      "text": "ついてえ事務局の方からお願いします局長"
    },
    {
      "start": 58.92,
      "duration": 6.8,
      "text": "局長ですはいえそれではですね進行予定表"
    },
    {
      "start": 62.68,
      "duration": 5.72,
      "text": "の方ご覧いただきたいと思いますえ1番の"
    },
    {
      "start": 65.72,
      "duration": 5.759,
      "text": "本会議は先ほど会議宣告終了しております"
    },
    {
      "start": 68.4,
      "duration": 5.96,
      "text": "え2番の議会運営委員会及び同協議会に"
    },
    {
      "start": 71.479,
      "duration": 5.361,
      "text": "つきましてはえただいまあの委員長の方"
    },
    {
      "start": 74.36,
      "duration": 5.6,
      "text": "からもご説明ございましたように調査1件"
    },
    {
      "start": 76.84,
      "duration": 6.16,
      "text": "でえ括弧1の市長総案件の取り扱いについ"
    },
    {
      "start": 79.96,
      "duration": 6.36,
      "text": "て括弧2会議及び会議配りの決定括弧3の"
    },
    {
      "start": 83.0,
      "duration": 6.56,
      "text": "案件2先委員会の決定についてご確認を"
    },
    {
      "start": 86.32,
      "duration": 7.119,
      "text": "いただきますでえ2番の進行予定というの"
    },
    {
      "start": 89.56,
      "duration": 6.08,
      "text": "は今説明してるものですで2番の議会運営"
    },
    {
      "start": 93.439,
      "duration": 6.121,
      "text": "委員会が終わりましたら3番の本会議に"
    },
    {
      "start": 95.64,
      "duration": 7.439,
      "text": "戻りましてえ議会運営委員長の報告後1"
    },
    {
      "start": 99.56,
      "duration": 8.96,
      "text": "会議録署名議員の指名に会議の決定で3の"
    },
    {
      "start": 103.079,
      "duration": 9.36,
      "text": "議案第39号の説明質疑を行いえ討論採決"
    },
    {
      "start": 108.52,
      "duration": 7.559,
      "text": "は一次保留となりますで4番の議会運営"
    },
    {
      "start": 112.439,
      "duration": 7.081,
      "text": "委員会及び同協議会でえ議案第39号の"
    },
    {
      "start": 116.079,
      "duration": 7.481,
      "text": "討論採決の確認をさせていただきえ本会議"
    },
    {
      "start": 119.52,
      "duration": 6.879,
      "text": "にりましてえ議案第39号の討論採決を"
    },
    {
      "start": 123.56,
      "duration": 5.16,
      "text": "行うというような形で本日の進行について"
    },
    {
      "start": 126.399,
      "duration": 5.601,
      "text": "は以上のようになります以上"
    },
    {
      "start": 128.72,
      "duration": 6.76,
      "text": "ですはいそれでは委員会に入ってよろしい"
    },
    {
      "start": 132.0,
      "duration": 3.48,
      "text": "ですか大丈夫ですか"
    },
    {
      "start": 136.8,
      "duration": 4.84,
      "text": "はいおはようございますおはようござい"
    },
    {
      "start": 139.599,
      "duration": 4.041,
      "text": "ただいまから議会委員会の会議を開きます"
    },
    {
      "start": 141.64,
      "duration": 4.0,
      "text": "たちに本日の議事に入ります当委員会に"
    },
    {
      "start": 143.64,
      "duration": 4.72,
      "text": "付託されております案件は調査一件であり"
    },
    {
      "start": 145.64,
      "duration": 4.879,
      "text": "ます議長からお手元に議会運営委員会協議"
    },
    {
      "start": 148.36,
      "duration": 4.64,
      "text": "事項が提示されておりますのでその順序に"
    },
    {
      "start": 150.519,
      "duration": 5.481,
      "text": "従って順次協議していきたいと思います"
    },
    {
      "start": 153.0,
      "duration": 6.08,
      "text": "初めに臨時会の会議及び会議祝等議会運に"
    },
    {
      "start": 156.0,
      "duration": 7.239,
      "text": "関する調査を議題といたします協議事項1"
    },
    {
      "start": 159.08,
      "duration": 6.439,
      "text": "令和6年第2回臨時会提出案件を行います"
    },
    {
      "start": 163.239,
      "duration": 4.601,
      "text": "協議事項に示されております通り市長送付"
    },
    {
      "start": 165.519,
      "duration": 6.281,
      "text": "案件は一件であります部局から発言があれ"
    },
    {
      "start": 167.84,
      "duration": 6.92,
      "text": "ばこれを求めます部です村部長はいええ令"
    },
    {
      "start": 171.8,
      "duration": 8.56,
      "text": "和6年第2回臨時会についてご説明いたし"
    },
    {
      "start": 174.76,
      "duration": 9.0,
      "text": "ますえ本臨時会は日を本日8月16日と8"
    },
    {
      "start": 180.36,
      "duration": 7.599,
      "text": "月14日に告し同日議案を送付いたしまし"
    },
    {
      "start": 183.76,
      "duration": 8.32,
      "text": "たえ不議案件につきましては議案第39号"
    },
    {
      "start": 187.959,
      "duration": 7.241,
      "text": "令和6年度小金一般会計補正予算第3回で"
    },
    {
      "start": 192.08,
      "duration": 5.92,
      "text": "ございますえ本件につきましては本会議で"
    },
    {
      "start": 195.2,
      "duration": 3.84,
      "text": "の即決をお願いいたします以上よろしくお"
    },
    {
      "start": 198.0,
      "duration": 4.04,
      "text": "願いいたし"
    },
    {
      "start": 199.04,
      "duration": 5.36,
      "text": "ますはいただいまの総務長の発言の通り"
    },
    {
      "start": 202.04,
      "duration": 8.24,
      "text": "市長総案件一見についてご確にいます"
    },
    {
      "start": 204.4,
      "duration": 8.399,
      "text": "でしょうかはい水委えっと先ほど会議でま"
    },
    {
      "start": 210.28,
      "duration": 5.959,
      "text": "市長からあのこのような時期に開催する"
    },
    {
      "start": 212.799,
      "duration": 6.201,
      "text": "ことになりえ心苦しく思っているとまいう"
    },
    {
      "start": 216.239,
      "duration": 6.121,
      "text": "発言があってま一定のなんていうかま議事"
    },
    {
      "start": 219.0,
      "duration": 6.519,
      "text": "進行でしたっけねそれに答えるあの形が"
    },
    {
      "start": 222.36,
      "duration": 7.32,
      "text": "あったんですが私からもですねあの議案"
    },
    {
      "start": 225.519,
      "duration": 7.28,
      "text": "そのものの必要性や内容について特にあの"
    },
    {
      "start": 229.68,
      "duration": 6.16,
      "text": "申し上げることはないんですがあの16日"
    },
    {
      "start": 232.799,
      "duration": 6.36,
      "text": "に至るやっぱりこの間の経過についてはま"
    },
    {
      "start": 235.84,
      "duration": 6.599,
      "text": "市長は心苦しく思ってるとま16日にの"
    },
    {
      "start": 239.159,
      "duration": 6.16,
      "text": "開催についてま申し訳ないて話があったん"
    },
    {
      "start": 242.439,
      "duration": 6.201,
      "text": "ですけどもう少しこの間の経過については"
    },
    {
      "start": 245.319,
      "duration": 5.041,
      "text": "ですねその問題点についてあの発言して"
    },
    {
      "start": 248.64,
      "duration": 6.519,
      "text": "いただきたかったなっていう風に考えて"
    },
    {
      "start": 250.36,
      "duration": 8.36,
      "text": "ますで7月31日にあの第1方であの市議"
    },
    {
      "start": 255.159,
      "duration": 6.32,
      "text": "会に今回の事案が報告されその時にその"
    },
    {
      "start": 258.72,
      "duration": 5.24,
      "text": "えっと臨時会やるとすれば19日かそれ"
    },
    {
      "start": 261.479,
      "duration": 5.881,
      "text": "以降って話があったと思うんですねで"
    },
    {
      "start": 263.96,
      "duration": 5.92,
      "text": "その後要するに各会派を回ってあの今回の"
    },
    {
      "start": 267.36,
      "duration": 5.6,
      "text": "事案についての内容をもう少し説明しした"
    },
    {
      "start": 269.88,
      "duration": 6.44,
      "text": "いって話であの終わったと思うんですが"
    },
    {
      "start": 272.96,
      "duration": 6.32,
      "text": "それであのうちの会派に来たのが8月7日"
    },
    {
      "start": 276.32,
      "duration": 8.0,
      "text": "だったと思うんですね7日の夕方から夜に"
    },
    {
      "start": 279.28,
      "duration": 8.479,
      "text": "かけて市長と資産税課長があの会派にあの"
    },
    {
      "start": 284.32,
      "duration": 6.96,
      "text": "来てですねで説明されたんですがその時は"
    },
    {
      "start": 287.759,
      "duration": 6.921,
      "text": "ですねあの臨時会を16時に開催すると"
    },
    {
      "start": 291.28,
      "duration": 6.08,
      "text": "かっていう方針はあの要するに全くない"
    },
    {
      "start": 294.68,
      "duration": 6.959,
      "text": "ままあの来られたっていう風に私たちは"
    },
    {
      "start": 297.36,
      "duration": 7.839,
      "text": "受け止めていますであのあの臨時会または"
    },
    {
      "start": 301.639,
      "duration": 6.041,
      "text": "その先決処分っていうこともあの可能性と"
    },
    {
      "start": 305.199,
      "duration": 5.761,
      "text": "しては悪るみたいな話もありましたけどで"
    },
    {
      "start": 307.68,
      "duration": 6.76,
      "text": "16時の開催も選択肢の1つだっていう話"
    },
    {
      "start": 310.96,
      "duration": 6.28,
      "text": "はあったんですがで私たちの会派からは"
    },
    {
      "start": 314.44,
      "duration": 6.28,
      "text": "ですねあの議会から先決処分っていうこと"
    },
    {
      "start": 317.24,
      "duration": 6.399,
      "text": "をま認めるわけにはいかないとま先決処分"
    },
    {
      "start": 320.72,
      "duration": 7.28,
      "text": "はあの要するに認められないって話をした"
    },
    {
      "start": 323.639,
      "duration": 7.241,
      "text": "のと臨時会が開催されれば議会としては"
    },
    {
      "start": 328.0,
      "duration": 5.96,
      "text": "やっぱり臨時会なのであの馳せ参じに"
    },
    {
      "start": 330.88,
      "duration": 5.52,
      "text": "なければいけないとまいうその議会の議員"
    },
    {
      "start": 333.96,
      "duration": 5.88,
      "text": "としての要するになんていうかあり方"
    },
    {
      "start": 336.4,
      "duration": 7.56,
      "text": "みたいなことをその2点を市長には伝えて"
    },
    {
      "start": 339.84,
      "duration": 7.32,
      "text": "早く市長から方針を決めてま臨時会開くん"
    },
    {
      "start": 343.96,
      "duration": 6.12,
      "text": "だったらあ議長に申し出てほしいとまいう"
    },
    {
      "start": 347.16,
      "duration": 6.84,
      "text": "風にあので終わったと思うんですよで16"
    },
    {
      "start": 350.08,
      "duration": 6.36,
      "text": "日の開催ってなると1週間後ですからね各"
    },
    {
      "start": 354.0,
      "duration": 4.96,
      "text": "予定も入っていると思うんですねそういう"
    },
    {
      "start": 356.44,
      "duration": 5.84,
      "text": "こともあるのであのその辺はちょっとね"
    },
    {
      "start": 358.96,
      "duration": 6.72,
      "text": "よく考えた方がいいって発言をあのしたと"
    },
    {
      "start": 362.28,
      "duration": 6.28,
      "text": "いう風に考えていますでその後要するに"
    },
    {
      "start": 365.68,
      "duration": 6.16,
      "text": "臨時会開催っていうのがですね内々議員に"
    },
    {
      "start": 368.56,
      "duration": 6.079,
      "text": "伝えられるっていう形になってだからうち"
    },
    {
      "start": 371.84,
      "duration": 5.6,
      "text": "の会派としてはですねあの16日にその"
    },
    {
      "start": 374.639,
      "duration": 6.12,
      "text": "開催したいのでよろしくお願いしたいって"
    },
    {
      "start": 377.44,
      "duration": 7.68,
      "text": "話は一切なかったていう風にあの考えてい"
    },
    {
      "start": 380.759,
      "duration": 8.84,
      "text": "ますで僕もそのあの事柄の性質はよく"
    },
    {
      "start": 385.12,
      "duration": 7.0,
      "text": "分かるんですがあのなんていうのかあの"
    },
    {
      "start": 389.599,
      "duration": 5.521,
      "text": "こう形式的にお詫びをせようとか謝罪"
    },
    {
      "start": 392.12,
      "duration": 5.84,
      "text": "せよっていうつもりはないんだけど16日"
    },
    {
      "start": 395.12,
      "duration": 6.0,
      "text": "に開催したいっていうことになればこれ死"
    },
    {
      "start": 397.96,
      "duration": 6.679,
      "text": "のミスで要するに今回の議案あの事案が出"
    },
    {
      "start": 401.12,
      "duration": 5.84,
      "text": "てきたわけだから要するにそのあの16日"
    },
    {
      "start": 404.639,
      "duration": 6.161,
      "text": "の開催にあたってはですね高校こういう"
    },
    {
      "start": 406.96,
      "duration": 6.6,
      "text": "理由であの開催したいと16日にできれば"
    },
    {
      "start": 410.8,
      "duration": 5.239,
      "text": "是非あの応じてもらえないかっていう話が"
    },
    {
      "start": 413.56,
      "duration": 5.319,
      "text": "あって叱るべきだったという風に思うん"
    },
    {
      "start": 416.039,
      "duration": 6.56,
      "text": "ですがまそういう話もなくですねとにかく"
    },
    {
      "start": 418.879,
      "duration": 5.921,
      "text": "16に開催するというあの連絡だけが来"
    },
    {
      "start": 422.599,
      "duration": 5.88,
      "text": "るっていうのはちょっと今後の要するに"
    },
    {
      "start": 424.8,
      "duration": 6.92,
      "text": "議会と市長のあり方を考えた時にですね"
    },
    {
      "start": 428.479,
      "duration": 5.961,
      "text": "あのちょっとやっぱりね問題があるしあの"
    },
    {
      "start": 431.72,
      "duration": 7.0,
      "text": "乱暴だとま言わざる得ないっていう風に私"
    },
    {
      "start": 434.44,
      "duration": 7.56,
      "text": "はあの考えておりますで31日の第1歩の"
    },
    {
      "start": 438.72,
      "duration": 6.28,
      "text": "時に19日かそれ以降っていう日程がある"
    },
    {
      "start": 442.0,
      "duration": 6.8,
      "text": "程度要するに示されたとすればその時点で"
    },
    {
      "start": 445.0,
      "duration": 6.96,
      "text": "市長としてですねあの臨時会の開催あの何"
    },
    {
      "start": 448.8,
      "duration": 6.2,
      "text": "日に体こ目があの立てられたんじゃないか"
    },
    {
      "start": 451.96,
      "duration": 6.84,
      "text": "なていう風に思うので早くやっぱり市長と"
    },
    {
      "start": 455.0,
      "duration": 6.039,
      "text": "して方針を持ってあの望むべきだったと"
    },
    {
      "start": 458.8,
      "duration": 5.16,
      "text": "いうことについてはですねちょっとあの"
    },
    {
      "start": 461.039,
      "duration": 6.321,
      "text": "意見としてあの述べておきたいと思います"
    },
    {
      "start": 463.96,
      "duration": 7.0,
      "text": "しあの今後の要するにあの議会との調整に"
    },
    {
      "start": 467.36,
      "duration": 5.64,
      "text": "関してはですねあのまこういうその事案が"
    },
    {
      "start": 470.96,
      "duration": 5.4,
      "text": "今後起こるかどうかっていう分かりません"
    },
    {
      "start": 473.0,
      "duration": 6.72,
      "text": "けどあり得る話だと思うんですねそういう"
    },
    {
      "start": 476.36,
      "duration": 6.04,
      "text": "時にはですね是非ね丁寧に対応してもら"
    },
    {
      "start": 479.72,
      "duration": 5.439,
      "text": "必要があるとまいうことは発言しておき"
    },
    {
      "start": 482.4,
      "duration": 5.12,
      "text": "たいと思いますしこの内容については是非"
    },
    {
      "start": 485.159,
      "duration": 5.88,
      "text": "こういう発言があったとまいうこともです"
    },
    {
      "start": 487.52,
      "duration": 6.239,
      "text": "ねあの市長にもお伝え願いたいという風に"
    },
    {
      "start": 491.039,
      "duration": 4.961,
      "text": "あの思いますがその点だけちょっと確認し"
    },
    {
      "start": 493.759,
      "duration": 4.601,
      "text": "ておきたいと思いますがいかがでしょうか"
    },
    {
      "start": 496.0,
      "duration": 6.12,
      "text": "はい総部長はい総部"
    },
    {
      "start": 498.36,
      "duration": 8.64,
      "text": "長あのまず冒頭匠からもございましたが"
    },
    {
      "start": 502.12,
      "duration": 8.68,
      "text": "あの今回え急な開催になったことまた台風"
    },
    {
      "start": 507.0,
      "duration": 9.12,
      "text": "の中での開催ということでえ重ねてえ大変"
    },
    {
      "start": 510.8,
      "duration": 7.76,
      "text": "申し訳ございませんえそれであの議会との"
    },
    {
      "start": 516.12,
      "duration": 5.479,
      "text": "調整でございますがこちらに関しましては"
    },
    {
      "start": 518.56,
      "duration": 6.92,
      "text": "あの市長からもございましたが事案の内容"
    },
    {
      "start": 521.599,
      "duration": 7.8,
      "text": "からあできる限り早期のご議決をいただき"
    },
    {
      "start": 525.48,
      "duration": 6.4,
      "text": "たいということでえ市長担当部局でえご"
    },
    {
      "start": 529.399,
      "duration": 5.641,
      "text": "説明に上がらせていただいたという風に"
    },
    {
      "start": 531.88,
      "duration": 7.56,
      "text": "思ってございますあの繰り返しですがあ"
    },
    {
      "start": 535.04,
      "duration": 7.76,
      "text": "事案の内容からあ早期に付金等を支払う"
    },
    {
      "start": 539.44,
      "duration": 6.76,
      "text": "必要があるということでえ町内での調整"
    },
    {
      "start": 542.8,
      "duration": 6.88,
      "text": "これも財政的な面経理的な面え議案の作成"
    },
    {
      "start": 546.2,
      "duration": 6.199,
      "text": "の面という点でえ進めてきておりましてえ"
    },
    {
      "start": 549.68,
      "duration": 5.44,
      "text": "そのだけでできるだけ早くの日程という"
    },
    {
      "start": 552.399,
      "duration": 7.12,
      "text": "ことで16日という風にさせていただいた"
    },
    {
      "start": 555.12,
      "duration": 8.12,
      "text": "というところでございますえ今回えあの"
    },
    {
      "start": 559.519,
      "duration": 6.281,
      "text": "大変え申し訳ございませんあの議会とのご"
    },
    {
      "start": 563.24,
      "duration": 4.719,
      "text": "調性につきましては今後につきましても"
    },
    {
      "start": 565.8,
      "duration": 5.039,
      "text": "丁寧に進めていきたいと思ってございます"
    },
    {
      "start": 567.959,
      "duration": 8.0,
      "text": "のでこのようにまずは答弁させていただき"
    },
    {
      "start": 570.839,
      "duration": 7.841,
      "text": "ます他にございますかはい小林員ちょっと"
    },
    {
      "start": 575.959,
      "duration": 4.44,
      "text": "今の関係であのま早くあの議案の審査に"
    },
    {
      "start": 578.68,
      "duration": 4.2,
      "text": "入るべきだと思っておりますこのような"
    },
    {
      "start": 580.399,
      "duration": 5.521,
      "text": "天候でもありますのでなんですけどま今の"
    },
    {
      "start": 582.88,
      "duration": 6.32,
      "text": "ようなご発言ありましたのでね"
    },
    {
      "start": 585.92,
      "duration": 6.4,
      "text": "あのま丁寧さを変りたというところはあの"
    },
    {
      "start": 589.2,
      "duration": 6.079,
      "text": "その通りだと思いますでやはり会派であ"
    },
    {
      "start": 592.32,
      "duration": 4.92,
      "text": "いったお話があってその後大きく方針が"
    },
    {
      "start": 595.279,
      "duration": 6.201,
      "text": "変わっていくということになればですね"
    },
    {
      "start": 597.24,
      "duration": 8.2,
      "text": "あのすぐにま議長の方に会派の開催を求め"
    },
    {
      "start": 601.48,
      "duration": 5.52,
      "text": "て会派を開いてえそこで一定の整理をすれ"
    },
    {
      "start": 605.44,
      "duration": 3.959,
      "text": "ばこのようなことにはならなかったんでは"
    },
    {
      "start": 607.0,
      "duration": 4.92,
      "text": "ないかということでありますま今までは"
    },
    {
      "start": 609.399,
      "duration": 6.801,
      "text": "そうしてきたのかなと思っておりましてま"
    },
    {
      "start": 611.92,
      "duration": 8.08,
      "text": "その点まえ途中でえ情報"
    },
    {
      "start": 616.2,
      "duration": 6.16,
      "text": "をこう横で聞きながらですねえちょっと"
    },
    {
      "start": 620.0,
      "duration": 4.44,
      "text": "指摘できなかったことはま自分にも責任は"
    },
    {
      "start": 622.36,
      "duration": 4.88,
      "text": "あるのかなと思っておりますまたそういっ"
    },
    {
      "start": 624.44,
      "duration": 7.839,
      "text": "たことがあればま議会としてもですねえ"
    },
    {
      "start": 627.24,
      "duration": 7.8,
      "text": "この延滞金をまあどう捉えてえ開催時期を"
    },
    {
      "start": 632.279,
      "duration": 6.36,
      "text": "どうするのかもしくは先決処分ということ"
    },
    {
      "start": 635.04,
      "duration": 7.44,
      "text": "もこの議案の性質上ですねえやえないのか"
    },
    {
      "start": 638.639,
      "duration": 5.76,
      "text": "まそういったことをですねえま腹を終って"
    },
    {
      "start": 642.48,
      "duration": 3.799,
      "text": "話ができたんじゃないかとまこのように"
    },
    {
      "start": 644.399,
      "duration": 3.641,
      "text": "思っておりますま今後にしっかりと生かし"
    },
    {
      "start": 646.279,
      "duration": 5.881,
      "text": "ていただきたいとこのように発言しておき"
    },
    {
      "start": 648.04,
      "duration": 7.0,
      "text": "たいと思いますはい他にございますか"
    },
    {
      "start": 652.16,
      "duration": 4.919,
      "text": "よろしいですかはいではご意見として貴重"
    },
    {
      "start": 655.04,
      "duration": 4.799,
      "text": "によろしくお伝えくださいませはいそれで"
    },
    {
      "start": 657.079,
      "duration": 4.601,
      "text": "はただ今の総務長の発言の通り総1件に"
    },
    {
      "start": 659.839,
      "duration": 5.0,
      "text": "つきましてはご確認いただけますでしょう"
    },
    {
      "start": 661.68,
      "duration": 4.56,
      "text": "かはいご異議なしと認めます従って本件は"
    },
    {
      "start": 664.839,
      "duration": 4.201,
      "text": "ただいま申し上げました通りご確認"
    },
    {
      "start": 666.24,
      "duration": 5.44,
      "text": "いただきました協議事項括2会期及び会議"
    },
    {
      "start": 669.04,
      "duration": 4.12,
      "text": "割の決定を行います議長から指案が提示さ"
    },
    {
      "start": 671.68,
      "duration": 5.159,
      "text": "れておりますので議長の説明をお願い"
    },
    {
      "start": 673.16,
      "duration": 6.239,
      "text": "いたしますはいはいお手元に会議日割表括"
    },
    {
      "start": 676.839,
      "duration": 7.641,
      "text": "案を配布しておりますので事務局から説明"
    },
    {
      "start": 679.399,
      "duration": 8.44,
      "text": "します局長はいえ令和6年第2回小金審議"
    },
    {
      "start": 684.48,
      "duration": 8.039,
      "text": "会臨時会え会議表か案をご覧いただきたい"
    },
    {
      "start": 687.839,
      "duration": 8.361,
      "text": "と思いますえ8月16日金曜日本会議会議"
    },
    {
      "start": 692.519,
      "duration": 8.241,
      "text": "録署名議員の指名会期の決定議案の説明"
    },
    {
      "start": 696.2,
      "duration": 8.56,
      "text": "質疑委員会2または討論採決以上の通り令"
    },
    {
      "start": 700.76,
      "duration": 6.72,
      "text": "和6年第2回臨時会は8月16日の1日間"
    },
    {
      "start": 704.76,
      "duration": 5.6,
      "text": "としたというのが議長の新聞案でござい"
    },
    {
      "start": 707.48,
      "duration": 6.08,
      "text": "ます議長及び事務局の説明が終わりました"
    },
    {
      "start": 710.36,
      "duration": 5.4,
      "text": "ご意見ご質疑等はありますでしょうかはい"
    },
    {
      "start": 713.56,
      "duration": 4.04,
      "text": "お諮りいたします本件につきましては議長"
    },
    {
      "start": 715.76,
      "duration": 4.72,
      "text": "の諮問の通り決定することにご異議あり"
    },
    {
      "start": 717.6,
      "duration": 6.799,
      "text": "ませんかご異議なしとます従って会につき"
    },
    {
      "start": 720.48,
      "duration": 6.799,
      "text": "ましては8月16日の1日間とし会議割等"
    },
    {
      "start": 724.399,
      "duration": 6.481,
      "text": "につきましてはお手元の会議割費用括案の"
    },
    {
      "start": 727.279,
      "duration": 6.521,
      "text": "通り決定いたしました次に協議事項3え"
    },
    {
      "start": 730.88,
      "duration": 4.8,
      "text": "案件付託先委員会の決定を行います議長"
    },
    {
      "start": 733.8,
      "duration": 5.52,
      "text": "から指案が提示されておりますので議長の"
    },
    {
      "start": 735.68,
      "duration": 6.56,
      "text": "説明お願いいたします議長えお手元に2"
    },
    {
      "start": 739.32,
      "duration": 5.879,
      "text": "審査案件予定表かこ案を配布しております"
    },
    {
      "start": 742.24,
      "duration": 7.64,
      "text": "ので事務局から説明します"
    },
    {
      "start": 745.199,
      "duration": 7.961,
      "text": "局長はいえお手元のえ審査案件予定案を"
    },
    {
      "start": 749.88,
      "duration": 7.04,
      "text": "ご覧いただきたいと思いますえ本臨時会に"
    },
    {
      "start": 753.16,
      "duration": 8.0,
      "text": "付議されております案件は議案第39号令"
    },
    {
      "start": 756.92,
      "duration": 7.4,
      "text": "は6年度小金市一般会計補正予算え第3回"
    },
    {
      "start": 761.16,
      "duration": 6.44,
      "text": "以上1件については本日の本会議に上程し"
    },
    {
      "start": 764.32,
      "duration": 6.6,
      "text": "説明質疑後委員会付託を省略して即決し"
    },
    {
      "start": 767.6,
      "duration": 5.359,
      "text": "たいというのが議長の指案でございます"
    },
    {
      "start": 770.92,
      "duration": 4.88,
      "text": "議長及び事務局の説明は終わりましたご"
    },
    {
      "start": 772.959,
      "duration": 8.161,
      "text": "意見ご式とはございます"
    },
    {
      "start": 775.8,
      "duration": 7.96,
      "text": "かはい山府長はいえっとこのあのえ即決と"
    },
    {
      "start": 781.12,
      "duration": 6.519,
      "text": "いうことなんですけれどもこれあの歳入"
    },
    {
      "start": 783.76,
      "duration": 6.96,
      "text": "歳出総括は別々という形での審議になるの"
    },
    {
      "start": 787.639,
      "duration": 3.081,
      "text": "かを確認したいと思い"
    },
    {
      "start": 791.56,
      "duration": 9.88,
      "text": "ます局長はい局ですはいえ歳入再室につい"
    },
    {
      "start": 796.76,
      "duration": 9.759,
      "text": "ては一括の形での質疑となります以上"
    },
    {
      "start": 801.44,
      "duration": 8.519,
      "text": "ですあ委員会じゃないんではいですはい"
    },
    {
      "start": 806.519,
      "duration": 5.601,
      "text": "よろしいですかはい他にございますかはい"
    },
    {
      "start": 809.959,
      "duration": 3.921,
      "text": "お諮りいたします本件につきましては議長"
    },
    {
      "start": 812.12,
      "duration": 4.32,
      "text": "の質問の通り決定することにご異議あり"
    },
    {
      "start": 813.88,
      "duration": 4.959,
      "text": "ませんかご異議がめております従って本件"
    },
    {
      "start": 816.44,
      "duration": 5.24,
      "text": "については議長の指の通り決定いたしまし"
    },
    {
      "start": 818.839,
      "duration": 6.721,
      "text": "た次に括弧4その他につきましてご発言は"
    },
    {
      "start": 821.68,
      "duration": 6.56,
      "text": "ございますかはい以上で臨時会の会期及び"
    },
    {
      "start": 825.56,
      "duration": 4.92,
      "text": "会議不等議会運営に関する調査を終了し"
    },
    {
      "start": 828.24,
      "duration": 5.039,
      "text": "ます以上で当委員会に負されました案件の"
    },
    {
      "start": 830.48,
      "duration": 5.24,
      "text": "審査は全部終了いたしましたこれで議会委"
    },
    {
      "start": 833.279,
      "duration": 4.761,
      "text": "委員会の会議を閉じ参加いたしますお疲れ"
    },
    {
      "start": 835.72,
      "duration": 6.359,
      "text": "様でし"
    },
    {
      "start": 838.04,
      "duration": 4.039,
      "text": "たあ"
    }
  ]
}