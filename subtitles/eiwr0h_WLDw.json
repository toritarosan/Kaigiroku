{
  "entries": [
    {
      "start": 91.96,
      "duration": 3.0,
      "text": "です"
    },
    {
      "start": 186.12,
      "duration": 7.0,
      "text": "それでは始めます白さんよろしいでしょう"
    },
    {
      "start": 189.04,
      "duration": 7.6,
      "text": "かね初めてもねはいえそれでは皆さ"
    },
    {
      "start": 193.12,
      "duration": 7.199,
      "text": "こんにちはあブーねブーから行きますはい"
    },
    {
      "start": 196.64,
      "duration": 6.959,
      "text": "どうぞえこんにちはただ今から広報協議会"
    },
    {
      "start": 200.319,
      "duration": 6.48,
      "text": "の会議を開きますえ直に議題に入りますえ"
    },
    {
      "start": 203.599,
      "duration": 7.161,
      "text": "1え各部会の報告についてを行いますえ"
    },
    {
      "start": 206.799,
      "duration": 9.44,
      "text": "始めに1面改革部会の報告を求めます小林"
    },
    {
      "start": 210.76,
      "duration": 8.24,
      "text": "さんえっと元にえ第5回の部会の会議録を"
    },
    {
      "start": 216.239,
      "duration": 7.72,
      "text": "お配りをさせていただいておりますえご覧"
    },
    {
      "start": 219.0,
      "duration": 12.72,
      "text": "くださいえっと今我々としてはですねえ"
    },
    {
      "start": 223.959,
      "duration": 11.321,
      "text": "来年3月の後の回線後特別後臨時号まこれ"
    },
    {
      "start": 231.72,
      "duration": 8.28,
      "text": "についてのですねえっとレイアウト変更A"
    },
    {
      "start": 235.28,
      "duration": 7.4,
      "text": "4番のですねえ検討をさせていいという"
    },
    {
      "start": 240.0,
      "duration": 5.799,
      "text": "とこですまターゲットとしてはえ今年の"
    },
    {
      "start": 242.68,
      "duration": 5.479,
      "text": "えっと秋のですね予算要望にまつげて"
    },
    {
      "start": 245.799,
      "duration": 5.8,
      "text": "いけるようにということで進めていると"
    },
    {
      "start": 248.159,
      "duration": 6.08,
      "text": "いうことでありますえ具体的にえ少し栄養"
    },
    {
      "start": 251.599,
      "duration": 5.521,
      "text": "にした形"
    },
    {
      "start": 254.239,
      "duration": 6.72,
      "text": "をアとして"
    },
    {
      "start": 257.12,
      "duration": 6.359,
      "text": "え叩き台をですねま皆さんで意見交換をし"
    },
    {
      "start": 260.959,
      "duration": 4.561,
      "text": "てるとこでありますえっと細かいところは"
    },
    {
      "start": 263.479,
      "duration": 3.481,
      "text": "見ていただいて分かるところなんですが"
    },
    {
      "start": 265.52,
      "duration": 7.56,
      "text": "えっと"
    },
    {
      "start": 266.96,
      "duration": 8.679,
      "text": "見開きのページでええ議員のま紹介などを"
    },
    {
      "start": 273.08,
      "duration": 5.76,
      "text": "ですね記載をさせていただきたいまそこに"
    },
    {
      "start": 275.639,
      "duration": 5.881,
      "text": "あの前にも少し触れたと思いますがえっと"
    },
    {
      "start": 278.84,
      "duration": 5.16,
      "text": "あまりそのメッセージみたいなとこは"
    },
    {
      "start": 281.52,
      "duration": 5.56,
      "text": "なかったのでま豊富や思いまこういった"
    },
    {
      "start": 284.0,
      "duration": 5.24,
      "text": "ものを載せてるま議会もありましたので"
    },
    {
      "start": 287.08,
      "duration": 4.92,
      "text": "参考にさせていただいて小金でもそのよう"
    },
    {
      "start": 289.24,
      "duration": 6.44,
      "text": "にしたら良いのではないかということでえ"
    },
    {
      "start": 292.0,
      "duration": 7.84,
      "text": "検討してるところでありますえっとですね"
    },
    {
      "start": 295.68,
      "duration": 6.44,
      "text": "あと丸5のとこにございますけれどもお"
    },
    {
      "start": 299.84,
      "duration": 5.56,
      "text": "今住所とかメールアドレスとかま様々あり"
    },
    {
      "start": 302.12,
      "duration": 6.519,
      "text": "ますがえ今え諸々"
    },
    {
      "start": 305.4,
      "duration": 7.2,
      "text": "の変更がまホームページなどでもされてる"
    },
    {
      "start": 308.639,
      "duration": 7.361,
      "text": "と思いますうまそれに順じた形でですねま"
    },
    {
      "start": 312.6,
      "duration": 5.92,
      "text": "こちらへの記載というのはま最小限として"
    },
    {
      "start": 316.0,
      "duration": 5.639,
      "text": "えあとはまホームページの方にま誘導して"
    },
    {
      "start": 318.52,
      "duration": 5.88,
      "text": "いくというような方向を考えてるとこです"
    },
    {
      "start": 321.639,
      "duration": 6.84,
      "text": "ま具体的にはま次回"
    },
    {
      "start": 324.4,
      "duration": 6.079,
      "text": "え以降ですねえ皆さんにお見せできればま"
    },
    {
      "start": 328.479,
      "duration": 4.801,
      "text": "そこでまた細かなご意をいただければと"
    },
    {
      "start": 330.479,
      "duration": 6.761,
      "text": "思っておりますまかこ2の今後の検討事項"
    },
    {
      "start": 333.28,
      "duration": 8.96,
      "text": "についてえご覧くださいまず1つはですね"
    },
    {
      "start": 337.24,
      "duration": 8.799,
      "text": "紙質としてですねま同じ再生子でもえ様々"
    },
    {
      "start": 342.24,
      "duration": 8.36,
      "text": "他市の事例を並べてみますとえもっとこの"
    },
    {
      "start": 346.039,
      "duration": 8.361,
      "text": "発色のいいものが結構ございますえま前回"
    },
    {
      "start": 350.6,
      "duration": 8.319,
      "text": "A4でお試しでやってみた時のものは"
    },
    {
      "start": 354.4,
      "duration": 6.88,
      "text": "ちょっとま写真も外でえ遠くから日陰を"
    },
    {
      "start": 358.919,
      "duration": 4.361,
      "text": "移したといういうところもあるんですがま"
    },
    {
      "start": 361.28,
      "duration": 5.319,
      "text": "紙の発色もちょっと悪かったんじゃないか"
    },
    {
      "start": 363.28,
      "duration": 6.0,
      "text": "というま経験上からですね少しその紙質に"
    },
    {
      "start": 366.599,
      "duration": 7.6,
      "text": "ついても検討ができないものかということ"
    },
    {
      "start": 369.28,
      "duration": 8.6,
      "text": "を考えておりますまた丸2ですえ回線時の"
    },
    {
      "start": 374.199,
      "duration": 6.84,
      "text": "集合写真え第1会議室での避弾を使ったえ"
    },
    {
      "start": 377.88,
      "duration": 8.08,
      "text": "集合写真を1枚撮っておりますがえこの"
    },
    {
      "start": 381.039,
      "duration": 6.641,
      "text": "回線号の表紙を想定した形でま外でも1枚"
    },
    {
      "start": 385.96,
      "duration": 6.4,
      "text": "取っていただくことってのはできないのか"
    },
    {
      "start": 387.68,
      "duration": 7.2,
      "text": "なということをま考えておりますまで丸"
    },
    {
      "start": 392.36,
      "duration": 7.119,
      "text": "さんにもつがるんですがまその際ですね"
    },
    {
      "start": 394.88,
      "duration": 9.159,
      "text": "えっと個人の写真撮影を行っております"
    },
    {
      "start": 399.479,
      "duration": 9.041,
      "text": "がま今のえ議会代りなどを見てもですねま"
    },
    {
      "start": 404.039,
      "duration": 8.321,
      "text": "その時の写真を使っている方はほとんどい"
    },
    {
      "start": 408.52,
      "duration": 7.239,
      "text": "ないとで使っている方でもですねせっかく"
    },
    {
      "start": 412.36,
      "duration": 6.36,
      "text": "取ったので使ってるという人もが多くて"
    },
    {
      "start": 415.759,
      "duration": 5.56,
      "text": "あのこの写真がないと困るという人は"
    },
    {
      "start": 418.72,
      "duration": 6.919,
      "text": "おそらく少ないじゃないかなというま考え"
    },
    {
      "start": 421.319,
      "duration": 7.801,
      "text": "からですね例えば予算上の解決策からすれ"
    },
    {
      "start": 425.639,
      "duration": 6.56,
      "text": "ばまこちらの個人撮影をやめてえ集合の"
    },
    {
      "start": 429.12,
      "duration": 4.919,
      "text": "写真を2カットにしていただくまこんな"
    },
    {
      "start": 432.199,
      "duration": 4.041,
      "text": "ことも検討できないのかなということで"
    },
    {
      "start": 434.039,
      "duration": 4.84,
      "text": "投げかけさせていただきたいと思っており"
    },
    {
      "start": 436.24,
      "duration": 5.639,
      "text": "ますえ次回については"
    },
    {
      "start": 438.879,
      "duration": 7.081,
      "text": "あま"
    },
    {
      "start": 441.879,
      "duration": 8.081,
      "text": "今後今日何これ6月15日あ定例会中の"
    },
    {
      "start": 445.96,
      "duration": 6.12,
      "text": "広報協議会終了後にですねえまたうせをし"
    },
    {
      "start": 449.96,
      "duration": 4.12,
      "text": "たいということで考えております以上です"
    },
    {
      "start": 452.08,
      "duration": 4.119,
      "text": "何かございましたらお願いしますはいご"
    },
    {
      "start": 454.08,
      "duration": 4.799,
      "text": "報告ありがとうございますただ今の報告に"
    },
    {
      "start": 456.199,
      "duration": 3.56,
      "text": "対してあのご意見またご質問ございます"
    },
    {
      "start": 458.879,
      "duration": 6.0,
      "text": "でしょう"
    },
    {
      "start": 459.759,
      "duration": 8.041,
      "text": "かはい斉藤さんあのすいません私市市"
    },
    {
      "start": 464.879,
      "duration": 5.72,
      "text": "改革の方だったんですけどちょこ部局に"
    },
    {
      "start": 467.8,
      "duration": 5.079,
      "text": "行きたいんですがあの個人写真あれはなん"
    },
    {
      "start": 470.599,
      "duration": 5.88,
      "text": "か記録かなんかでどうしても必要なもんな"
    },
    {
      "start": 472.879,
      "duration": 6.6,
      "text": "んですかねま議員がなんかで締め手配され"
    },
    {
      "start": 476.479,
      "duration": 3.0,
      "text": "たら"
    },
    {
      "start": 480.0,
      "duration": 6.8,
      "text": "はい次長はいえっと記録ま取っていただく"
    },
    {
      "start": 484.319,
      "duration": 7.361,
      "text": "もお持ちの方も今出してもらってるような"
    },
    {
      "start": 486.8,
      "duration": 7.48,
      "text": "形になるので特にあれだよねあのうんあの"
    },
    {
      "start": 491.68,
      "duration": 5.16,
      "text": "撮っていただく方もいればあの出して"
    },
    {
      "start": 494.28,
      "duration": 4.72,
      "text": "いただく方もいるんで一応そういう"
    },
    {
      "start": 496.84,
      "duration": 5.4,
      "text": "取り扱いだよ"
    },
    {
      "start": 499.0,
      "duration": 5.4,
      "text": "ねうちはいさうちとしてあのおっしゃる"
    },
    {
      "start": 502.24,
      "duration": 4.48,
      "text": "そのなんか保存とかそういう保存しなきゃ"
    },
    {
      "start": 504.4,
      "duration": 5.239,
      "text": "いけないというものではないというはい"
    },
    {
      "start": 506.72,
      "duration": 6.72,
      "text": "はいはいはい"
    },
    {
      "start": 509.639,
      "duration": 6.161,
      "text": "はあの一般質問の写真は全部その回線の時"
    },
    {
      "start": 513.44,
      "duration": 5.079,
      "text": "に撮った写真で強制的に全部やってたん"
    },
    {
      "start": 515.8,
      "duration": 4.88,
      "text": "ですがいつの頃からか自分が出したのでも"
    },
    {
      "start": 518.519,
      "duration": 5.4,
      "text": "いいということになって今はそっちの方が"
    },
    {
      "start": 520.68,
      "duration": 5.76,
      "text": "圧倒的に主流になったという歴史的経過が"
    },
    {
      "start": 523.919,
      "duration": 5.681,
      "text": "ありますねえだから逆に言うとそういう"
    },
    {
      "start": 526.44,
      "duration": 6.36,
      "text": "状況だったらば撮影が必要ないってこと"
    },
    {
      "start": 529.6,
      "duration": 3.2,
      "text": "ですね実態上の"
    },
    {
      "start": 534.279,
      "duration": 6.521,
      "text": "記そうです"
    },
    {
      "start": 537.48,
      "duration": 5.52,
      "text": "ね昔あとなんか4年に1回なんか卒業"
    },
    {
      "start": 540.8,
      "duration": 5.96,
      "text": "アルバムみたいなのくれたよ"
    },
    {
      "start": 543.0,
      "duration": 6.32,
      "text": "ねえ卒業アルバムであのアルバムくれたん"
    },
    {
      "start": 546.76,
      "duration": 4.199,
      "text": "ですよでそれに議員活動4年間の写真を"
    },
    {
      "start": 549.32,
      "duration": 4.0,
      "text": "議会事務機が撮って写真をペタペタ貼った"
    },
    {
      "start": 550.959,
      "duration": 4.32,
      "text": "のくれたんですよあれ立派なアルバムだっ"
    },
    {
      "start": 553.32,
      "duration": 5.079,
      "text": "たよ"
    },
    {
      "start": 555.279,
      "duration": 6.481,
      "text": "ね遠藤さんが知らないってこと"
    },
    {
      "start": 558.399,
      "duration": 6.721,
      "text": "は私と斎藤さんが知ってるってことは平成"
    },
    {
      "start": 561.76,
      "duration": 7.0,
      "text": "13年まであったってことだね"
    },
    {
      "start": 565.12,
      "duration": 6.92,
      "text": "えあちょ違うだ思い出したえっとね2冊"
    },
    {
      "start": 568.76,
      "duration": 6.04,
      "text": "しかないから僕5年と9年だから平成13"
    },
    {
      "start": 572.04,
      "duration": 5.56,
      "text": "年にもらったのが最後だそれ以降にあって"
    },
    {
      "start": 574.8,
      "duration": 5.84,
      "text": "ことエドあ違うたちょうどほら裸でエド"
    },
    {
      "start": 577.6,
      "duration": 6.56,
      "text": "さんちょっといなかった時期だったか"
    },
    {
      "start": 580.64,
      "duration": 5.8,
      "text": "なすいません思い出話にっ私も知らない"
    },
    {
      "start": 584.16,
      "duration": 6.08,
      "text": "ですええすいませんあのということなんで"
    },
    {
      "start": 586.44,
      "duration": 5.839,
      "text": "ございますねえはいということです他に"
    },
    {
      "start": 590.24,
      "duration": 3.4,
      "text": "ございますかこの件ではいいですかはい"
    },
    {
      "start": 592.279,
      "duration": 4.761,
      "text": "あの水さん"
    },
    {
      "start": 593.64,
      "duration": 9.0,
      "text": "どうぞはいあのごご報告ありがとうござい"
    },
    {
      "start": 597.04,
      "duration": 10.0,
      "text": "ますでえっと前回そのえっと人気半ばのえ"
    },
    {
      "start": 602.64,
      "duration": 7.68,
      "text": "人事改善の時にあのA4番に作った時に"
    },
    {
      "start": 607.04,
      "duration": 5.6,
      "text": "確か後であのQRコードでアンケートつけ"
    },
    {
      "start": 610.32,
      "duration": 6.6,
      "text": "とけばよかったねみたいな話が出たような"
    },
    {
      "start": 612.64,
      "duration": 6.28,
      "text": "気がしていましてで次回あのそれも検討し"
    },
    {
      "start": 616.92,
      "duration": 6.12,
      "text": "ていただけたらいいかなと思ったのでお"
    },
    {
      "start": 618.92,
      "duration": 7.359,
      "text": "願いしますはい小林さんはいあのその意見"
    },
    {
      "start": 623.04,
      "duration": 5.84,
      "text": "出したの私だったのででこのやり取りも"
    },
    {
      "start": 626.279,
      "duration": 4.0,
      "text": "毎回やってるので忘れずに乗せるようにし"
    },
    {
      "start": 628.88,
      "duration": 2.72,
      "text": "ます"
    },
    {
      "start": 630.279,
      "duration": 6.041,
      "text": "谷ございます"
    },
    {
      "start": 631.6,
      "duration": 8.72,
      "text": "かはい安田さんはいえっと今後の検討事項"
    },
    {
      "start": 636.32,
      "duration": 7.639,
      "text": "の神室の検討なんですけどもこれはあの"
    },
    {
      "start": 640.32,
      "duration": 6.36,
      "text": "前回あの作ったあの皆さんのあの表紙の"
    },
    {
      "start": 643.959,
      "duration": 6.281,
      "text": "写真のが発色がちょっといまいだったと"
    },
    {
      "start": 646.68,
      "duration": 6.76,
      "text": "いう反省ということですよねうんそれも含"
    },
    {
      "start": 650.24,
      "duration": 6.279,
      "text": "あそれも含めはい紙質だけの問題ではない"
    },
    {
      "start": 653.44,
      "duration": 5.92,
      "text": "のかなって印刷の問題っていう風に捉えて"
    },
    {
      "start": 656.519,
      "duration": 7.32,
      "text": "まもうちょっと写真が入るようなっていう"
    },
    {
      "start": 659.36,
      "duration": 7.08,
      "text": "検討が必要っということではいはいですね"
    },
    {
      "start": 663.839,
      "duration": 5.161,
      "text": "はいありがとうございますはい小林さんえ"
    },
    {
      "start": 666.44,
      "duration": 4.72,
      "text": "あのやさんおっしゃる通りですのでま他"
    },
    {
      "start": 669.0,
      "duration": 5.079,
      "text": "方面からですねあのせっかく作ったもの"
    },
    {
      "start": 671.16,
      "duration": 5.76,
      "text": "ですのでいい形でなるように色々アイデア"
    },
    {
      "start": 674.079,
      "duration": 5.681,
      "text": "をま部局も議員の皆さんからもいただいて"
    },
    {
      "start": 676.92,
      "duration": 5.12,
      "text": "え仕上げていただけたいなと思ってますえ"
    },
    {
      "start": 679.76,
      "duration": 4.96,
      "text": "であの今も安田さんからもあったんですが"
    },
    {
      "start": 682.04,
      "duration": 4.919,
