{
  "entries": [
    {
      "start": 88.439,
      "duration": 7.121,
      "text": "はいただいまから予算特別委員会の会議を"
    },
    {
      "start": 91.84,
      "duration": 6.76,
      "text": "開きます本日は年長の私が委員長が選さ"
    },
    {
      "start": 95.56,
      "duration": 6.0,
      "text": "れるまで委員長の職務を行いますたしに"
    },
    {
      "start": 98.6,
      "duration": 5.839,
      "text": "議題に入ります議題は当委員会の委員長の"
    },
    {
      "start": 101.56,
      "duration": 5.8,
      "text": "ご選についてでありますご選の方法につい"
    },
    {
      "start": 104.439,
      "duration": 6.481,
      "text": "てはいかがいたしましょうかどなたか選出"
    },
    {
      "start": 107.36,
      "duration": 7.56,
      "text": "方法についてご意見がありませんかはい森"
    },
    {
      "start": 110.92,
      "duration": 7.119,
      "text": "さんえ指名推薦でお願いいたします"
    },
    {
      "start": 114.92,
      "duration": 6.4,
      "text": "ただいま選出方法について指名推によると"
    },
    {
      "start": 118.039,
      "duration": 6.641,
      "text": "のご意見がありますがにより決定すること"
    },
    {
      "start": 121.32,
      "duration": 5.399,
      "text": "にご異議ありませんか講義なしと認め"
    },
    {
      "start": 124.68,
      "duration": 4.439,
      "text": "ただいま申し上げました通り決定いたし"
    },
    {
      "start": 126.719,
      "duration": 8.121,
      "text": "ますどの他かご推薦をいただけます"
    },
    {
      "start": 129.119,
      "duration": 10.041,
      "text": "でしょうか森さんえっと23番片山香議員"
    },
    {
      "start": 134.84,
      "duration": 8.16,
      "text": "を推薦をいたしますえ大変あのえ沈着冷静"
    },
    {
      "start": 139.16,
      "duration": 8.84,
      "text": "って先日も何かあのお言葉をいだいた"
    },
    {
      "start": 143.0,
      "duration": 7.76,
      "text": "ところですがえなおかつえ原理原則を大切"
    },
    {
      "start": 148.0,
      "duration": 6.68,
      "text": "にしてま公平な"
    },
    {
      "start": 150.76,
      "duration": 7.36,
      "text": "運営をされるのにふさわしい方だと思って"
    },
    {
      "start": 154.68,
      "duration": 5.36,
      "text": "おりますので是非片山さんに委員長をお"
    },
    {
      "start": 158.12,
      "duration": 6.16,
      "text": "願いしたいと思いますよろしくお願い"
    },
    {
      "start": 160.04,
      "duration": 7.199,
      "text": "いたしますただいま片山河委員を委員長に"
    },
    {
      "start": 164.28,
      "duration": 5.64,
      "text": "との推薦がございましたお諮りいたします"
    },
    {
      "start": 167.239,
      "duration": 6.121,
      "text": "片山香委員を委員長に選出することにご"
    },
    {
      "start": 169.92,
      "duration": 6.52,
      "text": "異議ありませんかなご異議なしと認めます"
    },
    {
      "start": 173.36,
      "duration": 8.0,
      "text": "従ってたい指名いたしました通り選出する"
    },
    {
      "start": 176.44,
      "duration": 8.96,
      "text": "ことに決定いたしました委員にまし山委員"
    },
    {
      "start": 181.36,
      "duration": 6.36,
      "text": "のご挨拶をお願いいしますはい山さんはい"
    },
    {
      "start": 185.4,
      "duration": 4.68,
      "text": "あ委員長に先いただきましてありがとう"
    },
    {
      "start": 187.72,
      "duration": 5.159,
      "text": "ございますあさんもありがとうございます"
    },
    {
      "start": 190.08,
      "duration": 4.439,
      "text": "あのちょっとあのとてもちょっと誰誰の"
    },
    {
      "start": 192.879,
      "duration": 3.92,
      "text": "こと言っ"
    },
    {
      "start": 194.519,
      "duration": 5.28,
      "text": "てお聞してき"
    },
    {
      "start": 196.799,
      "duration": 4.241,
      "text": "たいやいあの皆さんそう思ってるやっぱり"
    },
    {
      "start": 199.799,
      "duration": 3.841,
      "text": "ね"
    },
    {
      "start": 201.04,
      "duration": 5.6,
      "text": "はいいやいちょっとあの久しぶりの委員長"
    },
    {
      "start": 203.64,
      "duration": 5.2,
      "text": "なのであのえっと皆さんにお手伝え"
    },
    {
      "start": 206.64,
      "duration": 4.599,
      "text": "いただければと思っておりますあの高委員"
    },
    {
      "start": 208.84,
      "duration": 5.72,
      "text": "もですねあの無事解除者が皆さんのおかげ"
    },
    {
      "start": 211.239,
      "duration": 5.121,
      "text": "て設置されておりますのであのえっとよそ"
    },
    {
      "start": 214.56,
      "duration": 3.84,
      "text": "に私も行っても大丈夫かなと思いまして"
    },
    {
      "start": 216.36,
      "duration": 4.439,
      "text": "あの今回引き受けさせていただこうと思っ"
    },
    {
      "start": 218.4,
      "duration": 4.6,
      "text": "ておりますあのどうぞよろしくお願い"
    },
    {
      "start": 220.799,
      "duration": 2.201,
      "text": "いたし"
    },
    {
      "start": 223.959,
      "duration": 9.36,
      "text": "ますこれで私の職務は終了いたしました委"
    },
    {
      "start": 228.08,
      "duration": 5.239,
      "text": "長と交代するためしばらく休憩いたします"
    },
    {
      "start": 256.12,
      "duration": 6.72,
      "text": "はいはいはいはい再開いたしますはいはい"
    },
    {
      "start": 259.759,
      "duration": 5.481,
      "text": "はいはい再開いたしますえこれから副委長"
    },
    {
      "start": 262.84,
      "duration": 4.88,
      "text": "の誤選を行いますご選の方法について"
    },
    {
      "start": 265.24,
      "duration": 5.399,
      "text": "いかがいたしましょうかどなたか選出方法"
    },
    {
      "start": 267.72,
      "duration": 6.44,
      "text": "についてご意見がありませんかはいはい"
    },
    {
      "start": 270.639,
      "duration": 7.481,
      "text": "遠藤さんお願いします指名推薦でお願いし"
    },
    {
      "start": 274.16,
      "duration": 6.08,
      "text": "ますただいま選出方法について指名推薦に"
    },
    {
      "start": 278.12,
      "duration": 5.04,
      "text": "よるとのご意見がありますが指名推薦に"
    },
    {
      "start": 280.24,
      "duration": 5.2,
      "text": "より決定することにご異議ありませんか議"
    },
    {
      "start": 283.16,
      "duration": 4.92,
      "text": "ご異議なしと認めただいま申し上げました"
    },
    {
      "start": 285.44,
      "duration": 4.96,
      "text": "通り決定いたしますどなったかご推薦"
    },
    {
      "start": 288.08,
      "duration": 6.28,
      "text": "いただけますでしょうかはいはい遠藤さん"
    },
    {
      "start": 290.4,
      "duration": 6.68,
      "text": "はいえいつも果敢にあえる場面にその"
    },
    {
      "start": 294.36,
      "duration": 7.36,
      "text": "チャレンジをしつつ小金市議会をリード"
    },
    {
      "start": 297.08,
      "duration": 8.119,
      "text": "する沖浦淳議員を副長ににご推薦します"
    },
    {
      "start": 301.72,
      "duration": 6.759,
      "text": "はいただいま沖浦淳用副委長にとの推薦が"
    },
    {
      "start": 305.199,
      "duration": 5.641,
      "text": "ございましたお諮りいたします沖浦淳委員"
    },
    {
      "start": 308.479,
      "duration": 5.841,
      "text": "を副委員長に選出することにご異議あり"
    },
    {
      "start": 310.84,
      "duration": 5.48,
      "text": "ませんかなしご異議なしと認めます従って"
    },
    {
      "start": 314.32,
      "duration": 4.48,
      "text": "ただいま指名いたしました通り選出する"
    },
    {
      "start": 316.32,
      "duration": 5.92,
      "text": "ことに決定いたしましたただいま福井長に"
    },
    {
      "start": 318.8,
      "duration": 4.27,
      "text": "選出された沖浦淳委員のご挨拶をお願い"
    },
    {
      "start": 322.24,
      "duration": 2.28,
      "text": "いたします"
    },
    {
      "start": 323.07,
      "duration": 4.89,
      "text": "[音楽]"
    },
    {
      "start": 324.52,
      "duration": 4.76,
      "text": "はいどないお言葉いただきましてどうも"
    },
    {
      "start": 327.96,
      "duration": 4.6,
      "text": "ありがとうございます江野さんありがとう"
    },
    {
      "start": 329.28,
      "duration": 7.16,
      "text": "ございますえっと今あの推薦いただきまし"
    },
    {
      "start": 332.56,
      "duration": 6.16,
      "text": "てえ私もあの副委員長っていう職はもしか"
    },
    {
      "start": 336.44,
      "duration": 6.12,
      "text": "したらちょっと久しぶりなのかなと思い"
    },
    {
      "start": 338.72,
      "duration": 8.199,
      "text": "ますけれどもあの片山委員長心底サポート"
    },
    {
      "start": 342.56,
      "duration": 6.6,
      "text": "してえ議事の進行あの円滑な技術園に務め"
    },
    {
      "start": 346.919,
      "duration": 5.4,
      "text": "たいと思いますのでえ皆様のご協力も"
    },
    {
      "start": 349.16,
      "duration": 3.159,
      "text": "どうぞよろしくお願いいたし"
    },
    {
      "start": 354.24,
      "duration": 8.84,
      "text": "ますはいえ以上で予算特別委員会の会議を"
    },
    {
      "start": 358.44,
      "duration": 4.64,
      "text": "終了いたしますはい"
    }
  ]
}