{
  "video_id": "tolh-7DE9DQ",
  "entries": [
    {
      "start": 14.36,
      "duration": 5.52,
      "text": "呼び出しよう。えっと、それでは、あの、"
    },
    {
      "start": 16.84,
      "duration": 5.96,
      "text": "議会運営委員会、協議会を始めたいと思い"
    },
    {
      "start": 19.88,
      "duration": 7.28,
      "text": "ますが、今日は午前中、あの、オンライン"
    },
    {
      "start": 22.8,
      "duration": 6.68,
      "text": "会議のテスト会議ということで、えっと、"
    },
    {
      "start": 27.16,
      "duration": 5.439,
      "text": "まずね、議会運営委員会の会議を正式な"
    },
    {
      "start": 29.48,
      "duration": 6.239,
      "text": "会議開きますっていうことにして、で、"
    },
    {
      "start": 32.599,
      "duration": 6.321,
      "text": "あの、一旦休憩、オンライン、テスト会議"
    },
    {
      "start": 35.719,
      "duration": 6.281,
      "text": "を会開催するため、あの、休憩するって"
    },
    {
      "start": 38.92,
      "duration": 6.6,
      "text": "いうことで、あの、一旦その休憩に入って"
    },
    {
      "start": 42.0,
      "duration": 6.12,
      "text": "、あの、テスト会議という風にあのして"
    },
    {
      "start": 45.52,
      "duration": 5.84,
      "text": "いきたいという風に思います。で、あの"
    },
    {
      "start": 48.12,
      "duration": 6.64,
      "text": "ちょっと事前にあの参加されてるその委員"
    },
    {
      "start": 51.36,
      "duration": 6.64,
      "text": "以外の議員の方もあの説明聞いといて"
    },
    {
      "start": 54.76,
      "duration": 5.68,
      "text": "もらった方がいいかなと思いますので1回"
    },
    {
      "start": 58.0,
      "duration": 5.64,
      "text": "ちょっと議場に来ていただければと思うん"
    },
    {
      "start": 60.44,
      "duration": 8.28,
      "text": "ですがああ委員会室ねに来ていただければ"
    },
    {
      "start": 63.64,
      "duration": 5.08,
      "text": "と思うんですがよろしくお願いします。"
    },
    {
      "start": 213.84,
      "duration": 5.08,
      "text": "じゃあ、おはようございます。あの、議会"
    },
    {
      "start": 216.239,
      "duration": 5.681,
      "text": "運営委員会の協議会始めたいと思いますが"
    },
    {
      "start": 218.92,
      "duration": 5.679,
      "text": "、今日は午前中、あの、オンライン会議の"
    },
    {
      "start": 221.92,
      "duration": 4.72,
      "text": "テスト会議ということで、で、あの、"
    },
    {
      "start": 224.599,
      "duration": 5.161,
      "text": "新しい方もいらっしゃるので、ちょっと"
    },
    {
      "start": 226.64,
      "duration": 6.679,
      "text": "この間の経過だけ簡単にあの、説明して"
    },
    {
      "start": 229.76,
      "duration": 6.559,
      "text": "おきますと、えっと、オンライン会議を"
    },
    {
      "start": 233.319,
      "duration": 6.48,
      "text": "実施するための、えっと、協議をずっと"
    },
    {
      "start": 236.319,
      "duration": 8.12,
      "text": "こう重ねてきまして、で、一応ね、委員会"
    },
    {
      "start": 239.799,
      "duration": 6.16,
      "text": "条例改正案と運営の手引き案までは"
    },
    {
      "start": 244.439,
      "duration": 4.64,
      "text": "確認されたんですね。"
    },
    {
      "start": 245.959,
      "duration": 6.961,
      "text": "で、あの、災害時、えっと、感染症も含む"
    },
    {
      "start": 249.079,
      "duration": 6.44,
      "text": "。この時に限ってあの委員会でのオン"
    },
    {
      "start": 252.92,
      "duration": 5.8,
      "text": "ライン参加を認めるとま、いうことになっ"
    },
    {
      "start": 255.519,
      "duration": 6.28,
      "text": "てはいるんですがで、あの2回にわって"
    },
    {
      "start": 258.72,
      "duration": 6.64,
      "text": "テスト会議開いたんですけどやっぱり音声"
    },
    {
      "start": 261.799,
      "duration": 6.481,
      "text": "の不具合とか映像がちょっとあの十分に"
    },
    {
      "start": 265.36,
      "duration": 5.399,
      "text": "確認できないとかっていう問題があって、"
    },
    {
      "start": 268.28,
      "duration": 6.08,
      "text": "今現状でどこまでできるのかっていう"
    },
    {
      "start": 270.759,
      "duration": 6.481,
      "text": "ところをあの技のそのこのシステムが"
    },
    {
      "start": 274.36,
      "duration": 4.839,
      "text": "新しくなりましたのであとタブレットも"
    },
    {
      "start": 277.24,
      "duration": 4.519,
      "text": "あの"
    },
    {
      "start": 279.199,
      "duration": 4.601,
      "text": "と配布されるっていうことになったので、"
    },
    {
      "start": 281.759,
      "duration": 4.361,
      "text": "それを踏まえてもう1回テスト会議やろ"
    },
    {
      "start": 283.8,
      "duration": 5.6,
      "text": "うってことになって、ちょっと今日に至っ"
    },
    {
      "start": 286.12,
      "duration": 5.72,
      "text": "たと、ま、いうことであります。あの、"
    },
    {
      "start": 289.4,
      "duration": 4.72,
      "text": "それで、あの、ちょっと議員の委員以外の"
    },
    {
      "start": 291.84,
      "duration": 4.56,
      "text": "人もあの、参加いただきまして、ま、"
    },
    {
      "start": 294.12,
      "duration": 4.28,
      "text": "忙しい中ありがとうございます。で、"
    },
    {
      "start": 296.4,
      "duration": 6.88,
      "text": "ちょっとあの、えっと、これからテスト"
    },
    {
      "start": 298.4,
      "duration": 8.639,
      "text": "会議をするんですが、あの、音声の状況で"
    },
    {
      "start": 303.28,
      "duration": 5.639,
      "text": "あるとか、あとその、えっと、画像が、"
    },
    {
      "start": 307.039,
      "duration": 5.0,
      "text": "あの、どう見えるのかっていうところに"
    },
    {
      "start": 308.919,
      "duration": 6.201,
      "text": "ついてはちょっと一緒にあの、確認して"
    },
    {
      "start": 312.039,
      "duration": 5.88,
      "text": "いただきたいと、ま、いうことで一応参加"
    },
    {
      "start": 315.12,
      "duration": 5.96,
      "text": "をしていただきました。で、一応あの説明"
    },
    {
      "start": 317.919,
      "duration": 6.361,
      "text": "しておきますと、1番最初の時はですね、"
    },
    {
      "start": 321.08,
      "duration": 6.88,
      "text": "片山さんの席にモニターを置くっていう"
    },
    {
      "start": 324.28,
      "duration": 6.24,
      "text": "予定だったんですが、あの今回その"
    },
    {
      "start": 327.96,
      "duration": 5.84,
      "text": "小金年市のWebっていうシステムを使っ"
    },
    {
      "start": 330.52,
      "duration": 5.72,
      "text": "て、あの会議をこう運営するっていう子"
    },
    {
      "start": 333.8,
      "duration": 6.32,
      "text": "たちにそのオンライン会議を実施するって"
    },
    {
      "start": 336.24,
      "duration": 7.799,
      "text": "いうことになりまして、で、あのモニター"
    },
    {
      "start": 340.12,
      "duration": 7.44,
      "text": "をですね、このマイクから音を流すって"
    },
    {
      "start": 344.039,
      "duration": 6.28,
      "text": "いう風な仕組みにする関係で、ちょっと"
    },
    {
      "start": 347.56,
      "duration": 5.359,
      "text": "持ってるケーブルの長さとかですね、そう"
    },
    {
      "start": 350.319,
      "duration": 5.72,
      "text": "いう関係上モニターはちょっとここに置か"
    },
    {
      "start": 352.919,
      "duration": 6.601,
      "text": "ざるを得ないということになりました。と"
    },
    {
      "start": 356.039,
      "duration": 6.241,
      "text": "パソコンについてもあそこに置かないと"
    },
    {
      "start": 359.52,
      "duration": 4.76,
      "text": "ちょっとケーブルの長さが足りなくて"
    },
    {
      "start": 362.28,
      "duration": 5.4,
      "text": "あそこに置かせてもらうっていうことに"
    },
    {
      "start": 364.28,
      "duration": 7.12,
      "text": "なりましたのでだから多分ねこのまんまで"
    },
    {
      "start": 367.68,
      "duration": 6.0,
      "text": "委員会はちょっと開けないとあの事務局が"
    },
    {
      "start": 371.4,
      "duration": 5.079,
      "text": "ちょっとモニター確認しながらあのや"
    },
    {
      "start": 373.68,
      "duration": 5.519,
      "text": "るっていうのなかなか難しいのでという風"
    },
    {
      "start": 376.479,
      "duration": 5.12,
      "text": "なことでこういう配置になってるという"
    },
    {
      "start": 379.199,
      "duration": 5.921,
      "text": "ことをまずあのご理解いただきたいと思い"
    },
    {
      "start": 381.599,
      "duration": 7.761,
      "text": "ます。で、一応そのモニターとあのあそこ"
    },
    {
      "start": 385.12,
      "duration": 7.199,
      "text": "にある広角カメラであとあのパソコン、え"
    },
    {
      "start": 389.36,
      "duration": 6.839,
      "text": "、ポケットWi-Fiえっとあとケーブル"
    },
    {
      "start": 392.319,
      "duration": 7.16,
      "text": "等はえ、情報システム化からお借りして"
    },
    {
      "start": 396.199,
      "duration": 7.0,
      "text": "あのやっているとまい状況です。で、これ"
    },
    {
      "start": 399.479,
      "duration": 5.921,
      "text": "からその、えっと、条例改正に至るかどう"
    },
    {
      "start": 403.199,
      "duration": 5.161,
      "text": "かっていうことを議論することになるん"
    },
    {
      "start": 405.4,
      "duration": 5.519,
      "text": "ですが、ま、条例でこの、えっと、オン"
    },
    {
      "start": 408.36,
      "duration": 5.44,
      "text": "ライン会議をや、認めるってことになって"
    },
    {
      "start": 410.919,
      "duration": 6.0,
      "text": "くると、あの、やっぱりその申し出があっ"
    },
    {
      "start": 413.8,
      "duration": 5.28,
      "text": "た時に必ず開けるっていう形にしとかない"
    },
    {
      "start": 416.919,
      "duration": 4.801,
      "text": "と、ま、いけないっていうのがこの間の"
    },
    {
      "start": 419.08,
      "duration": 5.799,
      "text": "議論になってまして、だからこのままで"
    },
    {
      "start": 421.72,
      "duration": 6.12,
      "text": "できるのかどうか、ま、現状はちょっと"
    },
    {
      "start": 424.879,
      "duration": 5.76,
      "text": "あそこにパソコンがある関係では難しいっ"
    },
    {
      "start": 427.84,
      "duration": 4.919,
      "text": "てことになりますけどけれども、あの、ま"
    },
    {
      "start": 430.639,
      "duration": 5.84,
      "text": "、そういうことも今後の議論になってき"
    },
    {
      "start": 432.759,
      "duration": 7.361,
      "text": "ますので、ま、そういう点含めて是非あの"
    },
    {
      "start": 436.479,
      "duration": 6.761,
      "text": "皆さんでご確認いただければという風に"
    },
    {
      "start": 440.12,
      "duration": 6.479,
      "text": "あの思います。で、あとですね、あの、"
    },
    {
      "start": 443.24,
      "duration": 5.679,
      "text": "オンライン会議のこの、えっと、Web"
    },
    {
      "start": 446.599,
      "duration": 5.561,
      "text": "っていうシステムでオンライン開くんです"
    },
    {
      "start": 448.919,
      "duration": 6.801,
      "text": "けど、あの、各議員の皆さんも、ま、委員"
    },
    {
      "start": 452.16,
      "duration": 6.159,
      "text": "以外の方も含めて参加できますので、その"
    },
    {
      "start": 455.72,
      "duration": 6.879,
      "text": "辺ちょっと事務局で説明してもらっていい"
    },
    {
      "start": 458.319,
      "duration": 4.28,
      "text": "です?入り方について。"
    },
    {
      "start": 466.599,
      "duration": 4.401,
      "text": "はい、すいません。"
    },
    {
      "start": 468.0,
      "duration": 3.0,
      "text": "えっと、昨日ですね、ガルーンのメッセージの方に皆さんにあの、オンライン会議のテスト会議の"
    },
    {
      "start": 475.72,
      "duration": 4.039,
      "text": "URL"
    },
    {
      "start": 476.759,
      "duration": 3.0,
      "text": "パスワード会議番号と合わせて送らせていただいております。"
    },
    {
      "start": 481.28,
      "duration": 6.4,
      "text": "で、今回タブレットで入られる方とご自身"
    },
    {
      "start": 484.68,
      "duration": 4.799,
      "text": "のパソコンで入られる方など様々な方"
    },
    {
      "start": 487.68,
      "duration": 4.4,
      "text": "いらっしゃると思うんですけれども、"
    },
    {
      "start": 489.479,
      "duration": 5.601,
      "text": "タブレットで入られる場合にあの"
    },
    {
      "start": 492.08,
      "duration": 4.959,
      "text": "タブレット上にガルーンのアプリがもう"
    },
    {
      "start": 495.08,
      "duration": 4.48,
      "text": "すでにダウンロードされてるかっていう"
    },
    {
      "start": 497.039,
      "duration": 3.321,
      "text": "ところ。あ、ごめんなさい。ごめんなさい"
    },
    {
      "start": 499.56,
      "duration": 3.8,
      "text": "。"
    },
    {
      "start": 500.36,
      "duration": 3.0,
      "text": "のあのアプリがダウンロードされてるかっていうところがちょっと"
    },
    {
      "start": 505.0,
      "duration": 3.0,
      "text": "あるんですけれどもアプリ自体はですね、あのコモのポータルサイトの方にもうすでにインストールができる状態にはしてありますので、そちらから必要であれば行ってい、あのメッセージで送らせていただいた"
    },
    {
      "start": 524.159,
      "duration": 3.0,
      "text": "URL等を入れて入ってただくっていう形になると思います。"
    },
    {
      "start": 529.519,
      "duration": 4.601,
      "text": "以上です。"
    },
    {
      "start": 531.12,
      "duration": 3.0,
      "text": "えっと、分かりましたか、皆さん?あの、コモって、あの、このタブレットに入ってると思うんです。そこをあの、押していただくと、あの、いろんなインストールアプリのメニューが出てきますので、で、そこに"
    },
    {
      "start": 546.839,
      "duration": 3.0,
      "text": "Webっていうのがあって、それをインストールって押せば、"
    },
    {
      "start": 551.64,
      "duration": 4.92,
      "text": "あの、インストールできますので、"
    },
    {
      "start": 553.88,
      "duration": 5.68,
      "text": "白、白いアイコンで真黄緑色の"
    },
    {
      "start": 556.56,
      "duration": 3.0,
      "text": "黄緑色の棒って書いてあります。"
    },
    {
      "start": 562.2,
      "duration": 3.0,
      "text": "あ、これ"
    },
    {
      "start": 587.519,
      "duration": 2.76,
      "text": "で、個人のブラ"
    },
    {
      "start": 590.6,
      "duration": 5.08,
      "text": "パソコンで入られる場合はURL"
    },
    {
      "start": 592.68,
      "duration": 3.0,
      "text": "そのままブラウザーで開けると思いますん"
    },
    {
      "start": 834.759,
      "duration": 3.0,
      "text": "じゃあお願いします。え、おはようございます。"
    },
    {
      "start": 840.279,
      "duration": 3.641,
      "text": "おはようございます。"
    },
    {
      "start": 840.92,
      "duration": 3.0,
      "text": "え、ただ今から議会運営委員会の会議を開きます。え、ここでお諮りいたします。"
    },
    {
      "start": 845.959,
      "duration": 7.041,
      "text": "本日調査を予定しております、議会改革に"
    },
    {
      "start": 849.12,
      "duration": 7.12,
      "text": "関する書問題の調査、え、かこ1議会に"
    },
    {
      "start": 853.0,
      "duration": 5.759,
      "text": "ついての調査項目7の4、え、市議会オン"
    },
    {
      "start": 856.24,
      "duration": 6.279,
      "text": "ライン会議について、え、協議の参考と"
    },
    {
      "start": 858.759,
      "duration": 5.801,
      "text": "するため委員会をしオンライン会議を行い"
    },
    {
      "start": 862.519,
      "duration": 4.521,
      "text": "たいと思います。え、これにご異議あり"
    },
    {
      "start": 864.56,
      "duration": 4.56,
      "text": "ませんか?え、ご異議なしと認め、その"
    },
    {
      "start": 867.04,
      "duration": 6.799,
      "text": "ように決定いたします。それではテスト"
    },
    {
      "start": 869.12,
      "duration": 4.719,
      "text": "会議のため、え、休憩いたします。"
    }
  ]
}