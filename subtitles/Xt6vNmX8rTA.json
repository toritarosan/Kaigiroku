{
  "entries": [
    {
      "start": 14.759,
      "duration": 6.641,
      "text": "お疲れ様でございますえ議会運委員会協議"
    },
    {
      "start": 17.52,
      "duration": 8.919,
      "text": "会を開かせていただきますはってます"
    },
    {
      "start": 21.4,
      "duration": 9.6,
      "text": "ね私違いますよねはいえそれではえ今回は"
    },
    {
      "start": 26.439,
      "duration": 7.321,
      "text": "議案第45号の討論決にいの確認一件のみ"
    },
    {
      "start": 31.0,
      "duration": 4.68,
      "text": "でございますえ討論を予定されてるとこは"
    },
    {
      "start": 33.76,
      "duration": 4.479,
      "text": "ございますでしょうかじゃ準々ますかね"
    },
    {
      "start": 35.68,
      "duration": 5.24,
      "text": "準備と信頼の姉さんはいはいえっと住民主"
    },
    {
      "start": 38.239,
      "duration": 6.0,
      "text": "と信頼の小金河野議員が賛成討論いたし"
    },
    {
      "start": 40.92,
      "duration": 8.119,
      "text": "ますはい賛成討論河野さんはいえ未来の"
    },
    {
      "start": 44.239,
      "duration": 7.681,
      "text": "小金は反対で討論で村山お願いいたします"
    },
    {
      "start": 49.039,
      "duration": 5.561,
      "text": "はい子供の権利を守るかさんあちは討論は"
    },
    {
      "start": 51.92,
      "duration": 6.439,
      "text": "ありませんなしはいえ日本共産党さん"
    },
    {
      "start": 54.6,
      "duration": 8.36,
      "text": "えっと反対討論水上です反対で水上さん"
    },
    {
      "start": 58.359,
      "duration": 7.041,
      "text": "はいえコメトさん賛成渡辺ふき子さんお"
    },
    {
      "start": 62.96,
      "duration": 5.199,
      "text": "賛成で渡辺ふき子さんはいえこがね面白く"
    },
    {
      "start": 65.4,
      "duration": 4.6,
      "text": "する回さんあ討論ありませんなしはいじゃ"
    },
    {
      "start": 68.159,
      "duration": 5.481,
      "text": "生活者ネットワークさ他お願いいたします"
    },
    {
      "start": 70.0,
      "duration": 7.439,
      "text": "はいえ生活者ネットワーク反対討論えあ"
    },
    {
      "start": 73.64,
      "duration": 7.08,
      "text": "全部反対討論です街の仲間たちえ緑繋がる"
    },
    {
      "start": 77.439,
      "duration": 5.36,
      "text": "小がね以上ですはい"
    },
    {
      "start": 80.72,
      "duration": 5.64,
      "text": "1234567件ですか"
    },
    {
      "start": 82.799,
      "duration": 7.441,
      "text": "ねはい賛成が2の反対後の討論ということ"
    },
    {
      "start": 86.36,
      "duration": 5.759,
      "text": "になりますねはいえそれではえっと"
    },
    {
      "start": 90.24,
      "duration": 4.559,
      "text": "最は通りということでよろしかった"
    },
    {
      "start": 92.119,
      "duration": 5.401,
      "text": "でしょうかはいはいそれでは以上でいいの"
    },
    {
      "start": 94.799,
      "duration": 5.921,
      "text": "かなはいそれでは以上でえ議会会協参加"
    },
    {
      "start": 97.52,
      "duration": 3.2,
      "text": "いたします"
    }
  ]
