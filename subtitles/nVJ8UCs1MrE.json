{
  "entries": [
    {
      "start": 22.64,
      "duration": 4.12,
      "text": "はい皆様お疲れ様です帝国前でございます"
    },
    {
      "start": 24.96,
      "duration": 3.559,
      "text": "がお揃いでございますので始めにさせて"
    },
    {
      "start": 26.76,
      "duration": 4.04,
      "text": "いただいてよろしいですかはいそれでは"
    },
    {
      "start": 28.519,
      "duration": 4.001,
      "text": "ただいまより議会運会議会を始めさせて"
    },
    {
      "start": 30.8,
      "duration": 4.759,
      "text": "いただきますお手元の協議事項をご覧"
    },
    {
      "start": 32.52,
      "duration": 5.8,
      "text": "くださいえ委員会の進行予定について審査"
    },
    {
      "start": 35.559,
      "duration": 5.0,
      "text": "権議長の諮問事項1件でございます議会"
    },
    {
      "start": 38.32,
      "duration": 5.28,
      "text": "運営に関する議長の諮問事項についてえ"
    },
    {
      "start": 40.559,
      "duration": 5.68,
      "text": "星願陳情の追加分の付託委員会についてえ"
    },
    {
      "start": 43.6,
      "duration": 4.439,
      "text": "議員の派遣について議会運営委員会継続"
    },
    {
      "start": 46.239,
      "duration": 4.8,
      "text": "審査議決についてこれいつもやってるやつ"
    },
    {
      "start": 48.039,
      "duration": 7.241,
      "text": "ですねでその他でご発言があればお願いを"
    },
    {
      "start": 51.039,
      "duration": 6.761,
      "text": "いたしますえ協議会事項でございましてえ"
    },
    {
      "start": 55.28,
      "duration": 5.239,
      "text": "議員提出議案の討論採決について確認をさ"
    },
    {
      "start": 57.8,
      "duration": 6.639,
      "text": "せていただきます討論がある会派"
    },
    {
      "start": 60.519,
      "duration": 9.321,
      "text": "お願いしますはい小金面白くす会さんはい"
    },
    {
      "start": 64.439,
      "duration": 8.0,
      "text": "え議員案第47号反対討論水谷ですはい"
    },
    {
      "start": 69.84,
      "duration": 7.279,
      "text": "47号反対で水谷さんおかございますか"
    },
    {
      "start": 72.439,
      "duration": 10.961,
      "text": "はいはい片山はい議長"
    },
    {
      "start": 77.119,
      "duration": 11.801,
      "text": "はいあはいえ47号にえ賛成討論渡辺大造"
    },
    {
      "start": 83.4,
      "duration": 7.2,
      "text": "賛成等はい47号賛成で渡辺大造以上2件"
    },
    {
      "start": 88.92,
      "duration": 5.08,
      "text": "でよろしかったですか"
    },
    {
      "start": 90.6,
      "duration": 5.32,
      "text": "はいえではえ採決については従前通りと"
    },
    {
      "start": 94.0,
      "duration": 5.759,
      "text": "いうことでよろしかったでしょうかはい"
    },
    {
      "start": 95.92,
      "duration": 3.839,
      "text": "それでは委委員会に入って参り"
    },
    {
      "start": 100.24,
      "duration": 4.839,
      "text": "ますただ今から議会運営委員会の会議を"
    },
    {
      "start": 102.92,
      "duration": 4.239,
      "text": "開きます直に議事に入ります当委員会に"
    },
    {
      "start": 105.079,
      "duration": 4.36,
      "text": "付託されております案件は議長の諮問事項"
    },
    {
      "start": 107.159,
      "duration": 4.081,
      "text": "1件であります議長からお手元に議会運営"
    },
    {
      "start": 109.439,
      "duration": 3.72,
      "text": "委員会協議事項が提示されておりますので"
    },
    {
      "start": 111.24,
      "duration": 4.08,
      "text": "その順序に従って順次協議をしてまいり"
    },
    {
      "start": 113.159,
      "duration": 4.161,
      "text": "たいと思います議会上に関する議長の諮問"
    },
    {
      "start": 115.32,
      "duration": 5.04,
      "text": "事項についてを議題といたします初めに"
    },
    {
      "start": 117.32,
      "duration": 5.28,
      "text": "協議事項括1正眼賃常の追加分の2委員会"
    },
    {
      "start": 120.36,
      "duration": 3.96,
      "text": "について行います議長の指案が示されて"
    },
    {
      "start": 122.6,
      "duration": 5.4,
      "text": "おりますので議長から説明をお願いいたし"
    },
    {
      "start": 124.32,
      "duration": 7.4,
      "text": "ますえ10月4日の午後5時までに"
    },
    {
      "start": 128.0,
      "duration": 5.959,
      "text": "受け付けました西岸陳情は陳情9権です"
    },
    {
      "start": 131.72,
      "duration": 7.519,
      "text": "細分につきましては事務局から説明します"
    },
    {
      "start": 133.959,
      "duration": 8.241,
      "text": "局長はいえ6陳情第42号から6陳情第"
    },
    {
      "start": 139.239,
      "duration": 7.72,
      "text": "50号までの先委員会につきましてはお"
    },
    {
      "start": 142.2,
      "duration": 8.24,
      "text": "手元の西が陳情の委員会委員会追加託予定"
    },
    {
      "start": 146.959,
      "duration": 6.321,
      "text": "表各案の通りでございますなお発言申し出"
    },
    {
      "start": 150.44,
      "duration": 5.12,
      "text": "につきましては委員会前日の生後までに"
    },
    {
      "start": 153.28,
      "duration": 4.84,
      "text": "発言申し出ができますことを申し添えて"
    },
    {
      "start": 155.56,
      "duration": 6.0,
      "text": "おきます以上の通り付託するというのが"
    },
    {
      "start": 158.12,
      "duration": 5.32,
      "text": "議長の新聞案でございます議長及び事務局"
    },
    {
      "start": 161.56,
      "duration": 3.44,
      "text": "の説明は終わりましたご意見ご質疑等"
    },
    {
      "start": 163.44,
      "duration": 4.719,
      "text": "ございます"
    },
    {
      "start": 165.0,
      "duration": 5.879,
      "text": "かお諮りいたします本件についてはお手元"
    },
    {
      "start": 168.159,
      "duration": 5.16,
      "text": "に配布されております2予定表括案の通り"
    },
    {
      "start": 170.879,
      "duration": 5.161,
      "text": "決定することにご異議ありませんかご異議"
    },
    {
      "start": 173.319,
      "duration": 5.2,
      "text": "なしと認め正眼陳情の2先委員会について"
    },
    {
      "start": 176.04,
      "duration": 5.24,
      "text": "はお手元の予定表の通り決定いたしました"
    },
    {
      "start": 178.519,
      "duration": 4.8,
      "text": "次に協議事故に議員の派遣についてを行い"
    },
    {
      "start": 181.28,
      "duration": 3.92,
      "text": "ます議長の指案が示されておりますので"
    },
    {
      "start": 183.319,
      "duration": 5.48,
      "text": "議長から説明をお願いいたしますはいえ"
    },
    {
      "start": 185.2,
      "duration": 6.08,
      "text": "事務局から説明いたしますはい局長え本日"
    },
    {
      "start": 188.799,
      "duration": 4.921,
      "text": "までに決定しております議員派遣につき"
    },
    {
      "start": 191.28,
      "duration": 5.76,
      "text": "ましてはお手元の資料の通りとなっており"
    },
    {
      "start": 193.72,
      "duration": 6.68,
      "text": "ます本件につきましては説明しぎ委員会"
    },
    {
      "start": 197.04,
      "duration": 6.759,
      "text": "負託を省略して即決するまた初犯の事情に"
    },
    {
      "start": 200.4,
      "duration": 6.399,
      "text": "より変更が生じた場合や閉会中に議員派遣"
    },
    {
      "start": 203.799,
      "duration": 6.921,
      "text": "が生じた場合などについてその日時場所"
    },
    {
      "start": 206.799,
      "duration": 6.961,
      "text": "目的及び派遣議員名等は議長に1に願い"
    },
    {
      "start": 210.72,
      "duration": 5.12,
      "text": "たいというのが議長の指案でございます"
    },
    {
      "start": 213.76,
      "duration": 5.119,
      "text": "議長及び事務局の説明は終わりましたご"
    },
    {
      "start": 215.84,
      "duration": 5.28,
      "text": "意見ご質疑とございますかお諮りいたし"
    },
    {
      "start": 218.879,
      "duration": 5.761,
      "text": "ます本件につきましては議長の諮問の通り"
    },
    {
      "start": 221.12,
      "duration": 8.64,
      "text": "決定することにご異議ありませんかご異議"
    },
    {
      "start": 224.64,
      "duration": 8.319,
      "text": "なしはいまいはい福委員すいませんえっと"
    },
    {
      "start": 229.76,
      "duration": 5.8,
      "text": "議員派遣の件ですけどえっと3番目に第2"
    },
    {
      "start": 232.959,
      "duration": 6.28,
      "text": "中学校70周年が入ってますけどあれ11"
    },
    {
      "start": 235.56,
      "duration": 7.72,
      "text": "月にもう1個なんかどっかの中学校で年"
    },
    {
      "start": 239.239,
      "duration": 4.041,
      "text": "あったよ僕なかったでし"
    },
    {
      "start": 243.879,
      "duration": 5.481,
      "text": "たはい"
    },
    {
      "start": 245.799,
      "duration": 6.64,
      "text": "次長ちょ3ヶ月予定表に入ってる11月の"
    },
    {
      "start": 249.36,
      "duration": 7.36,
      "text": "学校の予定としては11月22日の金曜日"
    },
    {
      "start": 252.439,
      "duration": 8.441,
      "text": "に東中学校の創立60周年記念の式典が"
    },
    {
      "start": 256.72,
      "duration": 7.88,
      "text": "入ってございます11月22日金曜日東中"
    },
    {
      "start": 260.88,
      "duration": 7.039,
      "text": "学校創立60周年記念式典13時30分"
    },
    {
      "start": 264.6,
      "duration": 3.319,
      "text": "からでございます以上"
    },
    {
      "start": 267.96,
      "duration": 4.2,
      "text": "ですはいございます"
    },
    {
      "start": 284.16,
      "duration": 6.759,
      "text": "かすいませんあの確定したものだけ今議員"
    },
    {
      "start": 288.12,
      "duration": 5.0,
      "text": "派遣をさせていただいてて東中学校のは"
    },
    {
      "start": 290.919,
      "duration": 5.28,
      "text": "ちょっと仮で予定として入ってございます"
    },
    {
      "start": 293.12,
      "duration": 6.56,
      "text": "ので今の時点で入っててでもしこの後起き"
    },
    {
      "start": 296.199,
      "duration": 6.321,
      "text": "た場合はまたあのえっと派遣の方をはい"
    },
    {
      "start": 299.68,
      "duration": 5.92,
      "text": "議長の方で掲載してあの派遣をかけると"
    },
    {
      "start": 302.52,
      "duration": 5.119,
      "text": "いう形になりますはいキあすいませんあの"
    },
    {
      "start": 305.6,
      "duration": 5.08,
      "text": "その順々で全然僕構わないんですけどなん"
    },
    {
      "start": 307.639,
      "duration": 5.56,
      "text": "か確定したて1度聞いたような気がしてた"
    },
    {
      "start": 310.68,
      "duration": 4.92,
      "text": "です3ヶ月予定の時それで今ちょっと仮が"
    },
    {
      "start": 313.199,
      "duration": 5.081,
      "text": "取れたんだていう話聞いてたんでそれで今"
    },
    {
      "start": 315.6,
      "duration": 5.64,
      "text": "伺かかったとですまあの確認していただけ"
    },
    {
      "start": 318.28,
      "duration": 5.56,
      "text": "大丈夫ですそれはい次長えっと今のところ"
    },
    {
      "start": 321.24,
      "duration": 4.48,
      "text": "うちとしてはちょっと仮の方で入れさせて"
    },
    {
      "start": 323.84,
      "duration": 6.12,
      "text": "いただいてますのではいはいよろしくお"
    },
    {
      "start": 325.72,
      "duration": 6.24,
      "text": "願いしますはい他にございますかはいでお"
    },
    {
      "start": 329.96,
      "duration": 4.079,
      "text": "諮りいたします本件については議長の諮問"
    },
    {
      "start": 331.96,
      "duration": 4.04,
      "text": "の通り決定することにご異議ありませんか"
    },
    {
      "start": 334.039,
      "duration": 4.28,
      "text": "ご異議なしと認めます従って本件は議長の"
    },
    {
      "start": 336.0,
      "duration": 5.0,
      "text": "諮問の通り決定いたしました次に協議事項"
    },
    {
      "start": 338.319,
      "duration": 5.72,
      "text": "括3議会運営委員会継続審査議決について"
    },
    {
      "start": 341.0,
      "duration": 6.919,
      "text": "行いますお諮りいたします次期定例会各"
    },
    {
      "start": 344.039,
      "duration": 7.041,
      "text": "臨時会を含むのえ会期及び会議配等議会"
    },
    {
      "start": 347.919,
      "duration": 6.56,
      "text": "運営に関する調査議会の会議規則委員会"
    },
    {
      "start": 351.08,
      "duration": 6.679,
      "text": "条例等に関する調査議会運営に関する議長"
    },
    {
      "start": 354.479,
      "duration": 5.601,
      "text": "の諮問事項について閉会中もなを継続して"
    },
    {
      "start": 357.759,
      "duration": 4.121,
      "text": "調査することにご異議ありませんかご異議"
    },
    {
      "start": 360.08,
      "duration": 4.08,
      "text": "なしと認めます従ってただいま申し上げ"
    },
    {
      "start": 361.88,
      "duration": 4.879,
      "text": "ました通り閉会中もを継続して調査する"
    },
    {
      "start": 364.16,
      "duration": 5.599,
      "text": "ことと決定いたしました協議事項括4その"
    },
    {
      "start": 366.759,
      "duration": 5.84,
      "text": "他でございますが何かご発言はございます"
    },
    {
      "start": 369.759,
      "duration": 4.56,
      "text": "かはい以上で当委員会に付託されており"
    },
    {
      "start": 372.599,
      "duration": 4.88,
      "text": "ます案件の審査は全て終了いたしました"
    },
    {
      "start": 374.319,
      "duration": 6.16,
      "text": "これで議会委員会の会議を参加いたします"
    },
    {
      "start": 377.479,
      "duration": 3.0,
      "text": "はい"
    }
  ]
}