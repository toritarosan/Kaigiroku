{
  "entries": [
    {
      "start": 0.0,
      "duration": 3.0,
      "text": "OG"
    },
    {
      "start": 120.119,
      "duration": 3.0,
      "text": "さ"
    },
    {
      "start": 159.28,
      "duration": 6.92,
      "text": "再開しますここで先ほど保留しました日程"
    },
    {
      "start": 162.319,
      "duration": 7.56,
      "text": "第2の保留を解き討論採決を行います議案"
    },
    {
      "start": 166.2,
      "duration": 6.8,
      "text": "第1号世界で唯一の戦争被爆国として各"
    },
    {
      "start": 169.879,
      "duration": 6.801,
      "text": "廃絶に向けて主導的な役割を果たすことを"
    },
    {
      "start": 173.0,
      "duration": 6.84,
      "text": "求める意見書本件は討論を行います初めに"
    },
    {
      "start": 176.68,
      "duration": 5.72,
      "text": "本件に反対のものの発言を許可します5番"
    },
    {
      "start": 179.84,
      "duration": 2.56,
      "text": "清水学"
    },
    {
      "start": 190.12,
      "duration": 7.28,
      "text": "議員議員案第1号世界で唯一の戦争被爆国"
    },
    {
      "start": 194.64,
      "duration": 5.4,
      "text": "として各廃絶に向けて指導的な役割を"
    },
    {
      "start": 197.4,
      "duration": 5.199,
      "text": "果たすことを求める意見書について町の"
    },
    {
      "start": 200.04,
      "duration": 6.479,
      "text": "仲間たちとして反対の立場で討論いたし"
    },
    {
      "start": 202.599,
      "duration": 7.28,
      "text": "ますえ我が国日本は世界で唯一の戦争被爆"
    },
    {
      "start": 206.519,
      "duration": 6.201,
      "text": "国であり日本政府は各兵器禁止条約が"
    },
    {
      "start": 209.879,
      "duration": 5.801,
      "text": "目指す核兵器廃絶という目標を共有して"
    },
    {
      "start": 212.72,
      "duration": 6.239,
      "text": "いることと思いますその意味では本意見書"
    },
    {
      "start": 215.68,
      "duration": 5.88,
      "text": "が求めている核兵器禁止条約締結国会議"
    },
    {
      "start": 218.959,
      "duration": 5.36,
      "text": "オブザーバーとして出席することは国際"
    },
    {
      "start": 221.56,
      "duration": 5.64,
      "text": "社会において日本の姿勢を示す点において"
    },
    {
      "start": 224.319,
      "duration": 5.881,
      "text": "は一定の意義があると考えますが"
    },
    {
      "start": 227.2,
      "duration": 6.56,
      "text": "オブザーバーとしての参加だったとしても"
    },
    {
      "start": 230.2,
      "duration": 6.72,
      "text": "当会議に参加することを日本を核の脅威に"
    },
    {
      "start": 233.76,
      "duration": 6.16,
      "text": "さらす国や地域がどのように受け取るかと"
    },
    {
      "start": 236.92,
      "duration": 6.879,
      "text": "いったことについて大きな懸念を拭い去る"
    },
    {
      "start": 239.92,
      "duration": 8.399,
      "text": "ことができません核兵器禁止条約には我が"
    },
    {
      "start": 243.799,
      "duration": 8.481,
      "text": "国に対し我が国に対し従前よりも一層重大"
    },
    {
      "start": 248.319,
      "duration": 7.2,
      "text": "かつ差し迫った脅威をもたらす中国ロシア"
    },
    {
      "start": 252.28,
      "duration": 7.359,
      "text": "北朝鮮など核兵器を保有している国がこの"
    },
    {
      "start": 255.519,
      "duration": 7.321,
      "text": "条約に1カ国も入っておらず未だ核兵器の"
    },
    {
      "start": 259.639,
      "duration": 7.881,
      "text": "ない世界への出口に至る筋道が立っており"
    },
    {
      "start": 262.84,
      "duration": 7.68,
      "text": "ませんえ私たちは唯一の戦争被爆国として"
    },
    {
      "start": 267.52,
      "duration": 5.92,
      "text": "核軍縮に向けて普段の努力をを重ねていか"
    },
    {
      "start": 270.52,
      "duration": 6.119,
      "text": "なければなりませんしかしながら同時に"
    },
    {
      "start": 273.44,
      "duration": 6.56,
      "text": "我が国のインド太平洋地域における安全"
    },
    {
      "start": 276.639,
      "duration": 7.521,
      "text": "保障の課題である各ミサイル開発を進める"
    },
    {
      "start": 280.0,
      "duration": 8.32,
      "text": "北朝鮮核戦力を拡大させる中国ロシアの"
    },
    {
      "start": 284.16,
      "duration": 7.8,
      "text": "軍事力の近代化軍事活動の活発化の傾向と"
    },
    {
      "start": 288.32,
      "duration": 7.68,
      "text": "いった不安定要因を抱えておりますそして"
    },
    {
      "start": 291.96,
      "duration": 7.2,
      "text": "日本はえ安全保障を究極的にアメリカの核"
    },
    {
      "start": 296.0,
      "duration": 7.36,
      "text": "の傘に依存するという現実からは目を"
    },
    {
      "start": 299.16,
      "duration": 7.4,
      "text": "そらすことはできませんそのために日本"
    },
    {
      "start": 303.36,
      "duration": 7.36,
      "text": "政府は国民の生命と財産を守る責務から"
    },
    {
      "start": 306.56,
      "duration": 7.44,
      "text": "安全保障上の脅威にえ適切に対処すると"
    },
    {
      "start": 310.72,
      "duration": 6.16,
      "text": "ともにえ政府としても各保有をアメリカ"
    },
    {
      "start": 314.0,
      "duration": 6.88,
      "text": "イギリスフランスロシア中国のご家国のみ"
    },
    {
      "start": 316.88,
      "duration": 7.48,
      "text": "に限る各拡散防止条約を通じて地道に核"
    },
    {
      "start": 320.88,
      "duration": 7.879,
      "text": "軍縮を前進させる筋道を追求する必要が"
    },
    {
      "start": 324.36,
      "duration": 8.559,
      "text": "あり核兵器保有国や条約指示国を含む国際"
    },
    {
      "start": 328.759,
      "duration": 7.121,
      "text": "社会における橋渡し役を果たし現実的な"
    },
    {
      "start": 332.919,
      "duration": 7.241,
      "text": "取り組みを粘り強く進めていくことが重要"
    },
    {
      "start": 335.88,
      "duration": 7.84,
      "text": "であると考えます以上踏まええ議案第1号"
    },
    {
      "start": 340.16,
      "duration": 6.4,
      "text": "世界で唯一の戦争被爆国として核廃絶に"
    },
    {
      "start": 343.72,
      "duration": 6.28,
      "text": "向けた主導的な役割りを果たすことを"
    },
    {
      "start": 346.56,
      "duration": 6.68,
      "text": "求める意見書について反討論反対討論と"
    },
    {
      "start": 350.0,
      "duration": 3.24,
      "text": "いたします"
    },
    {
      "start": 361.88,
      "duration": 7.84,
      "text": "次に本件に賛成のものの発言を許可します"
    },
    {
      "start": 364.88,
      "duration": 4.84,
      "text": "24番森戸洋子議員はい"
    },
    {
      "start": 392.24,
      "duration": 8.959,
      "text": "え銀案第1号世界で唯一の戦争被爆国とし"
    },
    {
      "start": 396.88,
      "duration": 7.56,
      "text": "て核兵器あ核廃絶に向けて指導的な役割を"
    },
    {
      "start": 401.199,
      "duration": 7.241,
      "text": "果たすことを求める意見書にえ賛成の立場"
    },
    {
      "start": 404.44,
      "duration": 8.319,
      "text": "から討論をいたしますえ昨日えある"
    },
    {
      "start": 408.44,
      "duration": 8.72,
      "text": "アメリカの科学雑誌があ核の時計が人類"
    },
    {
      "start": 412.759,
      "duration": 8.521,
      "text": "絶滅90秒前を指しているということを"
    },
    {
      "start": 417.16,
      "duration": 8.159,
      "text": "公表をいたしましたあ今や核兵器使用の"
    },
    {
      "start": 421.28,
      "duration": 7.88,
      "text": "可能性に人類が脅かされ続けなければなら"
    },
    {
      "start": 425.319,
      "duration": 7.081,
      "text": "ないえこんな状況になっていますえ昨年末"
    },
    {
      "start": 429.16,
      "duration": 6.28,
      "text": "日本避団協の皆さんがノーベル平和賞を"
    },
    {
      "start": 432.4,
      "duration": 7.28,
      "text": "受賞されたことをえ多分ここに"
    },
    {
      "start": 435.44,
      "duration": 8.199,
      "text": "いらっしゃる多くの皆さんも喜びそしてえ"
    },
    {
      "start": 439.68,
      "duration": 6.959,
      "text": "この核兵器廃絶に向けてえなんとか前に"
    },
    {
      "start": 443.639,
      "duration": 6.56,
      "text": "進めなければいけないと思われたのでは"
    },
    {
      "start": 446.639,
      "duration": 7.84,
      "text": "ないでしょうか長年被爆者に対しする誤解"
    },
    {
      "start": 450.199,
      "duration": 8.521,
      "text": "や偏見を乗り越え被爆の実装を語り継いで"
    },
    {
      "start": 454.479,
      "duration": 7.4,
      "text": "こられたことに私は頭が下がる思いです"
    },
    {
      "start": 458.72,
      "duration": 7.72,
      "text": "個人的にはなりますが私が核兵器廃絶の"
    },
    {
      "start": 461.879,
      "duration": 8.841,
      "text": "活動にえ参加をしたのは高校生1年生え"
    },
    {
      "start": 466.44,
      "duration": 8.28,
      "text": "15歳の時でありましたあれから50年"
    },
    {
      "start": 470.72,
      "duration": 6.479,
      "text": "硬い中で核兵器廃絶などと言って歩いてい"
    },
    {
      "start": 474.72,
      "duration": 6.039,
      "text": "たらそんなことができないできるはずが"
    },
    {
      "start": 477.199,
      "duration": 7.84,
      "text": "ないだろうと相手にされず白い目で見られ"
    },
    {
      "start": 480.759,
      "duration": 8.0,
      "text": "ていることをあの高校生の時に本当に心が"
    },
    {
      "start": 485.039,
      "duration": 7.041,
      "text": "折れそうになりましたしかし今回の受賞は"
    },
    {
      "start": 488.759,
      "duration": 7.16,
      "text": "被爆者だけではなく核兵器廃絶の活動に"
    },
    {
      "start": 492.08,
      "duration": 7.559,
      "text": "取り組む世界と日本の人々を励ますものと"
    },
    {
      "start": 495.919,
      "duration": 6.921,
      "text": "なりました世界はどうやっても変わらない"
    },
    {
      "start": 499.639,
      "duration": 6.201,
      "text": "アメリカが核を持っているんだから核の傘"
    },
    {
      "start": 502.84,
      "duration": 7.12,
      "text": "に入ることを辞めるわけにはいかないえ"
    },
    {
      "start": 505.84,
      "duration": 6.48,
      "text": "こんなことを考えている方が多くあ少なく"
    },
    {
      "start": 509.96,
      "duration": 6.6,
      "text": "なくいらっしゃいます先ほどの討論もそう"
    },
    {
      "start": 512.32,
      "duration": 7.36,
      "text": "でした声を出し続けることが世界の大きな"
    },
    {
      "start": 516.56,
      "duration": 7.68,
      "text": "変化を作り出すことを私は実感をしてい"
    },
    {
      "start": 519.68,
      "duration": 7.8,
      "text": "ます皆さん諦めずに声を出し続けていこう"
    },
    {
      "start": 524.24,
      "duration": 6.56,
      "text": "ではありませんか今回の事象の理由につい"
    },
    {
      "start": 527.48,
      "duration": 7.2,
      "text": "てノーベル委員会は広島長崎の被爆者に"
    },
    {
      "start": 530.8,
      "duration": 7.96,
      "text": "よる草の根運動である日本避難教が核兵器"
    },
    {
      "start": 534.68,
      "duration": 6.76,
      "text": "のない世界の実現に向けた努力特に核兵器"
    },
    {
      "start": 538.76,
      "duration": 5.88,
      "text": "が2度と使われてはならない理由を身を"
    },
    {
      "start": 541.44,
      "duration": 7.2,
      "text": "持って立証してきた功績によりえ受賞をさ"
    },
    {
      "start": 544.64,
      "duration": 7.439,
      "text": "れることになりましたえ私はノーベル平和"
    },
    {
      "start": 548.64,
      "duration": 9.319,
      "text": "ノーベル委員会の平和省を決定する委員会"
    },
    {
      "start": 552.079,
      "duration": 10.801,
      "text": "のこの受賞の理由をスピーチを読みました"
    },
    {
      "start": 557.959,
      "duration": 9.081,
      "text": "がま大変感動的でした40代の若い方がえ"
    },
    {
      "start": 562.88,
      "duration": 7.92,
      "text": "夜言バネフリードネス会長でありますが次"
    },
    {
      "start": 567.04,
      "duration": 7.96,
      "text": "のように語っています各のを世界の安全"
    },
    {
      "start": 570.8,
      "duration": 8.24,
      "text": "保障が核兵器に依存するような世界で文明"
    },
    {
      "start": 575.0,
      "duration": 7.88,
      "text": "が存続できると信じるのは浅である世界は"
    },
    {
      "start": 579.04,
      "duration": 7.479,
      "text": "人類の壊滅を持つ待つ牢獄ではないはず"
    },
    {
      "start": 582.88,
      "duration": 6.84,
      "text": "ですたえどれほど長く困難な道のりであっ"
    },
    {
      "start": 586.519,
      "duration": 6.041,
      "text": "ても私たちは日本避弾教から学ぶべき"
    },
    {
      "start": 589.72,
      "duration": 7.799,
      "text": "でしょう決して諦めてはなりませんこう"
    },
    {
      "start": 592.56,
      "duration": 7.32,
      "text": "語っています2017年7月国連で核兵器"
    },
    {
      "start": 597.519,
      "duration": 5.801,
      "text": "禁止条約が成立した時"
    },
    {
      "start": 599.88,
      "duration": 6.519,
      "text": "世界がの流れが大きく変わっていることに"
    },
    {
      "start": 603.32,
      "duration": 7.84,
      "text": "多くの皆さんが感動を覚えたのではない"
    },
    {
      "start": 606.399,
      "duration": 8.521,
      "text": "でしょうか核大国であるアメリカロシア"
    },
    {
      "start": 611.16,
      "duration": 6.88,
      "text": "中国フランスなどの核保有国の言いなりに"
    },
    {
      "start": 614.92,
      "duration": 7.08,
      "text": "ならない世界があることに新しい希望を"
    },
    {
      "start": 618.04,
      "duration": 7.4,
      "text": "持つことができました核兵器禁止長中国"
    },
    {
      "start": 622.0,
      "duration": 7.36,
      "text": "言いましたからね核兵器禁止条約は1月"
    },
    {
      "start": 625.44,
      "duration": 8.639,
      "text": "22日で発行4年となりました署名国は"
    },
    {
      "start": 629.36,
      "duration": 8.64,
      "text": "94カ国と国連革命国の半数に迫り締約国"
    },
    {
      "start": 634.079,
      "duration": 7.641,
      "text": "も73に達するなど国際法としての力を"
    },
    {
      "start": 638.0,
      "duration": 8.519,
      "text": "強めています国連のグテレス事務総長は"
    },
    {
      "start": 641.72,
      "duration": 8.359,
      "text": "15日1月15日に核の脅威がここ数十年"
    },
    {
      "start": 646.519,
      "duration": 6.281,
      "text": "で高まっていると危機感を表しました"
    },
    {
      "start": 650.079,
      "duration": 6.721,
      "text": "アメリカ大統領に就任したトランプ氏は1"
    },
    {
      "start": 652.8,
      "duration": 8.64,
      "text": "期目で核兵器の先制使用政策を強化し核"
    },
    {
      "start": 656.8,
      "duration": 9.2,
      "text": "戦力の近代化などを進めまし同政権が核"
    },
    {
      "start": 661.44,
      "duration": 8.48,
      "text": "兵器に固執する姿勢を強めるならば核兵器"
    },
    {
      "start": 666.0,
      "duration": 8.48,
      "text": "でロシアや中国と退治し合う危険な世界"
    },
    {
      "start": 669.92,
      "duration": 8.159,
      "text": "情勢があ現れることは明らかです対立と"
    },
    {
      "start": 674.48,
      "duration": 7.08,
      "text": "緊張の高まりの中で核兵器が偶発的に使用"
    },
    {
      "start": 678.079,
      "duration": 7.56,
      "text": "される危機も指摘されています核兵器の"
    },
    {
      "start": 681.56,
      "duration": 7.76,
      "text": "一般線と足らずが都市で爆発すれば深刻な"
    },
    {
      "start": 685.639,
      "duration": 7.44,
      "text": "気候危機が起き人類の生存が脅威にさらす"
    },
    {
      "start": 689.32,
      "duration": 7.4,
      "text": "されるとの研究報告もありますこれに対し"
    },
    {
      "start": 693.079,
      "duration": 6.921,
      "text": "核使を抑え核兵器のない世界への支えと"
    },
    {
      "start": 696.72,
      "duration": 6.679,
      "text": "なっているのが核兵器禁止条約でありこれ"
    },
    {
      "start": 700.0,
      "duration": 7.8,
      "text": "を生み出した世論と運動であり"
    },
    {
      "start": 703.399,
      "duration": 7.761,
      "text": "ます被爆者汚先頭に広島長崎の実装を広げ"
    },
    {
      "start": 707.8,
      "duration": 8.159,
      "text": "てきたことが禁止条約実現の力になってい"
    },
    {
      "start": 711.16,
      "duration": 8.6,
      "text": "ますえ昨年の11月にブラジルのリオリオ"
    },
    {
      "start": 715.959,
      "duration": 8.44,
      "text": "デジャネイロで開かれたあG20サミット"
    },
    {
      "start": 719.76,
      "duration": 7.44,
      "text": "ではえ核兵器のない世界という目標の推進"
    },
    {
      "start": 724.399,
      "duration": 7.081,
      "text": "に改めてコミットするとした宣言を"
    },
    {
      "start": 727.2,
      "duration": 7.72,
      "text": "アメリカロシアイギリスフランス中国の各"
    },
    {
      "start": 731.48,
      "duration": 8.28,
      "text": "5大国も受け入れて前回1で採択をされ"
    },
    {
      "start": 734.92,
      "duration": 8.4,
      "text": "ました核兵器を巡る危険な状況は伊坂も今"
    },
    {
      "start": 739.76,
      "duration": 7.56,
      "text": "警視はできない状況でありますこの禁止"
    },
    {
      "start": 743.32,
      "duration": 7.4,
      "text": "条約に示される世界の本流がこの危機を"
    },
    {
      "start": 747.32,
      "duration": 6.8,
      "text": "乗り越える展望であります核の傘にいる"
    },
    {
      "start": 750.72,
      "duration": 7.08,
      "text": "ことがいかに日本を危険にさらしているか"
    },
    {
      "start": 754.12,
      "duration": 7.56,
      "text": "世界の流れを見ない狭い考え方から脱却"
    },
    {
      "start": 757.8,
      "duration": 9.719,
      "text": "しようではありませんか条約参加を求める"
    },
    {
      "start": 761.68,
      "duration": 11.0,
      "text": "署名運動は今大きく広がっていましてえ"
    },
    {
      "start": 767.519,
      "duration": 10.201,
      "text": "1723463人に登っていますえ被爆"
    },
    {
      "start": 772.68,
      "duration": 11.08,
      "text": "880周年に問うべきは核兵器の国の政府"
    },
    {
      "start": 777.72,
      "duration": 11.64,
      "text": "がらをした各軍備完全廃絶を達成する明確"
    },
    {
      "start": 783.76,
      "duration": 9.439,
      "text": "な約束の実行でありますえ私たちはこの核"
    },
    {
      "start": 789.36,
      "duration": 9.76,
      "text": "兵器を2度と使わせないためにえこの日本"
    },
    {
      "start": 793.199,
      "duration": 8.841,
      "text": "政府が核兵器禁止条約にの批准を目指し"
    },
    {
      "start": 799.12,
      "duration": 5.88,
      "text": "まずはオブザーバー参加することこれは"
    },
    {
      "start": 802.04,
      "duration": 6.72,
      "text": "世界の流れから見ても当然のことであり"
    },
    {
      "start": 805.0,
      "duration": 6.44,
      "text": "ますアメリカの動きだけを気にしてこの"
    },
    {
      "start": 808.76,
      "duration": 6.639,
      "text": "世界の流れに逆行するような態度を取る"
    },
    {
      "start": 811.44,
      "duration": 8.959,
      "text": "ことは許されません是非この意見書を多く"
    },
    {
      "start": 815.399,
      "duration": 8.041,
      "text": "の皆さんが賛同されて核のない平和な世界"
    },
    {
      "start": 820.399,
      "duration": 3.641,
      "text": "と日本を作るために私たちもその一助とし"
    },
    {
      "start": 823.44,
      "duration": 4.959,
      "text": "て"
    },
    {
      "start": 824.04,
      "duration": 8.479,
      "text": "え役割を果たしていくことを強く求めまし"
    },
    {
      "start": 828.399,
      "duration": 7.56,
      "text": "てえ私の賛成討論といたしますありがとう"
    },
    {
      "start": 832.519,
      "duration": 3.44,
      "text": "ございました"
    },
    {
      "start": 852.279,
      "duration": 7.841,
      "text": "以上で討論を終了し"
    },
    {
      "start": 855.92,
      "duration": 7.839,
      "text": "ます本件は起立採決をしますお諮りします"
    },
    {
      "start": 860.12,
      "duration": 7.88,
      "text": "本件は原案の通り可決することに賛成の皆"
    },
    {
      "start": 863.759,
      "duration": 4.241,
      "text": "さんの起立を求めます"
    },
    {
      "start": 869.639,
      "duration": 7.88,
      "text": "キリ多数キリ多数本件は原案可決と決定し"
    },
    {
      "start": 875.399,
      "duration": 2.12,
      "text": "まし"
    },
    {
      "start": 889.68,
      "duration": 10.04,
      "text": "たはい日程第3正眼常の委員会を行います"
    },
    {
      "start": 895.44,
      "duration": 7.88,
      "text": "今定例会の1月27日までに理したはお"
    },
    {
      "start": 899.72,
      "duration": 7.64,
      "text": "手元にご配布しました託審査案件一覧表の"
    },
    {
      "start": 903.32,
      "duration": 8.56,
      "text": "通りです以上10件のうち7陳情第5号第"
    },
    {
      "start": 907.36,
      "duration": 8.279,
      "text": "6号第7号第8号第9号及び第10号を"
    },
    {
      "start": 911.88,
      "duration": 7.319,
      "text": "除く4件はお手元にご配布しました託審査"
    },
    {
      "start": 915.639,
      "duration": 8.0,
      "text": "案件一覧表の通り所管の常任委員会に付託"
    },
    {
      "start": 919.199,
      "duration": 8.76,
      "text": "しますお別れします奈新庄第5号新長者"
    },
    {
      "start": 923.639,
      "duration": 8.2,
      "text": "及びえ仮称新福司会官建設に関する陳情者"
    },
    {
      "start": 927.959,
      "duration": 9.041,
      "text": "の議員所への質疑かこ昨年12月13日の"
    },
    {
      "start": 931.839,
      "duration": 8.721,
      "text": "特別委員会の回答を求める陳情書17陳情"
    },
    {
      "start": 937.0,
      "duration": 7.759,
      "text": "第6号新長者及び仮称新福祉会館建設に"
    },
    {
      "start": 940.56,
      "duration": 8.399,
      "text": "する関する陳者の議員諸子への質疑かこ"
    },
    {
      "start": 944.759,
      "duration": 8.44,
      "text": "昨年12月13日の特別委員会の回答を"
    },
    {
      "start": 948.959,
      "duration": 7.281,
      "text": "求める陳情書2奈良陳情第7号小金士の新"
    },
    {
      "start": 953.199,
      "duration": 7.241,
      "text": "長者及び仮称新福祉会館の建設に関する"
    },
    {
      "start": 956.24,
      "duration": 9.12,
      "text": "見直し案の設計意図の伝達との未説明部分"
    },
    {
      "start": 960.44,
      "duration": 8.199,
      "text": "の説明機会を求める陳情書7陳情第8号"
    },
    {
      "start": 965.36,
      "duration": 7.2,
      "text": "小金士の身長者及び過小新福祉会館の建設"
    },
    {
      "start": 968.639,
      "duration": 7.841,
      "text": "に関する住民投票条例について市長が行っ"
    },
    {
      "start": 972.56,
      "duration": 7.24,
      "text": "た反対の意見等に関する陳情書奈良陳情第"
    },
    {
      "start": 976.48,
      "duration": 8.52,
      "text": "9号新長者及び仮称新福祉会館の建設に"
    },
    {
      "start": 979.8,
      "duration": 8.719,
      "text": "関する工事入札広告の実施時期期限及び"
    },
    {
      "start": 985.0,
      "duration": 4.959,
      "text": "VE提案及びその範囲の緩和に関する賃"
    },
    {
      "start": 988.519,
      "duration": 6.481,
      "text": "上昇"
    },
    {
      "start": 989.959,
      "duration": 8.8,
      "text": "及び7陳情第15現状に至る本質的課題の"
    },
    {
      "start": 995.0,
      "duration": 7.04,
      "text": "根源の救命を求め議会の役割と責任及び"
    },
    {
      "start": 998.759,
      "duration": 8.801,
      "text": "市長の果たすべき役割を共同で調査書の"
    },
    {
      "start": 1002.04,
      "duration": 8.039,
      "text": "作成を求める陳情書は庁舎と建設及び公共"
    },
    {
      "start": 1007.56,
      "duration": 4.719,
      "text": "施設マネジメント推進調査特別委員会に"
    },
    {
      "start": 1010.079,
      "duration": 6.44,
      "text": "付託したいと思いますこれにご異議あり"
    },
    {
      "start": 1012.279,
      "duration": 8.721,
      "text": "ませんかご異議なしと認め7陳第5号第6"
    },
    {
      "start": 1016.519,
      "duration": 7.12,
      "text": "号第7号第8号第9及び第10号は長者等"
    },
    {
      "start": 1021.0,
      "duration": 6.52,
      "text": "建設及び公共施設マネジメント推進調査"
    },
    {
      "start": 1023.639,
      "duration": 7.841,
      "text": "特別委員会に託することと決定しました各"
    },
    {
      "start": 1027.52,
      "duration": 7.08,
      "text": "常任委員会委員長議会委員長及び各特別"
    },
    {
      "start": 1031.48,
      "duration": 5.92,
      "text": "委員会委員長から委員会開催日の連絡を"
    },
    {
      "start": 1034.6,
      "duration": 5.839,
      "text": "受けていますのでお知らせします2月5日"
    },
    {
      "start": 1037.4,
      "duration": 6.36,
      "text": "は午前10時から議会運営委員会2月10"
    },
    {
      "start": 1040.439,
