      "text": "会2月日は午前10時から総務企画委員会"
    },
    {
      "start": 1052.12,
      "duration": 9.08,
      "text": "2月18日19日20日26日及び27日"
    },
    {
      "start": 1057.32,
      "duration": 8.239,
      "text": "はいずれも午前10時から21日は午前9"
    },
    {
      "start": 1061.2,
      "duration": 7.479,
      "text": "時から予算特別委員会2月28日は午前"
    },
    {
      "start": 1065.559,
      "duration": 6.721,
      "text": "10時から調査と建設及び公共施設"
    },
    {
      "start": 1068.679,
      "duration": 6.801,
      "text": "マネジメント推進調査特別委員会3月3日"
    },
    {
      "start": 1072.28,
      "duration": 8.12,
      "text": "は午前10時から行財政改革維新調査特別"
    },
    {
      "start": 1075.48,
      "duration": 7.8,
      "text": "委員会以上の通り本席からお知らせします"
    },
    {
      "start": 1080.4,
      "duration": 7.24,
      "text": "以上で本日の日程は全て終了しました本日"
    },
    {
      "start": 1083.28,
