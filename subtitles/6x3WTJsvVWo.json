      "start": 620.64,
      "duration": 5.879,
      "text": "の方で中を何か直すとかていうことは基本"
    },
    {
      "start": 623.88,
      "duration": 7.519,
      "text": "的にはできないと考えておりますですので"
    },
    {
      "start": 626.519,
      "duration": 7.76,
      "text": "あの訂正なりまあの撤回もしくは新しく出"
    },
    {
      "start": 631.399,
      "duration": 5.921,
      "text": "てきたものについてですねそれぞれ議会の"
    },
    {
      "start": 634.279,
      "duration": 6.841,
      "text": "方で例えば訂正であればその承認をやはり"
    },
    {
      "start": 637.32,
      "duration": 7.12,
      "text": "本会議であの承認を得なきゃあのいけない"
    },
    {
      "start": 641.12,
      "duration": 7.399,
      "text": "んですけどもその中身自体はまあの提出さ"
    },
    {
      "start": 644.44,
      "duration": 6.399,
      "text": "れているですねあの提出者の方であのそれ"
    },
    {
      "start": 648.519,
      "duration": 5.56,
      "text": "をどういうような扱いにするかという多分"
    },
    {
      "start": 650.839,
      "duration": 6.12,
      "text": "問題だと思いますので議会の方ではえその"
    },
    {
      "start": 654.079,
      "duration": 4.601,
      "text": "中身をですねま報告についてどういう質疑"
    },
    {
      "start": 656.959,
      "duration": 5.801,
      "text": "するかとかそういうことはあると思います"
    },
    {
      "start": 658.68,
      "duration": 6.08,
      "text": "がまいわゆるあの一般的に予算の修正とか"
    },
    {
      "start": 662.76,
      "duration": 4.28,
      "text": "ですねえそういうのとはちょっと違います"
    },
    {
      "start": 664.76,
      "duration": 4.68,
      "text": "のであのそれとはちょっと分けて考えて"
    },
    {
      "start": 667.04,
      "duration": 6.0,
      "text": "いただければと思います以上ですはい"
    },
    {
      "start": 669.44,
      "duration": 7.199,
      "text": "水上ということは今日のま質疑を踏まえて"
    },
    {
      "start": 673.04,
      "duration": 7.4,
      "text": "市長がどう対応されるのかとまあいう形に"
    },
    {
      "start": 676.639,
      "duration": 7.241,
      "text": "なってくるっていことなんですかねあとは"
    },
    {
      "start": 680.44,
      "duration": 6.36,
      "text": "だからちょっと議会のねそれぞれあの質疑"
    },
    {
      "start": 683.88,
      "duration": 5.68,
      "text": "の中でまどういう表明するのかま市長が"
    },
    {
      "start": 686.8,
      "duration": 5.2,
      "text": "それに基づいてまどういう対応するの"
    },
    {
      "start": 689.56,
      "duration": 5.64,
      "text": "かっていうようなあの形になってくると"
    },
    {
      "start": 692.0,
      "duration": 6.12,
      "text": "思いますけどただ内容についてはですね"
    },
    {
      "start": 695.2,
      "duration": 5.28,
      "text": "やっぱり厳しい意見が出されているので"
    },
    {
      "start": 698.12,
      "duration": 5.279,
      "text": "あの何らか対応せざるえないかなっていう"
    },
    {
      "start": 700.48,
      "duration": 6.24,
      "text": "風には考えておりますであとですねあの"
    },
    {
      "start": 703.399,
      "duration": 7.161,
      "text": "主張報告そもそも要するに提案される時に"
    },
    {
      "start": 706.72,
      "duration": 7.239,
      "text": "あの要するにそのえっと検証結果報告書に"
    },
    {
      "start": 710.56,
      "duration": 6.24,
      "text": "ついてはあの喧嘩委員じゃないあの議員も"
    },
    {
      "start": 713.959,
      "duration": 5.801,
      "text": "いるのであの詳細な質疑をさせてもらいた"
    },
    {
      "start": 716.8,
      "duration": 5.479,
      "text": "いって話をしてで部局も是非意しといて"
    },
    {
      "start": 719.76,
      "duration": 5.48,
      "text": "もらいたいと話をしたんですけど今日撤回"
    },
    {
      "start": 722.279,
      "duration": 5.481,
      "text": "っていうことになると報告書そのものへの"
    },
    {
      "start": 725.24,
      "duration": 5.159,
      "text": "質疑ができないっていう理解でいいん"
    },
    {
      "start": 727.76,
      "duration": 6.72,
      "text": "でしょうかだとすればやっぱりそういうも"
    },
    {
      "start": 730.399,
      "duration": 7.0,
      "text": "で開かれた主張報告が結局撤回になって"
    },
    {
      "start": 734.48,
      "duration": 4.88,
      "text": "しまったのであのどこかでやっぱりそれは"
    },
    {
      "start": 737.399,
      "duration": 4.841,
      "text": "ねやっぱり保証していただく必要があるか"
    },
    {
      "start": 739.36,
      "duration": 4.8,
      "text": "なっていう風に考えておりますのでその点"
    },
    {
      "start": 742.24,
      "duration": 5.48,
      "text": "はちょっとまた見といただきたいと思"
    },
    {
      "start": 744.16,
      "duration": 8.44,
      "text": "ちょっとはい議長はいえっとですね今日は"
    },
    {
      "start": 747.72,
      "duration": 7.96,
      "text": "あのええ今日の視聴報告の撤回の質疑は"
    },
    {
      "start": 752.6,
      "duration": 5.2,
      "text": "ですねえ視聴報告の撤回の理由について"
    },
    {
      "start": 755.68,
      "duration": 6.24,
      "text": "質疑をしますので"
    },
    {
      "start": 757.8,
      "duration": 5.8,
      "text": "えまこれの考え方に沿ってえ進めて"
    },
    {
      "start": 761.92,
      "duration": 4.68,
      "text": "いただきたいというのがあの議長としての"
    },
    {
      "start": 763.6,
      "duration": 5.52,
      "text": "思いでありますえ視聴報告の中身について"
    },
    {
      "start": 766.6,
      "duration": 6.599,
      "text": "あの細かく議論が始まりますと終わりませ"
    },
    {
      "start": 769.12,
      "duration": 6.92,
      "text": "んし今日のえ議題は主張報告の撤回の理由"
    },
    {
      "start": 773.199,
      "duration": 4.921,
      "text": "についての質疑になりますのでえこの点は"
    },
    {
      "start": 776.04,
      "duration": 4.56,
      "text": "あのご理解いただきたいと思いますあと"
    },
    {
      "start": 778.12,
      "duration": 6.48,
      "text": "それからあのええちょっと順番変わります"
    },
    {
      "start": 780.6,
      "duration": 6.52,
      "text": "けどもえ一旦そのえあの出ている主張報告"
    },
    {
      "start": 784.6,
      "duration": 5.32,
      "text": "もうすでに出ている主張報告は今議会の"
    },
    {
      "start": 787.12,
      "duration": 6.12,
      "text": "手元にありますですから"
    },
    {
      "start": 789.92,
      "duration": 5.32,
      "text": "えそれをどうかするっていうな話になり"
    },
    {
      "start": 793.24,
      "duration": 6.159,
      "text": "ますとあくまでも議会としてどうする"
    },
    {
      "start": 795.24,
      "duration": 6.76,
      "text": "かっていう扱いになりますのでねあの一応"
    },
    {
      "start": 799.399,
      "duration": 4.841,
      "text": "え公開になってますけどもじゃその公開に"
    },
    {
      "start": 802.0,
      "duration": 5.199,
      "text": "ついてどうするのかってよな話も議会とし"
    },
    {
      "start": 804.24,
      "duration": 7.36,
      "text": "てどう判断するかというのがあの大事に"
    },
    {
      "start": 807.199,
      "duration": 4.401,
      "text": "なると思いますので一応申しておき"
    },
    {
      "start": 811.68,
      "duration": 7.92,
      "text": "ますはい他にございますかめごはい小林"
    },
    {
      "start": 816.48,
      "duration": 7.56,
      "text": "事務的に私もあの確認しておきたいと思い"
    },
    {
      "start": 819.6,
      "duration": 6.96,
      "text": "ますがあの市長の撤回の報告の後にあの"
    },
    {
      "start": 824.04,
      "duration": 4.72,
      "text": "承認の前にあの義がないのでね確認しとき"
    },
    {
      "start": 826.56,
      "duration": 5.16,
      "text": "たいと思うんですこれ撤回された時に"
    },
    {
      "start": 828.76,
      "duration": 6.519,
      "text": "えっとそれを例えばこのま会議残り2日"
    },
    {
      "start": 831.72,
      "duration": 7.44,
      "text": "ですが市長が修正するしてもう1回出した"
    },
    {
      "start": 835.279,
      "duration": 6.401,
      "text": "いって言った場合ねあのよくあの同一議会"
    },
    {
      "start": 839.16,
      "duration": 6.679,
      "text": "同一議案はあの出せないっていう話あり"
    },
    {
      "start": 841.68,
      "duration": 5.839,
      "text": "ますけど要するにこの定例会の中で修正版"
    },
    {
      "start": 845.839,
      "duration": 6.761,
      "text": "を出すということはできないのかという"
    },
    {
      "start": 847.519,
      "duration": 7.68,
      "text": "ことが1つですあとは撤回があまなかなか"
    },
    {
      "start": 852.6,
      "duration": 5.76,
      "text": "こういうこともないのであれですが撤回が"
    },
    {
      "start": 855.199,
      "duration": 9.2,
      "text": "不承認になった場合にはこの主張報告と"
    },
    {
      "start": 858.36,
      "duration": 9.32,
      "text": "いうのは吊されてえまた再び主張報告をが"
    },
    {
      "start": 864.399,
      "duration": 5.44,
      "text": "開かれると本会議の中でまそういう理解で"
    },
    {
      "start": 867.68,
      "duration": 4.599,
      "text": "よろしいのかということ伺いたいと思い"
    },
    {
      "start": 869.839,
      "duration": 2.44,
      "text": "ます"
    },
    {
      "start": 876.839,
      "duration": 7.721,
      "text": "はいはい次長はいえっと1点目のえっと"
    },
    {
      "start": 880.759,
      "duration": 7.401,
      "text": "撤回を受けて新たに出し直しということに"
    },
    {
      "start": 884.56,
      "duration": 7.56,
      "text": "なりますのでそれはあの今期あ今定例会中"
    },
    {
      "start": 888.16,
      "duration": 6.44,
      "text": "あの可能になるかな取り下げてもうまた"
    },
    {
      "start": 892.12,
      "duration": 5.8,
      "text": "新しいものを出すということであれば"
    },
    {
      "start": 894.6,
      "duration": 7.0,
      "text": "なくなるということであればはい定解でも"
    },
    {
      "start": 897.92,
      "duration": 8.4,
      "text": "可能ということであと2点目につい"
    },
    {
      "start": 901.6,
      "duration": 7.64,
      "text": "どうえっと撤回が不承認あはいあの撤回は"
    },
    {
      "start": 906.32,
      "duration": 6.36,
      "text": "えっと不承認ま原則的にはあのえ"
    },
    {
      "start": 909.24,
      "duration": 6.399,
      "text": "マニュアルムボの方ではあの原則的には"
    },
    {
      "start": 912.68,
      "duration": 5.959,
      "text": "承認すべきとはあるんですがえ万が一あの"
    },
    {
      "start": 915.639,
      "duration": 6.0,
      "text": "不承認となった場合はえっと休憩を"
    },
    {
      "start": 918.639,
      "duration": 5.56,
      "text": "ちょっと入れまして今度あの撤回について"
    },
    {
      "start": 921.639,
      "duration": 6.521,
      "text": "はもうそれはえ承認されてないということ"
    },
    {
      "start": 924.199,
      "duration": 7.841,
      "text": "でえ元々出されたあの主張報告の方のあの"
    },
    {
      "start": 928.16,
      "duration": 7.52,
      "text": "ま質疑の続き今保留状態となってますので"
    },
    {
      "start": 932.04,
      "duration": 5.68,
      "text": "あの質疑の続きに入るかなということで1"
    },
    {
      "start": 935.68,
      "duration": 4.639,
      "text": "回"
    },
    {
      "start": 937.72,
      "duration": 5.96,
      "text": "はいはいということになりますはい以上で"
    },
    {
      "start": 940.319,
      "duration": 5.32,
      "text": "ございますはい小林はいあのご説明わかり"
    },
    {
      "start": 943.68,
      "duration": 4.8,
      "text": "ましたありがとうございますまたあの日本"
    },
    {
      "start": 945.639,
      "duration": 5.841,
      "text": "者の方であのコンセンサス取れてるかも"
    },
    {
      "start": 948.48,
      "duration": 6.719,
      "text": "しれませんがえ撤回の理由について市長が"
    },
    {
      "start": 951.48,
      "duration": 6.599,
      "text": "述べられるものについてですねあのまその"
    },
    {
      "start": 955.199,
      "duration": 4.241,
      "text": "後質疑がありますからあの誤った認識で"
    },
    {
      "start": 958.079,
      "duration": 6.281,
      "text": "質疑をするのも"
    },
    {
      "start": 959.44,
      "duration": 6.879,
      "text": "不とありますのでらな形で会議の前に文章"
    },
    {
      "start": 964.36,
      "duration": 4.479,
      "text": "でお配りいきたいと思いますけども"
    },
    {
      "start": 966.319,
      "duration": 2.52,
      "text": "よろしいでしょう"
    },
    {
      "start": 969.48,
      "duration": 7.719,
      "text": "か総務長はいあの検討させていただき"
    },
    {
      "start": 974.199,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 978.8,
      "duration": 5.839,
      "text": "はいはい大丈夫はい"
    },
    {
      "start": 981.68,
      "duration": 6.24,
      "text": "水谷はいえとちょっと1つ確認させていき"
    },
    {
      "start": 984.639,
      "duration": 6.88,
      "text": "たいんですが先ほどあの局長の弁の中"
    },
    {
      "start": 987.92,
      "duration": 6.32,
      "text": "にあできるのかということのの答案として"
    },
    {
      "start": 991.519,
      "duration": 5.281,
      "text": "取り下げまたは撤回となりますというお話"
    },
    {
      "start": 994.24,
      "duration": 5.76,
      "text": "だったんですけどその概念として取り下げ"
    },
    {
      "start": 996.8,
      "duration": 5.159,
      "text": "と撤回とは違うものなのか何かそういう"
    },
    {
      "start": 1000.0,
      "duration": 4.0,
      "text": "規定があるのかについてちょっと整理して"
    },
    {
      "start": 1001.959,
      "duration": 3.921,
      "text": "教えてくださいはい局長はいあの同様で"
    },
    {
      "start": 1004.0,
      "duration": 4.44,
      "text": "ございます"
    },
    {
      "start": 1005.88,
      "duration": 4.399,
      "text": "はいよろしいです"
    },
    {
      "start": 1008.44,
      "duration": 5.399,
      "text": "かはい"
    },
    {
      "start": 1010.279,
      "duration": 7.601,
      "text": "水谷同様ということはえっと法的効果は"
    },
    {
      "start": 1013.839,
      "duration": 5.521,
      "text": "同じという意味ですね呼び方が違うという"
    },
    {
      "start": 1017.88,
      "duration": 4.639,
      "text": "ことだけですか"
    },
    {
      "start": 1019.36,
      "duration": 7.079,
      "text": "はい局長あのま取り下げと撤回という言い"
    },
    {
      "start": 1022.519,
      "duration": 6.52,
      "text": "方が違いますけれども今現にあの提出され"
    },
    {
      "start": 1026.439,
      "duration": 5.4,
      "text": "てるものについてあの取り下げなのかそれ"
    },
    {
      "start": 1029.039,
      "duration": 4.88,
      "text": "とも撤回するのかっていう言葉の違いは"
    },
    {
      "start": 1031.839,
      "duration": 5.441,
      "text": "ありますけれどもあの効果としては同じ"
    },
    {
      "start": 1033.919,
      "duration": 5.961,
      "text": "ですはいはい他にございますかはい"
    },
    {
      "start": 1037.28,
      "duration": 2.6,
      "text": "ただいま副"
    },
    {
      "start": 1040.6,
      "duration": 8.76,
      "text": "長あさじゃはいえっとですねあの質疑が"
    },
    {
      "start": 1046.52,
      "duration": 5.519,
      "text": "あの報告についての質疑が止"
    },
    {
      "start": 1049.36,
      "duration": 4.28,
      "text": "いうのはあの専門家の方の了承がいられ"
    },
    {
      "start": 1052.039,
      "duration": 5.52,
      "text": "なかったっていうことになってるかと思い"
    },
    {
      "start": 1053.64,
      "duration": 6.399,
      "text": "ますでその件あのえっとそれで撤回をあの"
    },
    {
      "start": 1057.559,
      "duration": 4.441,
      "text": "承認するかどうかを決める際にその専門家"
    },
    {
      "start": 1060.039,
      "duration": 4.961,
      "text": "の方がどのようなことを主張されているの"
    },
    {
      "start": 1062.0,
      "duration": 5.64,
      "text": "かっていうことは皆さんと共通認識を持っ"
    },
    {
      "start": 1065.0,
      "duration": 7.039,
      "text": "ておいた方がいいかと思思いますえそれに"
    },
    {
      "start": 1067.64,
      "duration": 8.0,
      "text": "ついてあのえっと何かこう擬似進行などで"
    },
    {
      "start": 1072.039,
      "duration": 7.961,
      "text": "あの文言を読み上げるなどその質疑が"
    },
    {
      "start": 1075.64,
      "duration": 7.159,
      "text": "始まる前にあのちゃんとあの文章をの内容"
    },
    {
      "start": 1080.0,
      "duration": 4.96,
      "text": "を聴者の方にも分かるようにしっかりと"
    },
    {
      "start": 1082.799,
      "duration": 5.041,
      "text": "あの高頭で読み上げることが必要なのでは"
    },
    {
      "start": 1084.96,
      "duration": 5.12,
      "text": "ないかと思いますがえいかがでしょう"
    },
    {
      "start": 1087.84,
      "duration": 8.04,
      "text": "かいかがでしょう"
    },
    {
      "start": 1090.08,
      "duration": 8.04,
      "text": "かはいそれはあのま議会委員会の方でも"
    },
    {
      "start": 1095.88,
      "duration": 5.799,
      "text": "図りかねますねあのそれはもう議員の皆"
    },
    {
      "start": 1098.12,
      "duration": 6.32,
      "text": "さんでま本会本会議の話になるのでこれは"
    },
    {
      "start": 1101.679,
      "duration": 4.961,
      "text": "はいそれはその時の議長のご判断にもよる"
    },
    {
      "start": 1104.44,
      "duration": 4.44,
      "text": "と思いますが基本的には質疑でやって"
    },
    {
      "start": 1106.64,
      "duration": 5.76,
      "text": "いただくのが通例かなと思いますけれども"
    },
    {
      "start": 1108.88,
      "duration": 5.679,
      "text": "まそこは議員のご判断によるかなそして"
    },
    {
      "start": 1112.4,
      "duration": 4.32,
      "text": "議長のおさきによるかなという風に思って"
    },
    {
      "start": 1114.559,
      "duration": 5.48,
      "text": "おりますはいそれは議員会運委員会の中で"
    },
    {
      "start": 1116.72,
      "duration": 9.0,
      "text": "何か確認をするというのは難しいと思い"
    },
    {
      "start": 1120.039,
      "duration": 7.481,
      "text": "ますはい小林まあの質疑の機会も十分に"
    },
    {
      "start": 1125.72,
      "duration": 4.24,
      "text": "ありますのでねま十分にって言ったって"
    },
    {
      "start": 1127.52,
      "duration": 5.56,
      "text": "あれですけどあの時間あるので質疑の中で"
    },
    {
      "start": 1129.96,
      "duration": 5.959,
      "text": "あそれをそういう情報をお持ちの方は"
    },
    {
      "start": 1133.08,
      "duration": 6.76,
      "text": "明らかにされるというのがあ通常だとは"
    },
    {
      "start": 1135.919,
      "duration": 6.481,
      "text": "思いますはい"
    },
    {
      "start": 1139.84,
      "duration": 2.56,
      "text": "大丈夫ですか"
    },
    {
      "start": 1144.6,
      "duration": 6.24,
      "text": "さあとはもうご判断でということですね"
    },
    {
      "start": 1147.36,
      "duration": 6.76,
      "text": "はいはいじゃあ片山副員長はいえっとです"
    },
    {
      "start": 1150.84,
      "duration": 5.52,
      "text": "ねあのま先ほど三上さんのからも"
    },
    {
      "start": 1154.12,
      "duration": 5.4,
      "text": "おっしゃってましたけれども結局そのま"
    },
    {
      "start": 1156.36,
      "duration": 5.72,
      "text": "今回のこの視聴報告の中であの検証結果"
    },
    {
      "start": 1159.52,
      "duration": 5.84,
      "text": "報告についてのま質疑もね一定こう含まれ"
    },
    {
      "start": 1162.08,
      "duration": 5.88,
      "text": "た形でま前議にへの説明質疑の場がなかっ"
    },
    {
      "start": 1165.36,
      "duration": 5.84,
      "text": "たのでえやろうと思ってたわけですがま"
    },
    {
      "start": 1167.96,
      "duration": 5.839,
      "text": "ないとあのえ諸国がなくなってしまうもん"
    },
    {
      "start": 1171.2,
      "duration": 5.88,
      "text": "ですからやっぱりこう質疑の場の保証とし"
    },
    {
      "start": 1173.799,
      "duration": 6.681,
      "text": "ましてはま前にもですね多少あの提案し"
    },
    {
      "start": 1177.08,
      "duration": 6.04,
      "text": "ました全員協議会などを開いてえ行うべき"
    },
    {
      "start": 1180.48,
      "duration": 4.6,
      "text": "ではないかと私は考えるんですねでま今日"
    },
    {
      "start": 1183.12,
      "duration": 5.28,
      "text": "の京とのはちょっと難しいかもしれません"
    },
    {
      "start": 1185.08,
      "duration": 6.0,
      "text": "けれどもま3月6日なりにですねあの最終"
    },
    {
      "start": 1188.4,
      "duration": 6.279,
      "text": "日でもいいのでそういった場をこうま"
    },
    {
      "start": 1191.08,
      "duration": 6.0,
      "text": "考えるのかあるいはこの検証結果報告自体"
    },
    {
      "start": 1194.679,
      "duration": 5.0,
      "text": "も撤回になるのかというようなことも"
    },
    {
      "start": 1197.08,
      "duration": 5.36,
      "text": "合わせましてやっぱりですねま市長の方"
    },
    {
      "start": 1199.679,
      "duration": 5.48,
      "text": "から一定のこう何か認識を示していただき"
    },
    {
      "start": 1202.44,
      "duration": 5.359,
      "text": "たいということをですねあの伝えて"
    },
    {
      "start": 1205.159,
      "duration": 5.361,
      "text": "いただきたいなと思っております本会議の"
    },
    {
      "start": 1207.799,
      "duration": 5.481,
      "text": "時に確認したいなと思ってますのであの"
    },
    {
      "start": 1210.52,
      "duration": 5.8,
      "text": "どうするのかということをま確認して"
    },
    {
      "start": 1213.28,
      "duration": 5.92,
      "text": "いただきたいなとあの予告ですねはいはい"
    },
    {
      "start": 1216.32,
      "duration": 5.96,
      "text": "あともう1つですねえっと先ほどからあの"
    },
    {
      "start": 1219.2,
      "duration": 7.4,
      "text": "ま先ほど安田さんの方おっしゃりあの点"
    },
    {
      "start": 1222.28,
      "duration": 7.8,
      "text": "ありましたけれどもえっと昨日あの議会の"
    },
    {
      "start": 1226.6,
      "duration": 7.16,
      "text": "あのえ方と行政当ててかな書いてあったん"
    },
    {
      "start": 1230.08,
      "duration": 5.839,
      "text": "ですかね宛先がえこの学者の方え市長報告"
    },
    {
      "start": 1233.76,
      "duration": 5.32,
      "text": "に出てくるお名前が上がってる学者の方"
    },
    {
      "start": 1235.919,
      "duration": 6.281,
      "text": "からの文書が配布されていますでこちらの"
    },
    {
      "start": 1239.08,
      "duration": 5.599,
      "text": "文章が非常にこうま重要なあのものだと"
    },
    {
      "start": 1242.2,
      "duration": 4.68,
      "text": "思っておりましてこちらについては"
    },
    {
      "start": 1244.679,
      "duration": 5.281,
      "text": "やっぱりこう正式資料にすべきだと私は"
    },
    {
      "start": 1246.88,
      "duration": 5.32,
      "text": "考えてるんですねで今がですねこの正式"
    },
    {
      "start": 1249.96,
      "duration": 4.24,
      "text": "資料にする手段としてどういった方法が"
    },
    {
      "start": 1252.2,
      "duration": 4.839,
      "text": "取れるのかという確認をちょっとしとき"
    },
    {
      "start": 1254.2,
      "duration": 4.92,
      "text": "たいなと思っておりまして例えばですねま"
    },
    {
      "start": 1257.039,
      "duration": 4.281,
      "text": "先ほどちょっと4社の中でもそれは聞いた"
    },
    {
      "start": 1259.12,
      "duration": 5.16,
      "text": "んですがちょっと今のところはないような"
    },
    {
      "start": 1261.32,
      "duration": 6.64,
      "text": "ことがあったんですけれどもこのえっと"
    },
    {
      "start": 1264.28,
      "duration": 6.32,
      "text": "例えばですね緊急質問が通告されるという"
    },
    {
      "start": 1267.96,
      "duration": 6.04,
      "text": "ことになりますとそれに付随する資料とし"
    },
    {
      "start": 1270.6,
      "duration": 9.079,
      "text": "て提出することはできるんでしょう"
    },
    {
      "start": 1274.0,
      "duration": 9.12,
      "text": "かはい事務的な話にはい次長はいえっと"
    },
    {
      "start": 1279.679,
      "duration": 6.081,
      "text": "片山議員あの緊急質問に例えば例えば緊急"
    },
    {
      "start": 1283.12,
      "duration": 7.0,
      "text": "質問に有罪するという主要であればそれは"
    },
    {
      "start": 1285.76,
      "duration": 8.76,
      "text": "あの事務的には可能かなというふに思って"
    },
    {
      "start": 1290.12,
      "duration": 6.84,
      "text": "おりますはいはい局長ですえっとですね今"
    },
    {
      "start": 1294.52,
      "duration": 4.88,
      "text": "次長が申し上げた通りあのその資料として"
    },
    {
      "start": 1296.96,
      "duration": 4.8,
      "text": "つつけることは可能ですけれどもま現時点"
    },
    {
      "start": 1299.4,
      "duration": 4.92,
      "text": "ですねあの今事務局の方にはまだそういう"
    },
    {
      "start": 1301.76,
      "duration": 4.6,
      "text": "お申しでいただいてないのでまこれから"
    },
    {
      "start": 1304.32,
      "duration": 4.479,
      "text": "いただくということになるとまたその"
    },
    {
      "start": 1306.36,
      "duration": 5.24,
      "text": "取り扱いに対する議運を開いてとかまその"
    },
    {
      "start": 1308.799,
      "duration": 5.24,
      "text": "辺の一定の手続きがかかるというところは"
    },
    {
      "start": 1311.6,
      "duration": 6.679,
      "text": "一応ご参考までに申し上げておき"
    },
    {
      "start": 1314.039,
      "duration": 6.0,
      "text": "ますはい委長はいえまちょっとその市に"
    },
    {
      "start": 1318.279,
      "duration": 4.241,
      "text": "する手段としてねどういったものがあるの"
    },
    {
      "start": 1320.039,
      "duration": 4.76,
      "text": "かなということでま一例としてあの挙げ"
    },
    {
      "start": 1322.52,
      "duration": 7.8,
      "text": "させていただきました以上"
    },
    {
      "start": 1324.799,
      "duration": 9.561,
      "text": "ですはい議長あの今の事務局の説明は私は"
    },
    {
      "start": 1330.32,
      "duration": 7.88,
      "text": "正式なあそうだあの今の事務局の説明は"
    },
    {
      "start": 1334.36,
      "duration": 7.88,
      "text": "ちょっとあの正確ではないかなとつまり本"
    },
    {
      "start": 1338.2,
      "duration": 8.76,
      "text": "会議を開いていてその質問する状況がある"
    },
    {
      "start": 1342.24,
      "duration": 9.12,
      "text": "中で緊急質問だと言って新たにこう提案を"
    },
    {
      "start": 1346.96,
      "duration": 6.959,
      "text": "された時にそれはあの取り扱うていうこと"
    },
    {
      "start": 1351.36,
      "duration": 6.72,
      "text": "になるのかどうかっていうことだと思うん"
    },
    {
      "start": 1353.919,
      "duration": 7.161,
      "text": "ですよい本会議が開いてなくてあ本会議で"
    },
    {
      "start": 1358.08,
      "duration": 6.56,
      "text": "別の議題がね別の議題が議論になってる時"
    },
    {
      "start": 1361.08,
      "duration": 6.24,
      "text": "に緊急質問であのこれを質疑したいって"
    },
    {
      "start": 1364.64,
      "duration": 6.88,
      "text": "いう時はそれは取り扱いについて議運で"
    },
    {
      "start": 1367.32,
      "duration": 8.839,
      "text": "図ったりするんだけど同じ議題で本会議を"
    },
    {
      "start": 1371.52,
      "duration": 7.44,
      "text": "開いている中で緊急質問っていうことは"
    },
    {
      "start": 1376.159,
      "duration": 5.681,
      "text": "ちょっと理論上もちょっと"
    },
    {
      "start": 1378.96,
      "duration": 4.959,
      "text": "どうなのかっていうことだと思うんですが"
    },
    {
      "start": 1381.84,
      "duration": 6.12,
      "text": "そこはもう少し丁寧"
    },
    {
      "start": 1383.919,
      "duration": 4.041,
      "text": "に説明していただけれ"
    },
    {
      "start": 1388.4,
      "duration": 6.879,
      "text": "ばはい疑長ごますはいえっとただいまのご"
    },
    {
      "start": 1392.44,
      "duration": 5.32,
      "text": "質問なんですけどもえっと緊急質問につい"
    },
    {
      "start": 1395.279,
      "duration": 4.28,
      "text": "てはご存知の通りえっとその緊急性がある"
    },
    {
      "start": 1397.76,
      "duration": 4.279,
      "text": "かどうかというのをですねえっと議運で"
    },
    {
      "start": 1399.559,
      "duration": 5.48,
      "text": "確認いたしましてで"
    },
    {
      "start": 1402.039,
      "duration": 5.88,
      "text": "えっと議運で一致すればあま本会議で"
    },
    {
      "start": 1405.039,
      "duration": 5.481,
      "text": "取り上げあまえっと議題にすることになり"
    },
    {
      "start": 1407.919,
      "duration": 7.24,
      "text": "ますけどもえっと一致しない場合について"
    },
    {
      "start": 1410.52,
      "duration": 6.36,
      "text": "はあうんその緊急質問ができないという"
    },
    {
      "start": 1415.159,
      "duration": 4.081,
      "text": "ことになりますなので言ってまずあの議運"
    },
    {
      "start": 1416.88,
      "duration": 4.679,
      "text": "でご判断えいただくことになるのかなって"
    },
    {
      "start": 1419.24,
      "duration": 5.2,
      "text": "いうのが1つですあとはえ本会議におき"
    },
    {
      "start": 1421.559,
      "duration": 5.281,
      "text": "ましてえそれでも緊急質問をえその議員の"
    },
    {
      "start": 1424.44,
      "duration": 5.56,
      "text": "方がされたいということであればまえっと"
    },
    {
      "start": 1426.84,
      "duration": 5.64,
      "text": "同義で出していただくえ場合がありますで"
    },
    {
      "start": 1430.0,
      "duration": 4.72,
      "text": "えっとまそこでもまた行ってえっと議会の"
    },
    {
      "start": 1432.48,
      "duration": 5.079,
      "text": "中でご判断いただくということでえござい"
    },
    {
      "start": 1434.72,
      "duration": 5.28,
      "text": "ますなのでえっと仮にそのあま本来であれ"
    },
    {
      "start": 1437.559,
      "duration": 5.48,
      "text": "ばえっと本会議でえっとその議題になっ"
    },
    {
      "start": 1440.0,
      "duration": 5.679,
      "text": "てるものをえっと緊急質問でえっと同じ"
    },
    {
      "start": 1443.039,
      "duration": 4.52,
      "text": "議題をで提案されるってことは多分ないと"
    },
    {
      "start": 1445.679,
      "duration": 4.12,
      "text": "は思うんですけどもあった場合についても"
    },
    {
      "start": 1447.559,
      "duration": 4.48,
      "text": "えたい申し上げたような手続きを行います"
    },
    {
      "start": 1449.799,
      "duration": 6.201,
      "text": "ので一定議会の方でご判断いただけるのか"
    },
    {
      "start": 1452.039,
      "duration": 7.041,
      "text": "なと思います以上ですはいよろしいですか"
    },
    {
      "start": 1456.0,
      "duration": 4.72,
      "text": "はいはい他にございます"
    },
    {
      "start": 1459.08,
      "duration": 5.0,
      "text": "か"
    },
    {
      "start": 1460.72,
      "duration": 5.24,
      "text": "はいはいえそれではお諮りいたします本件"
    },
    {
      "start": 1464.08,
      "duration": 3.88,
      "text": "については議長の質問の通り決定すること"
    },
    {
      "start": 1465.96,
      "duration": 4.16,
      "text": "にご異議ありませんかはいご異議なしと"
    },
    {
      "start": 1467.96,
      "duration": 4.4,
      "text": "認めます従って本件は議長の指の通り決定"
    },
    {
      "start": 1470.12,
      "duration": 5.039,
      "text": "いたしました協議事項かこにその他で"
    },
    {
      "start": 1472.36,
      "duration": 5.64,
      "text": "ございますが何かご発言はございますか"
    },
    {
      "start": 1475.159,
      "duration": 4.841,
      "text": "はいえ以上で議会運営に関する議長の諮問"
    },
    {
      "start": 1478.0,
      "duration": 4.2,
      "text": "事項について終わります以上で当委員会に"
    },
    {
      "start": 1480.0,
      "duration": 3.96,
      "text": "付託されております案件の審査は全て終了"
    },
    {
      "start": 1482.2,
      "duration": 4.88,
      "text": "いたしましたこれで議会運営委員会の会議"
    },
    {
      "start": 1483.96,
      "duration": 5.719,
      "text": "を閉じ参加いたしますはいその2は全部"
    },
    {
      "start": 1487.08,
      "duration": 6.24,
      "text": "終わった後ですねはいではこれで1回解散"
    },
    {
      "start": 1489.679,
      "duration": 3.641,
      "text": "ですお疲れ様です"
    }
  ]
}