{
  "entries": [
    {
      "start": 10.36,
      "duration": 5.56,
      "text": "はいお疲れ様でございますえ恐れでござい"
    },
    {
      "start": 13.2,
      "duration": 4.4,
      "text": "ますのでえ議会会協議会を始めさせて"
    },
    {
      "start": 15.92,
      "duration": 4.56,
      "text": "いただきますお手元の競技事項をご覧"
    },
    {
      "start": 17.6,
      "duration": 6.96,
      "text": "くださいえ委員会の進行予定について問"
    },
    {
      "start": 20.48,
      "duration": 6.799,
      "text": "事項1件でございますえ西岸近所の追加の"
    },
    {
      "start": 24.56,
      "duration": 6.199,
      "text": "2委員会議員権についてえ議員会運営委員"
    },
    {
      "start": 27.279,
      "duration": 6.721,
      "text": "会継続審査議決についてえその何かごお願"
    },
    {
      "start": 30.759,
      "duration": 5.441,
      "text": "ますそれではまず協議会事項の1議員提出"
    },
    {
      "start": 34.0,
      "duration": 6.76,
      "text": "議案の討論採決について採決あ"
    },
    {
      "start": 36.2,
      "duration": 11.039,
      "text": "いらっしゃいますかはい片山長はいえっと"
    },
    {
      "start": 40.76,
      "duration": 11.439,
      "text": "ですねえ銀案第7号のえ決に対てえ賛成"
    },
    {
      "start": 47.239,
      "duration": 10.12,
      "text": "討論高木高木さんはいはい他にいます"
    },
    {
      "start": 52.199,
      "duration": 7.081,
      "text": "かなしはいそれでは討論は銀のみという"
    },
    {
      "start": 57.359,
      "duration": 5.68,
      "text": "ことでご確認いいてよろしいですかはい"
    },
    {
      "start": 59.28,
      "duration": 3.759,
      "text": "それではじゃ委員に入ってまいり"
    },
    {
      "start": 64.159,
      "duration": 5.201,
      "text": "ますただ今から議会委員会の会議を開き"
    },
    {
      "start": 67.119,
      "duration": 4.441,
      "text": "ますただ時に入ります当委員会に付託され"
    },
    {
      "start": 69.36,
      "duration": 4.72,
      "text": "ております案件は議長の諮問事項1件で"
    },
    {
      "start": 71.56,
      "duration": 5.12,
      "text": "あります議長はお手に議会運営委員会協議"
    },
    {
      "start": 74.08,
      "duration": 4.24,
      "text": "事項が提示されておりますのでそ順序に"
    },
    {
      "start": 76.68,
      "duration": 3.56,
      "text": "従って順次協議をしてまいりたいと思い"
    },
    {
      "start": 78.32,
      "duration": 4.32,
      "text": "ます議会運営に関する議長の諮問事項に"
    },
    {
      "start": 80.24,
      "duration": 5.44,
      "text": "ついてを議題といたします始めに協議事項"
    },
    {
      "start": 82.64,
      "duration": 5.159,
      "text": "括1正上の追分の2先委員会について行い"
    },
    {
      "start": 85.68,
      "duration": 5.399,
      "text": "ます議長の指案が示されておりますので"
    },
    {
      "start": 87.799,
      "duration": 6.64,
      "text": "議長からお願いますええ3月4日の午後5"
    },
    {
      "start": 91.079,
      "duration": 6.481,
      "text": "時までに受付けました正眼陳情ませのでご"
    },
    {
      "start": 94.439,
      "duration": 7.121,
      "text": "報告いたしますただいま議長のご説明の"
    },
    {
      "start": 97.56,
      "duration": 7.12,
      "text": "通り追加分の願陳情はないということでご"
    },
    {
      "start": 101.56,
      "duration": 4.839,
      "text": "確認いただけますでしょうかはい追加分の"
    },
    {
      "start": 104.68,
      "duration": 4.399,
      "text": "はないということでご確認いただきました"
    },
    {
      "start": 106.399,
      "duration": 4.881,
      "text": "次に協議事項に議員の派遣について行い"
    },
    {
      "start": 109.079,
      "duration": 4.32,
      "text": "ます議長のが示されておりますので議長"
    },
    {
      "start": 111.28,
      "duration": 5.92,
      "text": "から説明お願いいたしますえ事務局から"
    },
    {
      "start": 113.399,
      "duration": 7.281,
      "text": "説明いたしますはい局長はいえ本日までに"
    },
    {
      "start": 117.2,
      "duration": 6.8,
      "text": "決定しております議員派がと報告いたし"
    },
    {
      "start": 120.68,
      "duration": 7.039,
      "text": "ますまた初犯の事情により変更が生じた"
    },
    {
      "start": 124.0,
      "duration": 8.319,
      "text": "場合や閉に委派遣が生じた場合などについ"
    },
    {
      "start": 127.719,
      "duration": 7.761,
      "text": "てその日次場所目的及び発議員名等は議長"
    },
    {
      "start": 132.319,
      "duration": 6.241,
      "text": "にご一任願いたいというのが議長の諮問案"
    },
    {
      "start": 135.48,
      "duration": 5.839,
      "text": "でございます議長及び事務局の説明は"
    },
    {
      "start": 138.56,
      "duration": 5.36,
      "text": "終わりましたご意見ご質とございます"
    },
    {
      "start": 141.319,
      "duration": 4.56,
      "text": "かしはいお諮りいたします本件については"
    },
    {
      "start": 143.92,
      "duration": 4.679,
      "text": "議長の問の通り決定することにご異議あり"
    },
    {
      "start": 145.879,
      "duration": 4.561,
      "text": "ませんかなしと認めます従って本件は議長"
    },
    {
      "start": 148.599,
      "duration": 5.0,
      "text": "の問の通り決定いたします"
    },
    {
      "start": 150.44,
      "duration": 6.12,
      "text": "次に協議事故3議会委員会継続審査議決に"
    },
    {
      "start": 153.599,
      "duration": 7.601,
      "text": "ついて行いますお諮りいたします時期定例"
    },
    {
      "start": 156.56,
      "duration": 8.36,
      "text": "会各臨時を含む図の会期及び会議祝等議会"
    },
    {
      "start": 161.2,
      "duration": 7.319,
      "text": "運営に関する査議会の会議規則委員会条例"
    },
    {
      "start": 164.92,
      "duration": 6.239,
      "text": "等に関する調査議会運営に関する議の問に"
    },
    {
      "start": 168.519,
      "duration": 5.161,
      "text": "ついて閉会中もなお継続して調査すること"
    },
    {
      "start": 171.159,
      "duration": 4.72,
      "text": "にご異議ありませんかいいなしとめます"
    },
    {
      "start": 173.68,
      "duration": 4.76,
      "text": "従ってただいま申し上げました通り閉会中"
    },
    {
      "start": 175.879,
      "duration": 5.521,
      "text": "もなを継続して調査することと決定しまし"
    },
    {
      "start": 178.44,
      "duration": 7.439,
      "text": "た協議事項4その他でございますが何かご"
    },
    {
      "start": 181.4,
      "duration": 4.479,
      "text": "発言はございますかはい"
    },
    {
      "start": 188.2,
      "duration": 6.16,
      "text": "小委員会うんうん"
    },
    {
      "start": 196.28,
      "duration": 7.12,
      "text": "えっといいですか"
    },
    {
      "start": 198.68,
      "duration": 7.24,
      "text": "はいちょっとあのまじゃないんであの該当"
    },
    {
      "start": 203.4,
      "duration": 5.479,
      "text": "される方があればあのいだいということで"
    },
    {
      "start": 205.92,
      "duration": 6.12,
      "text": "あの申し上げてきますけどもえっと"
    },
    {
      "start": 208.879,
      "duration": 6.201,
      "text": "タブレット記事作ったものとしてですね"
    },
    {
      "start": 212.04,
      "duration": 7.479,
      "text": "あの本会議場でえっとタブレット写真を"
    },
    {
      "start": 215.08,
      "duration": 8.04,
      "text": "撮ってるようなあ攻をがちょっと見かけ"
    },
    {
      "start": 219.519,
      "duration": 6.601,
      "text": "られましたこれは9条ので禁止事項に端末"
    },
    {
      "start": 223.12,
      "duration": 4.88,
      "text": "機の使用にあたって次の各5に掲げ事故に"
    },
    {
      "start": 226.12,
      "duration": 6.56,
      "text": "これを禁止するもの"
    },
    {
      "start": 228.0,
      "duration": 8.76,
      "text": "えその中のえっと2号会議音しまた録画"
    },
    {
      "start": 232.68,
      "duration": 9.36,
      "text": "することまこれは禁止されていてえ外た"
    },
    {
      "start": 236.76,
      "duration": 9.52,
      "text": "場合は2項でま議長があするまた中にて"
    },
    {
      "start": 242.04,
      "duration": 6.72,
      "text": "違反が改められない場合はえ使用を停止さ"
    },
    {
      "start": 246.28,
      "duration": 5.599,
      "text": "せるというようなになっておりますので"
    },
    {
      "start": 248.76,
      "duration": 5.88,
      "text": "あのま確認したわけではないのであれです"
    },
    {
      "start": 251.879,
      "duration": 6.561,
      "text": "ねあのせっかくですねあの本格的に使い"
    },
    {
      "start": 254.64,
      "duration": 6.839,
      "text": "出してるのでまルール守ってえしっかり"
    },
    {
      "start": 258.44,
      "duration": 5.44,
      "text": "あのま市民の役に立つためにということで"
    },
    {
      "start": 261.479,
      "duration": 6.921,
      "text": "入れてますのでね互に行きたいと思います"
    },
    {
      "start": 263.88,
      "duration": 4.52,
      "text": "のでよろしくお願いします"
    },
    {
      "start": 268.44,
      "duration": 9.479,
      "text": "はいはいはい他にございます"
    },
    {
      "start": 271.56,
      "duration": 11.88,
      "text": "かはい席ありがとうございますはいこれは"
    },
    {
      "start": 277.919,
      "duration": 8.361,
      "text": "競技はいではその他ああじゃねはいえ以上"
    },
    {
      "start": 283.44,
      "duration": 5.479,
      "text": "で当に付託されております案件の審査は"
    },
    {
      "start": 286.28,
      "duration": 5.639,
      "text": "全て終了いたしましたこれで議会委員会の"
    },
    {
      "start": 288.919,
      "duration": 5.651,
      "text": "業いたしますそれでは協議会事項のその他"
    },
    {
      "start": 291.919,
      "duration": 3.961,
      "text": "でございますけれどもあ総務"
    },
    {
      "start": 294.57,
      "duration": 4.23,
      "text": "[音楽]"
    },
    {
      "start": 295.88,
      "duration": 4.36,
      "text": "部総務部の皆様はこちらで結構でござい"
    },
    {
      "start": 298.8,
      "duration": 3.36,
      "text": "ますあお疲れ様"
    },
    {
      "start": 300.24,
      "duration": 4.64,
      "text": "はいそれではその他協議会のその他で"
    },
    {
      "start": 302.16,
      "duration": 6.24,
      "text": "ございます次長はいすいませんあの資料"
    },
    {
      "start": 304.88,
      "duration": 6.84,
      "text": "配らせていただいておりますえ制服議長案"
    },
    {
      "start": 308.4,
      "duration": 7.84,
      "text": "ということでお配りさせいあの前回3月4"
    },
    {
      "start": 311.72,
      "duration": 7.039,
      "text": "日昨日ですね議運の協議会の中でとご提案"
    },
    {
      "start": 316.24,
      "duration": 6.76,
      "text": "ありましたあの議案ホームページに掲載さ"
    },
    {
      "start": 318.759,
      "duration": 7.361,
      "text": "れてる議案のえ報告の部分でちょっと"
    },
    {
      "start": 323.0,
      "duration": 7.0,
      "text": "何かしらの表記のあれができないという"
    },
    {
      "start": 326.12,
      "duration": 6.76,
      "text": "ことでフご相談の上黄色い多分さん"
    },
    {
      "start": 330.0,
      "duration": 5.52,
      "text": "マーカーを引かいただける部分でちょっと"
    },
    {
      "start": 332.88,
      "duration": 5.2,
      "text": "案を作ってみましたあのちょっとご確認"
    },
    {
      "start": 335.52,
      "duration": 4.88,
      "text": "いただいてご協議いければ思います以上"
    },
    {
      "start": 338.08,
      "duration": 5.2,
      "text": "です"
    },
    {
      "start": 340.4,
      "duration": 7.799,
      "text": "はいただいまのについてご意見ご質と"
    },
    {
      "start": 343.28,
      "duration": 9.8,
      "text": "ございますかはい安員あ座っててですあ"
    },
    {
      "start": 348.199,
      "duration": 7.44,
      "text": "はいあすいませんえっとですねま中期報令"
    },
    {
      "start": 353.08,
      "duration": 5.92,
      "text": "和7年3月4日の本課において撤回となり"
    },
    {
      "start": 355.639,
      "duration": 5.721,
      "text": "ましたというのがま追加案件下のところに"
    },
    {
      "start": 359.0,
      "duration": 5.199,
      "text": "書いてあるのでですけどもちょっとこれの"
    },
    {
      "start": 361.36,
      "duration": 6.8,
      "text": "関係が分かりづらいなっていうような気が"
    },
    {
      "start": 364.199,
      "duration": 7.0,
      "text": "しまして追加提出案件もそのものが撤回と"
    },
    {
      "start": 368.16,
      "duration": 8.68,
      "text": "なったってことがもっと分かるようにこの"
    },
    {
      "start": 371.199,
      "duration": 8.72,
      "text": "提出案件PDF576KBかこ登のに続い"
    },
    {
      "start": 376.84,
      "duration": 6.24,
      "text": "てえ"
    },
    {
      "start": 379.919,
      "duration": 5.361,
      "text": "コメジこの案件は本会議において撤回と"
    },
    {
      "start": 383.08,
      "duration": 5.48,
      "text": "なりましたとかなんか案報告はってなっ"
    },
    {
      "start": 385.28,
      "duration": 8.479,
      "text": "てるんで視聴報告は何なのかっていうのが"
    },
    {
      "start": 388.56,
      "duration": 5.199,
      "text": "少し分かりかなというに思いまし"
    },
    {
      "start": 396.16,
      "duration": 5.599,
      "text": "たあの皆さん"
    },
    {
      "start": 398.759,
      "duration": 4.641,
      "text": "はいようなございましたけど皆さんいかが"
    },
    {
      "start": 401.759,
      "duration": 8.361,
      "text": "です"
    },
    {
      "start": 403.4,
      "duration": 11.519,
      "text": "かはい片山はいえっとですねあのまここの"
    },
    {
      "start": 410.12,
      "duration": 7.88,
      "text": "追ですかねここについてあのなんですが"
    },
    {
      "start": 414.919,
      "duration": 7.72,
      "text": "えっとですねこの"
    },
    {
      "start": 418.0,
      "duration": 8.919,
      "text": "え報告は除されないとことでこのままあの"
    },
    {
      "start": 422.639,
      "duration": 8.24,
      "text": "ま乗り続けるわけなんですよねであのえま"
    },
    {
      "start": 426.919,
      "duration": 7.441,
      "text": "あのえっとこの意見いいた学者の方からは"
    },
    {
      "start": 430.879,
      "duration": 6.121,
      "text": "ま削除欲しいていうようなあの要望がある"
    },
    {
      "start": 434.36,
      "duration": 6.519,
      "text": "とは思うわけですけれどもまそれがまあの"
    },
    {
      "start": 437.0,
      "duration": 6.0,
      "text": "ま会一長原則ということから言ってもでき"
    },
    {
      "start": 440.879,
      "duration": 4.641,
      "text": "ないというようなことについてちょっと"
    },
    {
      "start": 443.0,
      "duration": 5.039,
      "text": "あの局長の局長っていうか事務局の方から"
    },
    {
      "start": 445.52,
      "duration": 6.76,
      "text": "少しもう少しですね説明開きたいという"
    },
    {
      "start": 448.039,
      "duration": 6.201,
      "text": "こととあとそのの上で私はこの中期につい"
    },
    {
      "start": 452.28,
      "duration": 5.639,
      "text": "てはも少しした方がいいんじゃないかと"
    },
    {
      "start": 454.24,
      "duration": 6.0,
      "text": "思っておりましてあの今安さんがですねま"
    },
    {
      "start": 457.919,
      "duration": 4.441,
      "text": "こまのことだってのが分かりやすいように"
    },
    {
      "start": 460.24,
      "duration": 4.48,
      "text": "というまあの場所のことなどおっしゃっ"
    },
    {
      "start": 462.36,
      "duration": 4.76,
      "text": "てかったかな思うんですけれどもで"
    },
    {
      "start": 464.72,
      "duration": 4.24,
      "text": "やっぱりこれ視聴報告だっていうことが"
    },
    {
      "start": 467.12,
      "duration": 5.519,
      "text": "やっぱり分かるようにした方がいい思う"
    },
    {
      "start": 468.96,
      "duration": 6.76,
      "text": "ですであのま場所もそうなんですけもここ"
    },
    {
      "start": 472.639,
      "duration": 5.52,
      "text": "がなんてかなあのちょっとこの一分だと"
    },
    {
      "start": 475.72,
      "duration": 5.08,
      "text": "弱いのかなというのが1つあるかなと思っ"
    },
    {
      "start": 478.159,
      "duration": 5.081,
      "text": "ておりますもう1つやっぱりこのような形"
    },
    {
      "start": 480.8,
      "duration": 5.0,
      "text": "で削除ができないということにつあのもし"
    },
    {
      "start": 483.24,
      "duration": 4.919,
      "text": "できないんであればあのそのことをですね"
    },
    {
      "start": 485.8,
      "duration": 4.359,
      "text": "その学者の方にですね説明をしなければ"
    },
    {
      "start": 488.159,
      "duration": 4.281,
      "text": "いけないんではないかというふ思うわけ"
    },
    {
      "start": 490.159,
      "duration": 8.201,
      "text": "ですがその点についての確認をしていき"
    },
    {
      "start": 492.44,
      "duration": 8.8,
      "text": "たいと思いますはい事務長はいえっと"
    },
    {
      "start": 498.36,
      "duration": 7.36,
      "text": "こちらに掲載されたホームページれた報告"
    },
    {
      "start": 501.24,
      "duration": 7.239,
      "text": "をえ削除できないというようなえことです"
    },
    {
      "start": 505.72,
      "duration": 5.84,
      "text": "がえっとこのホームページに掲載という前"
    },
    {
      "start": 508.479,
      "duration": 7.321,
      "text": "にですねその報告今回議案ということで"
    },
    {
      "start": 511.56,
      "duration": 7.2,
      "text": "取り扱いをあのしていただいておりますで"
    },
    {
      "start": 515.8,
      "duration": 7.039,
      "text": "案の提案につきましてはま過去他のものに"
    },
    {
      "start": 518.76,
      "duration": 7.079,
      "text": "つきましてもえ撤回されたものま掲載され"
    },
    {
      "start": 522.839,
      "duration": 7.041,
      "text": "ているということでで今回視聴報告も同じ"
    },
    {
      "start": 525.839,
      "duration": 8.241,
      "text": "ような対であの掲載はあのそのまま残し"
    },
    {
      "start": 529.88,
      "duration": 7.399,
      "text": "ますがえ中期の応ということで今回あの"
    },
    {
      "start": 534.08,
      "duration": 5.999,
      "text": "ホームページの掲載の中期のところでえの"
    },
    {
      "start": 537.279,
      "duration": 7.041,
      "text": "記ということでえっとこいうような案を"
    },
    {
      "start": 540.079,
      "duration": 7.281,
      "text": "出させていただいてるところでますあと"
    },
    {
      "start": 544.32,
      "duration": 6.8,
      "text": "はよろしいです"
    },
    {
      "start": 547.36,
      "duration": 7.12,
      "text": "かあのまだから"
    },
    {
      "start": 551.12,
      "duration": 3.36,
      "text": "確まそれは"
    },
    {
      "start": 556.839,
      "duration": 7.801,
      "text": "ちょっとはい今の次長の説明としてはその"
    },
    {
      "start": 560.399,
      "duration": 7.041,
      "text": "だからここその議案なので作できていう"
    },
    {
      "start": 564.64,
      "duration": 7.24,
      "text": "ことですねていうあのご説明だったのかな"
    },
    {
      "start": 567.44,
      "duration": 7.2,
      "text": "と思いますですのでえ方法を取ることはま"
    },
    {
      "start": 571.88,
      "duration": 6.8,
      "text": "議会側としては難しいというようなことだ"
    },
    {
      "start": 574.64,
      "duration": 7.08,
      "text": "ということになりますでしょうかはい市長"
    },
    {
      "start": 578.68,
      "duration": 6.36,
      "text": "えっとですねえっとさ先ほど申し上げまし"
    },
    {
      "start": 581.72,
      "duration": 5.92,
      "text": "たその議案のあの取り扱いと同じよう対応"
    },
    {
      "start": 585.04,
      "duration": 6.68,
      "text": "しておりますのでまあの事務局としてそう"
    },
    {
      "start": 587.64,
      "duration": 7.4,
      "text": "いう議案と同じ対応をさせいただいてると"
    },
    {
      "start": 591.72,
      "duration": 5.799,
      "text": "いうことで他のえ手段と言いますと"
    },
    {
      "start": 595.04,
      "duration": 5.08,
      "text": "なかなかちょっとあのこういな中期を"
    },
    {
      "start": 597.519,
      "duration": 5.161,
      "text": "入れるような形でしかちょっと方法がない"
    },
    {
      "start": 600.12,
      "duration": 4.24,
      "text": "のかなというでお答えさせていただきます"
    },
    {
      "start": 602.68,
      "duration": 5.88,
      "text": "以上"
    },
    {
      "start": 604.36,
      "duration": 8.8,
      "text": "ですはい各員えっということを前提とし"
    },
    {
      "start": 608.56,
      "duration": 7.32,
      "text": "ましてあのまえっと知的言われた方に対し"
    },
    {
      "start": 613.16,
      "duration": 6.84,
      "text": "てですね議会がどうするかということを私"
    },
    {
      "start": 615.88,
      "duration": 9.24,
      "text": "は起するかなという風に考えるわけですで"
    },
    {
      "start": 620.0,
      "duration": 8.64,
      "text": "あのただここにですねもしたから例えばま"
    },
    {
      "start": 625.12,
      "duration": 9.399,
      "text": "えっと撤回となったなりたというところの"
    },
    {
      "start": 628.64,
      "duration": 9.319,
      "text": "前なのかなあのギアとしてま提出された"
    },
    {
      "start": 634.519,
      "duration": 5.361,
      "text": "ものについてのこう削除はできないけども"
    },
    {
      "start": 637.959,
      "duration": 5.401,
      "text": "あ撤回となりましたみたいなこととかです"
    },
    {
      "start": 639.88,
      "duration": 6.0,
      "text": "ねあのえなんて言うんですかあの書き方に"
    },
    {
      "start": 643.36,
      "duration": 4.8,
      "text": "ついてもう少し詳しくこなぜ削除できない"
    },
    {
      "start": 645.88,
      "duration": 3.72,
      "text": "のかということを書いておいた方がいいか"
    },
    {
      "start": 648.16,
      "duration": 4.56,
      "text": "なと思いまして今ちょっとごめんなさい"
    },
    {
      "start": 649.6,
      "duration": 5.799,
      "text": "あの分文案についてを考えてきてないん"
    },
    {
      "start": 652.72,
      "duration": 5.0,
      "text": "ですけれどもえここについての詳しい説明"
    },
    {
      "start": 655.399,
      "duration": 6.12,
      "text": "の方が必要かなという風に考えるという"
    },
    {
      "start": 657.72,
      "duration": 6.48,
      "text": "ことが1つとあえ党人の方に議会の方から"
    },
    {
      "start": 661.519,
      "duration": 5.801,
      "text": "説明をするというようなことは必要ではか"
    },
    {
      "start": 664.2,
      "duration": 3.12,
      "text": "思うんですがいかがでしょう"
    },
    {
      "start": 669.279,
      "duration": 3.0,
      "text": "か"
    },
    {
      "start": 672.76,
      "duration": 7.16,
      "text": "うんはいまずま初めの1つ目のまこの表現"
    },
    {
      "start": 678.24,
      "duration": 4.52,
      "text": "というかね書き方についてでございます"
    },
    {
      "start": 679.92,
      "duration": 4.719,
      "text": "あのま議会の方で一致すればということで"
    },
    {
      "start": 682.76,
      "duration": 5.44,
      "text": "ございますけど皆さん今のご提案について"
    },
    {
      "start": 684.639,
      "duration": 3.561,
      "text": "はです"
    },
    {
      "start": 692.2,
      "duration": 10.439,
      "text": "的ねまあ今のするかしないかぐらいもう"
    },
    {
      "start": 697.399,
      "duration": 8.921,
      "text": "少しねま議案としては削除ねここから削除"
    },
    {
      "start": 702.639,
      "duration": 7.801,
      "text": "はできないけれどもっていうようなことき"
    },
    {
      "start": 706.32,
      "duration": 4.12,
      "text": "さどうかということでし"
    },
    {
      "start": 710.68,
      "duration": 3.0,
      "text": "た"
    },
    {
      "start": 714.6,
      "duration": 9.08,
      "text": "が適"
    },
    {
      "start": 716.76,
      "duration": 9.319,
      "text": "な適切なはいはい安ましそのあの生はどう"
    },
    {
      "start": 723.68,
      "duration": 5.44,
      "text": "おっしゃられてるのかっていうのは確認は"
    },
    {
      "start": 726.079,
      "duration": 8.44,
      "text": "していない感じか今時点で"
    },
    {
      "start": 729.12,
      "duration": 10.079,
      "text": "はあの削除を求められているまだ削除する"
    },
    {
      "start": 734.519,
      "duration": 7.361,
      "text": "ことがを望まれているという段階なのかと"
    },
    {
      "start": 739.199,
      "duration": 7.681,
      "text": "いうことをちょ確認したまだ確認してい"
    },
    {
      "start": 741.88,
      "duration": 8.36,
      "text": "ないだから事情めばそう納得いただける"
    },
    {
      "start": 746.88,
      "duration": 6.199,
      "text": "ような形できできる"
    },
    {
      "start": 750.24,
      "duration": 2.839,
      "text": "と思ったんですけど"
    },
    {
      "start": 753.6,
      "duration": 8.64,
      "text": "もあの書いてあるんですね局が言われてる"
    },
    {
      "start": 758.399,
      "duration": 6.841,
      "text": "のはこの義のメンバーで一致してじゃあ"
    },
    {
      "start": 762.24,
      "duration": 7.399,
      "text": "ちゃんと確認した上で決めようことでば"
    },
    {
      "start": 765.24,
      "duration": 7.719,
      "text": "事務局はそういう風に動くしそこをあの義"
    },
    {
      "start": 769.639,
      "duration": 6.481,
      "text": "のの皆さんで決めてどういう結論で持って"
    },
    {
      "start": 772.959,
      "duration": 6.0,
      "text": "いくかっていうことだと思いますのでだと"
    },
    {
      "start": 776.12,
      "duration": 7.079,
      "text": "はいはい議長えっとちょっと今なかった"
    },
    {
      "start": 778.959,
      "duration": 7.521,
      "text": "ですけどもえ先生から特に削除を議会に"
    },
    {
      "start": 783.199,
      "duration": 6.0,
      "text": "対しては求められてるあのものはんですよ"
    },
    {
      "start": 786.48,
      "duration": 7.12,
      "text": "だから一応それだけは一応確認しておき"
    },
    {
      "start": 789.199,
      "duration": 7.961,
      "text": "たいと思いますはい水上あそれではその"
    },
    {
      "start": 793.6,
      "duration": 6.479,
      "text": "要するに専門家の方との関係なんですけど"
    },
    {
      "start": 797.16,
      "duration": 6.119,
      "text": "一応文章で是正を求めるっていうことが"
    },
    {
      "start": 800.079,
      "duration": 6.401,
      "text": "議会に対して応されていたと思うんですね"
    },
    {
      "start": 803.279,
      "duration": 6.8,
      "text": "であの一応ねあの議会に対する市民の意を"
    },
    {
      "start": 806.48,
      "duration": 7.159,
      "text": "聞くていうその仕組みがあってあの要する"
    },
    {
      "start": 810.079,
      "duration": 7.801,
      "text": "に匿名じゃなくてあのちとした名前が出さ"
    },
    {
      "start": 813.639,
      "duration": 7.681,
      "text": "れて議会に対しての要望が出てきた時にと"
    },
    {
      "start": 817.88,
      "duration": 5.28,
      "text": "して検討して回答するってい仕組みがある"
    },
    {
      "start": 821.32,
      "duration": 3.68,
      "text": "と思うんですねその音に載せ"
    },
    {
      "start": 823.16,
      "duration": 4.64,
      "text": "るっていうことも可能ではないかなって"
    },
    {
      "start": 825.0,
      "duration": 6.079,
      "text": "いう僕は思ってましてそういうゼルって"
    },
    {
      "start": 827.8,
      "duration": 6.399,
      "text": "いうようなあの要望に対してどう対応する"
    },
    {
      "start": 831.079,
      "duration": 5.161,
      "text": "のかもしこういう文書で行くことになれば"
    },
    {
      "start": 834.199,
      "duration": 5.161,
      "text": "この文章でいいかどうかそういう形に"
    },
    {
      "start": 836.24,
      "duration": 5.64,
      "text": "するっていうことをそのご本人に連絡をし"
    },
    {
      "start": 839.36,
      "duration": 5.36,
      "text": "て確認するっていう流れになってくるんで"
    },
    {
      "start": 841.88,
      "duration": 6.84,
      "text": "はないかなと思うのでそれはや今までの"
    },
    {
      "start": 844.72,
      "duration": 6.559,
      "text": "こう要するに制度みたいな形で運用できと"
    },
    {
      "start": 848.72,
      "duration": 7.359,
      "text": "思うんねだからそういう意味で言うとこの"
    },
    {
      "start": 851.279,
      "duration": 6.641,
      "text": "文書確定した上でご本に連絡をするとま"
    },
    {
      "start": 856.079,
      "duration": 4.921,
      "text": "いうことまではできると思ってるんです"
    },
    {
      "start": 857.92,
      "duration": 5.039,
      "text": "けどそれはちょっと議会の皆さんいかが"
    },
    {
      "start": 861.0,
      "duration": 3.56,
      "text": "でしょうか"
    },
    {
      "start": 862.959,
      "duration": 4.68,
      "text": "ね"
    },
    {
      "start": 864.56,
      "duration": 6.719,
      "text": "はいはいえっとすいません私があの聞い"
    },
    {
      "start": 867.639,
      "duration": 5.801,
      "text": "てる範囲ではせは削除欲しいという風に"
    },
    {
      "start": 871.279,
      "duration": 4.68,
      "text": "おっしゃったという風に聞いてるんですが"
    },
    {
      "start": 873.44,
      "duration": 4.92,
      "text": "なかなか今までの運用としては難しいと"
    },
    {
      "start": 875.959,
      "duration": 6.24,
      "text": "いうことでただそれは議会で決めることな"
    },
    {
      "start": 878.36,
      "duration": 6.96,
      "text": "のでっていう風に言われた時つえっと私の"
    },
    {
      "start": 882.199,
      "duration": 6.801,
      "text": "えっとまあの提案というかアイディアとし"
    },
    {
      "start": 885.32,
      "duration": 6.72,
      "text": "てはですねそのファイルを開いた時"
    },
    {
      "start": 889.0,
      "duration": 6.44,
      "text": "にちょっと修正使見てしまうかもしれない"
    },
    {
      "start": 892.04,
      "duration": 7.52,
      "text": "んですけどこのこのえっと報告は撤回と"
    },
    {
      "start": 895.44,
      "duration": 9.399,
      "text": "なりましたみたい注意書きがあの本体と"
    },
    {
      "start": 899.56,
      "duration": 7.32,
      "text": "違って貼るみたいな感じでできたらより"
    },
    {
      "start": 904.839,
      "duration": 4.761,
      "text": "あの分かりやすいのではないかなと思い"
    },
    {
      "start": 906.88,
      "duration": 5.399,
      "text": "ました書いたところしか見て見てないから"
    },
    {
      "start": 909.6,
      "duration": 4.4,
      "text": "からするとここの一分を見落としてしまっ"
    },
    {
      "start": 912.279,
      "duration": 2.321,
      "text": "たら分からないのではないかなと思うん"
    },
    {
      "start": 914.0,
      "duration": 5.24,
      "text": "です"
    },
    {
      "start": 914.6,
      "duration": 8.12,
      "text": "けどそれも議会できられるなのかいや"
    },
    {
      "start": 919.24,
      "duration": 7.24,
      "text": "えっと議案なので議案自体を何か触ること"
    },
    {
      "start": 922.72,
      "duration": 7.2,
      "text": "できないなのかどうでしょうこれは局長と"
    },
    {
      "start": 926.48,
      "duration": 6.839,
      "text": "か事務局この"
    },
    {
      "start": 929.92,
      "duration": 6.24,
      "text": "できないですはいはいじゃここで決め"
    },
    {
      "start": 933.319,
      "duration": 4.161,
      "text": "できるんですかただ今までそのような運用"
    },
    {
      "start": 936.16,
      "duration": 3.799,
      "text": "をしたことはございませんていうのは"
    },
    {
      "start": 937.48,
      "duration": 2.479,
      "text": "先ほどの"
    },
    {
      "start": 940.519,
      "duration": 4.76,
      "text": "説明はいいかがです"
    },
    {
      "start": 947.519,
      "duration": 7.68,
      "text": "か先ほど神さんのご意見"
    },
    {
      "start": 952.12,
      "duration": 8.639,
      "text": "はいまそういう市民からの要というでの"
    },
    {
      "start": 955.199,
      "duration": 8.241,
      "text": "ルートに載せた上でえまの対応検討をし"
    },
    {
      "start": 960.759,
      "duration": 6.681,
      "text": "それをご本人にお開始する"
    },
    {
      "start": 963.44,
      "duration": 6.16,
      "text": "という可ではないかというご意見でござい"
    },
    {
      "start": 967.44,
      "duration": 2.16,
      "text": "ます"
    },
    {
      "start": 970.279,
      "duration": 7.161,
      "text": "がはい水谷すいません水上さんのご提案と"
    },
    {
      "start": 974.319,
      "duration": 6.161,
      "text": "しては議会はこというのをまとめた上で"
    },
    {
      "start": 977.44,
      "duration": 5.959,
      "text": "そのご本人に確認してはどうかということ"
    },
    {
      "start": 980.48,
      "duration": 5.68,
      "text": "ですかねはい水あの多分ねホームページ見"
    },
    {
      "start": 983.399,
      "duration": 5.8,
      "text": "てもらうと分かると思うんですけど市民"
    },
    {
      "start": 986.16,
      "duration": 6.4,
      "text": "から議会に対するその意見要望についつい"
    },
    {
      "start": 989.199,
      "duration": 7.681,
      "text": "ては議会として回答するていうルールが"
    },
    {
      "start": 992.56,
      "duration": 7.56,
      "text": "作られておりますで市民から匿名以外の形"
    },
    {
      "start": 996.88,
      "duration": 7.199,
      "text": "議会に要望されたこと例えばこの間で言う"
    },
    {
      "start": 1000.12,
      "duration": 6.199,
      "text": "と膨張者から議に対要望が出されて議長が"
    },
    {
      "start": 1004.079,
      "duration": 6.801,
      "text": "回答したっていうのは一連あったんですね"
    },
    {
      "start": 1006.319,
      "duration": 9.161,
      "text": "あの交流育問題でで今回もやっぱりあの"
    },
    {
      "start": 1010.88,
      "duration": 8.56,
      "text": "要するにあの専門方があの実明が出されて"
    },
    {
      "start": 1015.48,
      "duration": 6.68,
      "text": "あの議会に対するそのあのましてほしいっ"
    },
    {
      "start": 1019.44,
      "duration": 5.359,
      "text": "ていう要望が出されてるわけだからこれは"
    },
    {
      "start": 1022.16,
      "duration": 5.12,
      "text": "だから議会してルートで検討するっていう"
    },
    {
      "start": 1024.799,
      "duration": 5.64,
      "text": "ことはできるんじゃないかなっていう風に"
    },
    {
      "start": 1027.28,
      "duration": 6.6,
      "text": "思ってるんですね解としてどう対応するの"
    },
    {
      "start": 1030.439,
      "duration": 6.12,
      "text": "かっていうことをまとめた上でご本に回答"
    },
    {
      "start": 1033.88,
      "duration": 6.36,
      "text": "するていう形のその仕組みになってます"
    },
    {
      "start": 1036.559,
      "duration": 8.161,
      "text": "からあそういう形でちょっと人と要するに"
    },
    {
