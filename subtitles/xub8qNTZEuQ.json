{
  "entries": [
    {
      "start": 9.12,
      "duration": 3.0,
      "text": "ね"
    },
    {
      "start": 74.56,
      "duration": 6.68,
      "text": "再開しますここで先ほど保留しました日程"
    },
    {
      "start": 78.28,
      "duration": 6.4,
      "text": "第2から日程第4までの3件の保留を時"
    },
    {
      "start": 81.24,
      "duration": 5.6,
      "text": "順次議題とし討論採決を行います議案第"
    },
    {
      "start": 84.68,
      "duration": 7.92,
      "text": "44号教育委員"
    },
    {
      "start": 86.84,
      "duration": 7.559,
      "text": "会教育長の任に同意を求めることについて"
    },
    {
      "start": 92.6,
      "duration": 5.32,
      "text": "これから討論を行い"
    },
    {
      "start": 94.399,
      "duration": 6.961,
      "text": "ます本件に対する討論を終了することにご"
    },
    {
      "start": 97.92,
      "duration": 9.4,
      "text": "異議ありませんかご異議な人認め討論を"
    },
    {
      "start": 101.36,
      "duration": 5.96,
      "text": "終了します直に採決しますお諮りし"
    },
    {
      "start": 107.36,
      "duration": 8.92,
      "text": "ますおおはかりしますはい本件について"
    },
    {
      "start": 112.719,
      "duration": 6.04,
      "text": "同意することにご異議ありませんかご異議"
    },
    {
      "start": 116.28,
      "duration": 5.56,
      "text": "なしと認め本件は同意することと決定"
    },
    {
      "start": 118.759,
      "duration": 3.081,
      "text": "いたしました"
    },
    {
      "start": 122.64,
      "duration": 3.0,
      "text": "っ"
    },
    {
      "start": 129.399,
      "duration": 6.961,
      "text": "て議案第45号教育委員会委員の任命に"
    },
    {
      "start": 133.8,
      "duration": 5.96,
      "text": "関し同意を求めることについてこれから"
    },
    {
      "start": 136.36,
      "duration": 6.76,
      "text": "討論を行います本件に対する討論を終了"
    },
    {
      "start": 139.76,
      "duration": 3.36,
      "text": "することにご異議ありません"
    },
    {
      "start": 143.519,
      "duration": 8.161,
      "text": "かご異議なと認め討論を終了しますに決し"
    },
    {
      "start": 148.04,
      "duration": 6.839,
      "text": "ますおりします本について同意することに"
    },
    {
      "start": 151.68,
      "duration": 6.76,
      "text": "ご異議ありませんかえご異議なしと認め"
    },
    {
      "start": 154.879,
      "duration": 9.08,
      "text": "本件は同意することと決定いたしまし"
    },
    {
      "start": 158.44,
      "duration": 10.0,
      "text": "た議案第34号米不足と価格高等への緊急"
    },
    {
      "start": 163.959,
      "duration": 7.601,
      "text": "対策を求める意見書本件は討論を行います"
    },
    {
      "start": 168.44,
      "duration": 6.96,
      "text": "本件に反対のものの発言を許可します9番"
    },
    {
      "start": 171.56,
      "duration": 3.84,
      "text": "井教子議員"
    },
    {
      "start": 185.28,
      "duration": 9.2,
      "text": "え議員案第344号米不足と価格高等への"
    },
    {
      "start": 190.76,
      "duration": 6.92,
      "text": "緊急対策を求める意見書に反対の立場から"
    },
    {
      "start": 194.48,
      "duration": 7.56,
      "text": "自由民主と信頼を代表して完結に討論を"
    },
    {
      "start": 197.68,
      "duration": 8.8,
      "text": "行いますえ今回一部品部が生じている原因"
    },
    {
      "start": 202.04,
      "duration": 8.52,
      "text": "として政府は米の在庫は最も少なくなる羽"
    },
    {
      "start": 206.48,
      "duration": 7.52,
      "text": "機であることあ羽機である8月にえ南海"
    },
    {
      "start": 210.56,
      "duration": 8.12,
      "text": "トラフ地震臨時情報とその後の地震や台風"
    },
    {
      "start": 214.0,
      "duration": 8.56,
      "text": "等により買い込み需要が発生したこと輸入"
    },
    {
      "start": 218.68,
      "duration": 7.6,
      "text": "輸送業者がお盆休みに入った影響もありえ"
    },
    {
      "start": 222.56,
      "duration": 8.44,
      "text": "商品の搬入に停滞が生じたことなどを挙げ"
    },
    {
      "start": 226.28,
      "duration": 8.72,
      "text": "ておりますさらに例年新前は8月中に九州"
    },
    {
      "start": 231.0,
      "duration": 7.92,
      "text": "から千葉茨城島の産地の早期前が出回り"
    },
    {
      "start": 235.0,
      "duration": 7.72,
      "text": "始め9月には1年の出荷量の4割程度まで"
    },
    {
      "start": 238.92,
      "duration": 8.159,
      "text": "本格的にでまりますが産地の情報によると"
    },
    {
      "start": 242.72,
      "duration": 7.68,
      "text": "え6年3枚の正育は順調に進んでいること"
    },
    {
      "start": 247.079,
      "duration": 6.52,
      "text": "平年より1週間程度収穫が早まる産地も"
    },
    {
      "start": 250.4,
      "duration": 7.0,
      "text": "あり合わせて出荷も前倒しに行われる"
    },
    {
      "start": 253.599,
      "duration": 7.001,
      "text": "見込みであるということをあ申しており"
    },
    {
      "start": 257.4,
      "duration": 7.239,
      "text": "そのように聞いておりますえまた政府に"
    },
    {
      "start": 260.6,
      "duration": 8.24,
      "text": "おいて米の取引業者であるえ中華業者や"
    },
    {
      "start": 264.639,
      "duration": 8.961,
      "text": "おろし売り業に対し常日から集荷販売在庫"
    },
    {
      "start": 268.84,
      "duration": 8.24,
      "text": "状況等の情報を聴取し毎月公表することで"
    },
    {
      "start": 273.6,
      "duration": 6.2,
      "text": "決め細かな情報提供を行うとともに円滑な"
    },
    {
      "start": 277.08,
      "duration": 6.839,
      "text": "流通を務めていただくよう働きかけると"
    },
    {
      "start": 279.8,
      "duration": 6.959,
      "text": "ともにおろし振り手誤射と介護を持ち円滑"
    },
    {
      "start": 283.919,
      "duration": 5.72,
      "text": "な集荷販売をえお願いしているということ"
    },
    {
      "start": 286.759,
      "duration": 6.44,
      "text": "も聞いておりますえさらに市内スーパーに"
    },
    {
      "start": 289.639,
      "duration": 7.641,
      "text": "おいてえすでに並んでるという情報も入っ"
    },
    {
      "start": 293.199,
      "duration": 7.641,
      "text": "ておりますえこうした状況の中で米不足と"
    },
    {
      "start": 297.28,
      "duration": 7.52,
      "text": "いう言い方で市議会からメを出すこと自体"
    },
    {
      "start": 300.84,
      "duration": 7.84,
      "text": "が市民の不安をかき立てえ開始めなどの"
    },
    {
      "start": 304.8,
      "duration": 7.08,
      "text": "行動をの呼び水ともなりかねずえ危機管理"
    },
    {
      "start": 308.68,
      "duration": 7.76,
      "text": "上も慎重であることが求められると考えて"
    },
    {
      "start": 311.88,
      "duration": 8.039,
      "text": "おりますえ最後にえ農業政策に関してはえ"
    },
    {
      "start": 316.44,
      "duration": 7.36,
      "text": "過去長い間米中心の対策が取られてきた"
    },
    {
      "start": 319.919,
      "duration": 7.241,
      "text": "ことの反省の上に農業全体と国民の職生活"
    },
    {
      "start": 323.8,
      "duration": 6.519,
      "text": "の変化を含めての議論は常に欠かせないえ"
    },
    {
      "start": 327.16,
      "duration": 6.159,
      "text": "日本の重要政策であることを申し上げ反対"
    },
    {
      "start": 330.319,
      "duration": 3.0,
      "text": "討論といたし"
    },
    {
      "start": 344.28,
      "duration": 8.0,
      "text": "ます以上で討論を終了します本件は起立"
    },
    {
      "start": 348.28,
      "duration": 7.199,
      "text": "採決をしますお諮りします本件は原案の"
    },
    {
      "start": 352.28,
      "duration": 6.52,
      "text": "通り可決することに賛成の皆さんの起立を"
    },
    {
      "start": 355.479,
      "duration": 3.321,
      "text": "求めます"
    },
    {
      "start": 363.36,
      "duration": 9.44,
      "text": "数"
    },
    {
      "start": 365.479,
      "duration": 11.28,
      "text": "数数キス数本件は原案可決と決定しました"
    },
    {
      "start": 372.8,
      "duration": 7.2,
      "text": "日程第5星願尋常の委員会付託を行います"
    },
    {
      "start": 376.759,
      "duration": 8.321,
      "text": "今定例会の9月3日までに受理した正眼"
    },
    {
      "start": 380.0,
      "duration": 9.72,
      "text": "陳情は6陳情第29号から第39号及び第"
    },
    {
      "start": 385.08,
      "duration": 9.0,
      "text": "41号の12件です以上12件のうち6"
    },
    {
      "start": 389.72,
      "duration": 8.16,
      "text": "38号を除く11件はお手元にご配布し"
    },
    {
      "start": 394.08,
      "duration": 8.239,
      "text": "ました付託審査案件一覧表の通り所管の"
    },
    {
      "start": 397.88,
      "duration": 8.0,
      "text": "常任委員会に付託しますお諮りします6"
    },
    {
      "start": 402.319,
      "duration": 7.761,
      "text": "陳情第38号コンプライアンスの観点から"
    },
    {
      "start": 405.88,
      "duration": 8.08,
      "text": "違法判決を受けた保育園条例を年度間を"
    },
    {
      "start": 410.08,
      "duration": 7.76,
      "text": "通して運用した令和5年度一般会計決算の"
    },
    {
      "start": 413.96,
      "duration": 6.079,
      "text": "不認定を求める陳情書は決算特別委員会に"
    },
    {
      "start": 417.84,
      "duration": 3.28,
      "text": "付託したいと思いますこれにご異議あり"
    },
    {
      "start": 420.039,
      "duration": 6.121,
      "text": "ません"
    },
    {
      "start": 421.12,
      "duration": 8.479,
      "text": "かご異議なしと認め6陳情第38号は決算"
    },
    {
      "start": 426.16,
      "duration": 6.68,
      "text": "特別委員会に付託することと決定しました"
    },
    {
      "start": 429.599,
      "duration": 7.0,
      "text": "各常任委員会委員長議会運営委員会委員長"
    },
    {
      "start": 432.84,
      "duration": 6.52,
      "text": "及び各特別委員会委員長から委員会開催日"
    },
    {
      "start": 436.599,
      "duration": 6.6,
      "text": "の連絡を受けていますのでお知らせします"
    },
    {
      "start": 439.36,
      "duration": 8.08,
      "text": "9月11日は午前10時から議会運営委員"
    },
    {
      "start": 443.199,
      "duration": 8.44,
      "text": "会9月12日は午前10時から厚生文教"
    },
    {
      "start": 447.44,
      "duration": 7.68,
      "text": "委員会9月13日はは午前9時から建設"
    },
    {
      "start": 451.639,
      "duration": 6.96,
      "text": "環境委員会9月17日は午前10時から"
    },
    {
      "start": 455.12,
      "duration": 6.84,
      "text": "総務企画委員会9月18日は午前10時"
    },
    {
      "start": 458.599,
      "duration": 5.801,
      "text": "から予算特別委員会9月19日は午前10"
    },
    {
      "start": 461.96,
      "duration": 5.84,
      "text": "時から長者等建設及び公共施設"
    },
    {
      "start": 464.4,
      "duration": 6.079,
      "text": "マネージメント推進調査特別委員会9月"
    },
    {
      "start": 467.8,
      "duration": 7.959,
      "text": "20日は午前10時から行財政改革推進"
    },
    {
      "start": 470.479,
      "duration": 9.081,
      "text": "調査特別委員会9月30日10月1日2日"
    },
    {
      "start": 475.759,
      "duration": 6.921,
      "text": "3日及び4日はいずれも午前10時から"
    },
    {
      "start": 479.56,
      "duration": 6.359,
      "text": "さん特別委員会以上の通り本席からお知ら"
    },
    {
      "start": 482.68,
      "duration": 8.68,
      "text": "せします以上で本日の日程は全て終了し"
    },
    {
      "start": 485.919,
      "duration": 5.441,
      "text": "ました本日はこれを持ちまして参加します"
    }
  ]
}