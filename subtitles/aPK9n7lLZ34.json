      "text": "ございますか"
    },
    {
      "start": 95.04,
      "duration": 5.84,
      "text": "はい一旦終わってもらっはい終わっちゃっ"
    },
    {
      "start": 98.159,
      "duration": 6.64,
      "text": "ていいあ終わっちゃってはいはいそれでは"
    },
    {
      "start": 100.88,
