{
  "entries": [
    {
      "start": 152.879,
      "duration": 4.36,
      "text": "あのこれちょっと言っていただいてはい"
    },
    {
      "start": 155.56,
      "duration": 5.0,
      "text": "マイク入れていただいてです"
    },
    {
      "start": 157.239,
      "duration": 6.08,
      "text": "ねえおはようございますえ協議会始めて"
    },
    {
      "start": 160.56,
      "duration": 6.319,
      "text": "いきたいと思いますがえ本日"
    },
    {
      "start": 163.319,
      "duration": 8.56,
      "text": "ええ田委員が"
    },
    {
      "start": 166.879,
      "duration": 8.681,
      "text": "え響きのためえ欠席をいたしますのでえ"
    },
    {
      "start": 171.879,
      "duration": 8.321,
      "text": "その旨えお伝えをいたしますえ本日え1日"
    },
    {
      "start": 175.56,
      "duration": 4.64,
      "text": "でございますよろしくお願いいたします"
    },
    {
      "start": 183.04,
      "duration": 7.199,
      "text": "それではえお手元ペーパーでえ本日の進行"
    },
    {
      "start": 185.879,
      "duration": 7.201,
      "text": "予定でございますがえ審査県え新城1件え"
    },
    {
      "start": 190.239,
      "duration": 6.801,
      "text": "保留となってましたえ6新城第47号の"
    },
    {
      "start": 193.08,
      "duration": 6.879,
      "text": "審査でえございますがえ委員の皆様にはえ"
    },
    {
      "start": 197.04,
      "duration": 6.52,
      "text": "この旨ええ議員の皆様に主旨ということで"
    },
    {
      "start": 199.959,
      "duration": 6.041,
      "text": "え了解を取っていたことについてえ今まで"
    },
    {
      "start": 203.56,
      "duration": 6.8,
      "text": "ちょっと説明がなくて大変え申し訳ござい"
    },
    {
      "start": 206.0,
      "duration": 7.599,
      "text": "ませんでした失礼いたしましたどうも"
    },
    {
      "start": 210.36,
      "duration": 7.079,
      "text": "えその他え何かございますでしょう"
    },
    {
      "start": 213.599,
      "duration": 7.881,
      "text": "かはいじゃではえ進めていきたいと思い"
    },
    {
      "start": 217.439,
      "duration": 4.041,
      "text": "ますはいじゃ"
    },
    {
      "start": 221.56,
      "duration": 5.48,
      "text": "はいおはようございますおはようござい"
    },
    {
      "start": 224.08,
      "duration": 6.64,
      "text": "ますただいまから建設環境委員会の会議を"
    },
    {
      "start": 227.04,
      "duration": 6.479,
      "text": "開きます直に本日の議事に入ります当委員"
    },
    {
      "start": 230.72,
      "duration": 6.64,
      "text": "会に付託されております案件は前回の委員"
    },
    {
      "start": 233.519,
      "duration": 6.8,
      "text": "会で保留といたしました新生1件です以上"
    },
    {
      "start": 237.36,
      "duration": 7.68,
      "text": "1件につきましては建設環境委員会審査"
    },
    {
      "start": 240.319,
      "duration": 10.241,
      "text": "予定表の通り行うことといたします直に6"
    },
    {
      "start": 245.04,
      "duration": 9.279,
      "text": "陳情第47号東小金駅北口の駐輪環境通勤"
    },
    {
      "start": 250.56,
      "duration": 7.12,
      "text": "通学お買い物等の向上を求める陳情書を"
    },
    {
      "start": 254.319,
      "duration": 5.32,
      "text": "議題といたしますえ部局から発言があり"
    },
    {
      "start": 257.68,
      "duration": 6.239,
      "text": "ましたらこれを求め"
    },
    {
      "start": 259.639,
      "duration": 4.28,
      "text": "ますこれから質疑を行い"
    },
    {
      "start": 266.88,
      "duration": 7.48,
      "text": "ます4ペジ4ページですはいえ本件につき"
    },
    {
      "start": 271.4,
      "duration": 6.639,
      "text": "まして委員長報告に載せる委員要望が"
    },
    {
      "start": 274.36,
      "duration": 7.36,
      "text": "ございましたら発言をお願いいたします委"
    },
    {
      "start": 278.039,
      "duration": 6.961,
      "text": "意見意見はいはいがございましたら発言を"
    },
    {
      "start": 281.72,
      "duration": 5.64,
      "text": "お願いいたします願しますはい以上で本件"
    },
    {
      "start": 285.0,
      "duration": 5.84,
      "text": "に対する質疑を終了することにご異議あり"
    },
    {
      "start": 287.36,
      "duration": 6.76,
      "text": "ませんかご異議なしと認めます従って質疑"
    },
    {
      "start": 290.84,
      "duration": 6.68,
      "text": "を終了いたしますこれから討論を行い"
    },
    {
      "start": 294.12,
      "duration": 5.76,
      "text": "ます本件に対する討論を終了することにご"
    },
    {
      "start": 297.52,
      "duration": 5.28,
      "text": "異ありませんか"
    },
    {
      "start": 299.88,
      "duration": 5.72,
      "text": "と認めます従って討論を終了いたします"
    },
    {
      "start": 302.8,
      "duration": 6.28,
      "text": "それでは直に採決いたしますお諮りいたし"
    },
    {
      "start": 305.6,
      "duration": 5.56,
      "text": "ます本件は主採択の上市長に送付すること"
    },
    {
      "start": 309.08,
      "duration": 6.44,
      "text": "にご異議ありません"
    },
    {
      "start": 311.16,
      "duration": 7.56,
      "text": "かご異議なしと認めますしって本件は出託"
    },
    {
      "start": 315.52,
      "duration": 7.119,
      "text": "の上市長に送付すべきものと決定いたし"
    },
    {
      "start": 318.72,
      "duration": 7.36,
      "text": "ました以上で本日の日程は全部終了いたし"
    },
    {
      "start": 322.639,
      "duration": 9.0,
      "text": "ました本日は以上で建設環境委員会を閉"
    },
    {
      "start": 326.08,
      "duration": 5.559,
      "text": "いたしますお疲れ様でしたえ皆様え"
    }
