{
  "entries": [
    {
      "start": 28.96,
      "duration": 3.88,
      "text": "えっと"
    },
    {
      "start": 30.48,
      "duration": 5.64,
      "text": "忘れる前に事務連絡でございますあの議会"
    },
    {
      "start": 32.84,
      "duration": 7.6,
      "text": "運営委員会メンバーの皆さんはあの例の"
    },
    {
      "start": 36.12,
      "duration": 7.439,
      "text": "さっきの中大付属の模擬議会のテーマ"
    },
    {
      "start": 40.44,
      "duration": 4.92,
      "text": "テーマを協議する日程決めをこれ終わって"
    },
    {
      "start": 43.559,
      "duration": 4.84,
      "text": "からちょっと残ってさせてください日程"
    },
    {
      "start": 45.36,
      "duration": 4.8,
      "text": "決め日程決めはいはい忘れないように僕は"
    },
    {
      "start": 48.399,
      "duration": 4.401,
      "text": "忘れてら言って"
    },
    {
      "start": 50.16,
      "duration": 5.64,
      "text": "くださいえっとこれはブーはいらないんだ"
    },
    {
      "start": 52.8,
      "duration": 8.04,
      "text": "よねはいそれではあの帝国でございますの"
    },
    {
      "start": 55.8,
      "duration": 7.12,
      "text": "で再開させていただきますはいえっとここ"
    },
    {
      "start": 60.84,
      "duration": 5.36,
      "text": "までありがとうございますそれではえ丸"
    },
    {
      "start": 62.92,
      "duration": 6.879,
      "text": "大きな国の4番の市民と議会についてと"
    },
    {
      "start": 66.2,
      "duration": 5.88,
      "text": "いうところでえ第11条についてはまあの"
    },
    {
      "start": 69.799,
      "duration": 4.761,
      "text": "申し送りになっておりました校長機能を"
    },
    {
      "start": 72.08,
      "duration": 6.84,
      "text": "どうするかということについてはま各会派"
    },
    {
      "start": 74.56,
      "duration": 8.199,
      "text": "の意見を11月16日いただいているので"
    },
    {
      "start": 78.92,
      "duration": 5.72,
      "text": "まこれは各読んでいただいてあの次回協議"
    },
    {
      "start": 82.759,
      "duration": 4.481,
      "text": "させていただければと思っておりますと"
    },
    {
      "start": 84.64,
      "duration": 5.28,
      "text": "一緒の括りにしておりますナンバー8のと"
    },
    {
      "start": 87.24,
      "duration": 5.48,
      "text": "ナンバー9のご提案について提案会話から"
    },
    {
      "start": 89.92,
      "duration": 5.839,
      "text": "ご説明をいただいてま会派でそれぞれ"
    },
    {
      "start": 92.72,
      "duration": 5.88,
      "text": "持ち帰るにあたってえ確認しておきたい時"
    },
    {
      "start": 95.759,
      "duration": 5.161,
      "text": "なを質疑を受けた上で持ち帰っていただい"
    },
    {
      "start": 98.6,
      "duration": 4.08,
      "text": "て次回協議をさせていただきたいという"
    },
    {
      "start": 100.92,
      "duration": 5.08,
      "text": "前提でお願いいたしますそれではナンバー"
    },
    {
      "start": 102.68,
      "duration": 6.439,
      "text": "8第3章市民と議会の関係第9条市民の声"
    },
    {
      "start": 106.0,
      "duration": 6.36,
      "text": "を反映させる議会第3項について提案会派"
    },
    {
      "start": 109.119,
      "duration": 7.081,
      "text": "の日本共産党さんからご説明お願いします"
    },
    {
      "start": 112.36,
      "duration": 8.16,
      "text": "はい水上えっとそれで現状のあの議会基本"
    },
    {
      "start": 116.2,
      "duration": 7.879,
      "text": "条例の第9条はえっと"
    },
    {
      "start": 120.52,
      "duration": 7.239,
      "text": "議会は市長から提案された議案について"
    },
    {
      "start": 124.079,
      "duration": 7.081,
      "text": "誠実に審議するものとし議員は必要に応じ"
    },
    {
      "start": 127.759,
      "duration": 6.921,
      "text": "てえっと市民の意見を聞く機会を設ける"
    },
    {
      "start": 131.16,
      "duration": 6.0,
      "text": "ものとするとまいうことになってあの市民"
    },
    {
      "start": 134.68,
      "duration": 6.88,
      "text": "の声を反映させる議会っていうことなん"
    },
    {
      "start": 137.16,
      "duration": 8.28,
      "text": "ですが市民の意見は議会が聞くのではなく"
    },
    {
      "start": 141.56,
      "duration": 6.399,
      "text": "議員が要するに必要に応じてあの聞く機会"
    },
    {
      "start": 145.44,
      "duration": 5.0,
      "text": "を設けるっていうこういう地底になってい"
    },
    {
      "start": 147.959,
      "duration": 8.041,
      "text": "ますこれについて"
    },
    {
      "start": 150.44,
      "duration": 9.28,
      "text": "あの議会はだけではなくあの議会もしくは"
    },
    {
      "start": 156.0,
      "duration": 7.04,
      "text": "あのえっとあ議員もしくは議会場などとし"
    },
    {
      "start": 159.72,
      "duration": 5.879,
      "text": "て議員議会として意見を聞くっていうこと"
    },
    {
      "start": 163.04,
      "duration": 5.72,
      "text": "にあの明確にした方がいいんではない"
    },
    {
      "start": 165.599,
      "duration": 6.841,
      "text": "かっていう提案なんですねでこれも議会"
    },
    {
      "start": 168.76,
      "duration": 5.559,
      "text": "基本条例策定にあたっては一定議論があっ"
    },
    {
      "start": 172.44,
      "duration": 6.0,
      "text": "てこういうところに落ち着いたんです"
    },
    {
      "start": 174.319,
      "duration": 7.121,
      "text": "けれども今実際あの議会報告会やってる中"
    },
    {
      "start": 178.44,
      "duration": 5.719,
      "text": "ではすでにもう議会としてその市民の意見"
    },
    {
      "start": 181.44,
      "duration": 5.879,
      "text": "を聞くっていう形になってきてると思うん"
    },
    {
      "start": 184.159,
      "duration": 6.321,
      "text": "ですね今校長のあり方についても議論"
    },
    {
      "start": 187.319,
      "duration": 6.161,
      "text": "するって形になってるわけだから議会とし"
    },
    {
      "start": 190.48,
      "duration": 5.64,
      "text": "て市民の意見を聞くっていうのが今"
    },
    {
      "start": 193.48,
      "duration": 5.72,
      "text": "当たり前のようにやられてきてるのでそう"
    },
    {
      "start": 196.12,
      "duration": 4.36,
      "text": "いうことの整合性から考えるとやっぱり"
    },
    {
      "start": 199.2,
      "duration": 5.16,
      "text": "その"
    },
    {
      "start": 200.48,
      "duration": 5.96,
      "text": "あの議員もしくは議会はとか議会として"
    },
    {
      "start": 204.36,
      "duration": 5.84,
      "text": "やっぱり意見を聞くってことを規定して"
    },
    {
      "start": 206.44,
      "duration": 6.2,
      "text": "おかないと今後の校長活動についてもも"
    },
    {
      "start": 210.2,
      "duration": 4.92,
      "text": "議員がやるってことになってくればその"
    },
    {
      "start": 212.64,
      "duration": 5.4,
      "text": "議会が必要なのかって話にもなりかねない"
    },
    {
      "start": 215.12,
      "duration": 5.64,
      "text": "のでここやっぱりね議会を入れるっていう"
    },
    {
      "start": 218.04,
      "duration": 6.279,
      "text": "風に整理した方がいいっていうことが1つ"
    },
    {
      "start": 220.76,
      "duration": 6.36,
      "text": "あるのともう1つはあのえっと各常任委員"
    },
    {
      "start": 224.319,
      "duration": 6.401,
      "text": "会で例えばあの市民との意見交換会を行"
    },
    {
      "start": 227.12,
      "duration": 5.759,
      "text": "うっていうことについては全くできない"
    },
    {
      "start": 230.72,
      "duration": 5.599,
      "text": "ことではないんだっていう風に事務局は"
    },
    {
      "start": 232.879,
      "duration": 6.521,
      "text": "説明するんですけどでもね正式に意見交換"
    },
    {
      "start": 236.319,
      "duration": 7.441,
      "text": "会やったっていうことはあの基本的にない"
    },
    {
      "start": 239.4,
      "duration": 7.6,
      "text": "と思んですねで議会議運であの市民との"
    },
    {
      "start": 243.76,
      "duration": 6.399,
      "text": "要するに憲交換会みたいなものを議員定数"
    },
    {
      "start": 247.0,
      "duration": 6.4,
      "text": "のあの関係であの開いたことはあってこれ"
    },
    {
      "start": 250.159,
      "duration": 7.2,
      "text": "はあの議会改革のテーマがあって広く言え"
    },
    {
      "start": 253.4,
      "duration": 6.6,
      "text": "ばあの議会運営委員会があの独自にその"
    },
    {
      "start": 257.359,
      "duration": 5.081,
      "text": "市民との意見交換会を開催したっていう"
    },
    {
      "start": 260.0,
      "duration": 5.72,
      "text": "ケースはまあったのかなとは思うんです"
    },
    {
      "start": 262.44,
      "duration": 7.68,
      "text": "けどであとはだから委員会として今やっ"
    },
    {
      "start": 265.72,
      "duration": 8.24,
      "text": "てるのはあの要するに市民有志からあ議会"
    },
    {
      "start": 270.12,
      "duration": 7.12,
      "text": "に申し出があってあの要するに議会も任位"
    },
    {
      "start": 273.96,
      "duration": 6.12,
      "text": "でいくっていう形で非公式な活動として"
    },
    {
      "start": 277.24,
      "duration": 6.04,
      "text": "あの市民の意見を聞くっていう形になっ"
    },
    {
      "start": 280.08,
      "duration": 5.8,
      "text": "てると思うんですねでまそれはねやっぱり"
    },
    {
      "start": 283.28,
      "duration": 5.72,
      "text": "その議会がやっぱり意見を聞くんだって"
    },
    {
      "start": 285.88,
      "duration": 4.84,
      "text": "ことをやっぱり条文上もはっきりさせて"
    },
    {
      "start": 289.0,
      "duration": 4.96,
      "text": "はっきりさせたからそれが進むかどう"
    },
    {
      "start": 290.72,
      "duration": 7.64,
      "text": "かっていう問題は別にしてもやっぱり常任"
    },
    {
      "start": 293.96,
      "duration": 7.239,
      "text": "委員会がやっぱりあの市民とのあの混乱を"
    },
    {
      "start": 298.36,
      "duration": 6.16,
      "text": "非公式な場ではななく公式なものとして"
    },
    {
      "start": 301.199,
      "duration": 5.321,
      "text": "やっていけばもっと議会代りなんかであの"
    },
    {
      "start": 304.52,
      "duration": 4.8,
      "text": "各委員会こういう活動してますっていう"
    },
    {
      "start": 306.52,
      "duration": 6.16,
      "text": "こともアピールできると思うのでまそう"
    },
    {
      "start": 309.32,
      "duration": 6.68,
      "text": "いう意味も含めてあの議員が聞くんでは"
    },
    {
      "start": 312.68,
      "duration": 6.16,
      "text": "なくあ議員が聞くだけではなく議会として"
    },
    {
      "start": 316.0,
      "duration": 5.479,
      "text": "もあの聞いた聞くっていう風にすべきでは"
    },
    {
      "start": 318.84,
      "duration": 6.12,
      "text": "ないかなっていう提案なんですね議会基本"
    },
    {
      "start": 321.479,
      "duration": 6.601,
      "text": "条例策定時からその後その議会の実践通じ"
    },
    {
      "start": 324.96,
      "duration": 5.2,
      "text": "て議会が意見を聞くっていうことが当然の"
    },
    {
      "start": 328.08,
      "duration": 5.48,
      "text": "ようになってきてるのでそういう意味も"
    },
    {
      "start": 330.16,
      "duration": 6.4,
      "text": "含めてあの改定が必要ではないかという"
    },
    {
      "start": 333.56,
      "duration": 5.84,
      "text": "提案です以上ですはいありがとうござい"
    },
    {
      "start": 336.56,
      "duration": 6.359,
      "text": "ますそれではこのご提案に対して持ち帰る"
    },
    {
      "start": 339.4,
      "duration": 6.28,
      "text": "にあたってああの次の協議に向けて現段階"
    },
    {
      "start": 342.919,
      "duration": 5.72,
      "text": "確認しておきたいことご質疑とございまし"
    },
    {
      "start": 345.68,
      "duration": 2.959,
      "text": "たらお願いいたし"
    },
    {
      "start": 352.6,
      "duration": 5.8,
      "text": "ますはいはい清委あの質問というどなたに"
    },
    {
      "start": 356.84,
      "duration": 5.199,
      "text": "質問していのかちょっと分からないんです"
    },
    {
      "start": 358.4,
      "duration": 7.76,
      "text": "けどもあの私もこの時求められたものに"
    },
    {
      "start": 362.039,
      "duration": 8.041,
      "text": "書いたわけがあるわけですけれどもあの"
    },
    {
      "start": 366.16,
      "duration": 5.8,
      "text": "議会基本条例策定時にその多分いろんなご"
    },
    {
      "start": 370.08,
      "duration": 4.08,
      "text": "意見があったと思うんです疑似録ちゃんと"
    },
    {
      "start": 371.96,
      "duration": 6.0,
      "text": "読んでなくて申し訳ないんですけどもその"
    },
    {
      "start": 374.16,
      "duration": 6.0,
      "text": "時にもえっと議会の声をとかっていう声も"
    },
    {
      "start": 377.96,
      "duration": 4.359,
      "text": "あったとは思うんですけどもま落ち着いた"
    },
    {
      "start": 380.16,
      "duration": 5.08,
      "text": "ところが議員だったのかもしれないんです"
    },
    {
      "start": 382.319,
      "duration": 5.761,
      "text": "けどもそのどうして議員になったのかって"
    },
    {
      "start": 385.24,
      "duration": 5.28,
      "text": "いう経緯がもし分かればお伺いしたいなと"
    },
    {
      "start": 388.08,
      "duration": 3.6,
      "text": "思っておるので今今日じゃなくてもいいの"
    },
    {
      "start": 390.52,
      "duration": 5.239,
      "text": "で"
    },
    {
      "start": 391.68,
      "duration": 7.04,
      "text": "えっとそこお願いしたいなと思いますはい"
    },
    {
      "start": 395.759,
      "duration": 6.081,
      "text": "水えと今ちょっと定かじゃないんですけど"
    },
    {
      "start": 398.72,
      "duration": 5.84,
      "text": "ちょっと会議録とか当時のその協議記録"
    },
    {
      "start": 401.84,
      "duration": 3.639,
      "text": "みたいなものをちょっと調べてみたいと"
    },
    {
      "start": 404.56,
      "duration": 3.199,
      "text": "思い"
    },
    {
      "start": 405.479,
      "duration": 7.201,
      "text": "ますはい"
    },
    {
      "start": 407.759,
      "duration": 4.921,
      "text": "はいはいその他にございます"
    },
    {
      "start": 416.24,
      "duration": 7.44,
      "text": "かま具体的な協議は次回からという"
    },
    {
      "start": 420.0,
      "duration": 6.68,
      "text": "ですがそれにあたってま今のご説明なのも"
    },
    {
      "start": 423.68,
      "duration": 5.959,
      "text": "含めてご確認しておきたいことなどあり"
    },
    {
      "start": 426.68,
      "duration": 6.519,
      "text": "ましたらお願いし"
    },
    {
      "start": 429.639,
      "duration": 3.56,
      "text": "ます大丈夫です"
    },
    {
      "start": 438.24,
      "duration": 10.079,
      "text": "か特になければナンバー8についてはこれ"
    },
    {
      "start": 444.639,
      "duration": 6.68,
      "text": "で大丈夫ですか他の皆様"
    },
    {
      "start": 448.319,
      "duration": 3.0,
      "text": "は"
    },
    {
      "start": 455.16,
      "duration": 6.479,
      "text": "はい大丈夫ですかいあいやいやナンバー8"
    },
    {
      "start": 459.16,
      "duration": 6.319,
      "text": "今のご提案について現時点で確認しておき"
    },
    {
      "start": 461.639,
      "duration": 5.721,
      "text": "たいことがとかあの質問があればご説明と"
    },
    {
      "start": 465.479,
      "duration": 6.84,
      "text": "か"
    },
    {
      "start": 467.36,
      "duration": 7.799,
      "text": "にはい水谷はいえっと私も意見交換の場を"
    },
    {
      "start": 472.319,
      "duration": 5.081,
      "text": "増やしていくこと自体はあの賛成する立場"
    },
    {
      "start": 475.159,
      "duration": 5.121,
      "text": "なのですけれどえっと今のご提案されてる"
    },
    {
      "start": 477.4,
      "duration": 6.799,
      "text": "会派のお考えとしてはこの議会はっていう"
    },
    {
      "start": 480.28,
      "duration": 8.16,
      "text": "風にま明示してで同時にその委員会単位"
    },
    {
      "start": 484.199,
      "duration": 7.761,
      "text": "なり何かその議会のあの合議体というか"
    },
    {
      "start": 488.44,
      "duration": 6.319,
      "text": "会議体として意見交換の場をあの設けて"
    },
    {
      "start": 491.96,
      "duration": 6.239,
      "text": "いくべきだという意味のご提案と理解して"
    },
    {
      "start": 494.759,
      "duration": 6.961,
      "text": "よろしいですかはい水上えっと特にあの"
    },
    {
      "start": 498.199,
      "duration": 6.881,
      "text": "常任委員会で市民との意見交換会っていう"
    },
    {
      "start": 501.72,
      "duration": 6.52,
      "text": "のをやっぱり正式な形で行えるようにした"
    },
    {
      "start": 505.08,
      "duration": 7.24,
      "text": "方があのいいんじゃないかと"
    },
    {
      "start": 508.24,
      "duration": 7.44,
      "text": "あの公生文教委員会で例えばあの障害者"
    },
    {
      "start": 512.32,
      "duration": 6.88,
      "text": "条例策定する際に意見交換会開いたりとか"
    },
    {
      "start": 515.68,
      "duration": 6.799,
      "text": "してきたのもこれも結局非公式の2位の"
    },
    {
      "start": 519.2,
      "duration": 6.36,
      "text": "会議だったですしで陳情者とのなんか困難"
    },
    {
      "start": 522.479,
      "duration": 7.121,
      "text": "みたいなことも過去あってそれも全部ね"
    },
    {
      "start": 525.56,
      "duration": 6.92,
      "text": "あのえっとま融資で参加みたいな形であの"
    },
    {
      "start": 529.6,
      "duration": 5.08,
      "text": "正式ななんていうか委員会としての意見"
    },
    {
      "start": 532.48,
      "duration": 5.32,
      "text": "交換ではなかったのでそういうものを正式"
    },
    {
      "start": 534.68,
      "duration": 5.12,
      "text": "にできるようにま非公式でやりやる分には"
    },
    {
      "start": 537.8,
      "duration": 3.96,
      "text": "ほら非公式でやった方がいいものもあると"
    },
    {
      "start": 539.8,
      "duration": 5.96,
      "text": "思うのでそれはそれでいいと思うんです"
    },
    {
      "start": 541.76,
      "duration": 6.96,
      "text": "けどあの公式にやっぱり基本は常任会など"
    },
    {
      "start": 545.76,
      "duration": 6.48,
      "text": "で特別委に含めてもいいのかもしれない"
    },
    {
      "start": 548.72,
      "duration": 6.92,
      "text": "ですけど意見交換するていうものをあの"
    },
    {
      "start": 552.24,
      "duration": 5.48,
      "text": "できるようにしてった方があの議会活動も"
    },
    {
      "start": 555.64,
      "duration": 4.84,
      "text": "こういうことやってますっていう風に非"
    },
    {
      "start": 557.72,
      "duration": 5.0,
      "text": "公式の会議はなかなか言えないですけど"
    },
    {
      "start": 560.48,
      "duration": 4.56,
      "text": "あのそういう見交換会についてはどんどん"
    },
    {
      "start": 562.72,
      "duration": 4.84,
      "text": "発信してった方がもいいと思いますのでま"
    },
    {
      "start": 565.04,
      "duration": 6.6,
      "text": "そういうこととして想定して"
    },
    {
      "start": 567.56,
      "duration": 9.32,
      "text": "ますはい他にございます"
    },
    {
      "start": 571.64,
      "duration": 7.879,
      "text": "かはい清水委あの公あ公式にもしやる場合"
    },
    {
      "start": 576.88,
      "duration": 4.959,
      "text": "ってそういう予算措置みたいなのっていう"
    },
    {
      "start": 579.519,
      "duration": 5.041,
      "text": "のもきっと必要になってくるのかどうかも"
    },
    {
      "start": 581.839,
      "duration": 4.841,
      "text": "ちょっと分からないんですけれどもうんと"
    },
    {
      "start": 584.56,
      "duration": 5.279,
      "text": "大きなところってその辺りかなと思って"
    },
    {
      "start": 586.68,
      "duration": 6.44,
      "text": "公式と非公式の辺りっていうのがそこの"
    },
    {
      "start": 589.839,
      "duration": 7.161,
      "text": "辺りもなんか今んところお考えがあればお"
    },
    {
      "start": 593.12,
      "duration": 7.399,
      "text": "伺いしたいんですけどはい委員例えばこの"
    },
    {
      "start": 597.0,
      "duration": 7.64,
      "text": "第1回でやるってこともできると思います"
    },
    {
      "start": 600.519,
      "duration": 7.361,
      "text": "し内容によって費用がかけられかからない"
    },
    {
      "start": 604.64,
      "duration": 7.84,
      "text": "形であと議会委員会がやったあの市民との"
    },
    {
      "start": 607.88,
      "duration": 8.519,
      "text": "意見交換会はあれは萌木ホールだった"
    },
    {
      "start": 612.48,
      "duration": 6.12,
      "text": "から萌木ですよねそれがまあのそういう"
    },
    {
      "start": 616.399,
      "duration": 5.321,
      "text": "ものとしてやった時には一定費用がかかり"
    },
    {
      "start": 618.6,
      "duration": 6.52,
      "text": "ますけどそれはあの事務局と相談しながら"
    },
    {
      "start": 621.72,
      "duration": 3.4,
      "text": "開催したと思いますの"
    },
    {
      "start": 628.04,
      "duration": 6.28,
      "text": "で"
    },
    {
      "start": 630.2,
      "duration": 8.04,
      "text": "はい長えっと萌木はですその時の萌木お"
    },
    {
      "start": 634.32,
      "duration": 3.92,
      "text": "借りしましたけども特にはですね"
    },
    {
      "start": 639.16,
      "duration": 7.6,
      "text": "え行政の方の利用ということであの特に"
    },
    {
      "start": 642.44,
      "duration": 8.6,
      "text": "あのえ利用量は変わってないおりませ"
    },
    {
      "start": 646.76,
      "duration": 4.28,
      "text": "んはい他にございます"
    },
    {
      "start": 652.88,
      "duration": 6.399,
      "text": "か大丈夫です"
    },
    {
      "start": 655.6,
      "duration": 6.2,
      "text": "かはいでは内容であればあナンバー8のご"
    },
    {
      "start": 659.279,
      "duration": 4.521,
      "text": "提案については以上でえ取りさせて"
    },
    {
      "start": 661.8,
      "duration": 5.88,
      "text": "いただいて次回協議させていただければと"
    },
    {
      "start": 663.8,
      "duration": 7.0,
      "text": "思いますではナンバー9第3章市民と議会"
    },
    {
      "start": 667.68,
      "duration": 5.64,
      "text": "の関係第10条校長会制度及び参考人制度"
    },
    {
      "start": 670.8,
      "duration": 4.839,
      "text": "を活用する議会についてえご提案会派の"
    },
    {
      "start": 673.32,
      "duration": 7.12,
      "text": "日本共産党さんからお願いいたしますはい"
    },
    {
      "start": 675.639,
      "duration": 9.0,
      "text": "水上委員えっと第10条はえっと議会は"
    },
    {
      "start": 680.44,
      "duration": 7.36,
      "text": "校長改制度及び参考人制度を積極的に活用"
    },
    {
      "start": 684.639,
      "duration": 6.401,
      "text": "するよう務めるものとするとまいうことに"
    },
    {
      "start": 687.8,
      "duration": 8.279,
      "text": "規定されているんでですがあのまいわゆる"
    },
    {
      "start": 691.04,
      "duration": 8.2,
      "text": "肺炎条例をあの審議する過程であの参考人"
    },
    {
      "start": 696.079,
      "duration": 6.921,
      "text": "承知を公文教委員会で決めていたにも"
    },
    {
      "start": 699.24,
      "duration": 7.24,
      "text": "関わらずあの先決処分が行われたという"
    },
    {
      "start": 703.0,
      "duration": 6.839,
      "text": "ことでその経過をこかに検証せよっていう"
    },
    {
      "start": 706.48,
      "duration": 7.12,
      "text": "ことを僕らはあの求めてるものではなく"
    },
    {
      "start": 709.839,
      "duration": 6.521,
      "text": "議会基本条例で積極的に議会は活用し"
    },
    {
      "start": 713.6,
      "duration": 5.359,
      "text": "ようっていうことを決めてるものを尊重さ"
    },
    {
      "start": 716.36,
      "duration": 5.76,
      "text": "れなかったっていう事態については"
    },
    {
      "start": 718.959,
      "duration": 6.641,
      "text": "やっぱり議会としての何らかのやっぱり"
    },
    {
      "start": 722.12,
      "duration": 6.32,
      "text": "あの表明があの議会基本条例をやっぱり"
    },
    {
      "start": 725.6,
      "duration": 5.479,
      "text": "その無視するようなことやっぱりま僕らの"
    },
    {
      "start": 728.44,
      "duration": 4.839,
      "text": "意見としてはおかしいっていうことを何ら"
    },
    {
      "start": 731.079,
      "duration": 5.12,
      "text": "か表明すべきではないかっていうことなの"
    },
    {
      "start": 733.279,
      "duration": 6.321,
      "text": "で条文とか地上解説をどう変え"
    },
    {
      "start": 736.199,
      "duration": 7.2,
      "text": "るっていうの提案ではなくこの要するに"
    },
    {
      "start": 739.6,
      "duration": 7.76,
      "text": "議会基本条例検証の報告書みたいなところ"
    },
    {
      "start": 743.399,
      "duration": 8.0,
      "text": "の中でどこかにそのあのこういう事態に"
    },
    {
      "start": 747.36,
      "duration": 7.039,
      "text": "ついてやっぱりの議会としてはあのなんか"
    },
    {
      "start": 751.399,
      "duration": 5.481,
      "text": "まあの遺憾だったっていう風に言えれば"
    },
    {
      "start": 754.399,
      "duration": 5.281,
      "text": "いいとは思うんですけどそういうその態度"
    },
    {
      "start": 756.88,
      "duration": 5.079,
      "text": "表明をした方がいいんではないかとまいう"
    },
    {
      "start": 759.68,
      "duration": 6.0,
      "text": "ような提案ですのでそういうこととして"
    },
    {
      "start": 761.959,
      "duration": 7.521,
      "text": "ちょっと考えてもらいたいという風に思い"
    },
    {
      "start": 765.68,
      "duration": 7.2,
      "text": "ますはい今のご説明等に対して何かご意見"
    },
    {
      "start": 769.48,
      "duration": 7.44,
      "text": "ご質等ございますか確認しておきたいこと"
    },
    {
      "start": 772.88,
      "duration": 6.6,
      "text": "はい最委員えっとそれは決議か何かでは"
    },
    {
      "start": 776.92,
      "duration": 7.76,
      "text": "ダメなんですか"
    },
    {
      "start": 779.48,
      "duration": 7.2,
      "text": "あのま議会基本条例の検証の場ではあるん"
    },
    {
      "start": 784.68,
      "duration": 4.04,
      "text": "ですけれども"
    },
    {
      "start": 786.68,
      "duration": 7.48,
      "text": "えま"
    },
    {
      "start": 788.72,
      "duration": 9.919,
      "text": "その基本条例にますわないような事例が"
    },
    {
      "start": 794.16,
      "duration": 6.919,
      "text": "あったとすればえ議会意思を示すためにや"
    },
    {
      "start": 798.639,
      "duration": 3.56,
      "text": "決議ということになるんじゃないかなと"
    },
    {
      "start": 801.079,
      "duration": 5.401,
      "text": "思うんです"
    },
    {
      "start": 802.199,
      "duration": 7.601,
      "text": "がという意見ですはい"
    },
    {
      "start": 806.48,
      "duration": 7.2,
      "text": "はいあのまていうあげると思うんですけど"
    },
    {
      "start": 809.8,
      "duration": 6.12,
      "text": "ちょっとあの時期がちょっと今あの随分日"
    },
    {
      "start": 813.68,
      "duration": 6.04,
      "text": "日程が経ってるのでちょっと決議っていう"
    },
    {
      "start": 815.92,
      "duration": 6.64,
      "text": "ななことは現時点馴染まないかなとは思う"
    },
    {
      "start": 819.72,
      "duration": 6.52,
      "text": "んですがただ議会基本条例でこういう風に"
    },
    {
      "start": 822.56,
      "duration": 6.92,
      "text": "定められてることについて当然そのあの"
    },
    {
      "start": 826.24,
      "duration": 5.839,
      "text": "市長の行動を縛るものではないんですけど"
    },
    {
      "start": 829.48,
      "duration": 5.32,
      "text": "ただやっぱり議会としてやっぱり積極的に"
    },
    {
      "start": 832.079,
      "duration": 5.44,
      "text": "活用しようていうことで活用しようとした"
    },
    {
      "start": 834.8,
      "duration": 5.56,
      "text": "わけだからそれはやっぱり尊重すべきだっ"
    },
    {
      "start": 837.519,
      "duration": 6.32,
      "text": "たんではないかなとして議会の意見として"
    },
    {
      "start": 840.36,
      "duration": 6.68,
      "text": "やっぱり表明した方があのよろしいんじゃ"
    },
    {
      "start": 843.839,
      "duration": 6.36,
      "text": "ないかとまその中身についてはそれぞれね"
    },
    {
      "start": 847.04,
      "duration": 6.56,
      "text": "考えがあるとは思うんですけどあの基本"
    },
    {
      "start": 850.199,
      "duration": 6.44,
      "text": "議会基本条例で定められたあの活用しよう"
    },
    {
      "start": 853.6,
      "duration": 5.2,
      "text": "ていうことについてあのこういうことを"
    },
    {
      "start": 856.639,
      "duration": 3.841,
      "text": "まあなんて言ったらいいのか無視するって"
    },
    {
      "start": 858.8,
      "duration": 5.399,
      "text": "いう風に言っていいのかどうか分かりませ"
    },
    {
      "start": 860.48,
      "duration": 5.96,
      "text": "んけどまそういうことについては議会とし"
    },
    {
      "start": 864.199,
      "duration": 5.721,
      "text": "ての意見をやっぱり何らか表明した方が"
    },
    {
      "start": 866.44,
      "duration": 8.16,
      "text": "いいんではないかなというような考えです"
    },
    {
      "start": 869.92,
      "duration": 7.919,
      "text": "はい清水委私もあの今日のご提案の説明を"
    },
    {
      "start": 874.6,
      "duration": 5.479,
      "text": "聞いて私が捉えていたこの提案とちょっと"
    },
    {
      "start": 877.839,
      "duration": 5.56,
      "text": "違っていたかというか"
    },
    {
      "start": 880.079,
      "duration": 5.041,
      "text": "あのま他の会話さん結構具体的なそのメタ"
    },
    {
      "start": 883.399,
      "duration": 4.8,
      "text": "バースとか書いてあったるところもあって"
    },
    {
      "start": 885.12,
      "duration": 6.68,
      "text": "その時に私記述はしたんですけどもその"
    },
    {
      "start": 888.199,
      "duration": 7.041,
      "text": "この提案内容を見る限り個別具体的な事案"
    },
    {
      "start": 891.8,
      "duration": 6.24,
      "text": "だとは思っていなかったのであのなかなか"
    },
    {
      "start": 895.24,
      "duration": 5.64,
      "text": "そのこの検証の場っていうのが個別具体的"
    },
    {
      "start": 898.04,
      "duration": 5.44,
      "text": "な案件を検証する場なのかどうかっていう"
    },
    {
      "start": 900.88,
      "duration": 4.84,
      "text": "のがなかなか適さないんじゃないかなって"
    },
    {
      "start": 903.48,
      "duration": 3.88,
      "text": "いうことだけは申し上げておきたいなと"
    },
    {
      "start": 905.72,
      "duration": 6.76,
      "text": "思いますちゃんと読んでなくてすいません"
    },
    {
      "start": 907.36,
      "duration": 5.12,
      "text": "でしたはいそこの方がございます"
    },
    {
      "start": 913.399,
      "duration": 10.36,
      "text": "かあのはいはい片山長はいえっとまあの"
    },
    {
      "start": 919.6,
      "duration": 8.52,
      "text": "個別さっき今さんが説明にあった通りその"
    },
    {
      "start": 923.759,
      "duration": 6.241,
      "text": "こと自体をねあの検証してこう何かこう"
    },
    {
      "start": 928.12,
      "duration": 4.68,
      "text": "すると話ではないということはおっしゃっ"
    },
    {
      "start": 930.0,
      "duration": 5.399,
      "text": "てたと思うんですねただそういったこうあ"
    },
    {
      "start": 932.8,
      "duration": 6.56,
      "text": "あの実証があったということは事実なわけ"
    },
    {
      "start": 935.399,
      "duration": 7.0,
      "text": "ででやっぱりこの議会基本条例をあの掲げ"
    },
    {
      "start": 939.36,
      "duration": 5.56,
      "text": "て議会運営していこうという中でま参考人"
    },
    {
      "start": 942.399,
      "duration": 4.281,
      "text": "承知などを大事にしてやってこうとまそれ"
    },
    {
      "start": 944.92,
      "duration": 4.039,
      "text": "色々取り組みていこううっていうような"
    },
    {
      "start": 946.68,
      "duration": 4.839,
      "text": "そういった思いがあってこの項目をつけた"
    },
    {
      "start": 948.959,
      "duration": 5.161,
      "text": "ということはあるのでやっぱりそういった"
    },
    {
      "start": 951.519,
      "duration": 4.961,
      "text": "ことをですね勝ちをしながらあの議会を"
    },
    {
      "start": 954.12,
      "duration": 4.8,
      "text": "運営していくということをやっていくべき"
    },
    {
      "start": 956.48,
      "duration": 4.919,
      "text": "じゃないかなと私は思ってますあのあの"
    },
    {
      "start": 958.92,
      "duration": 4.599,
      "text": "校長会とか参考人とかそういったものそう"
    },
    {
      "start": 961.399,
      "duration": 4.8,
      "text": "いった制度をしっかり使っていくという"
    },
    {
      "start": 963.519,
      "duration": 5.56,
      "text": "ことであの議論を進めていくということに"
    },
    {
      "start": 966.199,
      "duration": 5.241,
      "text": "ついてはやっぱりこうまただ阻害されて"
    },
    {
      "start": 969.079,
      "duration": 5.801,
      "text": "しまったっていうあの事実があったもの"
    },
    {
      "start": 971.44,
      "duration": 6.759,
      "text": "ですからまそういったあのことについては"
    },
    {
      "start": 974.88,
      "duration": 5.879,
      "text": "やっぱりこうま市長が誰であろうとね"
    },
    {
      "start": 978.199,
      "duration": 5.041,
      "text": "やっぱ尊重してもらうというようなことに"
    },
    {
      "start": 980.759,
      "duration": 4.121,
      "text": "ついてはあの議会の中で確認した方がいい"
    },
    {
      "start": 983.24,
      "duration": 6.719,
      "text": "んじゃないかなという風には私は思って"
    },
    {
      "start": 984.88,
      "duration": 7.36,
      "text": "ますはい清水委あとございましたあの私も"
    },
    {
      "start": 989.959,
      "duration": 4.921,
      "text": "そういう内容かなと校長会とかそういう"
    },
    {
      "start": 992.24,
      "duration": 5.2,
      "text": "ものなのかなと思っていたらあの今水上"
    },
    {
      "start": 994.88,
      "duration": 5.68,
      "text": "さんのご説明だとちょっと私も詳しくは"
    },
    {
      "start": 997.44,
      "duration": 5.6,
      "text": "ないんですが報告書等でその時の経緯を"
    },
    {
      "start": 1000.56,
      "duration": 5.079,
      "text": "意見議会として意見を出すべきだという"
    },
    {
      "start": 1003.04,
      "duration": 5.08,
      "text": "ようなことがあったのでちょっとそれは"
    },
    {
      "start": 1005.639,
      "duration": 4.76,
      "text": "個別具体的なものなのかなという風に思っ"
    },
    {
      "start": 1008.12,
      "duration": 7.199,
      "text": "たのとちょっと不勉強で申し訳ないんです"
    },
    {
      "start": 1010.399,
      "duration": 7.68,
      "text": "けどその議会基本条例として報告書で経緯"
    },
    {
      "start": 1015.319,
      "duration": 4.96,
      "text": "を意見するというようなことがあったん"
    },
    {
      "start": 1018.079,
      "duration": 4.481,
      "text": "ですけどけどもそれがどういったことなの"
    },
    {
      "start": 1020.279,
      "duration": 5.16,
      "text": "かもちょっとえっと合わせてごめんなさい"
    },
    {
      "start": 1022.56,
      "duration": 6.8,
      "text": "お教えていただけたらなと思って"
    },
    {
      "start": 1025.439,
      "duration": 6.76,
      "text": "ますはい水上報告書どういう風な形になる"
    },
    {
      "start": 1029.36,
      "duration": 6.76,
      "text": "かってのは僕もまだ分からないんですけど"
    },
    {
      "start": 1032.199,
      "duration": 6.801,
      "text": "もしあのそういう記述ができるんだったら"
    },
    {
      "start": 1036.12,
      "duration": 5.48,
      "text": "あの載せていく必要があるんじゃない"
    },
    {
      "start": 1039.0,
      "duration": 5.52,
      "text": "かっていうような提案なのであとまとめの"
    },
    {
      "start": 1041.6,
      "duration": 6.04,
      "text": "まとめ方はちょっと皆さんの意見であの"
    },
    {
      "start": 1044.52,
      "duration": 6.32,
      "text": "条文や地上のどう変えるかっていうこと"
    },
    {
      "start": 1047.64,
      "duration": 6.279,
      "text": "以外にやっぱり議会基本条例がどう生かさ"
    },
    {
      "start": 1050.84,
      "duration": 6.0,
      "text": "れたのかっていうことを全体として検証"
    },
    {
      "start": 1053.919,
      "duration": 7.401,
      "text": "するっていうことになってくると思うので"
    },
    {
      "start": 1056.84,
      "duration": 8.079,
      "text": "僕はある程度そういうそのあのこともあの"
    },
    {
      "start": 1061.32,
      "duration": 6.2,
      "text": "ま最後のまとめには反映していんではない"
    },
    {
      "start": 1064.919,
      "duration": 7.281,
      "text": "かなっていう風に考えておりましてまそう"
    },
    {
      "start": 1067.52,
      "duration": 6.88,
      "text": "いうことの提案にしておりますはいはい"
    },
    {
      "start": 1072.2,
      "duration": 4.599,
      "text": "清水委はいあのご説明ありがとうござい"
    },
    {
      "start": 1074.4,
      "duration": 5.12,
      "text": "ました今報告っていうのはその検証今回の"
    },
    {
      "start": 1076.799,
      "duration": 5.561,
      "text": "検証結果の報告のところでっていうこと"
    },
    {
      "start": 1079.52,
      "duration": 5.84,
      "text": "ですよねあ承知いたしまし"
    },
    {
      "start": 1082.36,
      "duration": 3.0,
      "text": "た"
    },
    {
      "start": 1086.28,
      "duration": 4.759,
      "text": "はい家ございます"
    },
    {
      "start": 1096.6,
      "duration": 6.559,
      "text": "かま報告ってのは先ほど大体ま3定ぐらい"
    },
    {
      "start": 1099.96,
      "duration": 6.56,
      "text": "に競技を得てその後まとめ報告書を作って"
    },
    {
      "start": 1103.159,
      "duration": 6.081,
      "text": "1月ぐらいにはま正式な報告書という形に"
    },
    {
      "start": 1106.52,
      "duration": 5.2,
      "text": "していくという中に"
    },
    {
      "start": 1109.24,
      "duration": 5.48,
      "text": "そういったことをま意見というか何かしら"
    },
    {
      "start": 1111.72,
      "duration": 6.56,
      "text": "の形で記載できないかというのがま案会派"
    },
    {
      "start": 1114.72,
      "duration": 7.319,
      "text": "のご意見であるということでござい"
    },
    {
      "start": 1118.28,
      "duration": 5.12,
      "text": "ます他に現時点で何かご質疑確認したい"
    },
    {
      "start": 1122.039,
      "duration": 3.76,
      "text": "ことございます"
    },
    {
      "start": 1123.4,
      "duration": 5.6,
      "text": "か大丈夫です"
    },
    {
      "start": 1125.799,
      "duration": 6.401,
      "text": "かそれではナンバー9の提案については"
    },
    {
      "start": 1129.0,
      "duration": 6.799,
      "text": "以上でよろしいですかはいそれでは以上で"
    },
    {
      "start": 1132.2,
      "duration": 8.839,
      "text": "終了とさせていただきますこれで本日の"
    },
    {
      "start": 1135.799,
      "duration": 9.281,
      "text": "日程は全て終了しましたえっと次回につい"
    },
    {
      "start": 1141.039,
      "duration": 6.64,
      "text": "てはですね先ほど持ち替えまあの事務局に"
    },
    {
      "start": 1145.08,
      "duration": 5.4,
      "text": "確認していただいた確認をこれからして"
    },
    {
      "start": 1147.679,
      "duration": 5.921,
      "text": "まいります合理的配慮のところと環境整備"
    },
    {
      "start": 1150.48,
      "duration": 6.52,
      "text": "のところについてを最初にありましてそれ"
    },
    {
      "start": 1153.6,
      "duration": 8.52,
      "text": "がま終わればちょっと一分保留になってる"
    },
    {
      "start": 1157.0,
      "duration": 8.12,
      "text": "ナンバー7のご提案ですねに戻って"
    },
    {
      "start": 1162.12,
      "duration": 4.64,
      "text": "えっとま今現状ね合理的配慮を進めてると"
    },
    {
      "start": 1165.12,
      "duration": 4.52,
      "text": "いうとこ変更点を記載してはどうかという"
    },
    {
      "start": 1166.76,
      "duration": 6.88,
      "text": "ことですね戻ってやらせていただきまして"
    },
    {
      "start": 1169.64,
      "duration": 6.24,
      "text": "それが次にえっと今日今確認をして"
    },
    {
      "start": 1173.64,
      "duration": 5.08,
      "text": "いただいたえ第11条とナンバー8"
    },
    {
      "start": 1175.88,
      "duration": 5.12,
      "text": "ナンバー9について行わさせていただいて"
    },
    {
      "start": 1178.72,
      "duration": 3.52,
      "text": "もし今日と同じようにあの早めに進んで"
    },
    {
      "start": 1181.0,
      "duration": 4.799,
      "text": "いくようであればその次のナンバー"
    },
    {
      "start": 1182.24,
      "duration": 7.319,
      "text": "1415の頭出しという形で考えており"
    },
    {
      "start": 1185.799,
      "duration": 5.201,
      "text": "ますので次回のご協にまでにご準備を"
    },
    {
      "start": 1189.559,
      "duration": 5.12,
      "text": "よろしくお願いいたし"
    },
    {
      "start": 1191.0,
      "duration": 6.84,
      "text": "ますたに何か全体ございますかなければ"
    },
    {
      "start": 1194.679,
      "duration": 5.641,
      "text": "これで終了いたしますはいそれでは以上で"
    },
    {
      "start": 1197.84,
      "duration": 4.68,
      "text": "ええ議会基本条例検証協議会を終了いたし"
    },
    {
      "start": 1200.32,
      "duration": 4.12,
      "text": "ますお疲れ様でございましたごしたそれで"
    },
    {
      "start": 1202.52,
      "duration": 4.8,
      "text": "は議会運営委員会の皆様ちょっと残って"
    },
    {
      "start": 1204.44,
      "duration": 2.88,
      "text": "日程協議させて"
    },
    {
      "start": 1227.159,
      "duration": 3.0,
      "text": "ください"
    }
  ]
}