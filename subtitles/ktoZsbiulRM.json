    },
    {
      "start": 832.24,
      "duration": 5.959,
      "text": "え、皆さんの活発な議論、え、そして、え"
    },
    {
      "start": 835.079,
      "duration": 6.041,
      "text": "、ま、中立な議会運営、え、目指して"
    },
    {
      "start": 838.199,
      "duration": 5.56,
      "text": "まいりますので、え、また皆様から様々な"
    },
    {
      "start": 841.12,
      "duration": 4.76,
      "text": "ご意見や、あの、ご教授いただきながら"
    },
    {
      "start": 843.759,
      "duration": 4.161,
      "text": "ですね、え、進めていきたいと思っており"
    },
    {
      "start": 845.88,
      "duration": 4.199,
      "text": "ますので、え、どうぞよろしくお願いし"
    },
    {
      "start": 847.92,
