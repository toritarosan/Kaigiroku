      "duration": 7.161,
      "text": "あり見直しが必要であると請求者が主張"
    },
    {
      "start": 742.279,
      "duration": 7.281,
      "text": "する点に対して現設計案は現状において何"
    },
    {
      "start": 746.44,
      "duration": 7.72,
      "text": "ら問題なくえ適正な設計案であることに"
    },
    {
      "start": 749.56,
      "duration": 8.399,
      "text": "ついて意見を述べる1建設工事費について"
    },
    {
      "start": 754.16,
      "duration": 7.72,
      "text": "かこ請求の用紙丸1について建設費につい"
    },
    {
      "start": 757.959,
      "duration": 7.44,
      "text": "ては過去に例のない資材価格の高等に直面"
    },
    {
      "start": 761.88,
      "duration": 6.92,
      "text": "したことを踏まえ現在はその概算を約"
    },
    {
      "start": 765.399,
      "duration": 6.641,
      "text": "11億円見込んでいるが平米単価により"
    },
    {
      "start": 768.8,
      "duration": 7.719,
      "text": "直近の都内における身長者建設事例と比較"
    },
    {
      "start": 772.04,
      "duration": 7.799,
      "text": "すると平均的な金額である2広場について"
    },
    {
      "start": 776.519,
      "duration": 7.12,
      "text": "かこ請求の用紙丸2について"
    },
    {
      "start": 779.839,
      "duration": 7.0,
      "text": "広場については平常時は市民が憩え"
    },
    {
      "start": 783.639,
      "duration": 5.76,
      "text": "イベント等にも利用できまた災害時には"
