    {
      "start": 672.24,
      "duration": 6.48,
      "text": "見直し案なるものを比較対象するとしても"
    },
    {
      "start": 675.36,
      "duration": 6.88,
      "text": "現設計案を見直し案通りに修正するとして"
    },
    {
      "start": 678.72,
      "duration": 6.48,
      "text": "えその工事遂行可能性は不透明であり現"
    },
    {
      "start": 682.24,
      "duration": 7.56,
      "text": "設計を大きく変更"
    },
    {
      "start": 685.2,
      "duration": 9.0,
      "text": "するまたは計画を大きく方向転換を得ない"
    },
    {
      "start": 689.8,
      "duration": 7.44,
      "text": "となればえこれまで支出した4億円と同額"
    },
    {
      "start": 694.2,
      "duration": 6.759,
      "text": "程度の追加支出の他えこれまでの経過を"
    },
    {
      "start": 697.24,
      "duration": 6.52,
      "text": "踏まえると実施設計完了までに相当程度の"
    },
    {
      "start": 700.959,
      "duration": 6.161,
      "text": "年数が必要となり着工の見通しが立たなく"
    },
    {
      "start": 703.76,
      "duration": 5.199,
      "text": "なる可能性があるまた公正なプロポーザル"
    },
    {
      "start": 707.12,
      "duration": 5.159,
