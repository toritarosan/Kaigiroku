{
  "entries": [
    {
      "start": 6.2,
      "duration": 3.0,
      "text": "よ"
    },
    {
      "start": 58.32,
      "duration": 5.799,
      "text": "それではあのですけどもあのですのでたい"
    },
    {
      "start": 62.48,
      "duration": 3.16,
      "text": "と思い"
    },
    {
      "start": 64.119,
      "duration": 5.881,
      "text": "ます"
    },
    {
      "start": 65.64,
      "duration": 4.36,
      "text": "ああえ"
    },
    {
      "start": 90.479,
      "duration": 6.0,
      "text": "憩中に議会運委員会を開催していますので"
    },
    {
      "start": 93.28,
      "duration": 5.4,
      "text": "議会運委員長の報告を求めます3番岸正"
    },
    {
      "start": 96.479,
      "duration": 2.201,
      "text": "委員"
    },
    {
      "start": 101.6,
      "duration": 6.839,
      "text": "長議会委員会の報告をいたします議会営"
    },
    {
      "start": 104.92,
      "duration": 7.28,
      "text": "委員会は令和6年第1回臨時会に開始え"
    },
    {
      "start": 108.439,
      "duration": 6.28,
      "text": "本日7月18日に開催し協議いたしました"
    },
    {
      "start": 112.2,
      "duration": 5.72,
      "text": "のでその結果についてご報告申し上げます"
    },
    {
      "start": 114.719,
      "duration": 7.521,
      "text": "本臨時会に議されます案件は市長提出案件"
    },
    {
      "start": 117.92,
      "duration": 9.4,
      "text": "として令和6年7月日けで市長から議案第"
    },
    {
      "start": 122.24,
      "duration": 8.519,
      "text": "38号小市の新長者及びえ仮称かこ仮称え"
    },
    {
      "start": 127.32,
      "duration": 5.88,
      "text": "新福祉会館の建設に関する住民投票条例"
    },
    {
      "start": 130.759,
      "duration": 6.521,
      "text": "以上1件が送付されております以上のこと"
    },
    {
      "start": 133.2,
      "duration": 6.56,
      "text": "から本臨時会の会期及び会議不案件の2先"
    },
    {
      "start": 137.28,
      "duration": 5.08,
      "text": "委員会などについて協議いたしましたその"
    },
    {
      "start": 139.76,
      "duration": 7.759,
      "text": "結果本理事会の会議につきまして"
    },
    {
      "start": 142.36,
      "duration": 8.56,
      "text": "は本臨時会の会期につきましては本日7月"
    },
    {
      "start": 147.519,
      "duration": 6.921,
      "text": "18日から7月31日まででの14日間と"
    },
    {
      "start": 150.92,
      "duration": 6.48,
      "text": "することと決定いたしましたまた会議祝に"
    },
    {
      "start": 154.44,
      "duration": 6.159,
      "text": "ついてはお手元にご配布いたしております"
    },
    {
      "start": 157.4,
      "duration": 6.72,
      "text": "会議被表の通り決定し案件の取り扱いに"
    },
    {
      "start": 160.599,
      "duration": 7.0,
      "text": "ついては説明質疑後委員会負託を省略し"
    },
    {
      "start": 164.12,
      "duration": 6.96,
      "text": "即決することと決定いたしましたまた請求"
    },
    {
      "start": 167.599,
      "duration": 8.121,
      "text": "代表者の意見陳述については7月31日"
    },
    {
      "start": 171.08,
      "duration": 8.72,
      "text": "午前10時から小金市議会議場においてえ"
    },
    {
      "start": 175.72,
      "duration": 6.84,
      "text": "請求代表者最大6人から1人15分以内で"
    },
    {
      "start": 179.8,
      "duration": 5.079,
      "text": "え意見陳述を行うことと決定いたしました"
    },
    {
      "start": 182.56,
      "duration": 4.84,
      "text": "以上で議会運営委員会の報告を終了いたし"
    },
    {
      "start": 184.879,
      "duration": 5.201,
      "text": "ます議会運営委員長の報告に対して質疑は"
    },
    {
      "start": 187.4,
      "duration": 5.52,
      "text": "ありませんか質疑を終了することにご異議"
    },
    {
      "start": 190.08,
      "duration": 7.36,
      "text": "ありませんかご異議なしと認め質疑を終了"
    },
    {
      "start": 192.92,
      "duration": 4.52,
      "text": "し議会運営委員長の報告を終了し"
    },
    {
      "start": 197.92,
      "duration": 6.679,
      "text": "ますお別れします議会運営委員長の報告"
    },
    {
      "start": 201.36,
      "duration": 6.48,
      "text": "通り決定することにご異議ありませんかご"
    },
    {
      "start": 204.599,
      "duration": 7.64,
      "text": "異議なしと認め理会運委員長の報告通り"
    },
    {
      "start": 207.84,
      "duration": 8.16,
      "text": "決定しました一定第1会議録署名議員の"
    },
    {
      "start": 212.239,
      "duration": 7.441,
      "text": "指名を行います会議録署名議員はえ会議"
    },
    {
      "start": 216.0,
      "duration": 8.879,
      "text": "規則第118条の規定により議長において"
    },
    {
      "start": 219.68,
      "duration": 9.68,
      "text": "15番田久議員16番水上浩議員を指名し"
    },
    {
      "start": 224.879,
      "duration": 9.521,
      "text": "ます日程第2会議の決定を議題としますお"
    },
    {
      "start": 229.36,
      "duration": 9.519,
      "text": "分れします今今臨時会の会議は本日7月"
    },
    {
      "start": 234.4,
      "duration": 7.6,
      "text": "18日から7月31日までの14日間と"
    },
    {
      "start": 238.879,
      "duration": 8.401,
      "text": "することにごありませんかご異議なしと"
    },
    {
      "start": 242.0,
      "duration": 9.76,
      "text": "認め会期は本日7月18日から7月31日"
    },
    {
      "start": 247.28,
      "duration": 9.4,
      "text": "までの14日間と決定しました日程第3"
    },
    {
      "start": 251.76,
      "duration": 8.599,
      "text": "議案第38号小金市の身長者及び仮称新"
    },
    {
      "start": 256.68,
      "duration": 9.799,
      "text": "福祉会館の建設に関する住民投票条例を"
    },
    {
      "start": 260.359,
      "duration": 6.12,
      "text": "議題とします提案理由の説明を求めます"
    },
    {
      "start": 266.68,
      "duration": 9.519,
      "text": "長おはようございますおはようございます"
    },
    {
      "start": 270.84,
      "duration": 8.88,
      "text": "議案第38号小金市の新長者及び各仮称新"
    },
    {
      "start": 276.199,
      "duration": 8.241,
      "text": "福祉会館の建設に関する住民投票条例をご"
    },
    {
      "start": 279.72,
      "duration": 9.16,
      "text": "提案申し上げます令和6年7月1日付けで"
    },
    {
      "start": 284.44,
      "duration": 8.319,
      "text": "条例制定請求代表者加藤典道さん他5人"
    },
    {
      "start": 288.88,
      "duration": 8.12,
      "text": "から地方自治法第74条第1項の規定に"
    },
    {
      "start": 292.759,
      "duration": 7.921,
      "text": "より小金市の新長者及び各仮称新福祉会館"
    },
    {
      "start": 297.0,
      "duration": 6.84,
      "text": "の建設に関する住民投票条例のの請求が"
    },
    {
      "start": 300.68,
      "duration": 6.56,
      "text": "あったので道場第3項の規定により意見を"
    },
    {
      "start": 303.84,
      "duration": 6.56,
      "text": "ふして議するものでありますえこれより"
    },
    {
      "start": 307.24,
      "duration": 7.88,
      "text": "その意見を述べさせていただき"
    },
    {
      "start": 310.4,
      "duration": 9.28,
      "text": "ます古賀の新長者及び各仮称新福祉会館の"
    },
    {
      "start": 315.12,
      "duration": 7.72,
      "text": "建設に関する住民投票条例に対する意見小"
    },
    {
      "start": 319.68,
      "duration": 8.959,
      "text": "の新長者及び各仮称新福祉会館の建設に"
    },
    {
      "start": 322.84,
      "duration": 11.199,
      "text": "関する住民投票条例案以下本条例案という"
    },
    {
      "start": 328.639,
      "duration": 9.801,
      "text": "には体である理由は以下の通りであります"
    },
    {
      "start": 334.039,
      "duration": 9.241,
      "text": "第1身長者等建設にかかる経緯及び今後に"
    },
    {
      "start": 338.44,
      "duration": 8.72,
      "text": "ついて1これまでの経緯について本市の"
    },
    {
      "start": 343.28,
      "duration": 7.88,
      "text": "身長者等建設事業については昭和61年"
    },
    {
      "start": 347.16,
      "duration": 8.64,
      "text": "にえ建設候補地の検討を開始し平成23年"
    },
    {
      "start": 351.16,
      "duration": 6.0,
      "text": "3月に新長者基本構想を策定し建設予定値"
    },
    {
      "start": 355.8,
      "duration": 6.28,
      "text": "を選定し"
    },
    {
      "start": 357.16,
      "duration": 8.319,
      "text": "た選定したええ平成25年3月には新長者"
    },
    {
      "start": 362.08,
      "duration": 6.92,
      "text": "建設基本計画を策定したが平成26年度に"
    },
    {
      "start": 365.479,
      "duration": 7.201,
      "text": "は事業事態を凍結することとなったえその"
    },
    {
      "start": 369.0,
      "duration": 7.96,
      "text": "後新長者を含む施設の複合化を検討する"
    },
    {
      "start": 372.68,
      "duration": 8.28,
      "text": "こととなり平成30年12月に新長者仮称"
    },
    {
      "start": 376.96,
      "duration": 7.56,
      "text": "新福祉会館複合化整備方針を策定したえ"
    },
    {
      "start": 380.96,
      "duration": 7.04,
      "text": "これを受けて平成31年3月から基本設計"
    },
    {
      "start": 384.52,
      "duration": 8.0,
      "text": "に着手し令和2年3月にこれを完了して"
    },
    {
      "start": 388.0,
      "duration": 7.68,
      "text": "同年6月から設計に着手し一旦は中断した"
    },
    {
      "start": 392.52,
      "duration": 4.72,
      "text": "ものの令和5年10月から実施設計を再開"
    },
    {
      "start": 395.68,
      "duration": 5.0,
      "text": "して現在に至って"
    },
    {
      "start": 397.24,
      "duration": 6.56,
      "text": "いるこれらの経緯は市ホームページや司法"
    },
    {
      "start": 400.68,
      "duration": 6.0,
      "text": "で公表し市議会へも報告してきている"
    },
    {
      "start": 403.8,
      "duration": 5.88,
      "text": "ところではあるが改めてこれらをまとめ"
    },
    {
      "start": 406.68,
      "duration": 4.519,
      "text": "資料1及び資料2として添付しているので"
    },
    {
      "start": 409.68,
      "duration": 6.16,
      "text": "参照され"
    },
    {
      "start": 411.199,
      "duration": 8.961,
      "text": "たい2実施設計の進捗状況及び今後につい"
    },
    {
      "start": 415.84,
      "duration": 9.359,
      "text": "て実施設計の主な作業工程には計内容の"
    },
    {
      "start": 420.16,
      "duration": 8.28,
      "text": "検討図面作成各種申請手続き積算がある"
    },
    {
      "start": 425.199,
      "duration": 6.761,
      "text": "現在の進捗状況としては設計内容の検討"
    },
    {
      "start": 428.44,
      "duration": 7.319,
      "text": "及び図面作成は完了しており各種申請"
    },
    {
      "start": 431.96,
      "duration": 9.84,
      "text": "手続きについては本年7月に建築確認申請"
    },
    {
      "start": 435.759,
      "duration": 9.481,
      "text": "書提出翌8月には建築確認済み省交付の"
    },
    {
      "start": 441.8,
      "duration": 6.92,
      "text": "見込みであるえまた積算については実施中"
    },
    {
      "start": 445.24,
      "duration": 6.6,
      "text": "である本年10月には実施設計は完了する"
    },
    {
      "start": 448.72,
      "duration": 7.8,
      "text": "予定であるところ現状は実施設計の最終"
    },
    {
      "start": 451.84,
      "duration": 8.52,
      "text": "段階にあるそして庁舎と複合施設建設事業"
    },
    {
      "start": 456.52,
      "duration": 6.88,
      "text": "の再開方針についてにおいてはえ今後想定"
    },
    {
      "start": 460.36,
      "duration": 7.799,
      "text": "スケジュールについて本年12月に工事"
    },
    {
      "start": 463.4,
      "duration": 9.519,
      "text": "予算可決その後施工者先行を行い令和7年"
    },
    {
      "start": 468.159,
      "duration": 9.0,
      "text": "7月着令和9年11月春行令和10年4月"
    },
    {
      "start": 472.919,
      "duration": 8.28,
      "text": "共用開としているこのように新長者等建設"
    },
    {
      "start": 477.159,
      "duration": 5.641,
      "text": "事業は約40年にわる年月をかけ最終局面"
    },
    {
      "start": 481.199,
      "duration": 6.96,
      "text": "を迎えて"
    },
    {
      "start": 482.8,
      "duration": 9.32,
      "text": "いる第2現行案と見直し案を比較対象とし"
    },
    {
      "start": 488.159,
      "duration": 7.32,
      "text": "た住民投票について現行案と見直し案を"
    },
    {
      "start": 492.12,
      "duration": 5.199,
      "text": "比較対象とした住民投票は適当ではない"
    },
    {
      "start": 495.479,
      "duration": 5.041,
      "text": "ことについて意見を"
    },
    {
      "start": 497.319,
      "duration": 7.84,
      "text": "述べる条例案第2条の定義から明らかな"
    },
    {
      "start": 500.52,
      "duration": 8.72,
      "text": "通り現行案とは現設計案であり設計その"
    },
    {
      "start": 505.159,
      "duration": 4.961,
      "text": "ものである他方見直し案とは請求代表者に"
    },
    {
      "start": 509.24,
      "duration": 3.76,
      "text": "おい"
    },
    {
      "start": 510.12,
      "duration": 5.479,
      "text": "現設計案のうちいくつかの項目を取り上げ"
    },
    {
      "start": 513.0,
      "duration": 4.64,
      "text": "これを見直すべき項目として提案するに"
    },
    {
      "start": 515.599,
      "duration": 7.12,
      "text": "すぎないものであり設計では"
    },
    {
      "start": 517.64,
      "duration": 7.639,
      "text": "ない第1及びえ資料1の通り現設計案は"
    },
    {
      "start": 522.719,
      "duration": 5.721,
      "text": "いくつもの段階を経て具体化されすでに"
    },
    {
      "start": 525.279,
      "duration": 6.961,
      "text": "実施設計の段階に入り本年10月にはこれ"
    },
    {
      "start": 528.44,
      "duration": 7.44,
      "text": "が完了するという最終段階にあるこの間"
    },
    {
      "start": 532.24,
      "duration": 6.44,
      "text": "基本設計については実績体制等の参加資格"
    },
    {
      "start": 535.88,
      "duration": 5.56,
      "text": "を備えた設計者を広く公募しプロポーザル"
    },
    {
      "start": 538.68,
      "duration": 6.92,
      "text": "によって構成に選定した設計者において"
    },
    {
      "start": 541.44,
      "duration": 7.28,
      "text": "設計されているかかる基本設計は当該設計"
    },
    {
      "start": 545.6,
      "duration": 6.12,
      "text": "者において中断前には実施設計の積算まで"
    },
    {
      "start": 548.72,
      "duration": 6.4,
      "text": "終えており施工者が実際に工事を進める"
    },
    {
      "start": 551.72,
      "duration": 8.119,
      "text": "ことができるよう細部詳細部分まで設計を"
    },
    {
      "start": 555.12,
      "duration": 8.56,
      "text": "行っているまた原設計案は各段階で市民"
    },
    {
      "start": 559.839,
      "duration": 6.961,
      "text": "参加の手法を持ち市民の意見を取り入れて"
    },
    {
      "start": 563.68,
      "duration": 6.2,
      "text": "おり特に設計段階においては市民"
    },
    {
      "start": 566.8,
      "duration": 5.52,
      "text": "ワークショップUDレビュー小金ティグ"
    },
    {
      "start": 569.88,
      "duration": 5.0,
      "text": "市民説明会設計レビューパブリック"
    },
    {
      "start": 572.32,
      "duration": 5.84,
      "text": "コメント等の多くの市民参加の機会を設け"
    },
    {
      "start": 574.88,
      "duration": 8.199,
      "text": "可能な限りの意見の市民の意見を反映して"
    },
    {
      "start": 578.16,
      "duration": 7.799,
      "text": "いるえ加えて現設計案は各段階で市議会で"
    },
    {
      "start": 583.079,
      "duration": 5.641,
      "text": "の意見及び決議を踏まえて検討を進めてき"
    },
    {
      "start": 585.959,
      "duration": 6.801,
      "text": "ており特に市議会で可決された決議につい"
    },
    {
      "start": 588.72,
      "duration": 8.08,
      "text": "てはその都度対応検討判断決定し進めてき"
    },
    {
      "start": 592.76,
      "duration": 8.16,
      "text": "ている結果として政争関連施設の暫定移設"
    },
    {
      "start": 596.8,
      "duration": 7.56,
      "text": "を行わない施設配置発注方式の見直し広場"
    },
    {
      "start": 600.92,
      "duration": 6.599,
      "text": "面積の拡大親水対策にかかる外交レベル等"
    },
    {
      "start": 604.36,
      "duration": 7.32,
      "text": "の見直し現設計の検証実施などの対応を"
    },
    {
      "start": 607.519,
      "duration": 7.44,
      "text": "行い現設計案に至っている当然にこれに"
    },
    {
      "start": 611.68,
      "duration": 7.159,
      "text": "関連する予算は都度意思決定期間たる市議"
    },
    {
      "start": 614.959,
      "duration": 6.081,
      "text": "会の議決を得ている令和5年6月には中断"
    },
    {
      "start": 618.839,
      "duration": 6.641,
      "text": "していた実施設計を再開するための予算案"
    },
    {
      "start": 621.04,
      "duration": 7.96,
      "text": "を令和5年第2回定例会に提出したが議員"
    },
    {
      "start": 625.48,
      "duration": 6.4,
      "text": "提案によって再開にあたり現設計案の検証"
    },
    {
      "start": 629.0,
      "duration": 6.48,
      "text": "を実施する予算を含めた予算案に修正可決"
    },
    {
      "start": 631.88,
      "duration": 6.72,
      "text": "されたえこれを受けて同年7月から8月に"
    },
    {
      "start": 635.48,
      "duration": 6.2,
      "text": "検証を実施しその結果を踏まえ同年10月"
    },
    {
