{
  "entries": [
    {
      "start": 8.92,
      "duration": 8.12,
      "text": "えおはようございますお揃いですので"
    },
    {
      "start": 12.12,
      "duration": 4.92,
      "text": "検察すませまだ揃ってない"
    },
    {
      "start": 28.96,
      "duration": 3.0,
      "text": "です"
    },
    {
      "start": 39.44,
      "duration": 5.92,
      "text": "えおはようございますえ建設環境委員会"
    },
    {
      "start": 42.48,
      "duration": 6.28,
      "text": "協議会開催したいと思いますえ本日の委員"
    },
    {
      "start": 45.36,
      "duration": 6.32,
      "text": "会進行予定でございますがえ本日の委員会"
    },
    {
      "start": 48.76,
      "duration": 6.439,
      "text": "審査予定表の順序で審査を行うことについ"
    },
    {
      "start": 51.68,
      "duration": 7.96,
      "text": "てということでえ審査案件所管事務調査え"
    },
    {
      "start": 55.199,
      "duration": 8.441,
      "text": "一件でございますえ行政察についてえ日時"
    },
    {
      "start": 59.64,
      "duration": 8.32,
      "text": "はえ令和6年4月24日え水曜日となり"
    },
    {
      "start": 63.64,
      "duration": 7.64,
      "text": "ましたえ察項目及び察地はえ地域公共交通"
    },
    {
      "start": 67.96,
      "duration": 7.88,
      "text": "計画についてということで東京とたさんに"
    },
    {
      "start": 71.28,
      "duration": 7.08,
      "text": "え決定をいたしましたえその他何かござい"
    },
    {
      "start": 75.84,
      "duration": 2.52,
      "text": "ますでしょう"
    },
    {
      "start": 78.92,
      "duration": 5.0,
      "text": "かということであればはいあの委員会で"
    },
    {
      "start": 81.52,
      "duration": 5.4,
      "text": "この確認を今日は取るだけなのではい必殺"
    },
    {
      "start": 83.92,
      "duration": 5.0,
      "text": "のですねはいはいじゃあ行き"
    },
    {
      "start": 86.92,
      "duration": 3.96,
      "text": "ましょ"
    },
    {
      "start": 88.92,
      "duration": 4.6,
      "text": "はい"
    },
    {
      "start": 90.88,
      "duration": 2.64,
      "text": "おはようござい"
    },
    {
      "start": 96.0,
      "duration": 6.399,
      "text": "ますただ今から検察環境委員会の会議を"
    },
    {
      "start": 99.759,
      "duration": 7.201,
      "text": "開きます当委員会に付託されております"
    },
    {
      "start": 102.399,
      "duration": 7.801,
      "text": "案件は所管事務調査1件です以上1件に"
    },
    {
      "start": 106.96,
      "duration": 7.6,
      "text": "つきまして建設環境委員会審査予定表の"
    },
    {
      "start": 110.2,
      "duration": 8.04,
      "text": "通り行うことといたしますたちに行政察に"
    },
    {
      "start": 114.56,
      "duration": 9.12,
      "text": "かかる所管事務調査の継続審査議決を行い"
    },
    {
      "start": 118.24,
      "duration": 9.36,
      "text": "ます設委員会の行政察は地域公共交通計画"
    },
    {
      "start": 123.68,
      "duration": 7.76,
      "text": "についてを察項目として実施することとし"
    },
    {
      "start": 127.6,
      "duration": 8.68,
      "text": "地域公共交通計画についてを当委員会の"
    },
    {
      "start": 131.44,
      "duration": 8.28,
      "text": "所管事務調査事件とし閉会中の継続調査と"
    },
    {
      "start": 136.28,
      "duration": 6.2,
      "text": "することにご異議ありませんかご異議なし"
    },
    {
      "start": 139.72,
      "duration": 6.599,
      "text": "と認めます従ってただ今申し上げました"
    },
    {
      "start": 142.48,
      "duration": 9.119,
      "text": "通り決定いたしましたなお閉会中の委員"
    },
    {
      "start": 146.319,
      "duration": 10.041,
      "text": "派遣は長に対し委員派遣要求を行うことと"
    },
    {
      "start": 151.599,
      "duration": 8.64,
      "text": "し派遣委員日地場所目的及び経費等の"
    },
    {
      "start": 156.36,
      "duration": 7.2,
      "text": "手続きについては委員長にご一任願いたい"
    },
    {
      "start": 160.239,
      "duration": 6.0,
      "text": "と思いますこれにご異議ありませんかご"
    },
    {
      "start": 163.56,
      "duration": 6.959,
      "text": "異議なしと認めますしってただいま"
    },
    {
      "start": 166.239,
      "duration": 7.841,
      "text": "申し上げた通り決定いたしました以上で"
    },
    {
      "start": 170.519,
      "duration": 7.0,
      "text": "本日の日程は全部終了いたしました本日は"
    },
    {
      "start": 174.08,
      "duration": 4.76,
      "text": "以上で建設環境委員会を閉会いたしますご"
    },
    {
      "start": 177.519,
      "duration": 4.321,
      "text": "苦労様でし"
    },
    {
      "start": 178.84,
      "duration": 3.0,
      "text": "た"
    },
    {
      "start": 185.72,
      "duration": 3.0,
      "text": "JA"
    }
  ]
}