{
  "entries": [
    {
      "start": 175.44,
      "duration": 6.519,
      "text": "えただいまから予算特別委員会の会議を"
    },
    {
      "start": 178.4,
      "duration": 6.44,
      "text": "開きます本はね年長の私が委員長がご選さ"
    },
    {
      "start": 181.959,
      "duration": 5.801,
      "text": "れるまで委員長の職務を行いますたしに"
    },
    {
      "start": 184.84,
      "duration": 5.759,
      "text": "議題に入ります議題は当委員会の委員長の"
    },
    {
      "start": 187.76,
      "duration": 5.28,
      "text": "ご戦についてであります誤選の方法につい"
    },
    {
      "start": 190.599,
      "duration": 6.36,
      "text": "てはいかがいたしましょうかどなたか選出"
    },
    {
      "start": 193.04,
      "duration": 8.559,
      "text": "方法についてご意見がありませんか片山"
    },
    {
      "start": 196.959,
      "duration": 7.481,
      "text": "さん指名推薦でお願いしますたただ今選出"
    },
    {
      "start": 201.599,
      "duration": 5.72,
      "text": "方法について指名推薦によるとのご意見が"
    },
    {
      "start": 204.44,
      "duration": 6.28,
      "text": "ありますが指名推により決定することにご"
    },
    {
      "start": 207.319,
      "duration": 6.241,
      "text": "異議ありませんか異議と認めただいま"
    },
    {
      "start": 210.72,
      "duration": 6.04,
      "text": "申し上げました通り決定いたしますどの他"
    },
    {
      "start": 213.56,
      "duration": 5.239,
      "text": "かご推薦いただけます"
    },
    {
      "start": 216.76,
      "duration": 8.0,
      "text": "か片山"
    },
    {
      "start": 218.799,
      "duration": 10.121,
      "text": "さんはいえっとですねあの私とあの同期で"
    },
    {
      "start": 224.76,
      "duration": 8.08,
      "text": "えこの間16年間ですねまクを同にしてき"
    },
    {
      "start": 228.92,
      "duration": 7.48,
      "text": "ましたはいあのえま立場とかね考え方はこ"
    },
    {
      "start": 232.84,
      "duration": 6.44,
      "text": "違うんですけれどもあのえクを共にしてき"
    },
    {
      "start": 236.4,
      "duration": 4.8,
      "text": "ましたえ公明党の渡辺子さんを推薦したい"
    },
    {
      "start": 239.28,
      "duration": 7.76,
      "text": "と"
    },
    {
      "start": 241.2,
      "duration": 8.72,
      "text": "あのあのあのってね理の場であのきちんと"
    },
    {
      "start": 247.04,
      "duration": 5.039,
      "text": "議論ができるということで非常に私はあの"
    },
    {
      "start": 249.92,
      "duration": 4.959,
      "text": "貴重な経験をさせていただいたなと思って"
    },
    {
      "start": 252.079,
      "duration": 4.44,
      "text": "おりますあのまこの間ですねあの2回も"
    },
    {
      "start": 254.879,
      "duration": 4.001,
      "text": "市長が辞めてしまうとかねそういったこと"
    },
    {
      "start": 256.519,
      "duration": 5.24,
      "text": "もあの色々と一緒に経験しましたけれども"
    },
    {
      "start": 258.88,
      "duration": 4.68,
      "text": "まそのようなことも乗り越えましてあのま"
    },
    {
      "start": 261.759,
      "duration": 4.601,
      "text": "こうやってあの一緒にできてきたことと"
    },
    {
      "start": 263.56,
      "duration": 6.4,
      "text": "いうのを非常に私としては貴重な財産だな"
    },
    {
      "start": 266.36,
      "duration": 6.279,
      "text": "と思っておりますでまたあのね財政学あの"
    },
    {
      "start": 269.96,
      "duration": 4.679,
      "text": "推進調査特別委員会の委員長今なさって"
    },
    {
      "start": 272.639,
      "duration": 5.201,
      "text": "くださっておりますけれどもまそういった"
    },
    {
      "start": 274.639,
      "duration": 7.081,
      "text": "あの擬人運営を見ましても非常にこう冷静"
    },
    {
      "start": 277.84,
      "duration": 6.24,
      "text": "な形であの穏やかに冷静にこう記事を運営"
    },
    {
      "start": 281.72,
      "duration": 5.28,
      "text": "してくださってるということからもま公平"
    },
    {
      "start": 284.08,
      "duration": 5.2,
      "text": "構成なの記事運営を期待できると思いまし"
    },
    {
      "start": 287.0,
      "duration": 4.08,
      "text": "て推薦させていただきたいと思いますま"
    },
    {
      "start": 289.28,
      "duration": 3.359,
      "text": "このような推薦の言葉を述べさせて"
    },
    {
      "start": 291.08,
      "duration": 6.0,
      "text": "いただきまして本当にありがとうござい"
    },
    {
      "start": 292.639,
      "duration": 4.441,
      "text": "ますどうぞよろしくお願いいたします"
    },
    {
      "start": 300.44,
      "duration": 6.199,
      "text": "これからりますの"
    },
    {
      "start": 302.16,
      "duration": 7.44,
      "text": "でただいま渡辺委員を委員長にとの推薦が"
    },
    {
      "start": 306.639,
      "duration": 5.681,
      "text": "ございましたお諮りいたします渡辺副子"
    },
    {
      "start": 309.6,
      "duration": 6.12,
      "text": "委員を委員長に選出することに合意あり"
    },
    {
      "start": 312.32,
      "duration": 6.08,
      "text": "ませんか合議なしと認めます従って"
    },
    {
      "start": 315.72,
      "duration": 5.56,
      "text": "ただいま指名いたしました通り選出する"
    },
    {
      "start": 318.4,
      "duration": 5.799,
      "text": "ことに決定いたしましたただいま委員長に"
    },
    {
      "start": 321.28,
      "duration": 6.44,
      "text": "選出されました渡辺復委員のご挨拶をお"
    },
    {
      "start": 324.199,
      "duration": 9.241,
      "text": "願いいたします"
    },
    {
      "start": 327.72,
      "duration": 8.919,
      "text": "さんいいですまだまだまだえ渡辺富子で"
    },
    {
      "start": 333.44,
      "duration": 6.92,
      "text": "ございますえご推薦また決定いただきまし"
    },
    {
      "start": 336.639,
      "duration": 8.12,
      "text": "てありがとうございますえただいまの片山"
    },
    {
      "start": 340.36,
      "duration": 7.839,
      "text": "香委員のえ発言はあの非常に私も同じ思い"
    },
    {
      "start": 344.759,
      "duration": 5.44,
      "text": "であの暗くを共にした16年だったなと"
    },
    {
      "start": 348.199,
      "duration": 6.921,
      "text": "あのそのようにあの考えるところであり"
    },
    {
      "start": 350.199,
      "duration": 9.161,
      "text": "ますあのえ初めてのあの予算え特別委員会"
    },
    {
      "start": 355.12,
      "duration": 6.44,
      "text": "の委員長ということでありましてあの皆様"
    },
    {
      "start": 359.36,
      "duration": 4.52,
      "text": "にははあのご協力いただくこともあの"
    },
    {
      "start": 361.56,
      "duration": 5.32,
      "text": "たくさんあるかと思いますまたあの最近は"
    },
    {
      "start": 363.88,
      "duration": 5.599,
      "text": "あの時々聞き取りにくい時もあったりして"
    },
    {
      "start": 366.88,
      "duration": 6.48,
      "text": "あのそよではあの皆さんに本当にあのご"
    },
    {
      "start": 369.479,
      "duration": 6.12,
      "text": "協力いただきながらあの公平え公正なえ"
    },
    {
      "start": 373.36,
      "duration": 5.959,
      "text": "擬人運営に努めて参りたいと思っており"
    },
    {
      "start": 375.599,
      "duration": 3.72,
      "text": "ますのでどうかよろしくお願いいたし"
    },
    {
      "start": 381.08,
      "duration": 6.16,
      "text": "ますこれで私の職務は終了いたしました"
    },
    {
      "start": 384.52,
      "duration": 5.72,
      "text": "委員長と交代するためしばらく休憩いたし"
    },
    {
      "start": 387.24,
      "duration": 3.0,
      "text": "ます"
    },
    {
      "start": 395.0,
      "duration": 7.71,
      "text": "予算委員会ってなんか最後に必ずさん"
    },
    {
      "start": 398.73,
      "duration": 3.98,
      "text": "[笑い]"
    },
    {
      "start": 408.28,
      "duration": 8.36,
      "text": "委あそういうこともできるんですねし"
    },
    {
      "start": 412.19,
      "duration": 4.45,
      "text": "[笑い]"
    },
    {
      "start": 419.68,
      "duration": 5.68,
      "text": "から副委長のご選を行いますご選の方法に"
    },
    {
      "start": 423.08,
      "duration": 5.72,
      "text": "ついてはいかがいたしましょうかどなたか"
    },
    {
      "start": 425.36,
      "duration": 6.8,
      "text": "選出方法についてご意見がありませんか"
    },
    {
      "start": 428.8,
      "duration": 7.04,
      "text": "はい水谷委員はい指名推薦でお願いします"
    },
    {
      "start": 432.16,
      "duration": 6.599,
      "text": "はいただいまえ推薦法選出方法について"
    },
    {
      "start": 435.84,
      "duration": 5.359,
      "text": "使命推薦によるとのご意見がありますが"
    },
    {
      "start": 438.759,
      "duration": 5.081,
      "text": "使命推薦により決定することにご異議あり"
    },
    {
      "start": 441.199,
      "duration": 5.361,
      "text": "ませんかないご異議なしと認めただいま"
    },
    {
      "start": 443.84,
      "duration": 7.12,
      "text": "申し上げました通り決定いたしますどなた"
    },
    {
      "start": 446.56,
      "duration": 8.039,
      "text": "かご推薦いただけますかはい"
    },
    {
      "start": 450.96,
      "duration": 6.519,
      "text": "水谷はいあのいつも質疑ではですね事実や"
    },
    {
      "start": 454.599,
      "duration": 5.801,
      "text": "根拠を指摘しながら端的で分かりやすい"
    },
    {
      "start": 457.479,
      "duration": 8.521,
      "text": "あの質疑をされていてまたあの現在もあの"
    },
    {
      "start": 460.4,
      "duration": 7.96,
      "text": "新長者及び新福祉会館の建設及び公共施設"
    },
    {
      "start": 466.0,
      "duration": 4.28,
      "text": "マネージメントの特別委員会でもあの副"
    },
    {
      "start": 468.36,
      "duration": 5.0,
      "text": "委員長としてしっかりとあの委員長を"
    },
    {
      "start": 470.28,
      "duration": 4.96,
      "text": "サポートしてらっしゃる酒井越子委員を"
    },
    {
      "start": 473.36,
      "duration": 6.839,
      "text": "推薦したいと思い"
    },
    {
      "start": 475.24,
      "duration": 8.639,
      "text": "ますただいま委員を副長とのがございまし"
    },
    {
      "start": 480.199,
      "duration": 6.641,
      "text": "たお諮りいたします越子委員を副委員長に"
    },
    {
      "start": 483.879,
      "duration": 5.521,
      "text": "選出することにご異議ありませんかご異議"
    },
    {
      "start": 486.84,
      "duration": 5.079,
      "text": "なしと認めます従ってただ今指名いたし"
    },
    {
      "start": 489.4,
      "duration": 6.16,
      "text": "ました通り選出することに決定いたしまし"
    },
    {
      "start": 491.919,
      "duration": 7.321,
      "text": "たただ今副委員長に選出された酒井越子"
    },
    {
      "start": 495.56,
      "duration": 6.479,
      "text": "委員のご挨拶をお願いいたしますはい坂"
    },
    {
      "start": 499.24,
      "duration": 5.2,
      "text": "委員はいあのご推薦及びご承認いただき"
    },
    {
      "start": 502.039,
      "duration": 6.12,
      "text": "ましてありがとうございました先ほど委員"
    },
    {
      "start": 504.44,
      "duration": 5.84,
      "text": "長からえっと総称予算の委員長をあの"
    },
    {
      "start": 508.159,
      "duration": 5.56,
      "text": "預かるの初めてというような発言あったん"
    },
    {
      "start": 510.28,
      "duration": 6.639,
      "text": "ですが私もですね当初予算の副委長をさせ"
    },
    {
      "start": 513.719,
      "duration": 6.841,
      "text": "ていただくのはこの度が初めてとなります"
    },
    {
      "start": 516.919,
      "duration": 6.441,
      "text": "えっと委員会運営には皆様のご協力があっ"
    },
    {
      "start": 520.56,
      "duration": 4.92,
      "text": "てこそだとは思いますのでまご推薦及びご"
    },
    {
      "start": 523.36,
      "duration": 5.28,
      "text": "承認いただきましたことも踏まえまして"
    },
    {
      "start": 525.48,
      "duration": 5.919,
      "text": "えっと円滑な委員会運営に私も協力して"
    },
    {
      "start": 528.64,
      "duration": 6.24,
      "text": "まいりたいと思いますので皆様のご協力も"
    },
    {
      "start": 531.399,
      "duration": 3.481,
      "text": "何卒よろしくお願いいたし"
    },
    {
      "start": 535.519,
      "duration": 8.721,
      "text": "ます以上で予算特別委員会の議を終了"
    },
    {
      "start": 540.24,
      "duration": 7.48,
      "text": "いたしますそれではあのえ特別委員会の"
    },
    {
      "start": 544.24,
      "duration": 7.48,
      "text": "あの協議をさせていただきたいと思います"
    },
    {
      "start": 547.72,
      "duration": 7.84,
      "text": "え1月21日の議会委員会で確認されまし"
    },
    {
      "start": 551.72,
      "duration": 7.559,
      "text": "たが一般会計当初予算の歳出の質疑に関し"
    },
    {
      "start": 555.56,
      "duration": 6.88,
      "text": "ましてはえ昨年同様全体を4区分に分けて"
    },
    {
      "start": 559.279,
      "duration": 6.8,
      "text": "行います詳細に関しましてはお手元にお"
    },
    {
      "start": 562.44,
      "duration": 7.04,
      "text": "配りしてあります令和7年第1回定例会"
    },
    {
      "start": 566.079,
      "duration": 7.88,
      "text": "予算特別委員会審査区分についての通り"
    },
    {
      "start": 569.48,
      "duration": 8.479,
      "text": "です総合え教育会議の質疑区分については"
    },
    {
      "start": 573.959,
      "duration": 7.241,
      "text": "え令和5年の決算特別委員会及び令和6年"
    },
    {
      "start": 577.959,
      "duration": 8.041,
      "text": "2月15日の議会運営委員会においてご"
    },
    {
      "start": 581.2,
      "duration": 8.56,
      "text": "議論のありました歳入歳出予算え事項別"
    },
    {
      "start": 586.0,
      "duration": 7.32,
      "text": "明細書の総合教育会議に要する経費関連の"
    },
    {
      "start": 589.76,
      "duration": 7.12,
      "text": "質疑につきましては令和7年第1回定例会"
    },
    {
      "start": 593.32,
      "duration": 6.759,
      "text": "予算特別委員会審査区分についての通り"
    },
    {
      "start": 596.88,
      "duration": 6.12,
      "text": "歳出第1区分での質疑となりますが質疑の"
    },
    {
      "start": 600.079,
      "duration": 6.361,
      "text": "内容により教育委員会に答弁を求めるもの"
    },
    {
      "start": 603.0,
      "duration": 6.6,
      "text": "については歳出第4区分での質疑を行い"
    },
    {
      "start": 606.44,
      "duration": 7.12,
      "text": "たいと思いますまた総括質疑につきまして"
    },
    {
      "start": 609.6,
      "duration": 8.12,
      "text": "はえ姿勢における総合的な観点からの質疑"
    },
    {
      "start": 613.56,
      "duration": 8.719,
      "text": "及び令和7年第1回定例会予算特別委員会"
    },
    {
      "start": 617.72,
      "duration": 9.08,
      "text": "新作文についての資料の通り人件費業界あ"
    },
    {
      "start": 622.279,
      "duration": 7.041,
      "text": "行財政改革全般等のえ質疑を行う場である"
    },
    {
      "start": 626.8,
      "duration": 5.56,
      "text": "と考えております各委員におかれましては"
    },
    {
      "start": 629.32,
      "duration": 7.079,
      "text": "ご協力のほどよろしくお願い申し上げます"
    },
    {
      "start": 632.36,
      "duration": 8.36,
      "text": "次に裏面の予算特別委員会第1回定例会の"
    },
    {
      "start": 636.399,
      "duration": 6.161,
      "text": "え区分別え審査時間についてえ過去4年間"
    },
    {
      "start": 640.72,
      "duration": 5.16,
      "text": "分をご覧"
    },
    {
      "start": 642.56,
      "duration": 6.32,
      "text": "くださいえこのうちえ一般会計当初予算の"
    },
    {
      "start": 645.88,
      "duration": 6.88,
      "text": "歳出に対する第1区分から第4区分までの"
    },
    {
      "start": 648.88,
      "duration": 7.759,
      "text": "質疑の合計時間数で見ますとえ令和5年は"
    },
    {
      "start": 652.76,
      "duration": 7.4,
      "text": "35時間41分でしたが令和6年は38"
    },
    {
      "start": 656.639,
      "duration": 6.561,
      "text": "時間20分となっておりましたまた総括"
    },
    {
      "start": 660.16,
      "duration": 7.479,
      "text": "質疑の時間数で見ますと令和6年について"
    },
    {
      "start": 663.2,
      "duration": 7.56,
      "text": "はえ2時間25分となっておりました審査"
    },
    {
      "start": 667.639,
      "duration": 5.64,
      "text": "時間に関しては各年度の予算の内容による"
    },
    {
      "start": 670.76,
      "duration": 6.639,
      "text": "ところも多々あると思いますが限られた"
    },
    {
      "start": 673.279,
      "duration": 7.841,
      "text": "時間において活発かつ効率的なえ審議が"
    },
    {
      "start": 677.399,
      "duration": 6.56,
      "text": "進められますよう議事の進行に特段の配慮"
    },
    {
      "start": 681.12,
      "duration": 6.12,
      "text": "ご協力につきまして委員長よりお願い"
    },
    {
      "start": 683.959,
      "duration": 6.641,
      "text": "申し上げます右玉の答弁体制に関しまして"
    },
    {
      "start": 687.24,
      "duration": 8.76,
      "text": "は教育長については教育委員会に関する"
    },
    {
      "start": 690.6,
      "duration": 10.359,
      "text": "予算審査を行う初日え補正え歳入4日目え"
    },
    {
      "start": 696.0,
      "duration": 8.76,
      "text": "第4区分え6日目総括のえ委員会に出席し"
    },
    {
      "start": 700.959,
      "duration": 6.56,
      "text": "ていただきその他はえ実績にて審査を聞い"
    },
    {
      "start": 704.76,
      "duration": 5.28,
      "text": "ていただきたいと思っておりますまた説明"
    },
    {
      "start": 707.519,
      "duration": 5.841,
      "text": "員については答弁が必要な際に入れ替わる"
    },
    {
      "start": 710.04,
      "duration": 7.28,
      "text": "ようお願いいたします資料説明につきまし"
    },
    {
      "start": 713.36,
      "duration": 8.24,
      "text": "ては本年においてもえ各部長職からのえ"
    },
    {
      "start": 717.32,
      "duration": 7.44,
      "text": "資料懸命の報告は省福市長から事前に提出"
    },
    {
      "start": 721.6,
      "duration": 6.0,
      "text": "した通りです程度の発言にとめてえ参り"
    },
    {
      "start": 724.76,
      "duration": 6.319,
      "text": "たいと思いますその後え資料内容について"
    },
    {
      "start": 727.6,
      "duration": 7.359,
      "text": "え議があれば議事進行上の発言としてお"
    },
    {
      "start": 731.079,
      "duration": 6.921,
      "text": "受けいたします何か皆さんからご質問など"
    },
    {
      "start": 734.959,
      "duration": 6.801,
      "text": "ありますかよろしいでしょうかはいえそれ"
    },
    {
      "start": 738.0,
      "duration": 6.04,
      "text": "では以上で予算特別委員会協議会を終了"
    },
    {
