{
  "entries": [
    {
      "start": 42.399,
      "duration": 5.32,
      "text": "トイレ行ってました。"
    },
    {
      "start": 44.719,
      "duration": 3.0,
      "text": "えっと、じゃあ議会委員会協議会始めます。えっと、まずあの討論ありますか?"
    },
    {
      "start": 50.52,
      "duration": 0.96,
      "text": "し"
    },
    {
      "start": 51.039,
      "duration": 1.281,
      "text": "なし。"
    },
    {
      "start": 51.48,
      "duration": 2.599,
      "text": "はい。"
    },
    {
      "start": 52.32,
      "duration": 3.919,
      "text": "はい。川野さん。はい。"
    },
    {
      "start": 54.079,
      "duration": 4.721,
      "text": "はい。え、議員案第29"
    },
    {
      "start": 56.239,
      "duration": 5.441,
      "text": "号、え、川野です。"
    },
    {
      "start": 58.8,
      "duration": 4.719,
      "text": "えっと、反対討論"
    },
    {
      "start": 61.68,
      "duration": 2.96,
      "text": "失礼しました。反対です。"
    },
    {
      "start": 63.519,
      "duration": 3.161,
      "text": "はい。"
    },
    {
      "start": 64.64,
      "duration": 3.96,
      "text": "はい。"
    },
    {
      "start": 66.68,
      "duration": 3.16,
      "text": "はい。新さん"
    },
    {
      "start": 68.6,
      "duration": 2.68,
      "text": "30号"
    },
    {
      "start": 69.84,
      "duration": 4.44,
      "text": "ごめん。えっと、30"
    },
    {
      "start": 71.28,
      "duration": 3.0,
      "text": "号。えっと、これの賛成討論を、え、藤川さんですね。さん"
    },
    {
      "start": 79.32,
      "duration": 2.839,
      "text": "はい。"
    },
    {
      "start": 80.479,
      "duration": 2.32,
      "text": "他ありますか?"
    },
    {
      "start": 82.159,
      "duration": 1.881,
      "text": "なし"
    },
    {
      "start": 82.799,
      "duration": 4.241,
      "text": "なし。はい。"
    },
    {
      "start": 84.04,
      "duration": 3.0,
      "text": "じゃあ、えっと、採決態度は充前通りということで、"
    },
    {
      "start": 88.36,
      "duration": 3.92,
      "text": "あと閉中委員会、"
    },
    {
      "start": 90.46,
      "duration": 4.339,
      "text": "[音楽]"
    },
    {
      "start": 92.28,
      "duration": 3.6,
      "text": "閉中委員会なんですが"
    },
    {
      "start": 94.799,
      "duration": 4.081,
      "text": "10月17"
    },
    {
      "start": 95.88,
      "duration": 3.0,
      "text": "でしたっけね。あれ持ち帰ってもらったのがで、大丈夫でしょうか?ちょっと早いんですけど。です。"
    },
    {
      "start": 101.119,
      "duration": 3.36,
      "text": "じゃ、10月大丈夫ですか皆さん?はい。"
    },
    {
      "start": 104.04,
      "duration": 1.24,
      "text": "はい。10"
    },
    {
      "start": 104.479,
      "duration": 3.801,
      "text": "月17"
    },
    {
      "start": 105.28,
      "duration": 3.0,
      "text": "日であとそのそうなった時の協議報告書とかはどうなるんでしょうか?"
    },
    {
      "start": 112.84,
      "duration": 4.48,
      "text": "はい。え、事係長"
    },
    {
      "start": 114.52,
      "duration": 4.919,
      "text": "すいません。えっと、提出物なんですけども、基本的には"
    },
    {
      "start": 117.32,
      "duration": 3.2,
      "text": "2週間前になりますので、"
    },
    {
      "start": 119.439,
      "duration": 4.081,
      "text": "17日から14"
    },
    {
      "start": 120.52,
      "duration": 3.0,
      "text": "日前ってなると決算中になります。"
    },
    {
      "start": 123.96,
      "duration": 5.159,
      "text": "3日、3日まで"
    },
    {
      "start": 126.119,
      "duration": 3.0,
      "text": "になりますのでよろしくお願いします。"
    },
    {
      "start": 130.08,
      "duration": 3.0,
      "text": "あの、今回あまり書くことないと思うので、あの、その辺は配慮してやっていんじゃないかと思いますので、で、あと日曜議会について、これは"
    },
    {
      "start": 142.879,
      "duration": 2.521,
      "text": "持ち帰えてもらったのが"
    },
    {
      "start": 144.72,
      "duration": 3.68,
      "text": "確認され、"
    },
    {
      "start": 145.4,
      "duration": 3.0,
      "text": "確認できてますかね?"
    },
    {
      "start": 148.64,
      "duration": 4.319,
      "text": "今度また10月7日の日にいいです。"
    },
    {
      "start": 151.239,
      "duration": 4.561,
      "text": "いや、いいすかね?じゃあ、10月7"
    },
    {
      "start": 152.959,
      "duration": 5.041,
      "text": "日の日に確認したいと思いますので"
    },
    {
      "start": 155.8,
      "duration": 5.2,
      "text": "ご確認お願いしたいと思います。"
    },
    {
      "start": 158.0,
      "duration": 3.0,
      "text": "え、その他、え、何かありますでしょうか?"
    },
    {
      "start": 161.239,
      "duration": 3.0,
      "text": "なし。じゃあ以上で議会運営委員会統協闘議会終わります。"
    },
    {
      "start": 188.0,
      "duration": 3.239,
      "text": "はい。"
    }
  ]
}