{
  "entries": [
    {
      "start": 32.64,
      "duration": 3.0,
      "text": "ラ終わったらもう"
    },
    {
      "start": 51.44,
      "duration": 3.08,
      "text": "1回変わった"
    },
    {
      "start": 59.16,
      "duration": 3.0,
      "text": "あ"
    },
    {
      "start": 144.319,
      "duration": 5.161,
      "text": "おはようございます。"
    },
    {
      "start": 146.48,
      "duration": 3.0,
      "text": "ただ今から本日の会議を開きます。日程第"
    },
    {
      "start": 149.76,
      "duration": 3.16,
      "text": "1"
    },
    {
      "start": 149.92,
      "duration": 3.0,
      "text": "位視聴報告を行います。昨日に引き続き市聴報告に対する質疑を行います。森戸さん"
    },
    {
      "start": 157.72,
      "duration": 3.0,
      "text": "はい。え、自然環境に対する問題について、え、市長の市長報告に対していくつか質問をいたしました。"
    },
    {
      "start": 167.72,
      "duration": 7.96,
      "text": "しかし市長からはですね、え、一体その"
    },
    {
      "start": 171.4,
      "duration": 8.4,
      "text": "大きな影響があった場合というこの文言の"
    },
    {
      "start": 175.68,
      "duration": 7.96,
      "text": "、え、問題だとかそれから、え、いくつか"
    },
    {
      "start": 179.8,
      "duration": 6.6,
      "text": "質問をいたしましたが、あ、合理的な説明"
    },
    {
      "start": 183.64,
      "duration": 6.56,
      "text": "はありませんでした。ただ保全対策につい"
    },
    {
      "start": 186.4,
      "duration": 7.759,
      "text": "て確認しできる限り最小限に抑えていくと"
    },
    {
      "start": 190.2,
      "duration": 8.64,
      "text": "いう答弁しかなく、これでは全く、え、"
    },
    {
      "start": 194.159,
      "duration": 7.961,
      "text": "この自然環境が守られるかどうかは保証が"
    },
    {
      "start": 198.84,
      "duration": 6.24,
      "text": "ありません。しかもできる限り最小限に"
    },
    {
      "start": 202.12,
      "duration": 7.039,
      "text": "抑えていくということについて例えばと"
    },
    {
      "start": 205.08,
      "duration": 6.84,
      "text": "言って私は絶滅種がこれがもし保全でき"
    },
    {
      "start": 209.159,
      "duration": 5.681,
      "text": "なかったらどうするんだということを伺っ"
    },
    {
      "start": 211.92,
      "duration": 5.8,
      "text": "ていますが明解な答弁はありません。"
    },
    {
      "start": 214.84,
      "duration": 5.36,
      "text": "え、その点についてですね、改めて、え、"
    },
    {
      "start": 217.72,
      "duration": 6.56,
      "text": "市長の見解を伺いたいと思います。この"
    },
    {
      "start": 220.2,
      "duration": 8.52,
      "text": "絶滅器具種が絶滅するようなことになれば"
    },
    {
      "start": 224.28,
      "duration": 7.0,
      "text": "一体誰が責任を取るんでしょうか?あの、"
    },
    {
      "start": 228.72,
      "duration": 7.04,
      "text": "ま、そういう点でどうかっていうことです"
    },
    {
      "start": 231.28,
      "duration": 8.0,
      "text": "ね。それからあの、"
    },
    {
      "start": 235.76,
      "duration": 7.44,
      "text": "ま、是非ですね、あの、もうちょっと具体"
    },
    {
      "start": 239.28,
      "duration": 8.2,
      "text": "的にお答えをいただきたいと思います。"
    },
    {
      "start": 243.2,
      "duration": 6.119,
      "text": "それから検証結果の問題でありますが、"
    },
    {
      "start": 247.48,
      "duration": 5.45,
      "text": "えっと"
    },
    {
      "start": 249.319,
      "duration": 4.681,
      "text": "検証結果については"
    },
    {
      "start": 252.93,
      "duration": 5.95,
      "text": "[音楽]"
    },
    {
      "start": 254.0,
      "duration": 7.84,
      "text": "うんとうんんてなってる人がいる。あの、"
    },
    {
      "start": 258.88,
      "duration": 6.199,
      "text": "あれですね。え、1つはあ、ごめんなさい"
    },
    {
      "start": 261.84,
      "duration": 3.239,
      "text": "ね。ちょっと"
    },
    {
      "start": 266.8,
      "duration": 3.28,
      "text": "うん。"
    },
    {
      "start": 272.4,
      "duration": 9.079,
      "text": "1つは、あ、混雑対策の問題として、え、"
    },
    {
      "start": 278.68,
      "duration": 5.4,
      "text": "34115線が上げられているわけです。"
    },
    {
      "start": 281.479,
      "duration": 5.881,
      "text": "で、課長からはですね、交通機能は"
    },
    {
      "start": 284.08,
      "duration": 6.6,
      "text": "6000台だと6000台以上のところと"
    },
    {
      "start": 287.36,
      "duration": 5.559,
      "text": "いうことなんですが、私は令和3年は"
    },
    {
      "start": 290.68,
      "duration": 5.359,
      "text": "もっと下がってるんじゃないですかと。"
    },
    {
      "start": 292.919,
      "duration": 5.441,
      "text": "連着通り含めてね、3000台だとか、"
    },
    {
      "start": 296.039,
      "duration": 4.561,
      "text": "あの、下がっているにも関わらず6000"
    },
    {
      "start": 298.36,
      "duration": 6.76,
      "text": "台に合わせるっていう理由は何なんですか"
    },
    {
      "start": 300.6,
      "duration": 8.08,
      "text": "?平成27年の交通先に合わせていて、令"
    },
    {
      "start": 305.12,
      "duration": 5.88,
      "text": "和3年の交通先に合わせていないのはどう"
    },
    {
      "start": 308.68,
      "duration": 5.4,
      "text": "いうことなんですかって聞いています。え"
    },
    {
      "start": 311.0,
      "duration": 5.96,
      "text": "、その点ですね、あの、しっかりとした"
    },
    {
      "start": 314.08,
      "duration": 5.839,
      "text": "答弁をいただきたいし、ま、あの、課長も"
    },
    {
      "start": 316.96,
      "duration": 7.12,
      "text": "認めになったように1.25を超えている"
    },
    {
      "start": 319.919,
      "duration": 6.56,
      "text": "ところはないということで優先性の検証と"
    },
    {
      "start": 324.08,
      "duration": 6.16,
      "text": "して行っているということなんですが、"
    },
    {
      "start": 326.479,
      "duration": 7.241,
      "text": "1.25以下のところの優先性が"
    },
    {
      "start": 330.24,
      "duration": 6.36,
      "text": "34115になる理由は、あ、分かりませ"
    },
    {
      "start": 333.72,
      "duration": 5.12,
      "text": "ん。あの、小金街道の渋滞解消とか"
    },
    {
      "start": 336.6,
      "duration": 7.24,
      "text": "おっしゃってたわけですよね。で、しかし"
    },
    {
      "start": 338.84,
      "duration": 8.359,
      "text": "実際の数字を見るとおここを整備あのし"
    },
    {
      "start": 343.84,
      "duration": 5.079,
      "text": "なかったとしたらあ小金度はどうかって"
    },
    {
      "start": 347.199,
      "duration": 4.921,
      "text": "言うとほとんど変わりないじゃないですか"
    },
    {
      "start": 348.919,
      "duration": 5.84,
      "text": "。1以下じゃないですか。"
    },
    {
      "start": 352.12,
      "duration": 7.32,
      "text": "なぜここが優先されるっていうことになる"
    },
    {
      "start": 354.759,
      "duration": 7.56,
      "text": "んですか?全くこの検証がですね、あの、"
    },
    {
      "start": 359.44,
      "duration": 7.52,
      "text": "もしこの数字があ、あの、正しいとすれば"
    },
    {
      "start": 362.319,
      "duration": 8.0,
      "text": "ですね、え、最終的な結論がですね、全く"
    },
    {
      "start": 366.96,
      "duration": 6.6,
      "text": "違う方向になっていて、え、問題がある"
    },
    {
      "start": 370.319,
      "duration": 6.521,
      "text": "検証だと言わざるを得ませんが、え、その"
    },
    {
      "start": 373.56,
      "duration": 7.88,
      "text": "点でどうでしょうか?それと、あの、一方"
    },
    {
      "start": 376.84,
      "duration": 7.199,
      "text": "編集の問題であります。あの、ま、点問題"
    },
    {
      "start": 381.44,
      "duration": 5.24,
      "text": "を通る理由は確認していないということで"
    },
    {
      "start": 384.039,
      "duration": 7.481,
      "text": "ありますが、ま、私、あの、さっき、えっ"
    },
    {
      "start": 386.68,
      "duration": 8.799,
      "text": "と、府中側の都市計画道路が開けばってい"
    },
    {
      "start": 391.52,
      "duration": 10.959,
      "text": "たんですが、開かなくてもね、あの、うん"
    },
    {
      "start": 395.479,
      "duration": 12.28,
      "text": "、瞳街道から、え、天門台通りに抜けてと"
    },
    {
      "start": 402.479,
      "duration": 7.0,
      "text": "道路を左折し、え、2枚橋のその437号"
    },
    {
      "start": 407.759,
      "duration": 4.72,
      "text": "線に入るっていうこと"
    },
    {
      "start": 409.479,
      "duration": 3.0,
      "text": "はできるわけですよね。で、そういうことから"
    },
    {
      "start": 415.68,
      "duration": 4.359,
      "text": "定問題通りで"
    },
    {
      "start": 417.68,
      "duration": 2.519,
      "text": "連通りに行くのは遠すぎるから"
    },
    {
      "start": 420.039,
      "duration": 3.16,
      "text": "5"
    },
    {
      "start": 420.199,
      "duration": 3.0,
      "text": "丁目に行きたいのであれば東発道路を通ってその"
    },
    {
      "start": 424.759,
      "duration": 3.56,
      "text": "2枚橋の横で"
    },
    {
      "start": 426.56,
      "duration": 4.759,
      "text": "1丁目の437"
    },
    {
      "start": 428.319,
      "duration": 3.0,
      "text": "号線を通った方がその方が全然早いと"
    },
    {
      "start": 432.759,
      "duration": 3.88,
      "text": "いうことなんじゃないんですか。"
    },
    {
      "start": 434.639,
      "duration": 4.24,
      "text": "で、そういうですね、ま、クランクになっ"
    },
    {
      "start": 436.639,
      "duration": 5.041,
      "text": "てると、あ、ね、左折したり右折した"
    },
    {
      "start": 438.879,
      "duration": 5.72,
      "text": "りっていうのありますよ。で、しかしそう"
    },
    {
      "start": 441.68,
      "duration": 5.44,
      "text": "にしたって、あの、最も早くどう"
    },
    {
      "start": 444.599,
      "duration": 6.961,
      "text": "行きつくかっていうことであれば、そう"
    },
    {
      "start": 447.12,
      "duration": 7.0,
      "text": "いうやり方があるわけで、あの、是非消防"
    },
    {
      "start": 451.56,
      "duration": 4.6,
      "text": "所さんとはですね、あの、ま、今日"
    },
    {
      "start": 454.12,
      "duration": 5.799,
      "text": "いらっしゃらないけど誰がこれ言うのか"
    },
    {
      "start": 456.16,
      "duration": 5.8,
      "text": "分からないんですが、あの、しっかりと"
    },
    {
      "start": 459.919,
      "duration": 7.041,
      "text": "調整をする必要があるんじゃないでしょう"
    },
    {
      "start": 461.96,
      "duration": 8.76,
      "text": "か。従ってその一方編集がね、もちろん"
    },
    {
      "start": 466.96,
      "duration": 6.88,
      "text": "一方編集になることはあの1つの解決策で"
    },
    {
      "start": 470.72,
      "duration": 3.319,
      "text": "あ、あると思います。じゃあ、ぬ井南町の"
    },
    {
      "start": 473.84,
      "duration": 3.199,
      "text": "3"
    },
    {
      "start": 474.039,
      "duration": 3.0,
      "text": "丁目あたりにね、あの、崖の辺りがありますが、あそこに例えばよ、例えばよっていうか、例えば例えばですね、あの、道路を通して一方編集をね、解消するのかっていうことになるとそうはならないでしょう。"
    },
    {
      "start": 493.8,
      "duration": 7.76,
      "text": "だからあそこは新小金街道からあの上から"
    },
    {
      "start": 498.4,
      "duration": 7.28,
      "text": "向かってきてそれであ、上から南から"
    },
    {
      "start": 501.56,
      "duration": 7.56,
      "text": "向かってきて左折してぬ井南町に入例えば"
    },
    {
      "start": 505.68,
      "duration": 7.44,
      "text": "ですよに入るということになると思うん"
    },
    {
      "start": 509.12,
      "duration": 6.719,
      "text": "ですよ。ま、ま、一方編集いやいや崖が"
    },
    {
      "start": 513.12,
      "duration": 6.2,
      "text": "あるじゃないですか。例えばね。うん。だ"
    },
    {
      "start": 515.839,
      "duration": 6.08,
      "text": "からどこだって今小金は崖があるところが"
    },
    {
      "start": 519.32,
      "duration": 5.959,
      "text": "あるわけで、そこの一方編集を言い始め"
    },
    {
      "start": 521.919,
      "duration": 5.681,
      "text": "たらですね、霧りがないわけで、だから"
    },
    {
      "start": 525.279,
      "duration": 4.881,
      "text": "やれるべきことをしっかりとやっていくっ"
    },
    {
      "start": 527.6,
      "duration": 6.88,
      "text": "ていうことなんじゃないんでしょうか。え"
    },
    {
      "start": 530.16,
      "duration": 8.0,
      "text": "、そういう点でですね、私はあの、その"
    },
    {
      "start": 534.48,
      "duration": 6.72,
      "text": "ことと合わせてそこだけを広げても意味が"
    },
    {
      "start": 538.16,
      "duration": 8.16,
      "text": "ないって言ってるわけですよね。その"
    },
    {
      "start": 541.2,
      "duration": 7.12,
      "text": "広げる以上に必要なことは狭い道路をな何"
    },
    {
      "start": 546.32,
      "duration": 5.24,
      "text": "とかしたいっていうことなわけでしょ。"
    },
    {
      "start": 548.32,
      "duration": 6.16,
      "text": "狭い道路があるからあの難しい難しいって"
    },
    {
      "start": 551.56,
      "duration": 6.6,
      "text": "言われるわけですよ。だったら狭い道路を"
    },
    {
      "start": 554.48,
      "duration": 7.0,
      "text": "もう少しあのセットバックしてもらって"
    },
    {
      "start": 558.16,
      "duration": 6.0,
      "text": "そこを買収するということも含めてやって"
    },
    {
      "start": 561.48,
      "duration": 5.84,
      "text": "いけばいいじゃないですか。そういうお金"
    },
    {
      "start": 564.16,
      "duration": 5.6,
      "text": "も出さないでですね、あの道路だけを広げ"
    },
    {
      "start": 567.32,
      "duration": 5.12,
      "text": "るっていうのはね、ちょっとやっぱり"
    },
    {
      "start": 569.76,
      "duration": 5.04,
      "text": "街づりのあり方としての優先順位として"
    },
    {
      "start": 572.44,
      "duration": 5.88,
      "text": "どうなのかっていうことが問われるんじゃ"
    },
    {
      "start": 574.8,
      "duration": 7.479,
      "text": "ないかと思います。ま、その点ではですね"
    },
    {
      "start": 578.32,
      "duration": 6.4,
      "text": "、ま、市長も、え、道路だけを広げること"
    },
    {
      "start": 582.279,
      "duration": 6.081,
      "text": "ではないと言っておっしゃってはいますが"
    },
    {
      "start": 584.72,
      "duration": 6.2,
      "text": "、もう少しその辺りの計画をですね、あの"
    },
    {
      "start": 588.36,
      "duration": 6.24,
      "text": "、示すべきではないですか?え、その点"
    },
    {
      "start": 590.92,
      "duration": 7.159,
      "text": "いかがでしょうか?それから、あの、輸送"
    },
    {
      "start": 594.6,
      "duration": 6.88,
      "text": "道路の問題で緊急輸送道路私がなぜ言っ"
    },
    {
      "start": 598.079,
      "duration": 7.241,
      "text": "てるかって言うと、以前の議論の中で、え"
    },
    {
      "start": 601.48,
      "duration": 6.16,
      "text": "、小金井公園からその武蔵野公園に物資を"
    },
    {
      "start": 605.32,
      "duration": 5.32,
      "text": "輸送する必要が"
    },
    {
      "start": 607.64,
      "duration": 3.0,
      "text": "ま、そういう論があったと思うんですよ。"
    },
    {
      "start": 611.079,
      "duration": 3.0,
      "text": "で、しかし避難所ですから武蔵野公園はみ東"
    },
    {
      "start": 616.48,
      "duration": 3.12,
      "text": "5"
    },
    {
      "start": 616.6,
      "duration": 3.0,
      "text": "丁目の皆さんは広域避難所には逃げ避難しない。まずは一時避難所ですよ。一時避難所ね。だから一時避難所は東学校なわけで、あの、ここにあの物資を輸送するっていうことはあると思うんですよ。"
    },
    {
      "start": 636.079,
      "duration": 3.0,
      "text": "で、広域避難所の場合は何回も言いますが、東京都が運営するわけですよ、これは。で、東京都が物資を輸送する場合は立川の防災センターから第"
    },
    {
      "start": 648.079,
      "duration": 3.161,
      "text": "1"
    },
    {
      "start": 648.24,
      "duration": 3.0,
      "text": "次緊急輸送道路を通して、え、武資を輸送するんじゃないですかと。"
    },
    {
      "start": 653.8,
      "duration": 6.08,
      "text": "で、ま、先ほどの課長答弁の中で"
    },
    {
      "start": 656.6,
      "duration": 7.32,
      "text": "34115線は緊急総道路には指定されて"
    },
    {
      "start": 659.88,
      "duration": 7.6,
      "text": "いないということでありますから、あの、"
    },
    {
      "start": 663.92,
      "duration": 7.44,
      "text": "その点からするとですね、あの、この道路"
    },
    {
      "start": 667.48,
      "duration": 7.12,
      "text": "を活用してその小金公園から物資を輸送"
    },
    {
      "start": 671.36,
      "duration": 6.96,
      "text": "するというような役割を持った道路では"
    },
    {
      "start": 674.6,
      "duration": 8.28,
      "text": "ないということだと思います。で、ま、"
    },
    {
      "start": 678.32,
      "duration": 9.56,
      "text": "そういう点でね、あの、私はあの"
    },
    {
      "start": 682.88,
      "duration": 7.959,
      "text": "緊急輸送道路を活用した物資輸送を東京都"
    },
    {
      "start": 687.88,
      "duration": 6.759,
      "text": "に依頼するわけですから、え、この都市"
    },
    {
      "start": 690.839,
      "duration": 6.321,
      "text": "計画道路がなければ物資が輸送できないと"
    },
    {
      "start": 694.639,
      "duration": 5.561,
      "text": "いうことにはならない。え、そのことは"
    },
    {
      "start": 697.16,
      "duration": 6.28,
      "text": "ですね、あの、申し上げて、え、おきたい"
    },
    {
      "start": 700.2,
      "duration": 6.56,
      "text": "と思います。え、ま、その点でですね、"
    },
    {
      "start": 703.44,
      "duration": 4.519,
      "text": "見解があれば伺います。"
    },
    {
      "start": 706.76,
      "duration": 4.199,
      "text": "市長。"
    },
    {
      "start": 707.959,
      "duration": 3.0,
      "text": "はい。えっと、まず絶滅集も含めてまた、あの、え、再質問いただきました。"
    },
    {
      "start": 716.36,
      "duration": 4.8,
      "text": "え、ま、消北にも書いておりますが、え、"
    },
    {
      "start": 718.8,
      "duration": 5.64,
      "text": "同植物への影響の範囲は限定的であり、"
    },
    {
      "start": 721.16,
      "duration": 6.0,
      "text": "多くの種の保存は維持され、え、事業区域"
    },
    {
      "start": 724.44,
      "duration": 6.04,
      "text": "外にも同質の環境を広く分布するため、え"
    },
    {
      "start": 727.16,
      "duration": 6.44,
      "text": "、生物対応性を支える主要な、え、生息の"
    },
    {
      "start": 730.48,
      "duration": 4.76,
      "text": "場は残存し、え、生物の相互関係の影響が"
    },
    {
      "start": 733.6,
      "duration": 4.2,
      "text": "維持されると、ま、評価されてるという"
    },
    {
      "start": 735.24,
      "duration": 4.56,
      "text": "ことであります。で、え、絶滅寄付種が、"
    },
    {
      "start": 737.8,
      "duration": 2.68,
      "text": "ま、絶滅していいとは、あの、当然思い"
    },
    {
      "start": 739.8,
      "duration": 3.68,
      "text": "ません。"
    },
    {
      "start": 740.48,
      "duration": 3.0,
      "text": "で、えっと、それも含めてですね、影響が最小限に抑えることができるようにとしてもしっかり意見をしていきたいということでございます。以上です。"
    },
    {
      "start": 748.88,
      "duration": 3.0,
      "text": "都市計画課長。"
    },
    {
      "start": 752.68,
      "duration": 3.0,
      "text": "はい。え、戸議員から再度ご質問頂戴いたしました。えっと、一次検証についてのご質問でございます。えっと、繰り返しの答弁になりますけれども、えっと、先ほどあのご案内のあった混雑度については一次検証についての評価ではございません。"
    },
    {
      "start": 770.519,
      "duration": 6.44,
      "text": "あくまでも一次検証についての評価は、あ"
    },
    {
      "start": 773.72,
      "duration": 6.16,
      "text": "、交通所の交通量6000台でございます"
    },
    {
      "start": 776.959,
      "duration": 5.921,
      "text": "。で、これの根拠というのは、あの、将来"
    },
    {
      "start": 779.88,
      "duration": 7.24,
      "text": "交通量計によるものでございます。続き"
    },
    {
      "start": 782.88,
      "duration": 7.44,
      "text": "まして、その一方編集についての"
    },
    {
      "start": 787.12,
      "duration": 5.959,
      "text": "ご提案、ご質問でございますけれども、"
    },
    {
      "start": 790.32,
      "duration": 5.199,
      "text": "その到達ルートのご提案も頂いている"
    },
    {
      "start": 793.079,
      "duration": 5.2,
      "text": "ところでございますけれども、えっと我々"
    },
    {
      "start": 795.519,
      "duration": 5.481,
      "text": "の検証はあくまでも現在の消防関係者の"
    },
    {
      "start": 798.279,
      "duration": 5.521,
      "text": "現状のルートをヒアリングした結果、あ、"
    },
    {
      "start": 801.0,
      "duration": 6.04,
      "text": "現状と分析ということでございます。あと"
    },
    {
      "start": 803.8,
      "duration": 6.12,
      "text": "その狭い道路の確が難しいということで"
    },
    {
      "start": 807.04,
      "duration": 6.0,
      "text": "ございますので、もうその解決の方法とし"
    },
    {
      "start": 809.92,
      "duration": 5.84,
      "text": "て都市計画道路の整備が有効だということ"
    },
    {
      "start": 813.04,
      "duration": 6.12,
      "text": "でございます。続きまして、あの、緊急"
    },
    {
      "start": 815.76,
      "duration": 7.079,
      "text": "郵送道路についてのご質問でございます"
    },
    {
      "start": 819.16,
      "duration": 5.919,
      "text": "けれども、これはあの緊急輸送道路は現動"
    },
    {
      "start": 822.839,
      "duration": 4.761,
      "text": "に指定されているものでございますので、"
    },
    {
      "start": 825.079,
      "duration": 6.801,
      "text": "え、未整備の都市計画には指定されてない"
    },
    {
      "start": 827.6,
      "duration": 6.479,
      "text": "ということでございます。以上です。"
    },
    {
      "start": 831.88,
      "duration": 5.199,
      "text": "進行ですか?森さん、"
    },
    {
      "start": 834.079,
      "duration": 3.0,
      "text": "あの、狭い道路は難しいっていうことじゃなくて、狭い道路をまず広げることが優先課題じゃないですかって言ってるわけですよ。その点について、あの、答弁を求めていますのでよろしくお願いします。"
    },
    {
      "start": 848.88,
      "duration": 2.8,
      "text": "道路管理課長です。"
    },
    {
      "start": 849.759,
      "duration": 4.921,
      "text": "道路管理課長、"
    },
    {
      "start": 851.68,
      "duration": 3.0,
      "text": "え、狭い道路をあの克服するという件でございます。"
    },
    {
      "start": 856.519,
      "duration": 6.88,
      "text": "えっと、まず建築基準法の中で、ま、2道"
    },
    {
      "start": 859.6,
      "duration": 7.039,
      "text": "道路というあのものがございまして、えっ"
    },
    {
      "start": 863.399,
      "duration": 5.44,
      "text": "と、中心線から2mについては、ま、あの"
    },
    {
      "start": 866.639,
      "duration": 5.32,
      "text": "、建築する際はセットバックするという"
    },
    {
      "start": 868.839,
      "duration": 7.321,
      "text": "ルールがございます。で、それから、えっ"
    },
    {
      "start": 871.959,
      "duration": 8.0,
      "text": "と、ご提案の通り限動を5.5に確すると"
    },
    {
      "start": 876.16,
      "duration": 6.599,
      "text": "いう場合で、え、あっても遠動の身内を"
    },
    {
      "start": 879.959,
      "duration": 5.041,
      "text": "取得しなければならず、え、結局は幼稚"
    },
    {
      "start": 882.759,
      "duration": 5.241,
      "text": "倍収が必要となります。"
    },
    {
      "start": 885.0,
      "duration": 3.0,
      "text": "で、そうすると遠動の方のご理解やご力が不可欠となってまいります。で、さらに当該そういう道路についてはあの、えっと、作"
    },
    {
      "start": 895.519,
      "duration": 3.32,
      "text": "11"
    },
    {
      "start": 895.839,
      "duration": 3.0,
      "text": "みたいに計画線が存在しないとで、計画線を作るところから始まりますので、"
    },
    {
      "start": 903.44,
      "duration": 5.68,
      "text": "もそう言ってないじゃん。で、そうすると"
    },
    {
      "start": 905.32,
      "duration": 7.079,
      "text": "、ま、生場なかなか難しいのかなという"
    },
    {
      "start": 909.12,
      "duration": 6.6,
      "text": "ところでございますし、またあの西武玉"
    },
    {
      "start": 912.399,
      "duration": 6.481,
      "text": "多摩川線のトンネルが、ま、ボトルネック"
    },
    {
      "start": 915.72,
      "duration": 7.96,
      "text": "という状況になります。で、もしその"
    },
    {
      "start": 918.88,
      "duration": 8.079,
      "text": "トンネルを克服するためには野側にあの"
    },
    {
      "start": 923.68,
      "duration": 6.279,
      "text": "克服しなきゃしなければ現実的には難しい"
    },
    {
      "start": 926.959,
      "duration": 6.161,
      "text": "という状況でございますので、ま、しって"
    },
    {
      "start": 929.959,
      "duration": 6.44,
      "text": "、ま、言動確十分な機能を果たすことが"
    },
    {
      "start": 933.12,
      "duration": 6.399,
      "text": "できず、えっと、また現実的な、えっと、"
    },
    {
      "start": 936.399,
      "duration": 7.041,
      "text": "整備手法ともならないと考えてるとこで"
    },
    {
      "start": 939.519,
      "duration": 3.921,
      "text": "ございます。以上です。"
    },
    {
      "start": 943.6,
      "duration": 3.799,
      "text": "森さん、"
    },
    {
      "start": 944.399,
      "duration": 3.0,
      "text": "あの、私はね、か、あの、狭い道路を克してくれとは言ってないんですよ。あの、セットバックしたりして、そこの部分をあの、府宙は府中とか重士は買収してるわけですよ。補助金出してるんですよ。そういうことができるんじゃないんですかって言ってるわけ。あの、"
    },
    {
      "start": 964.6,
      "duration": 3.0,
      "text": "狭い道路はね、で、そのなんか都市計画決定をしろとかそういうことじゃないんですよ。"
    },
    {
      "start": 969.36,
      "duration": 3.0,
      "text": "だって府中は都市計画決定してその狭い道路をね、あの、わざわざ広げるために補助金を出してるわけじゃないんですよ。そこのことを言ってるわけですよ。だからちょっとね、あの、私の質問の意図と答弁が食い違うので委員長、その通り答弁してると思います。今さんがおっしゃったに答弁答弁しておりますので"
    },
    {
      "start": 993.759,
      "duration": 4.841,
      "text": "整理をしていただきたいと思います。"
    },
    {
      "start": 995.6,
      "duration": 3.0,
      "text": "いや、ですから、え、森さんと同じことを答弁しました。"
    },
    {
      "start": 999.6,
      "duration": 5.44,
      "text": "いや、議員長違うんですよ。"
    },
    {
      "start": 1002.04,
      "duration": 3.0,
      "text": "あ、議員長、私は克服しろって言ってないんですよね。あの、言動セットバックしてね。"
    },
    {
      "start": 1010.36,
      "duration": 3.0,
      "text": "違う、違う。それはあの、都市計画決定をして、都市計画決定をして克服する話と違うんですよ。"
    },
    {
      "start": 1017.68,
      "duration": 7.08,
      "text": "そこのその例えば4mとかいうあのしか"
    },
    {
      "start": 1021.6,
      "duration": 6.92,
      "text": "ないところでね、そこだけ狭くなってると"
    },
    {
      "start": 1024.76,
      "duration": 6.559,
      "text": "いうことのところについて補助金を出して"
    },
    {
      "start": 1028.52,
      "duration": 5.319,
      "text": "あの通行ができるように広げてもらうって"
    },
    {
      "start": 1031.319,
      "duration": 4.72,
      "text": "いうそういうことなんですよ。だったら"
    },
    {
      "start": 1033.839,
      "duration": 4.641,
      "text": "なんで府中や重歩でできてるんですかって"
    },
    {
      "start": 1036.039,
      "duration": 5.8,
      "text": "ことですよ。都市計画決定してやってる"
    },
    {
      "start": 1038.48,
      "duration": 4.68,
      "text": "わけじゃないでしょ。墨切りをあの広げる"
    },
    {
      "start": 1041.839,
      "duration": 4.321,
      "text": "にしてもね。"
    },
    {
      "start": 1043.16,
      "duration": 3.0,
      "text": "そのことを言ってるんで、ちょっとあの課長があの私の質問の中身があの悪かったら申し訳ないんだけどもしご解されていたらあのちょっとその辺りはあの答弁をいただきたいと思います。"
    },
    {
      "start": 1046.319,
      "duration": 3.08,
      "text": "[拍手]"
    },
    {
      "start": 1058.36,
      "duration": 6.28,
      "text": "あの、だ、計画戦って言ったから勘違いし"
    },
    {
      "start": 1061.28,
      "duration": 6.44,
      "text": "てるんで、計画戦がないから作るじゃなく"
    },
    {
      "start": 1064.64,
      "duration": 5.52,
      "text": "て、計画だから、あの、いずれにしろね、"
    },
    {
      "start": 1067.72,
      "duration": 5.839,
      "text": "民地を、あの、買収しなきゃいけないって"
    },
    {
      "start": 1070.16,
      "duration": 4.72,
      "text": "いうことで、あの、買収もしくは協力を"
    },
    {
      "start": 1073.559,
      "duration": 3.48,
      "text": "いただかなければいけないっていう風にご"
    },
    {
      "start": 1074.88,
      "duration": 4.32,
      "text": "答えすればいいんじゃないかと思います。"
    },
    {
      "start": 1077.039,
      "duration": 5.041,
      "text": "あの、えっと、道路管理課長"
    },
    {
      "start": 1079.2,
      "duration": 5.44,
      "text": "道路管理課長です。それで、あの、"
    },
    {
      "start": 1082.08,
      "duration": 4.599,
      "text": "繰り返しの答弁になりますが、あの、"
    },
    {
      "start": 1084.64,
      "duration": 4.0,
      "text": "また答弁させていただきます。"
    },
    {
      "start": 1086.679,
      "duration": 3.0,
      "text": "えっと、ご屋の通りに限動"
    },
    {
      "start": 1088.64,
      "duration": 4.039,
      "text": "5.5m"
    },
    {
      "start": 1089.679,
      "duration": 3.0,
      "text": "に克服する場合であっても遠動のあの身内を取得しなければならない"
    },
    {
      "start": 1097.48,
      "duration": 5.079,
      "text": "ですよね。"
    },
    {
      "start": 1099.559,
      "duration": 3.0,
      "text": "そこまでは分かりますよね。え、"
    },
    {
      "start": 1102.6,
      "duration": 3.0,
      "text": "え、民長を取得しなければなりませんということは結局幼稚買収が必要となります。で、そうすると遠動の方のご理解や協力が不可欠となってまいります。"
    },
    {
      "start": 1114.48,
      "duration": 3.0,
      "text": "で、さらにそういう道路については、あの、どこまでセットバックしたらいいのか、どこまで買収したらいいのかっていう計画線がございません。線がございません。"
    },
    {
      "start": 1126.52,
      "duration": 4.159,
      "text": "で、その線を作るところから始まります。"
    },
    {
      "start": 1129.52,
      "duration": 3.159,
      "text": "はい。"
    },
    {
      "start": 1130.679,
      "duration": 5.0,
      "text": "そうすると"
    },
    {
      "start": 1132.679,
      "duration": 3.0,
      "text": "そうすると現状ではなかなか単独であのあの計画線がある道路ですら"
    },
    {
      "start": 1139.96,
      "duration": 3.0,
      "text": "難しい状況であるのであればこれから計画線を作って整備をするのはさらに困難を極めてくるのかなと思ってくるところでございます。"
    },
    {
      "start": 1154.08,
      "duration": 3.0,
      "text": "はい。あの答弁だきました。"
    },
    {
      "start": 1157.36,
      "duration": 3.0,
      "text": "はい。次の方岸田さん。"
    },
    {
      "start": 1160.49,
      "duration": 4.429,
      "text": "[音楽]"
    },
    {
      "start": 1161.919,
      "duration": 3.0,
      "text": "はい。えっと、ま、先ほど関連ではですね、あの、ま、市長には厳しいことを申し上げたと思っております。ま、あの、市議会議員の時代に考えが浅かったのかということについて、ま、視野が狭かった、ま、あるいは認めたくはないけれども否定はできないというご答弁だったかなという風に思っております。ま、一定にはやはりあの、それをめたいわけではなくてじめが必要でうと私自身は考えております。"
    },
    {
      "start": 1187.24,
      "duration": 5.799,
      "text": "うん。というのも、ま、私はこの優先整備"
    },
    {
      "start": 1189.6,
      "duration": 5.6,
      "text": "2路線の問題を政治問題化させ、市民の"
    },
    {
      "start": 1193.039,
      "duration": 4.721,
      "text": "分断をも生みかねない状況を作ったのは"
    },
    {
      "start": 1195.2,
      "duration": 5.479,
      "text": "白井市長ご自身であると考えています。え"
    },
    {
      "start": 1197.76,
      "duration": 5.64,
      "text": "、都市計画道路3411号線については、"
    },
    {
      "start": 1200.679,
      "duration": 5.161,
      "text": "あ、小金市長が了解できない状況化での"
    },
    {
      "start": 1203.4,
      "duration": 6.399,
      "text": "東京都での事業化は進めないよう求め、"
    },
    {
      "start": 1205.84,
      "duration": 5.68,
      "text": "東京都に3回の要請書と2回の面談で意思"
    },
    {
      "start": 1209.799,
      "duration": 5.0,
      "text": "を伝えてきたけれども、それでは足りない"
    },
    {
      "start": 1211.52,
      "duration": 5.84,
      "text": "と何度も強い区調で指摘をしてきたのが"
    },
    {
      "start": 1214.799,
      "duration": 5.481,
      "text": "白井議員でありました。ま、そのような、"
    },
    {
      "start": 1217.36,
      "duration": 5.24,
      "text": "あ、優先整備、二路線について否定的な"
    },
    {
      "start": 1220.28,
      "duration": 6.12,
      "text": "移行が強いということを受け止めて市町戦"
    },
    {
      "start": 1222.6,
      "duration": 6.88,
      "text": "での公約を掲げられて、え、緑や自然を"
    },
    {
      "start": 1226.4,
      "duration": 5.84,
      "text": "守るために西化市長以上の東京都への"
    },
    {
      "start": 1229.48,
      "duration": 5.36,
      "text": "働きかけを期待されて当選されたにも"
    },
    {
      "start": 1232.24,
      "duration": 6.08,
      "text": "関わらず、え、東京都への中心見直しの"
    },
    {
      "start": 1234.84,
      "duration": 6.6,
      "text": "要望は調整中との答弁を1年間も繰り返し"
    },
    {
      "start": 1238.32,
      "duration": 7.04,
      "text": "、1度も実現することはないままに、突然"
    },
    {
      "start": 1241.44,
      "duration": 6.599,
      "text": "に令和6年度予算で独自検証を行うことを"
    },
    {
      "start": 1245.36,
      "duration": 5.0,
      "text": "指政方針で述られました。ま、それから何"
    },
    {
      "start": 1248.039,
      "duration": 5.0,
      "text": "をどう検証するのか、多くの議員から質疑"
    },
    {
      "start": 1250.36,
      "duration": 5.799,
      "text": "があり、答弁は2点、3点し、え、道路"
    },
    {
      "start": 1253.039,
      "duration": 5.52,
      "text": "整備の賛否に関わらず、え、独自検証に"
    },
    {
      "start": 1256.159,
      "duration": 5.361,
      "text": "かかる決議が2本も提出される事態となっ"
    },
    {
      "start": 1258.559,
      "duration": 5.48,
      "text": "たわけでございます。ま、そのような状況"
    },
    {
      "start": 1261.52,
      "duration": 5.44,
      "text": "から始めようとした、ま、第1事件と第2"
    },
    {
      "start": 1264.039,
      "duration": 5.561,
      "text": "次受験省の内容は誰がどう見ても客観性、"
    },
    {
      "start": 1266.96,
      "duration": 5.64,
      "text": "公平性、透明性が担保されるものになら"
    },
    {
      "start": 1269.6,
      "duration": 5.28,
      "text": "なければ、ま、その結果が出た時に、え、"
    },
    {
      "start": 1272.6,
      "duration": 4.439,
      "text": "収集がつかなくなりますよと、ま、旧浦"
    },
    {
      "start": 1274.88,
      "duration": 4.48,
      "text": "議員の紹介もありましたけれども、継承を"
    },
    {
      "start": 1277.039,
      "duration": 4.281,
      "text": "鳴らしてきたところでございます。現状は"
    },
    {
      "start": 1279.36,
      "duration": 4.679,
      "text": "どうでしょうか?市長"
    },
    {
      "start": 1281.32,
      "duration": 5.599,
      "text": "市長はこの検証について何度も客観性、"
    },
    {
      "start": 1284.039,
      "duration": 5.961,
      "text": "公平性、透明性が担保されていると答弁さ"
    },
    {
      "start": 1286.919,
      "duration": 5.521,
      "text": "れますが、私が何度も助けを出したけれど"
    },
    {
      "start": 1290.0,
      "duration": 5.52,
      "text": "もそれを受け入れることなく、お金も時間"
    },
    {
      "start": 1292.44,
      "duration": 5.76,
      "text": "も人もかけない中途半端な検証を強行した"
    },
    {
      "start": 1295.52,
      "duration": 6.6,
      "text": "結果が、え、市長報告の拍手撤開であり"
    },
    {
      "start": 1298.2,
      "duration": 7.16,
      "text": "ました。そこから、あ、政治的判断をさ、"
    },
    {
      "start": 1302.12,
      "duration": 7.0,
      "text": "あ、総合的判断を再整理すると言いながら"
    },
    {
      "start": 1305.36,
      "duration": 7.08,
      "text": "、ま、半年も具体的な答弁は避けてこの"
    },
    {
      "start": 1309.12,
      "duration": 7.4,
      "text": "ように市張報告があ、示されたわけで"
    },
    {
      "start": 1312.44,
      "duration": 7.2,
      "text": "ございます。これまでの市民説明会や今日"
    },
    {
      "start": 1316.52,
      "duration": 6.639,
      "text": "の質疑を聞いていても市民や議会の理解が"
    },
    {
      "start": 1319.64,
      "duration": 6.6,
      "text": "進み、市長の説明責任が尽くされていると"
    },
    {
      "start": 1323.159,
      "duration": 5.961,
      "text": "は残念ながら言えない状況であり、あると"
    },
    {
      "start": 1326.24,
      "duration": 5.319,
      "text": "考えます。ま、それでもこの市長報告を"
    },
    {
      "start": 1329.12,
      "duration": 5.84,
      "text": "持って東京都に伝えるということであれば"
    },
    {
      "start": 1331.559,
      "duration": 7.6,
      "text": "、それはもう市長の政治的判断だと私は"
    },
    {
      "start": 1334.96,
      "duration": 7.24,
      "text": "考えます。市長の政治的判断だということ"
    },
    {
      "start": 1339.159,
      "duration": 4.76,
      "text": "であれば今回の主張報告を私は受け止め"
    },
    {
      "start": 1342.2,
      "duration": 5.24,
      "text": "たいと思いますがいかがでしょうか?お"
    },
    {
      "start": 1343.919,
      "duration": 3.521,
      "text": "答えください。"
    },
    {
      "start": 1362.24,
      "duration": 5.679,
      "text": "えっと、ま、厳し、厳しいこと、あの、"
    },
    {
      "start": 1364.919,
      "duration": 5.321,
      "text": "言われました。で、えっと、ま、この間の"
    },
    {
      "start": 1367.919,
      "duration": 5.64,
      "text": "、ま、警戒については、あの、まさんから"
    },
    {
      "start": 1370.24,
      "duration": 5.799,
      "text": "、え、ま、都度でね、あの、ま、厳しいご"
    },
    {
      "start": 1373.559,
      "duration": 5.521,
      "text": "指摘、え、ま、ご提案もいただいてきた"
    },
    {
      "start": 1376.039,
      "duration": 5.441,
      "text": "わけでございますが、え、ま、そのご意見"
    },
    {
      "start": 1379.08,
      "duration": 4.56,
      "text": "として、え、我々としても反映できる検証"
    },
    {
      "start": 1381.48,
      "duration": 4.199,
      "text": "にあたって反映できることは、え、ま、"
    },
    {
      "start": 1383.64,
      "duration": 4.84,
      "text": "反映できてきましたしてきたつもりで"
    },
    {
      "start": 1385.679,
      "duration": 6.201,
      "text": "ございますが、ただ、え、ま、元々検証"
    },
    {
      "start": 1388.48,
      "duration": 6.24,
      "text": "そのものがね、あの、するべきではないっ"
    },
    {
      "start": 1391.88,
      "duration": 4.24,
      "text": "ていうご意見が、ま、あった、あ、ことも"
    },
    {
      "start": 1394.72,
      "duration": 3.559,
      "text": "含めて、ま、岸記者さんがおっしゃった"
    },
    {
      "start": 1396.12,
      "duration": 4.64,
      "text": "ことは、あの、経過としては事実かなと"
    },
    {
      "start": 1398.279,
      "duration": 5.801,
      "text": "思ってます。で、えっと、ま、ちょっと"
    },
    {
      "start": 1400.76,
      "duration": 6.32,
      "text": "中途半端の検証というあのご発言もござい"
    },
    {
      "start": 1404.08,
      "duration": 4.839,
      "text": "ましたが、あのこの間私たちとしては、ま"
    },
    {
      "start": 1407.08,
      "duration": 3.52,
      "text": "、いろんなご意見いただいてご指摘も"
    },
    {
      "start": 1408.919,
      "duration": 4.481,
      "text": "いただいたりはしてますが、あの、決して"
    },
    {
      "start": 1410.6,
      "duration": 5.72,
      "text": "中途半端ーだとは思ってはいません。あの"
    },
    {
      "start": 1413.4,
      "duration": 5.6,
      "text": "、その、え、結果を含めてですね、私とし"
    },
    {
      "start": 1416.32,
      "duration": 4.839,
      "text": "てはこの、え、この間あの判断をしてきた"
    },
    {
      "start": 1419.0,
      "duration": 3.919,
      "text": "、判断と言いますか、え、この主張報告"
    },
    {
      "start": 1421.159,
      "duration": 4.601,
      "text": "どう再整理するかっていうことを考えてき"
    },
    {
      "start": 1422.919,
      "duration": 4.64,
      "text": "たわけであります。で、えっと、ま、反対"
    },
    {
      "start": 1425.76,
      "duration": 4.12,
      "text": "のご意見、もしくは納得いかないっていう"
    },
    {
      "start": 1427.559,
      "duration": 4.881,
      "text": "ご意見、あの、多々、あの、説明会、意見"
    },
    {
      "start": 1429.88,
      "duration": 5.799,
      "text": "交換会、え、そして、ま、今日の主張報告"
    },
    {
      "start": 1432.44,
      "duration": 6.359,
      "text": "含めていただいてるところは私も認識はし"
    },
    {
      "start": 1435.679,
      "duration": 5.961,
      "text": "ております。あの、結果的には、あの、ま"
    },
    {
      "start": 1438.799,
      "duration": 6.521,
      "text": "、それも含めて、あの、ま、政治的判断と"
    },
    {
      "start": 1441.64,
      "duration": 6.88,
      "text": "いうことは私としても、あの、え、ま、"
    },
    {
      "start": 1445.32,
      "duration": 5.52,
      "text": "覚悟して今回、あの、この主張報告に"
    },
    {
      "start": 1448.52,
      "duration": 5.32,
      "text": "基づいて、あの、東京党へ要望していき"
    },
    {
      "start": 1450.84,
      "duration": 3.68,
      "text": "たいと考えております。以上です。霧さん"
    },
    {
      "start": 1453.84,
      "duration": 3.68,
      "text": "。"
    },
    {
      "start": 1454.52,
      "duration": 3.0,
      "text": "はい、ご答弁ありがとうございました。ま、市長の政治的判断であるということを重く受け止めたいと思います。以上です。"
    },
    {
      "start": 1461.48,
      "duration": 3.0,
      "text": "他にございますか?"
    },
    {
      "start": 1466.96,
      "duration": 3.0,
      "text": "え、質疑を終了することにご異議ありませんか?"
    },
    {
      "start": 1470.44,
      "duration": 3.0,
      "text": "ご異議なしと認め報告を終了します。以上で本日の日程は全て終了しました。本日はこれを持って参加いたします。お疲れ様でした。"
    }
  ]
}