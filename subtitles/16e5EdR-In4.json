    },
    {
      "start": 1095.08,
      "duration": 9.36,
      "text": "ですよねであのこの金額と改正のですね"
    },
    {
      "start": 1100.88,
      "duration": 6.96,
      "text": "あの26市平均との差額っていうのがあっ"
    },
    {
      "start": 1104.44,
      "duration": 6.44,
      "text": "てまこれで見るとなんかあまあまあそうな"
    },
    {
      "start": 1107.84,
      "duration": 8.199,
      "text": "のかなと思うんですですがあのこの時期"
    },
    {
      "start": 1110.88,
      "duration": 10.6,
      "text": "三玉多各がですねえ賃金改定を行っている"
    },
    {
      "start": 1116.039,
      "duration": 8.801,
      "text": "わけでえそうなるとですねこのうん三玉"
    },
    {
      "start": 1121.48,
      "duration": 8.4,
      "text": "26市平均額も上がると思うんです"
    },
    {
      "start": 1124.84,
      "duration": 10.92,
      "text": "よだからそのなんか改正賃金額をその令和"
    },
    {
      "start": 1129.88,
      "duration": 9.08,
      "text": "6年4月1日時点の26市の平均との差額"
    },
    {
      "start": 1135.76,
      "duration": 7.48,
      "text": "と比較するっていうのはですねちょっと錯"
    },
    {
      "start": 1138.96,
      "duration": 7.28,
      "text": "を起こすなんか26市とですねよりも多い"
    },
    {
      "start": 1143.24,
      "duration": 6.52,
      "text": "じゃないかという錯覚を起こすことになっ"
    },
    {
      "start": 1146.24,
      "duration": 7.559,
      "text": "てですねちょっとこの表はいかがなのかな"
    },
    {
      "start": 1149.76,
      "duration": 8.0,
      "text": "と思っていますそれであの現行の状況で"
    },
    {
      "start": 1153.799,
      "duration": 9.041,
      "text": "見るとですねあの一般事務保健士看護士"
    },
    {
      "start": 1157.76,
      "duration": 9.56,
      "text": "栄養士児童構成院学童保育指導員学童保育"
    },
    {
      "start": 1162.84,
      "duration": 10.88,
      "text": "指導員補助社会福祉士精神保険福祉士学芸"
    },
    {
      "start": 1167.32,
      "duration": 12.32,
      "text": "員計査業などについては3玉平均よりもえ"
    },
    {
      "start": 1173.72,
      "duration": 10.04,
      "text": "ま低いわけですね低いわけですそれで"
    },
    {
      "start": 1179.64,
      "duration": 9.72,
      "text": "あの従ってですねえ今年度上げたとしても"
    },
    {
      "start": 1183.76,
      "duration": 9.24,
      "text": "え各多も上げるわけですからえまた多平均"
    },
    {
      "start": 1189.36,
      "duration": 7.28,
      "text": "よりも低い状況になるんじゃないかなと"
    },
    {
      "start": 1193.0,
      "duration": 7.24,
      "text": "いう風に思うんですねでやっぱりあの3玉"
    },
    {
      "start": 1196.64,
      "duration": 7.919,
      "text": "平均を上回る"
    },
    {
      "start": 1200.24,
      "duration": 8.04,
      "text": "えせめてですね上回っていかないとですね"
    },
    {
      "start": 1204.559,
      "duration": 7.721,
      "text": "あの職員のまあなんていう"
    },
    {
      "start": 1208.28,
      "duration": 6.8,
      "text": "か募集をかけてもですねやっぱりタと比較"
    },
    {
      "start": 1212.28,
      "duration": 6.48,
      "text": "すれば高い方に行くことになるわけです"
    },
    {
      "start": 1215.08,
      "duration": 8.36,
      "text": "からまその辺りはですねもうちょっとその"
    },
    {
      "start": 1218.76,
      "duration": 8.76,
      "text": "最低1時間の金額はあの上げていくべき"
    },
    {
      "start": 1223.44,
      "duration": 6.32,
      "text": "じゃないかせめて3玉平均までには持って"
    },
    {
      "start": 1227.52,
      "duration": 6.92,
      "text": "いく必要があるんじゃないかと思うんです"
    },
    {
      "start": 1229.76,
      "duration": 10.64,
      "text": "ですからあのま来年もまた最低賃金の改定"
    },
    {
      "start": 1234.44,
      "duration": 9.52,
      "text": "があると思うんですがえその3玉平均をに"
    },
    {
      "start": 1240.4,
      "duration": 7.12,
      "text": "近づくようにえ努力をすべきではないかな"
    },
    {
      "start": 1243.96,
      "duration": 6.04,
      "text": "と思いますがえその点の考え方を伺わせて"
    },
    {
      "start": 1247.52,
      "duration": 2.48,
      "text": "ください"
    },
    {
      "start": 1251.28,
      "duration": 7.759,
      "text": "以上職員課長はいえそれでは議案資料3の"
    },
    {
      "start": 1255.72,
      "duration": 6.48,
      "text": "作りというところで26平均とのという"
    },
    {
      "start": 1259.039,
      "duration": 6.161,
      "text": "ことになりますえ今え議員からお話が"
    },
    {
      "start": 1262.2,
      "duration": 6.28,
      "text": "ございましたようにこのえ資料のえ26市"
    },
    {
      "start": 1265.2,
      "duration": 6.24,
      "text": "の平均額は令和6年4月1日現在の平均額"
    },
    {
      "start": 1268.48,
      "duration": 5.64,
      "text": "でございますので今回10月1日で改正と"
    },
    {
      "start": 1271.44,
      "duration": 5.32,
      "text": "いう形でご提案をしてございますのでえ"
    },
    {
      "start": 1274.12,
      "duration": 5.12,
      "text": "その額との平均とのえ差額という資料の"
    },
    {
      "start": 1276.76,
      "duration": 4.88,
      "text": "出し方については委員のご意見という見方"
    },
    {
      "start": 1279.24,
      "duration": 4.439,
      "text": "もあろうかと思いますけれどもえ現行との"
    },
    {
      "start": 1281.64,
      "duration": 3.88,
      "text": "比較というようなところでの出し方という"
    },
    {
      "start": 1283.679,
      "duration": 3.441,
      "text": "と現時点ではこのような出し方になると"
    },
    {
      "start": 1285.52,
      "duration": 6.519,
      "text": "いうことでご理解をいただければと思い"
    },
    {
      "start": 1287.12,
      "duration": 7.84,
      "text": "ますえ続きて定の額でございますえ26時"
    },
    {
      "start": 1292.039,
      "duration": 5.681,
      "text": "平均を上回ることが最低でも必要ではない"
    },
    {
      "start": 1294.96,
      "duration": 5.959,
      "text": "かというようなご意見かとございます"
    },
    {
      "start": 1297.72,
      "duration": 6.0,
      "text": "え他種との均衡をどのように図っていくか"
    },
    {
      "start": 1300.919,
      "duration": 4.921,
      "text": "というようなことになりますがえ委議員"
    },
    {
      "start": 1303.72,
      "duration": 5.04,
      "text": "より今お話のあったご意見もあるかと思い"
    },
    {
      "start": 1305.84,
      "duration": 6.8,
      "text": "ますがえ本誌といたしましてはえ先ほどえ"
    },
    {
      "start": 1308.76,
      "duration": 5.84,
      "text": "ご説明したような方針でえ改定のえ考え方"
    },
    {
      "start": 1312.64,
      "duration": 5.08,
      "text": "を持っておりえそのことにつきましては"
    },
    {
      "start": 1314.6,
      "duration": 5.079,
      "text": "職員団体にもえ提案の上今回合意の上ご"
    },
    {
      "start": 1317.72,
      "duration": 5.6,
      "text": "提案をさせていいてるということでご理解"
    },
    {
      "start": 1319.679,
      "duration": 7.761,
      "text": "いただければと思います以上です森さんま"
    },
    {
      "start": 1323.32,
      "duration": 8.239,
      "text": "あのちょっと今後ですねこの26市平均と"
    },
    {
      "start": 1327.44,
      "duration": 6.239,
      "text": "の比較の資料のあの提案提出の仕方って"
    },
    {
      "start": 1331.559,
      "duration": 5.6,
      "text": "いうのはですねもう少し改善をして"
    },
    {
      "start": 1333.679,
      "duration": 7.161,
      "text": "いただけないかなということをあの要望を"
    },
    {
      "start": 1337.159,
      "duration": 6.081,
      "text": "しておきますそれからやっぱり26市平均"
    },
    {
      "start": 1340.84,
      "duration": 6.24,
      "text": "に引き上げるっていうことはどうしても私"
    },
    {
      "start": 1343.24,
      "duration": 8.559,
      "text": "はですねあの人材確保のためには必要な"
    },
    {
      "start": 1347.08,
      "duration": 9.4,
      "text": "ことだと考えていますえとりわけえま保健"
    },
    {
      "start": 1351.799,
      "duration": 7.641,
      "text": "士産看護士産というところま保育士産はた"
    },
    {
      "start": 1356.48,
      "duration": 6.199,
      "text": "あの26市平均よりも上回っているわけ"
    },
    {
      "start": 1359.44,
      "duration": 7.88,
      "text": "ですがしかしここがなかなか集まらないっ"
    },
    {
      "start": 1362.679,
      "duration": 7.24,
      "text": "ていうことからするとねあのまま平均をあ"
    },
    {
      "start": 1367.32,
      "duration": 7.56,
      "text": "まで近づけるっていうことと平均以上にし"
    },
    {
      "start": 1369.919,
      "duration": 8.561,
      "text": "てあの人材確保に努力をえしていくべきだ"
    },
    {
      "start": 1374.88,
      "duration": 8.44,
      "text": "なという風に思いますえまその点で市長の"
    },
    {
      "start": 1378.48,
      "duration": 7.96,
      "text": "考えがあれば伺わせていただきたいと思い"
    },
    {
      "start": 1383.32,
      "duration": 6.88,
      "text": "ますはい"
    },
    {
      "start": 1386.44,
      "duration": 6.32,
      "text": "長あのまご意見としてはあの理解する"
    },
    {
      "start": 1390.2,
      "duration": 4.959,
      "text": "ところでありますでえっとまこの間ですね"
    },
    {
      "start": 1392.76,
      "duration": 4.2,
      "text": "まこの表もそうなんですけどまずっとこの"
    },
    {
      "start": 1395.159,
      "duration": 5.321,
      "text": "形で出させていただいてるっていうのは"
    },
    {
      "start": 1396.96,
      "duration": 6.52,
      "text": "あのご存知かと思いますでえっとまその"
    },
    {
      "start": 1400.48,
      "duration": 5.799,
      "text": "他種との均衡の点に関してはですねあの"
    },
    {
      "start": 1403.48,
      "duration": 4.679,
      "text": "特にえっとどういう点でえやっぱり採用が"
    },
    {
      "start": 1406.279,
      "duration": 3.721,
      "text": "しにくいかっていう状況なんかはあの見"
    },
    {
      "start": 1408.159,
      "duration": 4.161,
      "text": "ながらですねあのまご意見としてまず"
    },
    {
      "start": 1410.0,
      "duration": 8.919,
      "text": "受け止めさせていただき"
    },
    {
      "start": 1412.32,
      "duration": 9.0,
      "text": "ますはいえ他にございますかなしはい質疑"
    },
    {
      "start": 1418.919,
      "duration": 5.401,
      "text": "を終了することにご異議ありませんかご"
    },
    {
      "start": 1421.32,
      "duration": 6.32,
      "text": "異議なしと認め質疑を終了しますお別れし"
    },
    {
      "start": 1424.32,
      "duration": 6.4,
      "text": "ます本件は委員会負託を省略し討論採決を"
    },
    {
      "start": 1427.64,
      "duration": 5.96,
      "text": "一時保留することにえご異議ありませんか"
    },
    {
      "start": 1430.72,
      "duration": 5.68,
      "text": "ご異議なしと認め本件は委員会負託を省略"
    },
    {
      "start": 1433.6,
      "duration": 6.4,
      "text": "し討論採決を一時保留することと決定し"
    },
    {
      "start": 1436.4,
      "duration": 6.68,
      "text": "ました議会委員会等するためしばらく休憩"
    },
    {
      "start": 1440.0,
      "duration": 3.08,
      "text": "します"
    }
  ]
}