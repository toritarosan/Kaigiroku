{
  "entries": [
    {
      "start": 171.14,
      "duration": 4.819,
      "text": "[音楽]"
    },
    {
      "start": 173.44,
      "duration": 5.079,
      "text": "再開いたします休憩勢に引き続き質疑を"
    },
    {
      "start": 175.959,
      "duration": 5.0,
      "text": "行いますそれでは持ち帰りいただいたこと"
    },
    {
      "start": 178.519,
      "duration": 4.681,
      "text": "でそちゃよろしいでしょうかはい総部長"
    },
    {
      "start": 180.959,
      "duration": 4.721,
      "text": "はいえお時いただきまして申し訳ござい"
    },
    {
      "start": 183.2,
      "duration": 5.92,
      "text": "ませんでしたえ市長に確認をいたしました"
    },
    {
      "start": 185.68,
      "duration": 6.8,
      "text": "市長の発言につきましてはえ映しをご用意"
    },
    {
      "start": 189.12,
      "duration": 5.6,
      "text": "いたしますのでえ議運終了後に参考にお"
    },
    {
      "start": 192.48,
      "duration": 4.92,
      "text": "配りをさせていただきたいと思いますので"
    },
    {
      "start": 194.72,
      "duration": 5.56,
      "text": "ご対応方よろしくお願いいたし"
    },
    {
      "start": 197.4,
      "duration": 6.04,
      "text": "ますはいということでございますこの件に"
    },
    {
      "start": 200.28,
      "duration": 7.84,
      "text": "ついて何かご意見ご質疑ございますかはい"
    },
    {
      "start": 203.44,
      "duration": 7.799,
      "text": "水上えっとまそうなるとまこのまま本会議"
    },
    {
      "start": 208.12,
      "duration": 5.119,
      "text": "ま一定時間取った後にま質疑に入ってい"
    },
    {
      "start": 211.239,
      "duration": 4.0,
      "text": "くっていうことにならざるええないかなと"
    },
    {
      "start": 213.239,
      "duration": 4.0,
      "text": "は思うんですがただちょっと資料を"
    },
    {
      "start": 215.239,
      "duration": 5.2,
      "text": "読み込む時間などもありますのでちょっと"
    },
    {
      "start": 217.239,
      "duration": 7.121,
      "text": "一定時間はもらいたいということとあと"
    },
    {
      "start": 220.439,
      "duration": 6.8,
      "text": "今日の視聴報告はですねこの優先整備路線"
    },
    {
      "start": 224.36,
      "duration": 5.04,
      "text": "の検証についての報告書これも合わせて"
    },
    {
      "start": 227.239,
      "duration": 5.401,
      "text": "質疑の対象になってくると思うんですね"
    },
    {
      "start": 229.4,
      "duration": 5.88,
      "text": "これに基づいて総合的判断されてるわけで"
    },
    {
      "start": 232.64,
      "duration": 5.599,
      "text": "建設環境委員会では一定報告されて質疑も"
    },
    {
      "start": 235.28,
      "duration": 6.72,
      "text": "されてると思うんですがあの玄関以外の"
    },
    {
      "start": 238.239,
      "duration": 7.441,
      "text": "委員はあの全く質疑しておりませんのでだ"
    },
    {
      "start": 242.0,
      "duration": 6.72,
      "text": "から場合によってはですね詳細7民の質疑"
    },
    {
      "start": 245.68,
      "duration": 6.399,
      "text": "に及ぶ場合もあると思いますのでま主張"
    },
    {
      "start": 248.72,
      "duration": 7.32,
      "text": "報告ではありますけどあのしるべく部局の"
    },
    {
      "start": 252.079,
      "duration": 5.481,
      "text": "方の要するに答弁もあのいただきたいとま"
    },
    {
      "start": 256.04,
      "duration": 4.199,
      "text": "いうことはちょっとお願いしておきたいと"
    },
    {
      "start": 257.56,
      "duration": 4.6,
      "text": "思いますのであのそういうことで進行して"
    },
    {
      "start": 260.239,
      "duration": 4.161,
      "text": "いただきたいとまいうことは議長にもお"
    },
    {
      "start": 262.16,
      "duration": 4.72,
      "text": "願いしておきたいと思いますちょっといい"
    },
    {
      "start": 264.4,
      "duration": 6.04,
      "text": "ですかはい議長ま今ちょっと議長にお願い"
    },
    {
      "start": 266.88,
      "duration": 9.759,
      "text": "て話がありましたけれどもまあのええ今日"
    },
    {
      "start": 270.44,
      "duration": 8.599,
      "text": "に本日に至るに先立ってえあの優先整備"
    },
    {
      "start": 276.639,
      "duration": 5.201,
      "text": "路線の調査をこういう風に行いますって"
    },
    {
      "start": 279.039,
      "duration": 6.281,
      "text": "いう風な話とかその結果の報告っていうの"
    },
    {
      "start": 281.84,
      "duration": 5.84,
      "text": "はあの建設環境委員会であのすでにあの"
    },
    {
      "start": 285.32,
      "duration": 5.04,
      "text": "質疑が行われていますので一応まそれを"
    },
    {
      "start": 287.68,
      "duration": 4.28,
      "text": "前提に今日を迎えているということだけは"
    },
    {
      "start": 290.36,
      "duration": 3.76,
      "text": "一応強調させていただきたいと思います"
    },
    {
      "start": 291.96,
      "duration": 4.959,
      "text": "あの発言するなとは言いませんねであと"
    },
    {
      "start": 294.12,
      "duration": 5.56,
      "text": "それからあの市長の後ろには今日え部長も"
    },
    {
      "start": 296.919,
      "duration": 4.601,
      "text": "課長もあの座ると聞いておりますのでえ"
    },
    {
      "start": 299.68,
      "duration": 4.0,
      "text": "発言を制限するつもりはありませんけども"
    },
    {
      "start": 301.52,
      "duration": 5.56,
      "text": "今言ったこと自体は一応ご理解いただき"
    },
    {
      "start": 303.68,
      "duration": 6.2,
      "text": "たいと思いますはい他にございますか"
    },
    {
      "start": 307.08,
      "duration": 4.399,
      "text": "ちょっとあはい片山福委ちょっと今議長が"
    },
    {
      "start": 309.88,
      "duration": 4.72,
      "text": "おっしゃったことをちょっと気になるん"
    },
    {
      "start": 311.479,
      "duration": 4.961,
      "text": "ですが私はこれ本来は全員協議会であの"
    },
    {
      "start": 314.6,
      "duration": 4.4,
      "text": "きちんと説明をすべきだって言ってたん"
    },
    {
      "start": 316.44,
      "duration": 4.92,
      "text": "ですねでそれがですねまこ今こいう主張"
    },
    {
      "start": 319.0,
      "duration": 5.16,
      "text": "報告総合的判断の方だけの視報告となって"
    },
    {
      "start": 321.36,
      "duration": 5.48,
      "text": "ますけれども本来はこの検証の結果につい"
    },
    {
      "start": 324.16,
      "duration": 6.039,
      "text": "てはこの報告書については全員協議会で"
    },
    {
      "start": 326.84,
      "duration": 5.479,
      "text": "全員議員があの質疑できるような場で報告"
    },
    {
      "start": 330.199,
      "duration": 4.081,
      "text": "して説明をすべきだというようなことを"
    },
    {
      "start": 332.319,
      "duration": 4.761,
      "text": "ですね申し上げてましたけれどもそうなっ"
    },
    {
      "start": 334.28,
      "duration": 5.44,
      "text": "てないでなくて今こういった状態でこの"
    },
    {
      "start": 337.08,
      "duration": 4.52,
      "text": "議会応援会だった日をですねこうような形"
    },
    {
      "start": 339.72,
      "duration": 4.52,
      "text": "で本会議を開くというようなことになって"
    },
    {
      "start": 341.6,
      "duration": 5.36,
      "text": "はなってるわけですですので今回のこの"
    },
    {
      "start": 344.24,
      "duration": 5.2,
      "text": "視聴報告と共にもし質疑をするんであれば"
    },
    {
      "start": 346.96,
      "duration": 4.359,
      "text": "ですね検証の報告書についてもこう一緒の"
    },
    {
      "start": 349.44,
      "duration": 3.68,
      "text": "質疑になっていくというようなことという"
    },
    {
      "start": 351.319,
      "duration": 3.761,
      "text": "のはこれあらかじめですねそのようなこと"
    },
    {
      "start": 353.12,
      "duration": 3.88,
      "text": "は折り込み済みだという風に私は考えて"
    },
    {
      "start": 355.08,
      "duration": 4.04,
      "text": "おりますのであの意見としては申し上げ"
    },
    {
      "start": 357.0,
      "duration": 4.199,
      "text": "いただきたいと思います意見としてはい他"
    },
    {
      "start": 359.12,
      "duration": 5.84,
      "text": "にございます"
    },
    {
      "start": 361.199,
      "duration": 5.681,
      "text": "はいえそれではですねえ議会に関する議長"
    },
    {
      "start": 364.96,
      "duration": 4.48,
      "text": "の諮問事項についてですねお諮りいたし"
    },
    {
      "start": 366.88,
      "duration": 4.84,
      "text": "ます本件については議長の諮問の通り決定"
    },
    {
      "start": 369.44,
      "duration": 4.08,
      "text": "することにご異議ありませんかはいご異議"
    },
    {
      "start": 371.72,
      "duration": 4.759,
      "text": "なしと認めます従って本件は議長の諮問の"
    },
    {
      "start": 373.52,
      "duration": 5.84,
      "text": "通り決定いたしました次に議項括にその他"
    },
    {
      "start": 376.479,
      "duration": 6.801,
      "text": "について何かご発言はございます"
    },
    {
      "start": 379.36,
      "duration": 5.76,
      "text": "かからもいいんでしたっけあの解はいでは"
    },
    {
      "start": 383.28,
      "duration": 3.6,
      "text": "以上で当委員会に付託されております案件"
    },
    {
      "start": 385.12,
      "duration": 4.44,
      "text": "の審査は全て終了いたしましたこれで議会"
    },
    {
      "start": 386.88,
      "duration": 5.84,
      "text": "委委員会の会議をと参加いたしますでは議"
    },
    {
      "start": 389.56,
      "duration": 7.96,
      "text": "会事項に移りましてにその他のところです"
    },
    {
      "start": 392.72,
      "duration": 8.319,
      "text": "ねはいはい本部長はいえ申し訳ございませ"
    },
    {
      "start": 397.52,
      "duration": 6.36,
      "text": "んえっと後日送付案件え小金市職員の勤務"
    },
    {
      "start": 401.039,
      "duration": 6.081,
      "text": "時間休日休暇等に関する条例の一部を改正"
    },
    {
      "start": 403.88,
      "duration": 6.12,
      "text": "する条例でございますけれどもえ2月26"
    },
    {
      "start": 407.12,
      "duration": 4.519,
      "text": "日または27日までに送付をさせて"
    },
    {
      "start": 410.0,
      "duration": 5.72,
      "text": "いただきますのでよろしくお願いいたし"
    },
    {
      "start": 411.639,
      "duration": 6.721,
      "text": "ますえまた小規模保育所や家庭的保育事業"
    },
    {
      "start": 415.72,
      "duration": 6.599,
      "text": "の基準を定める条例の整備条例を準備して"
    },
    {
      "start": 418.36,
      "duration": 7.239,
      "text": "ございますえこれは1月末日に交付され"
    },
    {
      "start": 422.319,
      "duration": 5.921,
      "text": "ええ7年4月1日施行の法改正がありえ"
    },
    {
      "start": 425.599,
      "duration": 6.081,
      "text": "急遽改正が必要となったものでございます"
    },
    {
      "start": 428.24,
      "duration": 6.44,
      "text": "え時期は同じく2月26日また27日まで"
    },
    {
      "start": 431.68,
      "duration": 5.28,
      "text": "に送付をさせていただきますのでえ今後"
    },
    {
      "start": 434.68,
      "duration": 4.079,
      "text": "担当がご説明に上がらせていただきたいと"
    },
    {
      "start": 436.96,
      "duration": 4.72,
      "text": "思ってございますよろしくお願いいたし"
    },
    {
      "start": 438.759,
      "duration": 5.321,
      "text": "ます以上でございますはいこの件について"
    },
    {
      "start": 441.68,
      "duration": 5.959,
      "text": "ご意見ご質ございますかはいよろしいです"
    },
    {
      "start": 444.08,
      "duration": 7.28,
      "text": "かはい他にその田のところでございますか"
    },
    {
      "start": 447.639,
      "duration": 7.721,
      "text": "はいはいそれでは以上で議会会協議会参加"
    },
    {
      "start": 451.36,
      "duration": 4.0,
      "text": "いたしますお疲れ様でした"
    }
  ]
}