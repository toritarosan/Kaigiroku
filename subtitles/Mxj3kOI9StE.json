{
  "entries": [
    {
      "start": 156.84,
      "duration": 4.72,
      "text": "はい皆さんお疲れ様でございます帝国で"
    },
    {
      "start": 159.44,
      "duration": 3.56,
      "text": "ございますの議会運会員の協議会を始め"
    },
    {
      "start": 161.56,
      "duration": 3.52,
      "text": "させていただきますお手元の協議事故を"
    },
    {
      "start": 163.0,
      "duration": 4.959,
      "text": "ご覧ください異長の指紋事項1件で正眼"
    },
    {
      "start": 165.08,
      "duration": 6.84,
      "text": "近所の2つ先委員会についてでございます"
    },
    {
      "start": 167.959,
      "duration": 6.681,
      "text": "えせえ締め切り期限までに受理した正眼"
    },
    {
      "start": 171.92,
      "duration": 5.08,
      "text": "陳情は陳情8件でございましたえ2先委員"
    },
    {
      "start": 174.64,
      "duration": 4.76,
      "text": "会については定評の通りでございますえ"
    },
    {
      "start": 177.0,
      "duration": 5.879,
      "text": "その他何かあればご発言くださいで協議会"
    },
    {
      "start": 179.4,
      "duration": 5.24,
      "text": "事項のところでえ第3回定例会の初日9月"
    },
    {
      "start": 182.879,
      "duration": 5.961,
      "text": "2日の日程についてお持ち帰りいただいて"
    },
    {
      "start": 184.64,
      "duration": 4.2,
      "text": "おりますので皆様よろしくお願いいたし"
    },
    {
      "start": 190.2,
      "duration": 9.599,
      "text": "ますまたはいということだそう"
    },
    {
      "start": 195.44,
      "duration": 7.84,
      "text": "ですはいはいじゃあ次回ということで"
    },
    {
      "start": 199.799,
      "duration": 3.481,
      "text": "よろしいですか進めさせていただいて"
    },
    {
      "start": 204.0,
      "duration": 7.76,
      "text": "はいあれ壊れた"
    },
    {
      "start": 208.08,
      "duration": 3.68,
      "text": "壊れで言えば"
    },
    {
      "start": 211.799,
      "duration": 3.561,
      "text": "えダメなの"
    },
    {
      "start": 281.84,
      "duration": 4.919,
      "text": "はいお願いし"
    },
    {
      "start": 283.96,
      "duration": 5.239,
      "text": "ますはいただいまから議会運営委員会の"
    },
    {
      "start": 286.759,
      "duration": 4.44,
      "text": "会議を開きます直に議事に入ります当委員"
    },
    {
      "start": 289.199,
      "duration": 4.321,
      "text": "会に付託されております案件は議長の諮問"
    },
    {
      "start": 291.199,
      "duration": 4.481,
      "text": "事項1件であります議長からお手元に議会"
    },
    {
      "start": 293.52,
      "duration": 4.08,
      "text": "運営委員会協議事項が提示されております"
    },
    {
      "start": 295.68,
      "duration": 4.519,
      "text": "のでその順序に従って順次協議をして"
    },
    {
      "start": 297.6,
      "duration": 4.72,
      "text": "まいりたいと思います議会運にする議長の"
    },
    {
      "start": 300.199,
      "duration": 4.921,
      "text": "問事項についてを議題といたします初めに"
    },
    {
      "start": 302.32,
      "duration": 4.84,
      "text": "協議事項1正が陳情の2先委員会について"
    },
    {
      "start": 305.12,
      "duration": 3.68,
      "text": "行います議長の指紋案が示されております"
    },
    {
      "start": 307.16,
      "duration": 5.16,
      "text": "ので議長から説明をお願いいたしますはい"
    },
    {
      "start": 308.8,
      "duration": 6.88,
      "text": "え5月31日の午後5時までに受付ました"
    },
    {
      "start": 312.32,
      "duration": 7.24,
      "text": "星願陳情は陳情8件です細部につきまして"
    },
    {
      "start": 315.68,
      "duration": 8.079,
      "text": "は事務局から説明しますはい局長はいえ6"
    },
    {
      "start": 319.56,
      "duration": 7.359,
      "text": "陳情第10号から6陳情第17号までの計"
    },
    {
      "start": 323.759,
      "duration": 6.481,
      "text": "8県の付託先委員会につきましてはお手元"
    },
    {
      "start": 326.919,
      "duration": 6.961,
      "text": "の西岸賃場の委員会託予定"
    },
    {
      "start": 330.24,
      "duration": 6.84,
      "text": "案の通りでございますえなお発言申し覧は"
    },
    {
      "start": 333.88,
      "duration": 6.4,
      "text": "現時点での発言予定でありまして各委員会"
    },
    {
      "start": 337.08,
      "duration": 6.36,
      "text": "の前日の後までに発言申し出ができますの"
    },
    {
      "start": 340.28,
      "duration": 7.4,
      "text": "で今後申し出が変更になる場合もござい"
    },
    {
      "start": 343.44,
      "duration": 7.12,
      "text": "ます以上の通り各常任委員会及び議会運営"
    },
    {
      "start": 347.68,
      "duration": 5.519,
      "text": "委員会に付託するというのが議長の諮問案"
    },
    {
      "start": 350.56,
      "duration": 6.24,
      "text": "でございます議長及び事務局の説明は"
    },
    {
      "start": 353.199,
      "duration": 7.161,
      "text": "終わりましたご意見ご質とございます"
    },
    {
      "start": 356.8,
      "duration": 6.04,
      "text": "かしはいおりいたしますついてはお手元に"
    },
    {
      "start": 360.36,
      "duration": 4.839,
      "text": "配布されております付託予定表括案の通り"
    },
    {
      "start": 362.84,
      "duration": 4.4,
      "text": "決定することにご異議ありませんかご異議"
    },
    {
      "start": 365.199,
      "duration": 4.041,
      "text": "なしと認め正眼陳情の付託先委員会につい"
    },
    {
      "start": 367.24,
      "duration": 4.6,
      "text": "てはお手元の予定表の通り決定いたしまし"
    },
    {
      "start": 369.24,
      "duration": 5.799,
      "text": "た協議事項括2その他でございますが何か"
    },
    {
      "start": 371.84,
      "duration": 4.799,
      "text": "ご発言はございますかよしよし以上で当"
    },
    {
      "start": 375.039,
      "duration": 3.481,
      "text": "委員会に2されております案件の審査は"
    },
    {
      "start": 376.639,
      "duration": 6.4,
      "text": "全て終了いたしましたこれで議会運委員会"
    },
    {
      "start": 378.52,
      "duration": 8.36,
      "text": "の会議を閉じ参加いたしますはいでは協議"
    },
    {
      "start": 383.039,
      "duration": 5.88,
      "text": "会に移りましてえま令和6年度第3回定例"
    },
    {
      "start": 386.88,
      "duration": 4.759,
      "text": "の認定についてはまたじゃ後日ということ"
    },
    {
      "start": 388.919,
      "duration": 5.161,
      "text": "であのお手数ですが単独会派の確認お願い"
    },
    {
      "start": 391.639,
      "duration": 7.521,
      "text": "しますその他について何かございます"
    },
    {
      "start": 394.08,
      "duration": 9.76,
      "text": "かはいそれでは以上で会運営会協議会よ"
    },
    {
      "start": 399.16,
      "duration": 4.68,
      "text": "当時参回をいたしますお疲れ様でした"
    }
  ]
}